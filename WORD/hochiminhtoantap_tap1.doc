\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \line \line \line \line S\'f9 CH\'a1M S\'e3C \'a2N C
\'c7N
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'a7\'a9y l\'b5 m\'e9t c\'a9u chuy\'d6n c\'f2, n\'e3 c\'f2
ng c\'f2 nh\'ad chi\'d5n tranh. Trong khi h\'f8a h\'d1n ph\'c8m h\'b5m cho nh\'f7ng ng\'ad\'eai \'a7\'abng D\'ad\'acng t\'d7nh nguy\'d6n(?) c\'dfn s\'e8ng v\'b5 v\'b5ng m\'b7 cho nh\'f7ng ng\'ad\'eai ch\'d5t "v\'d7 m\'c9u qu\'e8c", vi\'aan To\'b5n quy\'d2
n \'a7\'abng D\'ad\'acng \'ae\'b7 th\'e8t ra nh\'f7ng l\'eai c\'b6m \'ae\'e9ng nh\'ad sau:
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 C\'b8c anh gia nh\'cbp qu\'a9n \'ae\'e9i }{
\i\f37\fs20\insrsid1378858 h\'b5ng lo\'b9t, kh\'abng do d\'f9}{\f37\fs20\insrsid1378858  r\'eai qu\'aa cha \'ae\'cat t\'e6, n\'aci ch\'abn rau c\'bet r\'e8n c\'f1a m\'d7nh. L\'b5 l\'ddnh tr\'cbn, c\'b8c anh \'aei t\'dfng qu\'a9n \'ae\'d3 hy sinh x\'ad\'ac
ng m\'b8u c\'f1a m\'d7nh; l\'b5 l\'ddnh th\'ee, c\'b8c anh c\'e8ng hi\'d5n hai b\'b5n tay c\'f1a m\'d7nh" (1919).
\par L\'dech s\'f6 ch\'d0p nh\'ad v\'cby \'ae\'e3!
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 N\'d5u ng\'ad\'eai An Nam t\'e1 ra vui m\'f5ng khi ng\'ad
\'eai ta b\'bet h\'e4 \'aei l\'ddnh th\'d7 t\'b9i sao ng\'ad\'eai ta l\'b9i x\'ddch tay h\'e4 l\'efa \'ae\'d5n c\'b8c \'ae\'dea \'aei\'d3m t\'cbp trung? T\'b9o sao trong khi ch\'ea \'ae\'eei \'ae\'ada xu\'e8ng t\'b5u, ng\'ad\'eai ta l\'b9i nh\'e8t h\'e4
 trong Tr\'ad\'eang trung h\'e4c S\'b5i G\'dfn, b\'aan ngo\'b5i l\'b5 l\'ddnh c\'b6nh v\'d6 Ph\'b8p g\'b8c, l\'ad\'eci l\'aa \'eb \'ae\'c7u s\'f3ng, \'ae\'b9n \'ae\'b7 l\'aan n\'dfng? Ph\'b6i ch\'a8ng nh\'f7ng cu\'e9c bi\'d3u t\'d7nh \'ae\'c9m m\'b8u \'eb
 Cao Mi\'aan, nh\'f7ng cu\'e9c n\'e6i d\'cby \'eb S\'b5i G\'dfn, Bi\'aan Ho\'b5 v\'b5 \'eb nhi\'d2u \'ae\'dea ph\'ad\'acng kh\'b8c l\'b5 nh\'f7ng cu\'e9c bi\'d3u t\'d7nh c\'f1a "\'ae\'b8m ng\'ad\'eai" n\'abn n\'e3ng, mu\'e8n t\'dfng qu\'a9n "kh\'abng do d
\'f9"?
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ng\'ad\'eai ta ra s\'f8c \'ae\'b5n \'b8p d\'b7 man c\'b8
c cu\'e9c \'ae\'b6o ng\'f2 (v\'b5 c\'e3 ch\'f5ng 50% l\'ddnh d\'f9 b\'de \'ae\'b6o ng\'f2). Do \'ae\'e3, c\'b8c cu\'e9c kh\'ebi ngh\'dca \'ae\'b7 n\'e6 ra, nh\'adng b\'de b\'e4n th\'f9c d\'a9n d\'d7m trong b\'d3 m\'b8u. Nh\'f7ng ng\'ad\'eai An Nam \'cay c
\'f2ng b\'de ch\'d5t trong th\'eai chi\'d5n. Song ng\'ad\'eai ta s\'cf kh\'abng c\'f3ng t\'d5 h\'e4 "sau khi ch\'d5t", c\'dfn nh\'f7ng ng\'ad\'eai s\'e8ng s\'e3t th\'d7 c\'f2ng ch\'bcng \'ae\'ad\'eec quan To\'b5n quy\'d2n khen th\'ad\'ebng.
\par Ph\'b6i, quan To\'b5n quy\'d2n n\'e3i th\'aam r\'bbng, d\'dc nhi\'aan mu\'e8n x\'f8ng \'ae\'b8ng \'ae\'ad\'eec h\'ad\'ebng "\'a9n hu\'d6" v\'b5 "s\'f9 h\'cbu \'ae\'b7i" c\'f1a nh\'b5 n\'ad\'edc th\'d7 c\'b8c anh (nh\'f7ng ng\'ad\'eai l\'ddnh \'a7\'abng D
\'ad\'acng) "ph\'b6i c\'e3 h\'b9nh ki\'d3m t\'e8t, kh\'abng m\'b6y may t\'e1 ra thi\'d5u thi\'d6n ch\'dd".
\par Hi\'d6n nay, khi h\'e4 d\'efng r\'ad\'eeu v\'b5 thu\'e8c phi\'d6n do ch\'ddnh b\'b5n tay ch\'ddnh ph\'f1 b\'b8n th\'d7 c\'e3 th\'d3 n\'b5o h\'e4 l\'b9i kh\'abng ph\'b6i l\'b5 nh\'f7ng ng\'ad\'eai "d\'d4 b\'b6o"?
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 nguy\'d4n \'b8i qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 L'Humanit\'d0,}{\insrsid1378858 
\par ng\'b5y 2-11-1922.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s2\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel1\adjustright\rin0\lin0\itap0 \b\f37\fs28\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs20\insrsid1378858 
\par 
