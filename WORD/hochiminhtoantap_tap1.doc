\line XU\'caT B\'b6N B\'b8O }{\b0\i\insrsid1378858 LE PARIA}{\cs17\b0\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) \'a7\'c7u \'ae\'d2 do BBT \'ae\'c6t.}}}{\cs17\super\insrsid1378858 )}{\insrsid1378858 
\par }\pard\plain \qr \fi397\li0\ri425\sa240\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin425\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 \~}{\i\f37\fs20\insrsid1378858 Pari, ng\'b5y 10 th\'b8
ng 2 n\'a8m 1922
\par }\pard \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 C\'b8c \'ae\'e5ng ch\'dd th\'a9n m\'d5n,
\par C\'b8c \'ae\'e5ng ch\'dd \'ae\'b7 nh\'cbn hay s\'cf nh\'cbn m\'e9t b\'b6n \'aei\'d2u l\'d6 H\'e9i h\'eep t\'b8c c\'f1a b\'b8o }{\i\f37\fs20\insrsid1378858 Le Paria}{\f37\fs20\insrsid1378858 . H\'e9i n\'b5y \'aeang th\'b5nh l\'cbp s\'cf xu\'cat b\'b6n m
\'e9t t\'ea b\'b8o nh\'ad t\'aan \'ae\'b7 n\'aau v\'b5 \'ae\'e3 s\'cf l\'b5 m\'e9t xu\'cat b\'b6n ph\'c8m th\'cbt s\'f9 c\'f1a thu\'e9c \'ae\'dea.
\par Ch\'bcng c\'c7n nh\'can m\'b9nh \'ae\'d5n s\'f9 kh\'c8n c\'cap ph\'b6i cho ra t\'ea b\'b8o n\'b5y. C\'b8c b\'b9n ta \'eb ch\'ddnh qu\'e8c b\'bet \'ae\'c7u c\'b6m th\'cay c\'c7n ph\'b6i thay \'ae\'e6i t\'d7nh h\'d7nh hi\'d6n nay \'eb c\'b8c thu\'e9c \'ae
\'dea. Nh\'adng do ch\'e7 kh\'abng c\'e3 t\'ad li\'d6u, h\'e4 ch\'ea m\'b7i m\'b7i ho\'c6c h\'b5nh \'ae\'e9ng ch\'bcng ch\'bec ch\'ben g\'d7. Trong c\'b6 hai tr\'ad\'eang h\'eep, c\'e3 nguy c\'ac h\'e4 l\'b5m h\'b9i phong tr\'b5o chung \'ae\'d3 thi\'d5t l
\'cbp l\'b9i c\'abng l\'fd trong nh\'a9n d\'a9n c\'b8c thu\'e9c \'ae\'dea.
\par V\'d2 ph\'dda m\'d7nh, c\'b8c d\'a9n t\'e9c \'eb thu\'e9c \'ae\'dea ti\'d5p t\'f4c t\'ad\'ebng r\'bbng nh\'a9n d\'a9n Ph\'b8p lu\'abn lu\'abn l\'b5 nh\'f7ng vi\'aan ch\'f8c ho\'b9nh h\'e4e v\'b5 ch\'bcng c\'e3 l\'dfng x\'e3t th\'ad\'acng n\'b5y hay l\'b5
 nh\'f7ng t\'aan th\'f9c d\'a9n m\'b5 ch\'ad\'acng tr\'d7nh l\'b5 b\'e3c l\'e9t v\'cbt v\'b5 ng\'ad\'eai \'eb thu\'e9c \'ae\'dea. Ti\'d5ng n\'e3i c\'f1a nh\'f7ng c\'f9u chi\'d5n binh ng\'ad\'eai b\'b6n x\'f8, \'ae\'b7 t\'f5ng \'aeau kh\'e6 b\'aan c\'b9
nh nh\'f7ng "ng\'ad\'eai l\'abng l\'b8 x\'e5m xo\'b5m" \'eb Ph\'b8p, l\'b9i c\'b5ng b\'cat l\'f9c \'ae\'d3 ng\'a8n h\'e4 kh\'e1i tin r\'bbng m\'e4i binh \line s\'dc c\'f2 c\'f1a "\'ae\'b9i chi\'d5n", - d\'ad\'edi con m\'bet c\'b8c v\'de c\'e3 ch\'f8c quy
\'d2n \'eb thu\'e9c \'ae\'dea, - l\'b5 m\'e9t ng\'ad\'eai \'ae\'b8ng ng\'ea v\'b5 l\'b5 m\'e9t \'ae\'e8i t\'ad\'eeng ph\'b6i ki\'d3m so\'b8t \'ae\'c6c bi\'d6t nghi\'aam ng\'c6t.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 C\'b8c b\'b9n \'eb m\'c9u qu\'e8c, c\'b8c \'ae\'e5ng ch\'dd \'eb thu\'e9c \'ae\'dea, v\'d7 l\'eei \'ddch c\'f1a c\'ab
ng l\'fd, ch\'a9n l\'fd v\'b5 ti\'d5n b\'e9, c\'c7n ph\'b6i xo\'b8 kho\'b6ng c\'b8ch gi\'b6 t\'b9o d\'ad\'eang nh\'ad chia r\'cf c\'b8c \'ae\'e5ng ch\'dd. T\'ea }{\i\f37\fs20\insrsid1378858 Le Paria}{\f37\fs20\insrsid1378858 , l\'b5 t\'ea b\'b8o \'ae\'c7
u ti\'aan nh\'bbm m\'f4c \'ae\'ddch ho\'b5n th\'b5nh nhi\'d6m v\'f4 \'cay.
\par Nhi\'d6m v\'f4 n\'b5y ch\'bcng d\'d4 d\'b5ng g\'d7; \'ae\'d3 \'ae\'e8i ph\'e3, v\'edi hy v\'e4ng th\'beng l\'eei, ch\'f3ng t\'abi k\'aau g\'e4i s\'f9 t\'cbn tu\'fe c\'f1a c\'b8c \'ae\'e5ng ch\'dd m\'b5 t\'abi bi\'d5t l\'b5 v\'ab bi\'aan.
\par H\'b7y tham gia h\'e9i h\'eep t\'b8c c\'f1a ch\'f3ng ta, }{\i\f37\fs20\insrsid1378858 Le Paria}{\f37\fs20\insrsid1378858 , hay \'ae\'c6t mua d\'b5i h\'b9n ngay t\'f5 b\'a9y gi\'ea t\'ea b\'b8o c\'f1a ch\'f3ng t\'abi c\'efng t\'aan \'cay; ho\'c6c, n\'d5u 
\'ae\'ad\'eec, c\'b8c \'ae\'e5ng ch\'dd h\'b7y l\'b5m c\'b6 hai \'aei\'d2u tr\'aan. S\'f9 th\'b5nh c\'abng c\'f1a ch\'f3ng ta ph\'f4 thu\'e9c v\'b5o s\'f9 t\'cbn tu\'fe c\'f1a \'ae\'e5ng ch\'dd, v\'b5 t\'ad\'acng lai c\'b8c thu\'e9c \'ae\'dea l\'b9i ph
\'f4 thu\'e9c v\'b5o s\'f9 th\'b5nh c\'abng tr\'aan; ch\'f3ng ta d\'b8m kh\'bcng \'ae\'denh nh\'ad v\'cby .
\par C\'e8 g\'beng l\'aan m\'e9t ch\'f3t, b\'bbng c\'b8ch gi\'f3p \'ae\'ec ch\'f3ng t\'abi. C\'b8c b\'b9n v\'b5 c\'b8c \'ae\'e5ng ch\'dd, s\'cf ph\'f4c v\'f4 s\'f9 nghi\'d6p ho\'b5 b\'d7nh v\'b5 nh\'a9n lo\'b9i.
\par R\'cat th\'a9n thi\'d5t.
\par }\pard\plain \s24\qc \li2835\ri284\sb360\sa20\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin284\lin2835\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 Thay m\'c6t H\'e9i \'ae\'e5ng qu\'b6n tr\'de}
{\insrsid1378858 \line XT\'a3PHANY
\par }\pard \s24\qc \li2835\ri284\sa20\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin284\lin2835\itap0 {\f37\insrsid1378858 Th\'f1 qu\'fc ch\'ddnh}{\insrsid1378858 \line GUT\'a5NOA \'a7\'a5 TURY
\par }\pard \s24\qc \li2835\ri284\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin284\lin2835\itap0 {\f37\insrsid1378858 Th\'f1 qu\'fc ph\'f4}{\insrsid1378858  \line NGUY\'d4N \'b8I QU\'e8C
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'b5i li\'d6u \'ae\'b8nh m\'b8y, ti\'d5ng Ph\'b8p,
\par b\'b6n ch\'f4p l\'adu t\'b9i Vi\'d6n H\'e5 Ch\'dd Minh.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par 
\par }{\insrsid1378858 \~
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 L\'eaI K\'a3U G\'e4I
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-284\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~C\'b8ch ra b\'b8o h\'bbng th\'b8ng c\'f1a ch\'f3ng t\'ab
i n\'e3i l\'aan r\'bbng: }{\i\f37\fs20\insrsid1378858 Le Paria}{\f37\fs20\insrsid1378858  ra m\'bet b\'b9n \'ae\'e4c trong nh\'f7ng \'aei\'d2u ki\'d6n h\'d5t s\'f8c h\'b9n ch\'d5 v\'d2 ph\'ad\'acng di\'d6n t\'b5i ch\'ddnh. V\'b5 l\'eai tuy\'aan b\'e8 n
\'b5y gi\'f3p cho nh\'f7ng ai c\'e3 th\'d3 c\'dfn ph\'a9n v\'a9n v\'d2 h\'b5nh \'ae\'e9ng xu\'cat hi\'d6n \'eb \'ae\'a9y l\'c7n \'ae\'c7u ti\'aan kh\'e1i ph\'b6i m\'cat c\'abng t\'d7m hi\'d3u v\'ab \'ddch.
\par Th\'f9c v\'cby, trong l\'dech s\'f6 phong tr\'b5o qu\'c7n ch\'f3ng b\'b6n x\'f8 \'eb c\'b8c thu\'e9c \'ae\'dea c\'f1a Ph\'b8p, ch\'ada bao gi\'ea c\'e3 m\'e9t t\'ea b\'b8o \'ae\'ad\'eec l\'cbp ra \'ae\'d3 n\'e3i l\'aan n\'e7i \'aeau kh\'e6 v\'b5 t\'d7
nh tr\'b9ng c\'efng kh\'e8n chung c\'f1a h\'e4, b\'cat k\'d3 l\'b5 h\'e4 thu\'e9c \'ae\'cat n\'ad\'edc v\'b5 gi\'e8ng n\'dfi n\'b5o. }{\i\f37\fs20\insrsid1378858 Le Paria}{\f37\fs20\insrsid1378858  ra \'ae\'eai do s\'f9 \'ae\'e5ng c\'b6m s\'a9u s\'bec c
\'f1a c\'b8c \'ae\'e5ng ch\'dd \'eb B\'bec Phi, T\'a9y Phi thu\'e9c Ph\'b8p, Ma\'aeag\'b8txca, \'a7\'abng D\'ad\'acng, \'a1ngti\'ac v\'b5 Guyan. B\'b8o ra \'ae\'eai ch\'ddnh l\'b5 v\'d7 nh\'f7ng l\'eai h\'f8a h\'d1n d\'e8i tr\'b8 v\'d2 t\'f9 do v\'b5 c
\'abng l\'fd \'ae\'ad\'eec \'ae\'ada ra trong qu\'b8 tr\'d7nh cu\'e9c ch\'d0m gi\'d5t kh\'f1ng khi\'d5p nh\'f7ng n\'a8m 1914-1918, nh\'adng ho\'b5n to\'b5n kh\'abng \'ae\'ad\'eec th\'f9c hi\'d6n sau khi c\'acn gi\'abng t\'e8 d\'deu \'aei. T\'ea b\'b8o bi
\'d3u hi\'d6n \'fd th\'f8c t\'cbp th\'d3 c\'f1a nh\'f7ng ng\'ad\'eai v\'ab s\'b6n b\'b6n x\'f8 hi\'d3u r\'cat r\'e2 r\'bbng: b\'e4n b\'e3c l\'e9t l\'eei nhu\'cbn v\'b5 \'ae\'c6c quy\'d2n, \'ae\'c6c l\'eei, kh\'abng mu\'e8n m\'cat \'aei, d\'ef l\'b5 m\'e9
t ch\'f3t quy\'d2n l\'f9c v\'b5 ni\'d2m ki\'aau h\'b7nh c\'f1a ch\'f3ng. B\'e4n c\'c7m quy\'d2n v\'f5a m\'ef, v\'f5a \'aei\'d5c, kh\'abng mu\'e8n hi\'d3u ch\'f3t g\'d7 v\'d2 nh\'f7ng bi\'d5n c\'e8 \'aeang thai ngh\'d0n tr\'aan th\'d5 gi\'edi.
\par }{\i\f37\fs20\insrsid1378858 Le Paria}{\f37\fs20\insrsid1378858  t\'e8 c\'b8o nh\'f7ng s\'f9 l\'b9m quy\'d2n v\'d2 ch\'ddnh tr\'de, l\'e8i cai tr\'de \'ae\'e9c \'aeo\'b8n, t\'d7nh tr\'b9ng b\'de b\'e3c l\'e9t v\'d2 kinh t\'d5 m\'b5 nh\'a9n d\'a9n c\'b8c v
\'efng l\'b7nh th\'e6 r\'e9ng l\'edn \'eb h\'b6i ngo\'b9i \'aeang l\'b5 n\'b9n nh\'a9n. B\'b8o k\'aau g\'e4i h\'e4 \'aeo\'b5n k\'d5t l\'b9i, \'ae\'cau tranh cho ti\'d5n b\'e9 v\'d2 v\'cbt ch\'cat v\'b5 tinh th\'c7n c\'f1a ch\'ddnh h\'e4. B\'b8o k\'aau g
\'e4i h\'e4, t\'e6 ch\'f8c h\'e4, nh\'bbm m\'f4c \'ae\'ddch gi\'b6i ph\'e3ng nh\'f7ng ng\'ad\'eai b\'de \'b8p b\'f8c kh\'e1i c\'b8c l\'f9c l\'ad\'eeng th\'e8ng tr\'de, th\'f9c hi\'d6n t\'d7nh y\'aau th\'ad\'acng v\'b5 b\'b8c \'b8i.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 V\'b5 b\'a9y gi\'ea, \'ae\'e9i ng\'f2 \'ae\'b7 s\'bdn s\'b5ng, c\'b8c b\'b9n da v\'b5ng, da tr\'beng v\'b5 da \'aeen, h
\'b7y \'ae\'c6t mua b\'b8o c\'f1a ch\'f3ng t\'abi; h\'b7y g\'f6i cho ch\'f3ng t\'abi t\'b5i li\'d6u; h\'b7y \'ae\'f8ng b\'aan c\'b9nh ch\'f3ng t\'abi; h\'b7y ra s\'f8c \'f1ng h\'e9 ch\'f3ng t\'abi, d\'ef cho ch\'f3ng t\'abi c\'e3 g\'c6p ph\'b6i nh\'f7
ng lu\'e5ng b\'b7o t\'b8p ng\'ad\'eec chi\'d2u th\'d5 n\'b5o ch\'a8ng n\'f7a.
\par }{\i\f37\fs20\insrsid1378858 Le Paria}{\f37\fs20\insrsid1378858  \'ae\'b7 s\'bdn s\'b5ng b\'ad\'edc v\'b5o cu\'e9c chi\'d5n \'ae\'cau, m\'f4c \'ae\'ddch c\'f1a b\'b8o ch\'bec ch\'ben s\'cf \'ae\'b9t \'ae\'ad\'eec: \'ae\'e3 l\'b5 gi\'b6i ph\'e3ng lo\'b5
i ng\'ad\'eai.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~LE PARIA
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 Le Paria,}{\insrsid1378858  s\'e8 1,

\par ng\'b5y 1-4-1922.
