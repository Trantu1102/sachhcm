\par }\pard \s15\qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 Nh\'adng ch\'ddnh \'abng \'ae\'b7 "ph\'e3ng \'ae\'b9i" khi \'abng vi\'d5t tr\'aan b\'b8o }{\i\insrsid1378858 Rappel}{
\super\insrsid1378858 30 }{\insrsid1378858 r\'bbng nh\'f7ng s\'f9 vi\'d6c m\'b5 \'abng B\'d0ct\'abn v\'b9ch ra, \'ae\'d2u l\'b5 sai ho\'c6c ph\'e3ng \'ae\'b9i! Tr\'ad\'edc h\'d5t, ch\'ddnh ngay \'abng B\'e9 tr\'ad\'ebng B\'e9 Thu\'e9c \'ae\'dea c\'f2ng 
\'ae\'b7 bu\'e9c ph\'b6i th\'f5a nh\'cbn r\'bbng: "T\'d7nh tr\'b9ng t\'ad t\'ad\'ebng khinh r\'ce sinh m\'d6nh ng\'ad\'eai b\'b6n x\'f8 v\'c9n \'aeang c\'dfn". V\'b5 \'abng ta \'ae\'b7 "kh\'abng h\'d2 ch\'e8i c\'b7i m\'e9t s\'f9 vi\'d6c t\'b5n nh\'c9n n
\'b5o", m\'b5 ngh\'de s\'dc Boan\'edp \'ae\'b7 v\'b9ch ra. Sau n\'f7a, th\'ada \'abng }{\f38\insrsid1378858 \'b8}{\insrsid1378858 csimb\'ab, li\'d6u \'abng c\'e3 th\'d3 ch\'e8i c\'b7i \'ae\'ad\'eec r\'bbng, trong nh\'f7ng n\'a8m v\'f5a qua, - t\'f8c l\'b5
 sau cu\'e9c chi\'d5n tranh "v\'d7 c\'abng l\'fd"-, \'ae\'b7 c\'e3 \'ae\'d5n 80 v\'b9n ng\'ad\'eai b\'b6n x\'f8 "t\'d7nh nguy\'d6n" \'ae\'d5n l\'b5m vi\'d6c ho\'c6c b\'e1 m\'d7nh tr\'aan
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 \'ae\'cat Ph\'b8p, trong l\'f3c \'ae\'e3 th\'d7 c\'b8c nh\'b5
 khai ho\'b8 c\'f1a \'abng \'ae\'b7 \'a8n c\'bep, l\'ad\'eang g\'b9t, gi\'d5t h\'b9i ho\'c6c thi\'aau s\'e8ng (v\'b5 ch\'bec ch\'ben l\'b5 kh\'abng b\'de tr\'de t\'e9i) nh\'f7ng ng\'ad\'eai An Nam, ng\'ad\'eai Tuynidi, hay ng\'ad\'eai X\'aan\'aagan?

\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \'a4ng c\'dfn vi\'d5t ti\'d5p r\'bbng nh\'f7ng h\'b5
nh vi b\'cat c\'abng \'eb Ph\'b8p c\'dfn nhi\'d2u h\'acn \'eb c\'b8c thu\'e9c \'ae\'dea. Th\'d5 th\'d7 th\'ada \'abng }{\f38\fs20\insrsid1378858 \'b8}{\f37\fs20\insrsid1378858 csimb\'ab, h\'b7y cho ph\'d0p t\'abi n\'e3i r\'bbng, kh\'abng n\'aan c\'e3
 cao v\'e4ng \'aeem nh\'f7ng b\'b5i h\'e4c v\'d2 b\'d7nh \'ae\'bcng ho\'c6c c\'abng l\'fd \'aei d\'b9y cho ng\'ad\'eai kh\'b8c, khi ng\'ad\'eai ta kh\'abng th\'f9c hi\'d6n \'ae\'ad\'eec nh\'f7ng b\'b5i h\'e4c \'ae\'e3 \'eb n\'ad\'edc m\'d7nh. \'a7\'e3 l
\'b5 c\'b8i l\'abg\'ddch s\'ac \'ae\'bcng nh\'cat, ph\'b6i kh\'abng \'abng?
\par Theo \'abng, nh\'f7ng h\'b5nh vi v\'b5 c\'f6 ch\'d8 c\'f1a c\'b8c quan cai tr\'de thu\'e9c \'ae\'dea c\'f1a \'abng \'ae\'d2u \'ae\'b7 \'ae\'ad\'eec c\'b8c ph\'f1 to\'b5n quy\'d2n v\'b5 B\'e9 Thu\'e9c \'ae\'dea th\'f5a bi\'d5t, nh\'cbn x\'d0t v\'b5 ki\'d3
m tra r\'e5i. V\'cby, \'bet ph\'b6i l\'b5 m\'e9t trong hai \'aei\'d2u sau \'ae\'a9y: ho\'c6c l\'b5 v\'d7 \'abng \'ae\'b7ng tr\'dd n\'aan \'ae\'b7 qu\'aan m\'cat nh\'f7ng t\'aan nh\'ad B\'ab\'aeoanh, \'a7\'b8cl\'ac, Luycax\'ac v\'b5 bi\'d5t bao nhi\'aau t
\'aan kh\'b8c n\'f7a, h\'eep th\'b5nh \'ae\'b8m h\'b6o h\'b8n \'ae\'b7 l\'b5m r\'b9ng r\'ec v\'b5 v\'ce vang cho b\'e9 cai tr\'de thu\'e9c \'ae\'dea c\'f1a \'abng; ch\'f3ng \'ae\'b7 l\'b5m nh\'f7ng \'aei\'d2u \'ae\'b9i gian \'b8c, th\'d5 m\'b5 ch\'d8 b
\'de tr\'f5ng ph\'b9t b\'bbng c\'b8ch th\'a8ng ch\'f8c v\'b5 th\'ad\'ebng hu\'a9n ch\'ad\'acng th\'abi. Ho\'c6c l\'b5 \'abng \'ae\'b7 ngang nhi\'aan ch\'d5 gi\'d4u \'ae\'e9c gi\'b6 c\'f1a \'abng.
\par \'a4ng n\'e3i r\'bbng, v\'d2 m\'c6t thu\'e9c \'ae\'dea, n\'d5u n\'ad\'edc Ph\'b8p c\'e3 ph\'b9m l\'e7i th\'d7 ch\'bcng qua l\'b5 do c\'e3 qu\'b8 nhi\'d2u tinh th\'c7n cao c\'b6 \'ae\'cay th\'abi. Th\'ada \'abng }{\f38\fs20\insrsid1378858 \'b8}{
\f37\fs20\insrsid1378858 csimb\'ab, xin \'abng cho ch\'f3ng t\'abi bi\'d5t c\'e3 ph\'b6i v\'d7 tinh th\'c7n cao c\'b6 \'cay m\'b5 ng\'ad\'eai ta t\'ad\'edc m\'cat c\'f1a ng\'ad\'eai b\'b6n x\'f8 t\'cat c\'b6 m\'e4i quy\'d2n ng\'abn lu\'cbn, \'aei l\'b9
i, v.v. kh\'abng? Ph\'b6i ch\'a8ng c\'f2ng v\'d7 tinh th\'c7n \'cay m\'b5 ng\'ad\'eai ta bu\'e9c h\'e4 ph\'b6i ch\'deu c\'b8i th\'a9n ph\'cbn d\'a9n b\'b6n x\'f8 h\'ccn m\'e4n, m\'b5 ng\'ad\'eai ta t\'ad\'edc h\'d5t ru\'e9ng \'ae\'cat c\'f1a h\'e4 \'ae
\'d3 cho b\'e4n x\'a9m l\'a8ng, v\'b5 sau \'ae\'e3 bu\'e9c h\'e4 ph\'b6i lao \'ae\'e9ng nh\'ad k\'ce n\'ab l\'d6? Ch\'ddnh \'abng \'ae\'b7 n\'e3i r\'bbng gi\'e8ng ng\'ad\'eai Tahiti v\'d7 nghi\'d6n r\'ad\'eeu m\'b5 \'ae\'b7 ch\'d5t m\'dfn d\'c7n v\'b5 hi
\'d6n \'aeang \'aei \'ae\'d5n di\'d6t vong. Ph\'b6i ch\'a8ng c\'f2ng v\'d7 qu\'b8 \'ad cao c\'b6 m\'b5 c\'b8c \'abng \'ae\'b7 t\'d7m \'ae\'f1 c\'b8ch \'ae\'d3 l\'b5m cho ng\'ad\'eai An Nam say kh\'ad\'edt v\'edi r\'ad\'eeu c\'e5n c\'f1a c\'b8c \'abng v
\'b5 tr\'eb n\'aan u m\'aa, \'ae\'c7n \'ae\'e9n v\'edi thu\'e8c phi\'d6n c\'f1a c\'b8c \'abng?
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Sau c\'efng, \'abng n\'e3i \'ae\'d5n "b\'e6n ph\'cbn", \'ae
\'d5n "nh\'a9n \'ae\'b9o" v\'b5 "khai ho\'b8"! V\'cby b\'e6n ph\'cbn \'cay l\'b5 c\'b8i g\'d7? \'a4ng \'ae\'b7 \'aeem ph\'ab b\'b5y trong su\'e8t c\'b6 b\'b5i di\'d4n v\'a8n c\'f1a \'abng r\'e5i. \'a7\'e3 l\'b5 th\'de tr\'ad\'eang, l\'b5 c\'b9nh tranh, l
\'b5 l\'eei t\'f8c, l\'b5 \'ae\'c6c quy\'d2n. Bu\'abn b\'b8n, t\'b5i ch\'ddnh, \'ae\'e3 l\'b5 nh\'f7ng c\'b8i t\'ad\'eeng tr\'adng cho l\'dfng nh\'a9n \'ae\'b9o c\'f1a c\'b8c \'abng. S\'adu thu\'d5, lao d\'dech, b\'e3c l\'e9t n\'c6ng n\'d2, - c\'abng cu
\'e9c khai ho\'b8 c\'f1a c\'b8c \'abng, t\'e3m l\'b9i l\'b5 th\'d5 \'ae\'e3!
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Th\'ada \'abng }{\f38\fs20\insrsid1378858 \'b8}{
\f37\fs20\insrsid1378858 csimb\'ab, trong l\'f3c \'ae\'eei cho \'abng c\'e3 "m\'e9t ch\'f8c t\'ad\'edc hi\'d3n vinh nh\'cat m\'b5 ng\'ad\'eai ta c\'e3 th\'d3 m\'ac \'ad\'edc \'ae\'d5n" th\'d7 t\'abi xin ph\'d0p n\'e3i r\'bbng, n\'d5u tr\'ad\'edc kia V\'dd
chto Huyg\'ab bi\'d5t l\'b5 hi\'d6n nay \'abng vi\'d5t ra nh\'f7ng \'ae...i\'d2u nh\'ad th\'d5 tr\'aan t\'ea b\'b8o c\'f1a \'abng ta, th\'d7 \'abng ta \'ae\'b7 kh\'abng s\'b8ng l\'cbp ra n\'e3.
\par Mong \'abng, v.v..
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nguy\'d4n \'b8i qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 Le Paria,}{\insrsid1378858  s\'e8 10,

