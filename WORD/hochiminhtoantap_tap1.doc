\par }}\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 C\'a8n c\'f8 v\'b5o n\'e9i dung v\'b5 ho\'b5n c\'b6nh l
\'dech s\'f6 \'ae\'c7u nh\'f7ng n\'a8m 20, ch\'f3ng t\'abi cho r\'bbng t\'b8c gi\'b6 c\'f1a b\'b6n b\'b8o c\'b8o tr\'ad\'edc h\'d5t ph\'b6i l\'b5 m\'e9t ng\'ad\'eai Vi\'d6t Nam, m\'e9t ng\'ad\'eai am hi\'d3u s\'a9u s\'bec ch\'f1 ngh\'dca M\'b8c v\'b5 th
\'f9c t\'d5 l\'dech s\'f6 Vi\'d6t Nam trong qu\'b8 kh\'f8 v\'b5 hi\'d6n t\'b9i; m\'e9t ng\'ad\'eai c\'e3 quan ni\'d6m v\'d2 Vi\'d6t Nam nh\'ad m\'e9t th\'f9c th\'d3 th\'e8ng nh\'cat ch\'f8 kh\'abng ph\'b6i \'a7\'abng D\'ad\'acng m\'e9t th\'f9c th\'d3 thu
\'e9c \'ae\'dea v\'b5 ng\'ad\'eai \'ae\'e3, theo ch\'f3ng t\'abi, kh\'abng th\'d3 l\'b5 ai kh\'b8c ngo\'b5i Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 i Qu\'e8c - Ng\'ad\'eai Vi\'d6t Nam duy nh\'cat l\'f3c \'ae\'e3 s\'e8ng \'eb M
\'b8txc\'acva. Tr.464.
\par }{\f37\fs18\expnd0\expndtw-4\insrsid1378858 62. B\'b8o }{\i\f37\fs18\expnd0\expndtw-4\insrsid1378858 La Tribune indig\'ccne}{\f37\fs18\expnd0\expndtw-4\insrsid1378858 : B\'b8o c\'f1a ph\'b8i l\'cbp hi\'d5n \'a7\'abng D\'ad\'acng, xu\'cat b\'b6n \'eb S\'b5
i G\'dfn t\'f5 n\'a8m 1917 \'ae\'d5n 1925, m\'e7i tu\'c7n 3 k\'fa v\'b5o th\'f8 3, 5, 7. Tr.466.
\par }{\f37\fs18\insrsid1378858 
\par }{\b\f37\fs18\insrsid1378858 \column 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 
\par 
\par B\'b6N CH\'d8 D\'c9N T\'a3N NG\'a6\'eaI
\par }\pard\plain \s1\qc \li0\ri0\sa240\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\i\f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i0\fs22\insrsid1378858 A
\par }\pard\plain \qj \fi-426\li426\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin426\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 ARIXT\'e8T}{\f37\fs18\insrsid1378858  (kho\'b6
ng 384-322 TCN): Nh\'b5 tri\'d5t h\'e4c c\'e6 \'ae\'b9i Hy L\'b9p. Arixt\'e8t tr\'ef tr\'f5 gi\'f7a ch\'f1 ngh\'dca duy v\'cbt v\'b5 ch\'f1 ngh\'dca duy t\'a9m, sau \'abng ng\'b6 theo ch\'f1 ngh\'dca duy t\'a9m. V\'d2 nh\'cbn th\'f8c lu\'cbn, Arixt\'e8t g
\'c7n v\'edi ch\'f1 ngh\'dca duy v\'cbt. L\'b5 m\'e9t b\'e9 \'e3c b\'b8ch khoa, Arixt\'e8t \'ae\'d3 l\'b9i nhi\'d2u c\'abng tr\'d7nh nghi\'aan c\'f8u c\'e3 gi\'b8 tr\'de v\'d2 tri\'d5t h\'e4c, sinh v\'cbt h\'e4c, \'ae\'b9o \'ae\'f8c h\'e4c, thi ph\'b8p v
\'b5 c\'e3 \'b6nh h\'ad\'ebng to l\'edn v\'b5 l\'a9u d\'b5i trong n\'d2n v\'a8n minh ch\'a9u \'a2u.
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 B\'d0CT\'a5L\'a4,}{\f37\fs18\insrsid1378858  }{
\b\f37\fs18\insrsid1378858 Pie \'a3gien Max\'aclen}{\f37\fs18\insrsid1378858  (1827-1907): Nh\'b5 ho\'b8 h\'e4c ng\'ad\'eai Ph\'b8p. N\'a8m 1876 \'ae\'ad\'eec b\'c7u l\'b5m Vi\'d6n s\'dc th\'abng t\'can Vi\'d6n H\'b5n l\'a9m khoa h\'e4c P\'aat\'d0
cbua (Nga).
\par }\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 B\'d0CT\'a4NG,}{\fs18\insrsid1378858  }{
\b\fs18\insrsid1378858 Pie Mari \'a1ng\'aer\'aa}{\fs18\insrsid1378858  (1882-1968): Lu\'cbt s\'ad, ngh\'de s\'dc Qu\'e8c h\'e9i c\'f1a \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p n\'a8m 1919, d\'f9 \'a7\'b9i h\'e9i Tua n\'a8m 1920 (kh\'abng ph\'b6i l\'b5 \'ae\'b9i bi
\'d3u v\'b5 c\'e3 tham lu\'cbn); ngh\'de s\'dc Qu\'e8c h\'e9i c\'f1a \'a7\'b6ng C\'e9ng s\'b6n \'ae\'d5n n\'a8m 1932, sau \'ae\'e3 b\'e1 \'a7\'b6ng C\'e9ng s\'b6n.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 B\'a3HEN,}{\f37\fs18\insrsid1378858  }{
\b\f37\fs18\insrsid1378858 Pinh\'ab \'ae\'ea}{\f37\fs18\insrsid1378858  (1741-1799): C\'dfn g\'e4i l\'b5 B\'b8 \'a7a L\'e9c, gi\'b8o s\'dc ng\'ad\'eai Ph\'b8p. D\'ad\'edi danh ngh\'dca truy\'d2n \'ae\'b9o, B\'aahen \'ae\'b7 t\'ddch c\'f9c ho\'b9t \'ae\'e9
ng do th\'b8m v\'b5 chu\'c8n b\'de cho s\'f9 can thi\'d6p v\'b5 x\'a9m l\'ad\'eec c\'f1a th\'f9c d\'a9n Ph\'b8p v\'b5o n\'ad\'edc ta. B\'aahen l\'b5 k\'ce t\'ddch c\'f9c gi\'f3p Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 nh ch\'e8
ng l\'b9i s\'f9 nghi\'d6p th\'e8ng nh\'cat \'ae\'cat n\'ad\'edc c\'f1a phong tr\'b5o T\'a9y S\'acn; gi\'f3p Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 nh k\'fd v\'edi Ph\'b8p b\'b6n hi\'d6p \'ad\'edc b\'b8n n\'ad\'edc n\'a8m 1787.

\par }\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 \sect }\sectd 
