\par 
\par 
\par 
\par 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \line \line \line \line \'a7\'a4NG D\'a6\'a5NG
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-298\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~Tuy r\'bbng Qu\'e8c t\'d5 C\'e9ng s\'b6n \'ae\'b7 l\'b5
m cho v\'can \'ae\'d2 thu\'e9c \'ae\'dea c\'e3 \'ae\'ad\'eec t\'c7m quan tr\'e4ng x\'f8ng \'ae\'b8ng v\'edi n\'e3 b\'bbng c\'b8ch coi n\'e3 l\'b5 thu\'e9c v\'d2 nh\'f7ng v\'can \'ae\'d2 th\'eai s\'f9 kh\'c8n tr\'ad\'acng nh\'cat, nh\'adng trong th\'f9c ti
\'d4n, c\'b8c ban thu\'e9c \'ae\'dea \'eb c\'b8c c\'ad\'eang qu\'e8c th\'f9c d\'a9n, cho \'ae\'d5n nay, v\'c9n ch\'ada quan t\'a9m \'ae\'d5n v\'can \'ae\'d2 n\'b5y, th\'cbm ch\'dd c\'b8c ban n\'b5y c\'f2ng ch\'ada xem x\'d0t v\'can \'ae\'d2 m\'e9t c\'b8
ch nghi\'aam t\'f3c!
\par S\'f9 kh\'abng ho\'b9t \'ae\'e9ng n\'b5y th\'cbt \'ae\'b8ng ng\'b9c nhi\'aan, nh\'cat l\'b5 khi kh\'abng c\'dfn s\'f9 tranh c\'b7i n\'e9i b\'e9 trong \'ae\'b6ng \'ae\'b7 \'ae\'ad\'eec thanh tr\'f5, v\'b5 \'ae\'b8ng ng\'b9c nhi\'aan khi v\'can \'ae\'d2 tuy
\'d3n m\'e9 ng\'ad\'eai thu\'e9c \'ae\'dea l\'b9i \'ae\'ad\'eec ch\'f1 ngh\'dca t\'ad b\'b6n v\'b5 ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c c\'f1a ch\'ddnh qu\'e8c nghi\'aan c\'f8u r\'b8o ri\'d5t. S\'f9 kh\'abng ho\'b9t \'ae\'e9ng n\'b5y c\'e3 l\'cf do c\'b8c 
\'ae\'e5ng ch\'dd ch\'f3ng ta kh\'abng hi\'d3u bi\'d5t t\'d7nh h\'d7nh ch\'ddnh x\'b8c c\'f1a nh\'f7ng x\'f8 b\'de \'b8p b\'f8c. Do v\'cby, t\'abi th\'cay c\'e3 \'ddch, n\'d5u ph\'b8c ho\'b9 ng\'ben g\'e4n \'eb \'ae\'a9y t\'d7nh h\'d7nh c\'f1a m\'e9
t trong nh\'f7ng thu\'e9c \'ae\'dea l\'edn nh\'cat c\'f1a n\'ad\'edc Ph\'b8p, l\'b5 \'a7\'abng D\'ad\'acng.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-298\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 N\'e3i r\'bbng \'a7\'abng D\'ad\'acng g\'e5m hai m\'ad\'ac
i tri\'d6u ng\'ad\'eai b\'de b\'e3c l\'e9t, hi\'d6n nay \'ae\'b7 ch\'ddn mu\'e5i cho m\'e9t cu\'e9c c\'b8ch m\'b9ng l\'b5 sai, nh\'adng n\'e3i r\'bbng \'a7\'abng D\'ad\'acng kh\'abng mu\'e8n c\'b8ch m\'b9ng v\'b5 b\'bbng l\'dfng v\'edi ch\'d5 \'ae\'e9 b
\'a9y gi\'ea nh\'ad c\'b8c \'abng ch\'f1 c\'f1a ch\'f3ng ta th\'ad\'eang v\'c9n ngh\'dc nh\'ad th\'d5, th\'d7 l\'b9i c\'b5ng sai h\'acn n\'f7a. S\'f9 th\'cbt l\'b5 ng\'ad\'eai \'a7\'abng D\'ad\'acng kh\'abng c\'e3 m\'e9t ph\'ad\'acng ti\'d6n h\'b5nh \'ae
\'e9ng v\'b5 h\'e4c t\'cbp n\'b5o h\'d5t. B\'b8o ch\'dd, h\'e9i h\'e4p, l\'cbp h\'e9i, \'aei l\'b9i \'ae\'d2u b\'de c\'cam... Vi\'d6c c\'e3 nh\'f7ng b\'b8o ho\'c6c t\'b9p ch\'dd mang t\'ad t\'ad\'ebng ti\'d5n b\'e9 m\'e9t ch\'f3t ho\'c6c c\'e3 m\'e9t t
\'ea b\'b8o c\'f1a giai c\'cap c\'abng nh\'a9n Ph\'b8p l\'b5 m\'e9t t\'e9i n\'c6ng. R\'ad\'eeu c\'e5n v\'b5 thu\'e8c phi\'d6n c\'efng b\'b8o ch\'dd ph\'b6n \'ae\'e9ng c\'f1a b\'e4n c\'c7m quy\'d2n b\'e6 sung cho c\'b8i c\'abng cu\'e9c ngu d\'a9n c\'f1a ch
\'ddnh ph\'f1. M\'b8y ch\'d0m v\'b5 nh\'b5 t\'ef l\'b5m n\'e8t ph\'c7n c\'dfn l\'b9i.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 B\'de \'ae\'c7u \'ae\'e9c c\'b6 v\'d2 tinh th\'c7n l\'c9
n v\'d2 th\'d3 x\'b8c, b\'de b\'det m\'e5m v\'b5 b\'de giam h\'b7m, ng\'ad\'eai ta c\'e3 th\'d3 t\'ad\'ebng r\'bbng c\'b8i b\'c7y ng\'ad\'eai \'cay c\'f8 m\'b7i m\'b7i b\'de d\'efng l\'b5m \'ae\'e5 \'ae\'d3 t\'d5 c\'b8i \'abng th\'c7n t\'ad b\'b6n, r\'bb
ng b\'c7y ng\'ad\'eai \'ae\'e3 kh\'abng s\'e8ng n\'f7a, kh\'abng suy ngh\'dc n\'f7a v\'b5 l\'b5 v\'ab d\'f4ng trong vi\'d6c c\'b6i t\'b9o x\'b7 h\'e9i. Kh\'abng: }{\i\f37\fs20\insrsid1378858 ng\'ad\'eai \'a7\'abng D\'ad\'acng kh\'abng ch\'d5t, ng\'ad\'ea
i \'a7\'abng D\'ad\'acng v\'c9n s\'e8ng, s\'e8ng m\'b7i m\'b7i}{\f37\fs20\insrsid1378858 . S\'f9 \'ae\'c7u \'ae\'e9c c\'e3 h\'d6 th\'e8ng c\'f1a b\'e4n t\'ad b\'b6n th\'f9c d\'a9n kh\'abng th\'d3 l\'b5m t\'aa li\'d6t s\'f8c s\'e8ng, c\'b5ng kh\'abng th
\'d3 l\'b5m t\'aa li\'d6t t\'ad t\'ad\'ebng c\'b8ch m\'b9ng c\'f1a ng\'ad\'eai \'a7\'abng D\'ad\'acng. Lu\'e5ng gi\'e3 t\'f5 n\'ad\'edc Nga th\'ee thuy\'d2n, t\'f5 Trung Qu\'e8c c\'b8ch m\'b9ng ho\'c6c t\'f5 }{\f38\fs20\insrsid1378858 \'ca}{
\f37\fs20\insrsid1378858 n \'a7\'e9 chi\'d5n \'ae\'cau \'aeang th\'e6i \'ae\'d5n gi\'b6i \'ae\'e9c cho ng\'ad\'eai \'a7\'abng D\'ad\'acng. Ng\'ad\'eai \'a7\'abng D\'ad\'acng 
\par }\pard \qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 kh\'abng \'ae\'ad\'eec h\'e4c, \'ae\'f3ng th\'d5, b\'bbng s\'b8ch v\'eb v\'b5 b\'bbng di\'d4n v\'a8n, nh\'adng ng\'ad\'eai 
\'a7\'abng D\'ad\'acng nh\'cbn s\'f9 gi\'b8o d\'f4c b\'bbng c\'b8ch kh\'b8c. \'a7au kh\'e6, ngh\'cco \'ae\'e3i v\'b5 s\'f9 \'ae\'b5n \'b8p t\'b5n b\'b9o l\'b5 nh\'f7ng ng\'ad\'eai th\'c7y duy nh\'cat c\'f1a
\par h\'e4. N\'d5u nh\'f7ng ng\'ad\'eai x\'b7 h\'e9i ch\'f1 ngh\'dca l\'ac l\'b5 vi\'d6c gi\'b8o d\'f4c, th\'d7 giai c\'cap t\'ad s\'b6n th\'f9c d\'a9n v\'b5 b\'b6n x\'f8 - b\'e4n quan l\'b9i - c\'f8 ph\'f4 tr\'b8ch gi\'b8o d\'f4c b\'bbng ph\'ad\'acng ph\'b8
p c\'f1a ch\'f3ng. Ng\'ad\'eai \'a7\'abng D\'ad\'acng ti\'d5n b\'e9 m\'e9t c\'b8ch r\'cat m\'b5u nhi\'d6m v\'b5 khi th\'eai c\'ac cho ph\'d0p h\'e4 s\'cf bi\'d5t t\'e1 ra x\'f8ng \'ae\'b8ng v\'edi nh\'f7ng ng\'ad\'eai th\'c7y c\'f1a h\'e4. \'a7\'bb
ng sau s\'f9 ph\'f4c t\'efng ti\'aau c\'f9c, ng\'ad\'eai \'a7\'abng D\'ad\'acng gi\'cau m\'e9t c\'b8i g\'d7 \'aeang s\'abi s\'f4c, \'aeang g\'b5o th\'d0t v\'b5 s\'cf b\'efng n\'e6 m\'e9t c\'b8ch gh\'aa g\'edm, khi th\'eai c\'ac \'ae\'d5n. B\'e9 ph\'cbn 
\'adu t\'f3 c\'e3 nhi\'d6m v\'f4 ph\'b6i th\'f3c \'ae\'c8y cho th\'eai c\'ac \'ae\'e3 mau \'ae\'d5n.
\par }\pard \qj \fi397\li0\ri0\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 S\'f9 t\'b5n b\'b9o c\'f1a ch\'f1 ngh\'dca t\'ad b\'b6n \'ae\'b7 chu\'c8n b\'de \'ae\'cat r\'e5i: Ch\'f1 ngh\'dca x\'b7 h\'e9
i ch\'d8 c\'dfn ph\'b6i l\'b5m c\'b8i vi\'d6c l\'b5 gieo h\'b9t gi\'e8ng c\'f1a c\'abng cu\'e9c gi\'b6i ph\'e3ng n\'f7a th\'abi.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 NGUY\'d4N \'b8I QU\'e8C
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858\charrsid30160 T\'b9p ch\'dd }{
\i\f37\insrsid1378858\charrsid30160 La Revue Communiste,
\par }{\f37\insrsid1378858\charrsid30160 s\'e8 14, th\'b8ng 4-1921.}{\f37\insrsid1378858 
\par 
\par }\pard\plain \s21\qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
