\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 T\'f5 khi c\'e3 ch\'f1 ngh\'dca th\'f9c d\'a9n, nhi\'d2
u ng\'ad\'eai da tr\'beng \'ae\'b7 \'ae\'ad\'eec thu\'aa ti\'d2n \'ae\'d3 \'ae\'cam v\'ec m... nh\'f7ng ng\'ad\'eai da \'aeen. C\'e3 m\'e9t l\'c7n, m\'e9t ng\'ad\'eai da \'aeen l\'b9i c\'f2ng \'ae\'b7 \'ae\'ad\'eec thu\'aa ti\'d2n \'ae\'d3 l\'b5m nh\'ad v
\'cby \'ae\'e8i v\'edi m\'e9t ng\'ad\'eai da tr\'beng. L\'b5 ng\'ad\'eai ch\'e8ng l\'b9i m\'e4i th\'f8 b\'b9o l\'f9c, ch\'f3ng ta kh\'abng t\'b8n th\'b5nh c\'b6 hai l\'e8i \'ae\'e3. Nh\'adng s\'f9 vi\'d6c v\'c9n c\'f8 s\'ea s\'ea ra \'ae\'e3, th\'d7 ch
\'f3ng ta h\'b7y nh\'cbn x\'d0t xem sao. \'a7\'a9y, nh\'ad th\'d5 n\'b5y:
\par B\'bbng m\'e9t qu\'b6 \'ae\'cam  - n\'d5u kh\'abng ph\'b6i l\'b5 \'ae\'b7 \'ae\'cam m\'e9t c\'b8ch khoa h\'e4c th\'d7 \'ddt ra c\'f2ng l\'b5 m\'e9t qu\'b6 \'ae\'cam b\'bbng tr\'eai gi\'b8ng - Xiki \'ae\'b7 h\'b9 b\'d6 C\'b8cp\'a8ngchi\'aa \'ae\'d3 r\'e5i 
\'ae\'ddch th\'a9n m\'d7nh tr\'cco l\'aan.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Ch\'f8c v\'ab \'ae\'dech quy\'d2n Anh \'ae\'b7 chuy\'d3
n sang tay kh\'b8c, nh\'adng vinh quang c\'f1a d\'a9n t\'e9c v\'d2 m\'c6t th\'d3 thao th\'d7 kh\'abng h\'d2 b\'de t\'e6n th\'ad\'acng, v\'d7 r\'bbng Xiki l\'b5 ng\'ad\'eai con c\'f1a x\'f8 X\'aan\'aagan, do \'ae\'e3 l\'b5 con c\'f1a n\'ad\'edc Ph\'b8p, t
\'f8c l\'b5 ng\'ad\'eai Ph\'b8p v\'cby.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 M\'c6c d\'ef th\'d5, m\'e7i l\'c7n C\'b8cp\'a8ngchi\'aa th
\'beng th\'d7 d\'dc nhi\'aan l\'b5 do s\'f9 kh\'d0o l\'d0o v\'b5 khoa h\'e4c c\'f1a anh. Nh\'adng l\'c7n n\'b5o anh b\'de b\'b9i th\'d7 c\'f2ng \'ae\'d2u l\'b5 do s\'f8c l\'f9c th\'ab b\'b9o c\'f1a m\'e9t anh nh\'ad \'a7enx\'a9y ho\'c6c do c\'b8i ch\'a9
n ch\'aci \'b8c c\'f1a m\'e9t anh nh\'ad Xiki. V\'d7 th\'d5 trong tr\'cbn \'ae\'cau \'eb Bu\'fdpphal\'ab, ng\'ad\'eai ta \'ae\'b7 mu\'e8n tuy\'aan b\'e8 - v\'b5 ng\'ad\'eai ta c\'f2ng \'ae\'b7 tuy\'aan b\'e8 - r\'bbng Xiki m\'c6c d\'ef th\'beng \'ae\'ca
y, nh\'adng "c\'f2ng v\'c9n" l\'b5 b\'b9i. Nh\'adng c\'abng ch\'f3ng, lo\'b9i c\'abng ch\'f3ng t\'e8t, kh\'abng mu\'e8n nghe nh\'ad v\'cby. V\'b5 c\'abng l\'fd c\'f1a nh\'a9n d\'a9n \'ae\'b7 th\'beng: Xiki \'ae\'ad\'eec tuy\'aan b\'e8 l\'b5 v\'ab \'ae\'de
ch ho\'b5n c\'c7u v\'b5 n\'ad\'edc Ph\'b8p.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Sau khi b\'de m\'e9t ng\'ad\'eai da \'aeen h\'b9 \'aeo v\'b8n, C\'b8cp\'a8ngchi\'aa \'ae\'b7 b\'d7nh 
\par }\pard \qj \li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 th\'b6n \'aei th\'a8m n\'ad\'edc Nga, \'ae\'cat n\'ad\'edc c\'f1a nh\'f7ng ng\'ad\'eai \'a7\'e1. Ch\'f3ng ta ng\'ee
i khen Xiki v\'d2 th\'beng l\'eei c\'f1a anh. Ch\'f3ng ta c\'f2ng ng\'eei khen C\'b8cp\'a8ngchi\'aa v\'d2 l\'dfng v\'ab t\'ad c\'f1a anh.
\par }\pard \qc \li0\ri0\sb120\sa60\sl-300\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 *\line *     *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 S.D.N. (xin \'ae\'e4c l\'b5 xagi\'d0t \'ae\'aa naxi\'abng}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain 
\s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) }{\i\insrsid1378858 Sagesse des nations: }{\insrsid1378858 \'a7\'b9
o l\'fd cu\'e9c s\'e8ng.
\par 2) }{\i\insrsid1378858 Soci\'d0t\'d0 des Nations: H\'e9i qu\'e8c li\'aan.}})}{\f37\fs20\insrsid1378858 , ch\'f8 kh\'abng ph\'b6i x\'abxi\'aat\'aa \'ae\'aa naxi\'abng}{\f37\fs20\super\insrsid1378858 2)}{\f37\fs20\insrsid1378858 ) n\'e3i r\'bbng Th\'c7n T
\'b5i ch\'d8 c\'ad\'eai duy\'aan v\'edi m\'e9t ng\'ad\'eai gi\'b5u c\'e3. R\'acn\'aa Mar\'a8ng v\'b5 Xiki \'ae\'b7 l\'b5m ch\'b6y nhi\'d2u m\'f9c \'aeen. H\'acn n\'f7a, Xiki c\'dfn l\'b5m ch\'b6y c\'b6 m\'b8u \'ae\'e1. Ng\'ad\'eai ta l\'b5m nh\'ad c\'b6
 hai ng\'ad\'eai anh em ch\'a9u Phi c\'f1a ch\'f3ng ta c\'dfn c\'c7n \'ae\'d5n nhi\'d2u m\'f9c n\'f7a. Sau ng\'dfi b\'f3t ch\'a9m bi\'d5m c\'f1a Mar\'a8ng, \'ae\'abi g\'a8ng c\'f1a Xiki \'ae\'b7 l\'b5m rung \'ae\'e9ng \'ae\'d5n c\'b6 ch\'ddnh gi\'edi. V
\'b5 \'abng Luk\'aa, h\'e9i vi\'aan H\'e9i \'ae\'e5ng qu\'cbn Xen, \'ae\'b7 l\'cbp t\'f8c \'ae\'ada ra m\'e9t ki\'d5n ngh\'de \'ae\'denh c\'cam cu\'e9c \'ae\'cau quy\'d2n Anh ! Xin ph\'d0p \'abng Luk\'aa cho ch\'f3ng t\'abi k\'ddnh c\'c8n th\'ada v\'edi 
\'abng r\'bbng, nh\'ad v\'cby l\'b5 \'abng \'ae\'b7 l\'b5m m\'e9t vi\'d6c kh\'abng y\'aau n\'ad\'edc. Ch\'f3ng t\'abi xin gi\'b6i th\'ddch: V\'d2 ph\'ad\'acng di\'d6n ch\'ddnh tr\'de qu\'e8c t\'d5 c\'f1a ch\'f3ng ta, m\'e9t nh\'b5 v\'ab \'ae\'dech quy\'d2
n Anh h\'b9ng l\'abng c\'f2ng tuy\'aan truy\'d2n cho \'b6nh h\'ad\'ebng tinh th\'c7n c\'f1a ch\'f3ng ta ra n\'ad\'edc ngo\'b5i nh\'ad l\'b5 m\'e9t ng\'ad\'eai b\'cat t\'f6, m\'e9t ng\'ad\'eai quang vinh, m\'e9t ca s\'dc ho\'c6c m\'ad\'eai \'ae\'b9o qu\'a9
n (\'abng h\'b7y gi\'eb b\'b8o ch\'dd ra m\'b5 xem). V\'d2 ph\'ad\'acng di\'d6n qu\'e8c gia c\'f2ng c\'c7n thi\'d5t ph\'b6i c\'e3 m\'e9t v\'e2 s\'dc c\'e3 t\'b5i \'ae\'d3 n\'aau g\'ad\'acng v\'b5 khuy\'d5n kh\'ddch c\'b8i \'ae\'d1p v\'d2 th\'d3 l\'f9
c cho th\'d5 h\'d6 tr\'ce. V\'d2 ph\'ad\'acng di\'d6n thu\'e9c \'ae\'dea, m\'e9t tr\'cbn \'ae\'cau C\'b8cp\'a8ngchi\'aa - Xiki c\'e3 gi\'b8 tr\'de h\'acn m\'ad\'eai v\'b9n b\'b5i di\'d4n v\'a8n c\'f1a nh\'f7ng nh\'b5 cai tr\'de nh\'bbm ch\'f8ng t\'e1 cho
 nh\'f7ng con d\'a9n v\'b5 nh\'f7ng ng\'ad\'eai \'ae\'ad\'eec b\'b6o h\'e9 c\'f1a ch\'f3ng ta r\'bbng, ch\'f3ng ta mu\'e8n \'b8p d\'f4ng tri\'d6t \'ae\'d3 nguy\'aan t\'bec b\'d7nh \'ae\'bcng v\'d2 ch\'f1ng t\'e9c.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'e3 n\'aan hy sinh ba \'aei\'d2u l\'eei \'ae\'e3 cho m
\'e9t c\'b8i ch\'f1 ngh\'dca nh\'a9n \'ae\'b9o m\'ac h\'e5 n\'b5o \'ae\'e3 kh\'abng? Kh\'abng ! C\'e3 ph\'b6i kh\'abng, \'abng Xar\'ab?
\par }\pard\plain \qc \li0\ri0\sb120\sa60\sl-300\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 *\line *     *
\par }\pard \qj \li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Theo tin c\'b8c b\'b8o th\'d7 ng\'ad\'eai ta v\'f5a ra l\'d6nh treo gi\'df Xiki trong ch\'ddn th\'b8ng, kh\'abng cho d\'f9 t
\'cat c\'b6 c\'b8c v\'e2 \'ae\'b5i n\'ad\'edc Ph\'b8p (Nh\'ad v\'cby kh\'abng h\'d2 c\'e3 ngh\'dca l\'b5 ng\'ad\'eai ta s\'cf \'aeem treo Xiki \'ae\'b8ng th\'ad\'acng c\'f1a ch\'f3ng ta trong ch\'ddn th\'b8ng \'ae\'e5ng th\'eai tr\'aan t\'cat c\'b6 v\'e2 
\'ae\'b5i c\'f1a n\'ad\'edc Ph\'b8p \'ae\'a9u. - Xin nh\'ben v\'edi c\'b8c b\'b9n c\'f1a ch\'f3ng t\'abi \'eb X\'aan\'aagan nh\'ad v\'cby). L\'fd do: \'ae\'b7 l\'a8ng m\'b9 \'abng Quyni.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Sao th\'d5 nh\'d8? Tr\'ad\'edc \'ae\'a9y ng\'ad\'eai ta \'ae\'b7 tuy\'aan d\'ad\'acng Xiki v\'d7 anh \'ae\'b7 \'ae\'b8
nh s\'adng m\'f2i \'abng C\'b8cp\'a8ngchi\'aa c\'ac m\'b5. Ng\'b5y nay, Xiki ch\'ada h\'d2 \'ae\'f4ng \'ae\'d5n ch\'a9n l\'abng Quyni, m\'b5 sao ng\'ad\'eai ta \'ae\'b7 tuy\'aan b\'e8 h\'b9 anh xu\'e8ng nh\'ad v\'cby? Ng\'ad\'eai ta c\'f2ng kh\'abng h\'d2
 \'ae\'denh l\'b5m cho ch\'f3ng ta t\'ad\'ebng r\'bbng c\'b8i... m\'c6t c\'f1a Quyni m\'b6nh d\'ce v\'b5 qu\'fd b\'b8u h\'acn l\'b5 m\'c6t \'abng C\'b8cp\'a8ngchi\'aa, v\'b5 r\'bbng... Ch\'b6 ph\'b6i th\'d5. Th\'cbt ch\'bcng hi\'d3u ra sao. Ch\'f3ng t\'ab
i \'aeo\'b8n c\'e3 l\'cf l\'b5 th\'d5 n\'b5y: ng\'ad\'eai ta kh\'abng bao gi\'ea tha th\'f8 cho Xiki l\'b5 m\'e9t ng\'ad\'eai da \'aeen \'ae\'b7 th\'beng C\'b8cp\'a8ngchi\'aa l\'b5 m\'e9t ng\'ad\'eai da tr\'beng; v\'b5 tuy C\'b8cp\'a8ngchi\'aa kh\'abng c
\'e3 l\'dfng h\'bbn th\'ef, nh\'adng ch\'f1 ngh\'dca v\'de ch\'f1ng c\'f1a nh\'f7ng ng\'ad\'eai kh\'b8c th\'d7 l\'b9i \'aeem l\'dfng h\'bbn th\'ef. V\'b5 c\'b8i l\'fd do kia ch\'d8 l\'b5 m\'e9t c\'b8i l\'fd do... vin l\'cay cho c\'e3 l\'fd do m\'b5 th\'ab
i.
\par C\'f2ng theo c\'b8c b\'b8o \'ae\'e3, ch\'f3ng ta \'ae\'ad\'eec bi\'d5t r\'bbng B\'e9 tr\'ad\'ebng B\'e9 N\'e9i v\'f4 Anh \'ae\'b7 c\'cam cu\'e9c \'ae\'cau d\'f9 \'ae\'denh t\'f5 tr\'ad\'edc gi\'f7a Gi\'ab\'aa B\'d5chk\'d5t v\'b5 Xiki \'eb Lu\'a9n \'a7\'ab
n. Vi\'d6c n\'b5y kh\'abng l\'b5m cho ch\'f3ng ta ng\'b9c nhi\'aan. V\'d7 C\'f4 l\'edn n\'ad\'edc Anh \'ae\'b7 kh\'abng th\'d3 ti\'aau ho\'b8 n\'e6i m\'e3n b\'b8nh h\'d7nh l\'ad\'eci li\'d2m}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain 
\s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) }{\i\insrsid1378858 Croissant: }{\f38\insrsid1378858 \'fd }{
\insrsid1378858 n\'e3i h\'d7nh m\'c6t tr\'a8ng l\'ad\'eci li\'d2m tr\'aan l\'b8 c\'ea c\'f1a n\'ad\'edc Th\'e6 Nh\'dc K\'fa.
\par 2) }{\i\insrsid1378858 S\'abc\'abla}{\i\f38\insrsid1378858 : }{\f38\insrsid1378858 \'fd}{\insrsid1378858  n\'e3i t\'edi m\'b5u da c\'f1a ph\'c7n l\'edn ng\'ad\'eai }{\f38\insrsid1378858 \'ca}{\insrsid1378858 n \'a7\'e9.
\par 3) }{\i\insrsid1378858 Battling: }{\insrsid1378858 t\'aan d\'dech ra t\'f5 ti\'d5ng Anh c\'e3 ngh\'dca l\'b5 \'ae\'cau s\'dc.
\par 4) Nguy\'aan v\'a8n vi\'d5t b\'bbng ti\'d5ng Anh: }{\i\insrsid1378858 Understand.}})}{\f37\fs20\insrsid1378858  c\'f1a K\'aaman c\'f2ng nh\'ad m\'e3n s\'abc\'abla}{\f37\fs20\super\insrsid1378858 2)}{\f37\fs20\insrsid1378858  c\'f1a G\'a8ng\'aei cho n\'aa
n Ng\'b5i mu\'e8n b\'b8tlinh}{\f37\fs20\super\insrsid1378858 3)}{\f37\fs20\insrsid1378858  Xiki ph\'b6i nu\'e8t li\'d2u thu\'e8c t\'c8y c\'f1a Ng\'b5i, m\'c6c d\'ef Xiki l\'b5 m\'e9t ng\'ad\'eai Ph\'b8p. C\'b8c b\'b9n \'ae\'b7 hi\'d3u ch\'ada?}{
\f37\fs20\super\insrsid1378858 4)}{\f37\fs20\insrsid1378858 .}{\f37\fs20\super\insrsid1378858 
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb160\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nguy\'d4n \'b8i qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 Le Paria}{\insrsid1378858 , s\'e8 9,
\line ng\'b5y 1-12-1922.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\b\f37\fs20\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 NH\'f7NG QUAN TO\'b5 THU\'e9C \'a7\'deA\line T\'e8T B
\'f4NG C\'f1A CH\'f3NG TA
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 B\'bbng ch\'d8 th\'de ng\'b5y 10 th\'b8ng 10 n\'a8
m 1922, ch\'ddnh ph\'f1 \'ae\'b7 thi h\'b5nh ngh\'de \'ae\'denh v\'d2 b\'e6 nhi\'d6m ng\'ad\'eai v\'b5o ch\'f8c quan to\'b5 thu\'e9c \'ae\'dea. Trong s\'e8 nh\'f7ng ng\'ad\'eai \'ae\'e3, ch\'f3ng ta th\'cay t\'aan c\'b8c \'abng Luycax\'ac v\'b5 \'ab
ng Oabr\'a8ng.
\par C\'c7n nh\'bec l\'b9i s\'ac l\'ad\'eec lai l\'dech c\'f1a hai v\'de quan to\'b5 n\'b5y.
\par \'a4ng Luycax\'ac l\'b5 c\'f9u ch\'ad\'ebng l\'fd \'eb T\'a9y Phi thu\'e9c Ph\'b8p, \'ae\'b7 \'ae\'ad\'eec
\par n\'e3i t\'edi nh\'a9n v\'f4 r\'bec r\'e8i v\'f5a r\'e5i \'eb T\'abg\'ab. Trong th\'abng c\'b8o b\'b8o ch\'dd, B\'e9 tr\'ad\'ebng B\'e9 Thu\'e9c \'ae\'dea \'ae\'b7 bu\'e9c ph\'b6i tuy\'aan b\'e8: "Cu\'e9c \'aei\'d2u tra \'ae\'b7 x\'b8c \'ae\'denh \'ab
ng Luycax\'ac c\'e3 tham d\'f9 v\'b5o v\'f4 vi\'d6c, v\'b5 \'aei\'d2u \'ae\'e3 \'ae\'c6t tr\'b8ch nhi\'d6m r\'cat n\'c6ng n\'d2 l\'aan t\'e6 ch\'f8c quan to\'b5".
\par C\'e3 l\'cf \'ae\'d3 th\'ad\'ebng c\'abng v\'d2 vi\'d6c tham gia v\'f4 b\'aa b\'e8i, \'abng Luycax\'ac \'ae\'b7 \'ae\'ad\'eec b\'e6 nhi\'d6m l\'b5m ch\'f1 to\'b9 to\'b5 th\'ad\'eeng th\'c8m \'eb ch\'a9u Phi x\'ddch \'ae\'b9o thu\'e9c Ph\'b8p.
\par }\pard \qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 C\'dfn v\'d2 Oabr\'a8ng th\'d7 lai l\'dech c\'f1a \'abng ta \'ae\'acn gi\'b6n h\'acn v\'b5 \'ddt n\'e6i ti\'d5ng h\'acn. N\'a8
m 1920, m\'e9t ng\'ad\'eai Ph\'b8p h\'e4 l\'b5 \'a7uy\'d5cgri, nh\'a9n vi\'aan h\'b7ng P\'a9yru\'fdtx\'bec \'eb C\'a8ngcan (Ghin\'aa) \'aei s\'a8n. \'a4ng ta b\'ben m\'e9t con chim r\'aci xu\'e8ng s\'abng. M\'e9t em b\'d0 ch\'b9y ngang qua. \'a7uy\'d5
cgri t\'f3m em b\'d0 v\'f8t xu\'e8ng s\'abng v\'b5 ra l\'d6nh t\'d7m b\'bbng \'ae\'ad\'eec con chim. S\'abng s\'a9u, n\'ad\'edc ch\'b6y xi\'d5t, em b\'d0 kh\'abng bi\'d5t b\'aci, \'ae\'b7 ch\'d5t ch\'d7m. Cha m\'d1 n\'b9n nh\'a9n ki\'d6n l\'aan nh\'b5 
\'ae\'ad\'acng c\'f4c. \'a7uy\'d5cgri b\'de vi\'aan ch\'d8 huy khu g\'e4i \'ae\'d5n. Y \'ae\'e5ng \'fd tr\'b6 100 phr\'a8ng cho gia \'ae\'d7nh \'aeau kh\'e6 \'ae\'d3 \'d8m v\'f4 n\'b5y.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ng\'ad\'eai cha m\'d1 b\'cat h\'b9nh t\'f5 ch\'e8i c\'b8ch d\'b5n x\'d5p \'ae\'aa ti\'d6n \'cay. Vi\'aan ch\'d8 huy gi
\'cbn d\'f7 \'ae\'f8ng v\'d2 ph\'dda ng\'ad\'eai \'ae\'e5ng b\'b5o gi\'d5t ng\'ad\'eai c\'f1a m\'d7nh v\'b5 do\'b9 b\'e1 t\'ef hai v\'ee ch\'e5ng n\'d5u h\'e4 kh\'a8ng kh\'a8ng \'ae\'dfi tr\'f5ng tr\'de k\'ce gi\'d5t ng\'ad\'eai, sau \'ae\'e3, n\'e3
i chung \'ae\'b7 \'d8m v\'f4 \'cay \'aei.
\par Song c\'e3 m\'e9t b\'f8c th\'ad n\'c6c danh b\'b8o chuy\'d6n n\'b5y cho t\'e6ng c\'abng t\'e8 vi\'aan \'eb \'a7\'becca. To\'b5 \'b8n t\'e8i cao giao cho c\'abng t\'e8 vi\'aan s\'eb t\'b9i Oabr\'a8ng \'aei\'d2u tra t\'b9i ch\'e7. \'a4ng Oabr\'a8ng \'ae\'d5
n C\'a8ngcan, ng\'f1 t\'e8i t\'b9i nh\'b5 \'abng tr\'ad\'ebng ga. Ng\'b5y h\'abm sau, \'abng \'eb nh\'b5 \'a7\'ac Lavalie, tr\'ee l\'fd c\'f1a vi\'aan ch\'d8 huy khu, sau \'ae\'e3, \'aei v\'d2, th\'cbm ch\'dd ch\'ada h\'d2 b\'bet tay v\'b5o vi\'d6c \'aei
\'d2u tra. \'a7i\'d2u \'ae\'e3 kh\'abng ng\'a8n c\'b6n \'abng Oabr\'a8ng k\'d5t lu\'cbn r\'bbng b\'f8c th\'ad mang t\'ddnh ch\'cat vu kh\'e8ng. H\'e9i Li\'aan hi\'d6p thu\'e9c \'ae\'dea b\'b8o s\'f9 vi\'d6c n\'b5y cho H\'e9i Nh\'a9n quy\'d2n v\'b5 D\'a9
n quy\'d2n (ng\'b5y 22 th\'b8ng 12 n\'a8m 1921), nh\'adng c\'e3 l\'cf H\'e9i coi s\'f9 vi\'d6c kh\'abng l\'cay g\'d7 l\'b5m gi\'cbt g\'a9n l\'bem, n\'aan ch\'bcng th\'ccm quan t\'a9m \'ae\'d5n.
\par Sau chuy\'d5n vi\'d5ng th\'a8m C\'a8ngcan, \'abng Oabr\'a8ng trong khi ch\'ea n\'a9ng c\'cap, v\'c9n y\'aan \'e6n \'eb l\'b9i c\'ad\'acng v\'de c\'f1a m\'d7nh, nh\'cbn nh\'f7ng con g\'b5 m\'b8i t\'ac v\'b5 nh\'f7ng bao t\'b6i khoai t\'a9y t\'f5 ng\'ad\'ea
i b\'b9n c\'f1a \'abng l\'b5 \'abng Cudanh \'ae\'ac Lavalie g\'f6i bi\'d5u.
\par Nh\'ad c\'b8c b\'b9n th\'cay \'ae\'cay, \'abng Oabr\'a8ng qu\'b6 l\'b5 x\'f8ng \'ae\'b8ng v\'edi... ph\'c7n th\'ad\'ebng ch\'ddnh \'ae\'b8ng c\'f1a ch\'ddnh ph\'f1 n\'ad\'edc m\'d7nh - \'ae\'ad\'eec b\'e6 nhi\'d6m v\'b5o c\'ad\'acng v\'de T\'e6ng c\'ab
ng t\'e8 vi\'aan c\'f1a n\'ad\'edc c\'e9ng ho\'b5 \'eb \'a7\'becca.
\par V\'edi s\'f9 c\'e3 m\'c6t c\'f1a nh\'f7ng \'a7\'b8cl\'ac, nh\'f7ng B\'ab\'aeoanh, nh\'f7ng Oabr\'a8ng v\'b5 nh\'f7ng Luycax\'ac, c\'e3 th\'d3 n\'e3i r\'bbng v\'cbn m\'d6nh c\'f1a n\'d2n v\'a8n minh t\'e8i cao, c\'f2ng nh\'ad s\'e8 ph\'cbn c\'f1a d\'a9n b
\'b6n x\'f8 \'eb c\'b8c thu\'e9c \'ae\'dea \'ae\'d2u n\'bbm trong nh\'f7ng b\'b5n tay \'ae\'b8ng tin c\'cby.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nguy\'d4n \'b8i qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o}{\i\insrsid1378858  L'Humanit\'d0,}{\insrsid1378858 
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858\charrsid16600835 ng\'b5y 4-12-1922.}{
