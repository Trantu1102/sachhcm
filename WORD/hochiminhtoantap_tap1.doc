\par }{\f37\fs20\insrsid1378858 Nh\'f7ng thu\'e9c \'ae\'dea c\'f1a Ph\'b8p n\'e3i chung v\'b5 \'a7\'abng D\'ad\'acng n\'e3i ri\'aang \'ddt \'ae\'ad\'eec bi\'d5t \'ae\'d5n trong gi\'edi v\'ab s\'b6n v\'b5 c\'e9ng s\'b6n. Qu\'e8c t\'d5 C\'e9ng s\'b6n v\'b5 \'a7
\'b6ng C\'e9ng s\'b6n Ph\'b8p r\'cat \'ddt \'ae\'ad\'eec th\'abng tin v\'d2 nh\'f7ng g\'d7 x\'b6y ra \'eb nh\'f7ng thu\'e9c \'ae\'dea \'ae\'e3. C\'f4c th\'abng tin c\'f1a \'ae\'b6ng c\'c7n ph\'b6i \'ae\'ad\'eec th\'b5nh l\'cbp. C\'dfn nh\'ad \'eb \'ae\'a9
y, ch\'f3ng t\'abi tuy\'d6t \'ae\'e8i kh\'abng c\'e3 g\'d7.
\par }\pard \qj \fi397\li0\ri0\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 N\'d5u ch\'f3ng ta mu\'e8n ho\'b9t \'ae\'e9ng m\'e9t c\'b8ch c\'e3 \'ddch v\'d2 v\'can \'ae\'d2 thu\'e9c \'ae\'dea th\'d7 nh
\'cat thi\'d5t ph\'b6i b\'bet li\'aan l\'b9c v\'edi c\'b8c thu\'e9c \'ae\'dea \'ae\'e3.
\par V\'d2 ph\'c7n \'a7\'abng D\'ad\'acng, t\'f5 l\'f3c t\'abi t\'edi M\'b8txc\'acva \'ae\'b7 c\'e3 quy\'d5t \'ae\'denh r\'bbng sau 3 th\'b8ng l\'adu l\'b9i \'eb \'ae\'a9y, t\'abi s\'cf \'aei Trung Qu\'e8c \'ae\'d3 t\'d7m c\'b8ch li\'aan l\'b9c v\'edi \'ae\'ca
t n\'ad\'edc t\'abi. B\'a9y gi\'ea \'ae\'b7 l\'b5 }{\i\f37\fs20\insrsid1378858 th\'b8ng th\'f8 ch\'ddn}{\f37\fs20\insrsid1378858  t\'abi l\'adu l\'b9i v\'b5 }{\i\f37\fs20\insrsid1378858 th\'b8ng th\'f8 s\'b8u}{\f37\fs20\insrsid1378858  t\'abi ch\'ea \'ae
\'eei, v\'cby m\'b5 vi\'d6c l\'aan \'ae\'ad\'eang c\'f1a t\'abi ch\'ada \'ae\'ad\'eec quy\'d5t \'ae\'denh.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 T\'abi ngh\'dc l\'b5 kh\'abng c\'c7n thi\'d5t ph\'b6i n\'e3i \'eb \'ae\'a9y v\'d2 nh\'f7ng phong tr\'b5o c\'b8ch m\'b9
ng v\'b5 d\'a9n t\'e9c ch\'f1 ngh\'dca, tr\'ad\'edc kia ho\'c6c g\'c7n \'ae\'a9y; v\'d2 s\'f9 t\'e5n t\'b9i ho\'c6c kh\'abng t\'e5n t\'b9i c\'f1a c\'b8c t\'e6 ch\'f8c c\'abng nh\'a9n, c\'f1a nh\'f7ng ho\'b9t \'ae\'e9ng khu\'cay ph\'b8 c\'f1a c\'b8c h\'e9
i b\'dd m\'cbt v\'b5 c\'b8c h\'e9i th\'b6o, v\'d7 t\'abi kh\'abng c\'e3 \'fd \'ae\'denh \'ae\'d6 tr\'d7nh v\'edi c\'b8c \'ae\'e5ng ch\'dd m\'e9t lu\'cbn c\'ad\'acng, v\'b5 ch\'d8 mu\'e8n n\'aau cho th\'cay s\'f9 c\'c7n thi\'d5t \'ae\'e8i v\'edi ch\'f3ng t
\'abi l\'b5 ph\'b6i nghi\'aan c\'f8u }{\i\f38\fs20\insrsid1378858 T\'caT C\'b6}{\f37\fs20\insrsid1378858  m\'e9t c\'b8ch ch\'ddnh x\'b8c, v\'b5 ph\'b6i t\'b9o ra c\'b8i g\'d7 \'ae\'e3 n\'d5u ch\'ada c\'e3 g\'d7.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 V\'cby chuy\'d5n \'aei s\'cf l\'b5 m\'e9t chuy\'d5n \'aei 
\'ae\'d3 kh\'b6o s\'b8t v\'b5 nghi\'aan c\'f8u. T\'abi s\'cf ph\'b6i c\'e8 g\'beng:
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 A- Thi\'d5t l\'cbp nh\'f7ng quan h\'d6 gi\'f7a \'a7\'ab
ng D\'ad\'acng v\'b5 Qu\'e8c t\'d5 C\'e9ng s\'b6n.
\par B- Th\'abng b\'b8o cho Qu\'e8c t\'d5 C\'e9ng s\'b6n v\'d2 t\'d7nh h\'d7nh ch\'ddnh tr\'de, kinh t\'d5 v\'b5 x\'b7 h\'e9i c\'f1a thu\'e9c \'ae\'dea n\'b5y.
\par C- Ti\'d5p x\'f3c v\'edi c\'b8c t\'e6 ch\'f8c \'aeang t\'e5n t\'b9i \'eb \'ae\'e3, v\'b5
\par D- T\'e6 ch\'f8c m\'e9t c\'ac s\'eb th\'abng tin v\'b5 tuy\'aan truy\'d2n.
\par T\'abi h\'b5nh \'ae\'e9ng th\'d5 n\'b5o \'ae\'d3 ho\'b5n th\'b5nh nhi\'d6m v\'f4 n\'b5y? Tr\'ad\'edc h\'d5t t\'abi ph\'b6i \'aei Trung Qu\'e8c. Ti\'d5p \'ae\'e3 h\'ad\'edng s\'f9 ho\'b9t \'ae\'e9ng theo nh\'f7ng kh\'b6 n\'a8ng s\'cf xu\'cat hi\'d6n.

\par S\'e8 ti\'d2n c\'c7n thi\'d5t cho s\'f9 \'a8n \'eb c\'f1a t\'abi s\'cf l\'b5 bao nhi\'aau? - H\'bcn l\'b5 t\'abi s\'cf ph\'b6i \'ae\'e6i ch\'e7 lu\'abn, duy tr\'d7 nh\'f7ng m\'e8i li\'aan h\'d6 v\'edi c\'b8c gi\'edi kh\'b8c nhau, tr\'b6 ti\'d2n th\'ad t
\'ddn, mua nh\'f7ng \'can ph\'c8m n\'e3i v\'d2 \'a7\'abng D\'ad\'acng, ti\'d2n \'a8n v\'b5 ti\'d2n tr\'e4, v.v., v.v.. T\'abi t\'ddnh r\'bbng, sau khi tham kh\'b6o \'fd ki\'d5n c\'b8c \'ae\'e5ng ch\'dd ng\'ad\'eai Trung Qu\'e8c ph\'b6i c\'e3 m\'e9t ng\'a9
n s\'b8ch x\'cap x\'d8 100 \'ae\'abla M\'fc m\'e7i th\'b8ng, kh\'abng k\'d3 h\'b5nh tr\'d7nh Nga - Trung Qu\'e8c (v\'d7 t\'abi kh\'abng bi\'d5t gi\'b8 v\'d0).
\par T\'abi hy v\'e4ng r\'bbng nh\'f7ng \'aei\'d2u tr\'aan s\'cf c\'e3 th\'d3 d\'efng l\'b5m c\'ac s\'eb \'ae\'d3 c\'b8c \'ae\'e5ng ch\'dd th\'b6o lu\'cbn v\'d2 vi\'d6c c\'f6 t\'abi \'aei Vi\'d4n \'a7\'abng.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~Nguy\'d4n
