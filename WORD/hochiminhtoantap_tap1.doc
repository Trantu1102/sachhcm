ch: Thu Trang: }{\i\cgrid0\insrsid1378858 Ho Chi Minh\line \'b5 Paris, }{\cgrid0\insrsid1378858 Pari, 1993, tr. 69-70.\cell }\pard \s26\ql \li0\ri318\sl-260\slmult0\nowidctlpar\intbl\aspalpha\aspnum\faauto\adjustright\rin318\lin0 {\cgrid0\insrsid1378858 D
