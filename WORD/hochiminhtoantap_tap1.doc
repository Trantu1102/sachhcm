\'b5 NAM K\'fa}{\super\insrsid1378858 61}{\insrsid1378858 
\par }\pard\plain \qr \fi397\li0\ri567\sa160\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i\f37\fs20\cgrid0\insrsid1378858 M\'b8txc\'acva, 1924}{
\f37\fs20\cgrid0\insrsid1378858  
\par }\pard \qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\expnd0\expndtw-4\cgrid0\insrsid1378858 Cu\'e9c \'ae\'cau tranh giai c\'cap kh\'abng di\'d4n ra gi\'e8ng nh\'ad \'eb ph\'ad\'acng T\'a9
y.
\par }{\f37\fs20\cgrid0\insrsid1378858 V\'d2 ph\'dda ng\'ad\'eai lao \'ae\'e9ng, \'ae\'e3 l\'b5 s\'f9 kh\'abng gi\'b8c ng\'e9, s\'f9 nh\'c9n nh\'f4c v\'b5 v\'ab t\'e6 ch\'f8c. V\'d2 ph\'dda b\'e4n ch\'f1, kh\'abng c\'e3 m\'b8y m\'e3c, ru\'e9ng \'ae\'e5ng thu
\'e9c s\'eb h\'f7u c\'f1a nh\'f7ng \'ae\'dea ch\'f1 h\'b9ng trung v\'b5 h\'b9ng nh\'e1 v\'b5 nh\'f7ng k\'ce m\'b5 \'eb \'ae\'e3 \'ae\'ad\'eec coi l\'b5 \'ae\'b9i \'ae\'dea ch\'f1 th\'d7 ch\'d8 l\'b5 nh\'f7ng t\'aan l\'efn t\'det b\'aan c\'b9nh nh\'f7ng ng
\'ad\'eai tr\'efng t\'aan v\'edi h\'e4 \'eb ch\'a9u \'a2u v\'b5 ch\'a9u M\'fc; kh\'abng c\'e3 t\'fb ph\'f3 ng\'ad\'eai An Nam. Nh\'f7ng t\'aan tr\'e4c ph\'f3 \'eb \'ae\'e3 th\'d7 \'eb \'ae\'a9y ch\'d8 l\'b5 nh\'f7ng k\'ce th\'f9c l\'eei kh\'b8 gi\'b6 th
\'abi.
\par }{\f37\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 Cho n\'aan, n\'d5u n\'abng d\'a9n g\'c7n nh\'ad ch\'bcng c\'e3 g\'d7 th\'d7 \'ae\'dea ch\'f1 c\'f2ng kh\'abng c\'e3 v\'e8n li\'d5ng g\'d7 l\'edn; n\'d5u n\'abng d\'a9n ch\'d8 s\'e8ng b\'bbng c\'b8i t\'e8
i thi\'d3u c\'c7n thi\'d5t th\'d7 \'ae\'eai s\'e8ng c\'f1a \'ae\'dea ch\'f1 c\'f2ng ch\'bcng c\'e3 g\'d7 l\'b5 xa hoa; n\'d5u th\'ee thuy\'d2n kh\'abng bi\'d5t m\'d7nh b\'de b\'e3c l\'e9t bao nhi\'aau th\'d7 ch\'f1 l\'b9i kh\'abng h\'d2 bi\'d5t c\'abng c
\'f4 \'ae\'d3 b\'e3c l\'e9t c\'f1a h\'e4 l\'b5 m\'b8y m\'e3c; ng\'ad\'eai th\'d7 ch\'bcng c\'e3 c\'abng \'aeo\'b5n, k\'ce th\'d7 ch\'bcng c\'e3 t\'acr\'edt. Ng\'ad\'eai th\'d7 nh\'c9n nh\'f4c ch\'deu s\'e8 ph\'cbn c\'f1a m\'d7nh, k\'ce th\'d7 v\'f5a ph
\'b6i trong s\'f9 tham lam c\'f1a m\'d7nh. S\'f9 xung \'ae\'e9t v\'d2 quy\'d2n l\'eei c\'f1a h\'e4 \'ae\'ad\'eec gi\'b6m thi\'d3u. \'a7i\'d2u \'ae\'e3, kh\'abng th\'d3 ch\'e8i c\'b7i \'ae\'ad\'eec.
\par }{\f37\fs20\cgrid0\insrsid1378858 Nh\'adng ng\'ad\'eai ta s\'cf b\'b6o: th\'d5 l\'b5 ch\'f3ng ta \'eb th\'eai Trung c\'e6 \'b5? }{\f38\fs20\cgrid0\insrsid1378858 \'e5}{\f37\fs20\cgrid0\insrsid1378858 ! S\'cf l\'b5 qu\'b8 \'ae\'b8ng n\'d5u so s\'b8nh ng
\'ad\'eai "nh\'b5 qu\'aa"}{\cs17\f37\fs20\super\cgrid0\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 1) Nh\'f7ng ch\'f7 \'93nh\'b5 qu\'aa\'94 trong nguy\'aan b\'b6n vi\'d5t b\'bbng ti\'d5ng Vi\'d6t.}})}{\f37\fs20\cgrid0\insrsid1378858  v\'edi ng\'ad\'eai n\'abng n\'ab
. An Nam ch\'ada bao gi\'ea c\'e3 t\'a8ng l\'f7 v\'b5 thu\'d5 m\'ad\'eai ph\'c7n tr\'a8m. Ho\'b5ng \'ae\'d5 tr\'de 
\par }\pard \qj \li0\ri0\sa80\sl-248\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 v\'d7 nh\'adng ch\'bcng lo cai tr\'de g\'d7. T\'cat nhi\'aan l\'b5 \'ae\'b7 c\'e3 quan l\'b9i r\'e5i. Nh\'adng c\'e3 th
\'d3 so s\'b8nh h\'e4 v\'edi ch\'f3a phong ki\'d5n kh\'abng? Kh\'abng. Tr\'ad\'edc h\'d5t quan l\'b9i \'ae\'ad\'eec tuy\'d3n l\'f9a theo con \'ae\'ad\'eang d\'a9n ch\'f1: con \'ae\'ad\'eang thi c\'f6, m\'eb r\'e9ng cho m\'e4i ng\'ad\'eai v\'b5 m\'e4i ng
\'ad\'eai c\'e3 th\'d3 chu\'c8n b\'de thi m\'b5 ch\'bcng }{\i\f37\fs20\cgrid0\insrsid1378858 t\'e8n k\'d0m g\'d7. }{\f37\fs20\cgrid0\insrsid1378858 H\'acn n\'f7a, quy\'d2n l\'f9c c\'f1a quan l\'b9i \'ae\'ad\'eec c\'a9n b\'bbng b\'bbng t\'ddnh t\'f9 tr\'de
 c\'f1a x\'b7 th\'abn.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-248\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 X\'b7 h\'e9i }{\f38\fs20\cgrid0\insrsid1378858 \'ca}{\f37\fs20\cgrid0\insrsid1378858 n \'a7\'e9 - China}{
\cs17\f37\fs20\super\cgrid0\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {
\cgrid0\insrsid1378858 1) La soci\'d0t\'d0 Indo - Chinoise.}})}{\f37\fs20\cgrid0\insrsid1378858  - v\'b5 t\'abi c\'e3 th\'d3 n\'e3i: }{\f38\fs20\cgrid0\insrsid1378858 \'ca}{\f37\fs20\cgrid0\insrsid1378858 n \'a7\'e9 hay Trung Qu\'e8c v\'d2 m\'c6t c\'ca
u tr\'f3c kinh t\'d5, kh\'abng gi\'e8ng c\'b8c x\'b7 h\'e9i ph\'ad\'acng T\'a9y th\'eai Trung c\'e6, c\'f2ng nh\'ad th\'eai c\'cbn \'ae\'b9i, v\'b5 \'ae\'cau tranh giai c\'cap \'eb \'ae\'e3 kh\'abng quy\'d5t li\'d6t nh\'ad \'eb \'ae\'a9y.
\par Mai \'ae\'a9y, khi ch\'f1 ngh\'dca t\'ad b\'b6n ph\'ad\'acng T\'a9y l\'b5m \'ae\'e6i thay ph\'ad\'acng \'a7\'abng th\'d7 \'ae\'cau tranh giai c\'cap c\'e3 tr\'eb n\'aan quy\'d5t li\'d6t kh\'abng ? \'a7\'b9i th\'d3 l\'b5 c\'e3, n\'d5u x\'d0t g\'ad\'acng c
\'f1a Nh\'cbt B\'b6n.
\par Th\'cbt ra l\'b5 c\'e3, v\'d7 s\'f9 t\'a9y ph\'ad\'acng ho\'b8 ng\'b5y c\'b5ng t\'a8ng v\'b5 t\'cat y\'d5u c\'f1a ph\'ad\'acng \'a7\'abng; - n\'e3i c\'b8ch kh\'b8c, ch\'f1 ngh\'dca M\'b8c s\'cf c\'dfn \'ae\'f3ng c\'b6 \'eb \'ae\'e3. D\'ef sao th\'d7 c\'f2
ng kh\'abng th\'d3 c\'cam b\'e6 sung "c\'ac s\'eb l\'dech s\'f6" c\'f1a ch\'f1 ngh\'dca M\'b8c b\'bbng c\'b8ch \'ae\'ada th\'aam v\'b5o \'ae\'e3 nh\'f7ng t\'ad li\'d6u m\'b5 M\'b8c \'eb th\'eai m\'d7nh kh\'abng th\'d3 c\'e3 \'ae\'ad\'eec.
\par M\'b8c \'ae\'b7 x\'a9y d\'f9ng h\'e4c thuy\'d5t c\'f1a m\'d7nh tr\'aan m\'e9t tri\'d5t l\'fd nh\'cat \'ae\'denh c\'f1a l\'dech s\'f6, nh\'adng l\'dech s\'f6 n\'b5o? L\'dech s\'f6 ch\'a9u \'a2u. M\'b5 ch\'a9u \'a2u l\'b5 g\'d7? \'a7\'e3 ch\'ada ph\'b6i l
\'b5 to\'b5n th\'d3 nh\'a9n lo\'b9i.
\par M\'b8c cho ta bi\'d5t r\'bbng s\'f9 ti\'d5n tri\'d3n c\'b8c x\'b7 h\'e9i tr\'b6i qua ba giai \'aeo\'b9n: ch\'d5 \'ae\'e9 n\'ab l\'d6, ch\'d5 \'ae\'e9 n\'abng n\'ab, ch\'d5 \'ae\'e9 t\'ad b\'b6n; v\'b5 trong m\'e7i giai \'aeo\'b9n \'cay, \'ae\'ca
u tranh giai c\'cap c\'e3 kh\'b8c nhau. Ch\'f3ng ta ph\'b6i coi ch\'f5ng! C\'b8c d\'a9n t\'e9c Vi\'d4n \'a7\'abng c\'e3 tr\'b6i qua hai giai \'aeo\'b9n \'ae\'c7u kh\'abng? T\'f5 nhi\'d2u th\'d5 k\'fb nay, h\'e4 ch\'bcng h\'ad\'ebng \'ae\'ad\'eec th\'b8i b
\'d7nh hay sao \'ae\'d3 \'ae\'d5n m\'f8c l\'b5m cho ng\'ad\'eai ch\'a9u \'a2u khinh r\'ce h\'e4 (l\'ad\'eai nh\'b8c, m\'aa mu\'e9i h\'b5ng ngh\'d7n n\'a8m, v.v.)?
\par  Xem x\'d0t l\'b9i ch\'f1 ngh\'dca M\'b8c v\'d2 c\'ac s\'eb l\'dech s\'f6 c\'f1a n\'e3, c\'f1ng c\'e8 n\'e3 b\'bbng d\'a9n t\'e9c h\'e4c ph\'ad\'acng \'a7\'abng. \'a7\'e3 ch\'ddnh l\'b5 nhi\'d6m v\'f4 m\'b5 c\'b8c X\'abvi\'d5t \'ae\'b6m nhi\'d6m (ban thu
\'e9c \'ae\'dea c\'f1a ch\'f3ng t\'abi v\'f5a nh\'cbn \'ae\'ad\'eec th\'ad m\'eai ch\'f3ng t\'abi tham gia c\'abng t\'b8c n\'b5y). V\'b5 c\'b8c X\'abvi\'d5t s\'cf th\'b5nh c\'abng; v\'d7 r\'bbng, \'ae\'f8ng l\'aan tr\'aan c\'b8c th\'b5nh ki\'d5n ch\'f1
ng t\'e9c, h\'e4 s\'cf l\'b5m cho th\'d5 gi\'edi \'ae\'ad\'eec mi\'d4n nghe c\'b8c l\'eai t\'c7m ph\'b5o c\'f1a nh\'f7ng Gu\'fdtxtav\'ac L\'acb\'e8p v\'b5 nh\'f7ng H\'a8ngri Co\'e3c\'aei\'aa.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 (...)
\par }\pard \qj \fi397\li0\ri0\sa80\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Ch\'f1 ngh\'dca d\'a9n t\'e9c l\'b5 \'ae\'e9ng l\'f9c l\'edn c\'f1a \'ae\'cat n\'ad\'edc. Ch\'ddnh n\'e3 \'ae\'b7
 g\'a9y n\'aan cu\'e9c n\'e6i d\'cby ch\'e8ng thu\'d5 n\'a8m 1908, n\'e3 d\'b9y cho nh\'f7ng ng\'ad\'eai culi bi\'d5t ph\'b6n \'ae\'e8i, n\'e3 l\'b5m cho nh\'f7ng ng\'ad\'eai "nh\'b5 qu\'aa" ph\'b6n \'ae\'e8i ng\'c7m tr\'ad\'edc thu\'d5 t\'b9p d\'dech v
\'b5 thu\'d5 mu\'e8i. C\'f2ng ch\'f1 ngh\'dca d\'a9n t\'e9c \'ae\'b7 lu\'abn lu\'abn th\'f3c \'ae\'c8y c\'b8c nh\'b5 bu\'abn An Nam c\'b9nh tranh v\'edi ng\'ad\'eai Ph\'b8p v\'b5 ng\'ad\'eai Trung Qu\'e8c; n\'e3 \'ae\'b7 th\'f3c gi\'f4c thanh ni\'aan b
\'b7i kho\'b8, l\'b5m cho nh\'f7ng nh\'b5 c\'b8ch m\'b9ng tr\'e8n sang Nh\'cbt B\'b6n v\'b5 l\'b5m vua Duy T\'a9n m\'adu t\'ddnh kh\'ebi ngh\'dca n\'a8m 1917}{\cs17\f37\fs20\super\cgrid0\insrsid1378858 1{\footnote \pard\plain 
\s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 1) Cu\'e9c m\'adu kh\'ebi ngh\'dca di\'d4n ra n\'a8m 1916.}})}{
\f37\fs20\cgrid0\insrsid1378858 .
\par Chi\'d5n tranh \'ae\'b7 l\'b5m thay \'ae\'e6i ch\'f1 ngh\'dca d\'a9n t\'e9c:
\par 1. Ch\'f1 ngh\'dca d\'a9n t\'e9c \'ae\'b7 hi\'d6n \'ae\'b9i ho\'b8 khi chuy\'d3n t\'f5 gi\'edi th\'ad\'eeng l\'adu n\'b5y sang gi\'edi th\'ad\'eeng l\'adu kh\'b8c. Ch\'ddnh thanh ni\'aan An Nam ng\'b5y nay \'aeang ch\'d8 \'ae\'b9o n\'e3.
\par 2. Ch\'f1 ngh\'dca d\'a9n t\'e9c \'a8n s\'a9u v\'b5o qu\'c7n ch\'f3ng nh\'ea s\'f9 ph\'b8t tri\'d3n c\'f1a c\'b8c ph\'c7n t\'f6 th\'b5nh th\'de v\'b5 nh\'cat l\'b5 nh\'ea s\'f9 tuy\'d3n m\'e9 v\'b5 tr\'eb v\'d2 c\'f1a "l\'ddnh t\'d7nh nguy\'d6n".
\par 3. Trong ch\'f1 ngh\'dca d\'a9n t\'e9c c\'e3 c\'b6 l\'dfng c\'a8m gh\'d0t b\'e4n x\'a9m l\'ad\'eec Trung Qu\'e8c v\'b5 ng\'ad\'eai }{\f38\fs20\cgrid0\insrsid1378858 \'ca}{\f37\fs20\cgrid0\insrsid1378858 n \'a7\'e9 sinh c\'ac l\'cbp nghi\'d6p \'eb tr\'aan 
\'ae\'cat n\'ad\'edc n\'b5y.
\par 4. N\'e3 c\'e3 xu h\'ad\'edng h\'eep ph\'b8p ho\'b8 c\'b8c h\'d7nh th\'f8c bi\'d3u hi\'d6n v\'b5 y\'aau s\'b8ch c\'f1a n\'e3. M\'e9t m\'c6t, ch\'ddnh quy\'d2n nh\'ad\'eeng b\'e9. M\'c6t kh\'b8c, l\'edp thanh ni\'aan t\'f5 b\'e1 ph\'ad\'acng ph\'b8p ti\'d5
n h\'b5nh nh\'f7ng cu\'e9c n\'e6i d\'cby b\'e9t ph\'b8t c\'f1a l\'edp ng\'ad\'eai \'aei tr\'ad\'edc, v\'b5 ng\'b5y nay, ng\'ad\'eai ta thi\'aan v\'d2 chi\'d5n thu\'cbt c\'f1a nh\'f7ng nh\'b5 c\'b8ch m\'b9ng ch\'a9u \'a2u: tuy\'aan truy\'d2n, t\'e6 ch\'f8
c v\'b5 kh\'ebi ngh\'dca qu\'c7n ch\'f3ng. Trong khi l\'edp ng\'ad\'eai gi\'b5 mu\'e8n \'ae\'e9c l\'cbp ngay th\'d7 l\'edp tr\'ce y\'aau s\'b8ch nh\'f7ng thi\'d5t ch\'d5 chu\'c8n b\'de cho \'ae\'e9c l\'cbp (t\'ea }{\i\f37\fs20\cgrid0\insrsid1378858 
La Tribune indig\'ccne}{\f37\fs20\super\cgrid0\insrsid1378858 62}{\f37\fs20\cgrid0\insrsid1378858 :}{\i\f37\fs20\cgrid0\insrsid1378858  }{\f37\fs20\cgrid0\insrsid1378858 c\'ac quan c\'f1a ph\'b8i l\'cbp hi\'d5n).
\par (...)
\par C\'ad\'acng l\'dcnh c\'f1a ch\'f3ng t\'abi.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Ph\'ad\'acng h\'ad\'edng chung. 
\par }\pard \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Ph\'b8t \'ae\'e9ng ch\'f1 ngh\'dca d\'a9n t\'e9c b\'b6n x\'f8 nh\'a9n danh Qu\'e8c t\'d5 C\'e9ng s\'b6n. Kh\'c8
u hi\'d6u n\'b5y, do M\'b8txc\'acva tung ra, \'ae\'b8nh v\'b5o c\'b8c nh\'b5 t\'ad s\'b6n nh\'ad m\'e9t ngh\'dech l\'fd t\'b8o b\'b9o, nh\'adng th\'cbt ra \'aei\'d2u \'ae\'e3 c\'e3 ngh\'dca g\'d7? M\'e9t ch\'ddnh s\'b8ch mang t\'ddnh hi\'d6n th\'f9c tuy
\'d6t v\'eai. Gi\'ea \'ae\'a9y, ng\'ad\'eai ta s\'cf kh\'abng th\'d3 l\'b5m g\'d7 \'ae\'ad\'eec cho ng\'ad\'eai An Nam n\'d5u kh\'abng d\'f9a tr\'aan c\'b8c \'ae\'e9ng l\'f9c v\'dc \'ae\'b9i, v\'b5 duy nh\'cat c\'f1a \'ae\'eai s\'e8ng x\'b7 h\'e9i c\'f1
a h\'e4. Khi ch\'f1 ngh\'dca d\'a9n t\'e9c c\'f1a h\'e4 th\'beng l\'eei, th\'d7 \'ae\'b7 l\'a9u l\'bem r\'e5i, ph\'c7n l\'edn th\'d5 gi\'edi s\'cf x\'abvi\'d5t ho\'b8 v\'b5 l\'f3c \'ae\'e3, nh\'cat \'ae\'denh ch\'f1 ngh\'dca d\'a9n t\'e9c \'cay s\'cf bi
\'d5n th\'b5nh ch\'f1 ngh\'dca qu\'e8c t\'d5. Trong khi ch\'ea \'ae\'eei, ch\'f1 ngh\'dca d\'a9n t\'e9c s\'cf qu\'cay r\'e8i ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c Ph\'b8p v\'b5 b\'bbng vi\'d6c l\'b5m n\'b5y, Qu\'e8c t\'d5 C\'e9ng s\'b6n s\'cf \'ae\'ad\'eec l
\'eei tr\'f9c ti\'d5p.
\par a/ }{\f38\fs20\cgrid0\insrsid1378858 \'eb}{\f37\fs20\cgrid0\insrsid1378858  \'a7\'abng D\'ad\'acng.
\par H\'b5nh \'ae\'e9ng h\'eep ph\'b8p ph\'f4 thu\'e9c v\'b5o vi\'d6c n\'ad\'edc Ph\'b8p th\'f5a nh\'cbn c\'b8c X\'abvi\'d5t. \'a7i\'d2u \'ae\'c7u ti\'aan ph\'b6i l\'b5m l\'b5 s\'cf thi\'d5t l\'cbp c\'b8c l\'b7nh s\'f9 qu\'b8n Nga \'eb S\'b5i G\'dfn, H\'b6i Ph
\'dfng, H\'b5 N\'e9i, \'a7\'b5 N\'bdng. Nh\'f7ng l\'b7nh s\'f9 qu\'b8n n\'b5y t\'f9 nhi\'aan s\'cf l\'b5 nh\'f7ng trung t\'a9m tuy\'aan truy\'d2n ch\'f1 ngh\'dca b\'abns\'aav\'ddch v\'b5 l\'f9a ch\'e4n c\'b8c chi\'d5n s\'dc b\'b6n x\'f8 \'ae\'d3 g\'f6
i sang Nga. Ho\'b9t \'ae\'e9ng b\'cat h\'eep ph\'b8p s\'cf l\'b5 tr\'ee c\'cap cho m\'e9t t\'ea b\'b8o, r\'b6i truy\'d2n \'ae\'acn v\'b5 nh\'cat l\'b5 c\'b8c b\'b5i \'ae\'b6 k\'ddch b\'bbng ti\'d5ng b\'b6n x\'f8 v\'b5 ch\'f7 H\'b8n, l\'b5 t\'e6 ch\'f8c nh
\'f7ng h\'e9i k\'ddn. Nh\'a9n vi\'aan tuy\'aan truy\'d2n g\'e5m c\'e3: ng\'ad\'eai b\'b6n x\'f8, ng\'ad\'eai Ph\'b8p v\'b5 ng\'ad\'eai Nga, n\'d5u c\'e3 th\'d3 \'ae\'ad\'eec th\'d7, bi\'d5t ti\'d5ng n\'ad\'edc n\'b5y, v\'b5 l\'b5m m\'e9t ngh\'d2 khi\'d5
n h\'e4 ti\'d5p x\'f3c \'ae\'ad\'eec v\'edi d\'a9n b\'b6n x\'f8 (n\'f7 h\'e9 sinh, n\'f7 gi\'b8o vi\'aan, th\'c7y thu\'e8c \'eb n\'abng th\'abn, d\'a9n \'ae\'e5n \'aei\'d2n. M\'e9t lu\'cbt s\'ad cho ng\'ad\'eai b\'b6n x\'f8 s\'cf \'ae\'ad\'eec m\'e4i ng
\'ad\'eai bi\'d5t ti\'d5ng ngay). Th\'b5nh l\'cbp ra \'eb Ch\'ee L\'edn m\'e9t ph\'a9n b\'e9 c\'e9ng s\'b6n Trung Qu\'e8c.
\par b/ }{\f38\fs20\cgrid0\insrsid1378858 \'eb}{\f37\fs20\cgrid0\insrsid1378858  Nh\'cbt B\'b6n, \'eb Trung Qu\'e8c v\'b5 \'eb Xi\'aam.
\par Ti\'d5p x\'f3c v\'edi nh\'f7ng nh\'e3m ng\'ad\'eai di t\'b6n. Th\'b5nh l\'cbp m\'e9t l\'b7nh s\'f9 qu\'b8n \'eb V\'a9n Nam ph\'f1, th\'b5nh ph\'e8 r\'cat quan tr\'e4ng n\'bbm \'eb bi\'aan gi\'edi B\'bec K\'fa, trung t\'a9m tuy\'aan truy\'d2n \'ae\'c6t 
\'eb v\'de tr\'dd \'ae\'e3 r\'cat tuy\'d6t. Tranh th\'f1 l\'b5m cho c\'b8c X\'abvi\'d5t \'ae\'ad\'eec c\'abng nh\'cbn \'eb Xi\'aam n\'aci m\'b5 Anh, Ph\'b8p v\'b5 M\'fc lu\'abn lu\'abn c\'e3 m\'adu \'ae\'e5. M\'fc c\'e3 4 c\'e8 v\'can tr\'f9c thu\'e9c B
\'e9 Ngo\'b9i giao, Anh v\'b5 Ph\'b8p c\'e3 hai c\'e8 v\'can tr\'f9c thu\'e9c B\'e9 T\'ad ph\'b8p. T\'b9i sao n\'ad\'edc Nga l\'b9i kh\'abng c\'e3? H\'acn n\'f7a, m\'e9t l\'b7nh s\'f9 qu\'b8n \'eb B\'a8ng C\'e8c s\'cf t\'d7m th\'cay c\'b8c ng\'b6 \'ae\'ad
\'eang \'aei }{\f38\fs20\cgrid0\insrsid1378858 \'ca}{\f37\fs20\cgrid0\insrsid1378858 n \'a7\'e9 thu\'e9c Anh, Giava thu\'e9c H\'b5 Lan v\'b5 \'a7\'abng D\'ad\'acng thu\'e9c Ph\'b8p.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-273\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 c/ }{\f38\fs20\cgrid0\insrsid1378858 \'eb}{\f37\fs20\cgrid0\insrsid1378858  Ph\'b8p. 
\par Nh\'e3m c\'e9ng s\'b6n \'eb Ngh\'de vi\'d6n s\'cf c\'e3 hai nhi\'d6m v\'f4 quan tr\'e4ng: 
\par 1) Th\'f5a nh\'cbn c\'b8c X\'abvi\'d5t; 2) Xo\'b8 ch\'d5 \'ae\'e9 b\'b6n x\'f8. Trong nhi\'d6m k\'fa, s\'cf y\'aau c\'c7u b\'e1 thu\'e8c phi\'d6n \'eb \'a7\'abng D\'ad\'acng; n\'e3 s\'cf t\'e8 gi\'b8c c\'b8c v\'f4 b\'aa b\'e8i nh\'ad v\'f4 b\'aa b\'e8i c
\'f1a \'ae\'e9c quy\'d2n \'eb S\'b5i G\'dfn. T\'f5 Ph\'b8p \'ae\'d5n \'a7\'abng D\'ad\'acng qu\'b8 xa c\'b8ch v\'d7 v\'cby s\'cf kh\'abng c\'e3 v\'can \'ae\'d2 Ngh\'de vi\'d6n \'aei xem x\'d0t nh\'ad c\'e3 th\'d3 l\'b5m \'ae\'e8i v\'edi Angi\'aari v\'b5
 Tuynidi.
\par Ban thu\'e9c \'ae\'dea s\'cf lo tr\'ad\'edc h\'d5t vi\'d6c t\'e6 ch\'f8c c\'abng \'aeo\'b5n. H\'e9i li\'aan hi\'d6p thu\'e9c \'ae\'dea s\'cf l\'b5m \'ae\'f3ng v\'edi danh hi\'d6u c\'f1a m\'d7nh. T\'ea }{\i\f37\fs20\cgrid0\insrsid1378858 Le Paria }{
\f37\fs20\cgrid0\insrsid1378858 s\'cf ra m\'e7i tu\'c7n 2 l\'c7n.
\par Ho\'b9t \'ae\'e9ng thu\'e9c \'ae\'dea c\'f1a \'a7\'b6ng C\'e9ng s\'b6n Ph\'b8p h\'bcn l\'b5 c\'dfn y\'d5u k\'d0m nh\'adng ch\'f3t \'ddt n\'e3 l\'b5m \'ae\'ad\'eec th\'d7 ch\'bcng c\'e3 \'ae\'b6ng n\'b5o l\'b5m \'ae\'ad\'eec, c\'dfn n\'d5u n\'e3 ch\'ad
a quan t\'a9m \'ae\'d5n ng\'ad\'eai b\'b6n x\'f8, \'ae\'e3 l\'b5 v\'d7 ng\'ad\'eai b\'b6n x\'f8 ch\'ada \'ae\'d5n v\'edi n\'e3 \'ae\'ad\'eec m\'cay. Nhi\'d6m v\'f4 s\'e8 m\'e9t c\'f1a n\'e3 l\'b5 \'ae\'b5o t\'b9o nh\'f7ng chi\'d5n s\'dc b\'b6n x\'f8. \'a7
\'b5o t\'b9o kh\'abng ch\'d8 nh\'f7ng nh\'b5 tuy\'aan truy\'d2n m\'b5 c\'b6 nh\'f7ng nh\'b5 c\'b8ch m\'b9ng theo ki\'d3u ch\'a9u \'a2u.
\par d/ }{\f38\fs20\cgrid0\insrsid1378858 \'eb }{\f37\fs20\cgrid0\insrsid1378858 Nga.
\par Mu\'e8n th\'d5, \'ae\'ada \'ae\'d5n M\'b8txc\'acva hay \'ae\'d5n c\'b8c trung t\'a9m kh\'b8c, c\'b8c sinh vi\'aan An Nam (c\'dfn s\'edm \'ae\'d3 c\'e3 th\'d3 coi th\'ad\'eang ng\'ad\'eai tr\'dd th\'f8c). C\'f2ng \'ae\'ada c\'b6 nh\'f7ng ng\'ad\'eai lao 
\'ae\'e9ng ch\'a9n tay v\'d7 ph\'b6i \'ae\'b5o t\'b9o nh\'f7ng qu\'a9n nh\'a9n, thu\'fb th\'f1 cho h\'e5ng qu\'a9n b\'b6n x\'f8 v\'b5 c\'b8c chi b\'e9 x\'dd nghi\'d6p b\'b6n x\'f8, \'ae\'f1 s\'f8c thay th\'d5 c\'b8c k\'fc thu\'cbt vi\'aan c\'f1a ch\'f1
 ngh\'dca t\'ad b\'b6n.
\par (...)
\par K\'d5t lu\'cbn: Kh\'b6 n\'a8ng kh\'ebi ngh\'dca v\'f2 trang \'eb \'a7\'abng D\'ad\'acng. \'a7\'d3 c\'e3 c\'ac th\'beng l\'eei, m\'e9t cu\'e9c kh\'ebi ngh\'dca v\'f2 trang \'eb \'a7\'abng D\'ad\'acng:
\par  1. Ph\'b6i c\'e3 t\'ddnh ch\'cat m\'e9t cu\'e9c kh\'ebi ngh\'dca qu\'c7n ch\'f3ng ch\'f8 kh\'abng ph\'b6i m\'e9t cu\'e9c n\'e6i lo\'b9n. Cu\'e9c kh\'ebi ngh\'dca ph\'b6i \'ae\'ad\'eec chu\'c8n b\'de 
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-273\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\cgrid0\insrsid1378858 trong qu\'c7n ch\'f3ng, n\'e6 ra trong th\'b5nh ph\'e8
, theo ki\'d3u c\'b8c cu\'e9c c\'b8ch m\'b9ng \'eb ch\'a9u \'a2u, ch\'f8 kh\'abng ph\'b6i n\'e6 ra \'ae\'e9t ng\'e9t \'eb bi\'aan gi\'edi Trung Qu\'e8c, theo ph\'ad\'acng ph\'b8p c\'f1a nh\'f7ng nh\'b5 c\'b8ch m\'b9ng tr\'ad\'edc \'ae\'a9y.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 2. Cu\'e9c kh\'ebi ngh\'dca ph\'b6i \'ae\'ad\'eec n
\'ad\'edc Nga \'f1ng h\'e9. C\'b8c X\'abvi\'d5t s\'cf cung c\'cap v\'f2 kh\'dd, ti\'d2n b\'b9c v\'b5 c\'b8c k\'fc thu\'cbt vi\'aan, c\'b8c binh s\'dc, c\'b8c thu\'fb th\'f1 b\'b6n x\'f8 \'ae\'ad\'eec \'ae\'b5o t\'b9o tr\'ad\'edc \'ae\'e3 \'eb M\'b8txc\'ac
va. Ngo\'b5i ra, n\'ad\'edc Nga s\'cf c\'e3 m\'e9t h\'b9m \'ae\'e9i kh\'b8 m\'b9nh \'eb}{\i\f37\fs20\cgrid0\insrsid1378858  }{\f37\fs20\cgrid0\insrsid1378858 Th\'b8i B\'d7nh D\'ad\'acng, \'ae\'d3 ng\'a8n c\'b6n s\'f9 can thi\'d6p c\'f1a m\'e9t v\'b5i c
\'ad\'eang qu\'e8c c\'e3 tho\'b6 thu\'cbn v\'edi Ph\'b8p trong vi\'d6c ch\'e8ng ng\'ad\'eai b\'b6n x\'f8.
\par 3. Cu\'e9c kh\'ebi ngh\'dca ph\'b6i tr\'efng h\'eep v\'edi c\'b8ch m\'b9ng v\'ab s\'b6n \'eb Ph\'b8p.
\par 4. S\'f9 nghi\'d6p c\'f1a ng\'ad\'eai b\'b6n x\'f8 g\'ben m\'cbt thi\'d5t v\'edi s\'f9 nghi\'d6p c\'f1a v\'ab s\'b6n to\'b5n th\'d5 gi\'edi; m\'e7i khi ch\'f1 ngh\'dca c\'e9ng s\'b6n gi\'b5nh \'ae\'ad\'eec ch\'f3t \'ddt th\'beng l\'eei trong m\'e9t n\'ad
\'edc n\'b5o \'ae\'e3, nh\'cat l\'b5 trong m\'e9t qu\'e8c gia \'ae\'d5 qu\'e8c ch\'f1 ngh\'dca (n\'ad\'edc \'a7\'f8c ch\'bcng h\'b9n) th\'d7 \'ae\'e3 c\'b5ng l\'b5 th\'beng l\'eei c\'b6 cho ng\'ad\'eai An Nam.
\par 
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 In trong s\'b8ch H\'e5 Ch\'dd Minh,
\par }{\i\cgrid0\insrsid1378858 Nh\'f7ng b\'b5i vi\'d5t 1914-1969}{\cgrid0\insrsid1378858 
