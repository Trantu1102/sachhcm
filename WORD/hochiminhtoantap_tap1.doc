\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'cat c\'b6 c\'b8c \'ae\'e5ng ch\'dd \'ae\'d2u \'ae\'b7 n
\'e3i v\'d2 t\'d7nh h\'d7nh c\'f1a n\'abng d\'a9n trong \'ae\'cat n\'ad\'edc c\'b8c \'ae\'e5ng ch\'dd. T\'abi s\'cf kh\'abng l\'b5m tr\'dfn b\'e6n ph\'cbn c\'f1a t\'abi n\'d5u c\'e3 \'ae\'ad\'eec quy\'d2n \'ae\'d5n \'ae\'a9y v\'edi c\'b8c \'ae\'e5ng ch
\'dd m\'b5 t\'abi l\'b9i kh\'abng n\'e3i m\'e9t \'ae\'abi l\'eai v\'d2 t\'d7nh c\'b6nh c\'f1a n\'abng d\'a9n t\'b9i \'ae\'cat n\'ad\'edc t\'abi.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \'a7\'d3 minh ho\'b9 v\'edi c\'b8c \'ae\'e5ng ch\'dd t\'d7
nh c\'b6nh c\'f1a n\'abng d\'a9n \'a7\'abng D\'ad\'acng, t\'abi ph\'b6i \'ae\'ada ra m\'e9t s\'f9 so s\'b8nh: m\'e9t b\'aan l\'b5 ng\'ad\'eai n\'abng d\'a9n Nga v\'b5 m\'e9t b\'aan n\'f7a l\'b5 ng\'ad\'eai n\'abng d\'a9n \'a7\'abng D\'ad\'acng. N\'abng d
\'a9n Nga gi\'e8ng nh\'ad m\'e9t ng\'ad\'eai ng\'e5i ch\'d4m ch\'d6 trong chi\'d5c gh\'d5 b\'b5nh, c\'dfn n\'abng d\'a9n An Nam l\'b9i gi\'e8ng nh\'ad m\'e9t ng\'ad\'eai b\'de tr\'e3i v\'b5o m\'e9t chi\'d5c c\'e9t, \'ae\'c7u ng\'ad\'eec xu\'e8ng \'ae\'ca
t. N\'e3i th\'d5 kh\'abng ph\'b6i l\'b5 n\'e3i ph\'e3ng \'ae\'b9i \'ae\'a9u, sau \'ae\'a9y c\'b8c \'ae\'e5ng ch\'dd s\'cf th\'cay r\'e2.
\par Khi c\'b8c \'ae\'e5ng ch\'dd \'aei qua H\'e5ng tr\'ad\'eang, c\'b8c \'ae\'e5ng ch\'dd th\'cay c\'e3 kh\'bec m\'e9t d\'dfng ch\'f7 "Nh\'b5 th\'ea l\'b5 thu\'e8c phi\'d6n c\'f1a th\'d5 gi\'edi"; nh\'adng ch\'f3ng t\'abi, nh\'ea n\'d2n v\'a8n minh ph\'ad\'ac
ng T\'a9y m\'b5 ch\'f3ng t\'abi c\'e3 c\'b6 Nh\'b5 th\'ea l\'c9n thu\'e8c phi\'d6n.
\par V\'d2 thu\'e8c phi\'d6n, t\'abi s\'cf xin ch\'d8 k\'d3 l\'b9i v\'edi c\'b8c \'ae\'e5ng ch\'dd r\'bbng m\'e7i n\'a8m ch\'ddnh quy\'d2n Ph\'b8p \'eb thu\'e9c \'ae\'dea \'ae\'b7 b\'b8n cho d\'a9n An Nam g\'e5m 20 tri\'d6u ng\'ad\'eai, tr\'aan 400 tri\'d6u 
\'ae\'abla}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 
1) S\'e8 li\'d6u n\'b5y ch\'ada \'ae\'ad\'eec ki\'d3m tra l\'b9i. Ch\'f3ng t\'abi d\'dech \'ae\'f3ng theo b\'b6n ti\'d5ng Ph\'b8p.}})}{\f37\fs20\insrsid1378858  thu\'e8c phi\'d6n. V\'b5 m\'c6t kh\'b8c, ng\'ad\'eai ta \'ae\'b7 t\'ddnh ra r\'bbng c\'f8
 1.000 ty b\'b8n r\'ad\'eeu v\'b5 thu\'e8c phi\'d6n th\'d7 kh\'abng c\'e3 \'ae\'ad\'eec l\'cay 10 tr\'ad\'eang h\'e4c. \'a7\'cay l\'b5 nh\'f7ng s\'f9 th\'cbt.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 B\'a9y gi\'ea, t\'abi xin n\'e3i v\'ben t\'bet v\'edi c\'b8c \'ae\'e5ng ch\'dd v\'d2 chuy\'d6n Nh\'b5 th\'ea.
\par T\'abi \'ae\'b7 n\'e3i v\'edi c\'b8c \'ae\'e5ng ch\'dd r\'bbng nh\'f7ng t\'aan th\'f9c d\'a9n \'ae\'b7 t\'ad\'edc \'aeo\'b9t ng\'ad\'eai An Nam nh\'ad th\'d5 n\'b5o. B\'a9y gi\'ea, t\'abi xin n\'e3i \'ae\'d3 c\'b8c \'ae\'e5ng ch\'dd bi\'d5t Nh\'b5 th\'ea
 Kit\'ab \'ae\'b7 t\'ad\'edc \'aeo\'b9t n\'abng d\'a9n nh\'ad th\'d5 n\'b5o.
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Trong cu\'e9c x\'a9m chi\'d5m \'a7\'abng D\'ad\'ac
ng th\'d7 ch\'ddnh nh\'f7ng nh\'b5 truy\'d2n \'ae\'b9o Thi\'aan ch\'f3a \'ae\'b7 \'aei do th\'b8m \'ae\'d3 b\'b8o cho \'ae\'e9i qu\'a9n chi\'d5m \'ae\'e3ng bi\'d5t nh\'f7ng k\'d5 ho\'b9ch ph\'dfng th\'f1 c\'f1a n\'ad\'edc ch\'f3ng t\'abi. C\'f2ng ch\'dd
nh nh\'f7ng nh\'b5 truy\'d2n \'ae\'b9o \'ae\'b7 d\'c9n \'ae\'ad\'eang nh\'f7ng \'ae\'e9i qu\'a9n t\'can c\'abng, c\'f2ng ch\'ddnh l\'b9i l\'b5 nh\'f7ng nh\'b5 truy\'d2n \'ae\'b9o \'ae\'b7 l\'eei d\'f4ng t\'d7nh tr\'b9ng l\'e9n x\'e9n c\'f1a \'ae\'cat n
\'ad\'edc \'ae\'d3 \'a8n c\'bep nh\'f7ng v\'a8n b\'b6n ch\'f8ng nh\'cbn quy\'d2n s\'eb h\'f7u ru\'e9ng \'ae\'cat c\'f1a ng\'ad\'eai n\'abng d\'a9n n\'b5y n\'e4 hay c\'f1a m\'e9t l\'b5ng n\'b5o \'ae\'e3. Khi ho\'b5 b\'d7nh \'ae\'ad\'eec l\'cbp l\'b9i, n
\'abng d\'a9n tr\'eb v\'d2 th\'d7 t\'cat c\'b6 ru\'e9ng \'ae\'cat \'ae\'d2u \'ae\'b7 b\'de c\'b8c nh\'b5 truy\'d2n \'ae\'b9o n\'bem \'ae\'ad\'eec c\'b8c v\'a8n b\'b6n n\'e3i tr\'aan, chi\'d5m m\'cat. Ch\'ddnh b\'bbng c\'b8ch \'ae\'e3, m\'b5 \'eb Nam K\'fa
 nh\'f7ng nh\'b5 truy\'d2n \'ae\'b9o Thi\'aan ch\'f3a c\'e3 \'ae\'ad\'eec tr\'aan m\'e9t ph\'c7n t\'ad nh\'f7ng \'ae\'cat \'aeai c\'b5y c\'cay \'ae\'ad\'eec. }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  Campuchia, c\'b8c nh\'b5 truy\'d2n 
\'ae\'b9o n\'bem tr\'aan m\'e9t ph\'c7n ba ru\'e9ng \'ae\'cat; \'eb B\'bec K\'fa, ch\'d8 ri\'aang \'eb th\'f1 ph\'f1, trong th\'b5nh ph\'e8 H\'b5 N\'e9i, c\'b8c nh\'b5 truy\'d2n \'ae\'b9o c\'e3 nh\'f7ng b\'cat \'ae\'e9ng s\'b6n r\'e9ng bao la.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 H\'e4 c\'e3 \'ae\'ad\'eec c\'f1a c\'b6i v\'b5 chi\'d5m h
\'f7u ru\'e9ng \'ae\'cat c\'f1a n\'abng d\'a9n kh\'abng ph\'b6i ch\'d8 b\'bbng c\'b8ch \'ae\'e3. C\'b8c \'ae\'e5ng ch\'dd \'ae\'d2u bi\'d5t r\'bbng trong c\'b8c n\'ad\'edc ven bi\'d3n, nh\'cat l\'b5 trong nh\'f7ng n\'ad\'edc \'eb Vi\'d4n \'a7\'abng, th
\'ad\'eang x\'b6y ra gi\'abng b\'b7o v\'b5 l\'f4t l\'e9i l\'b5m cho m\'efa m\'b5ng th\'cat b\'b8t; c\'b8c nh\'b5 truy\'d2n \'ae\'b9o l\'eei d\'f4ng nh\'f7ng d\'dep \'ae\'e3 \'ae\'d3 \'f8ng tr\'ad\'edc ti\'d2n cho n\'abng d\'a9n v\'edi nh\'f7ng t\'fb su
\'cat l\'b7i r\'cat n\'c6ng v\'b5 m\'e9t th\'eai h\'b9n r\'cat ng\'ben. Bi\'d5t r\'e2 r\'b5ng l\'b5m nh\'ad v\'cby th\'d7 n\'abng d\'a9n kh\'abng bao gi\'ea c\'e3 th\'d3 tr\'b6 n\'ee \'ae\'ad\'eec, n\'aan c\'b8c nh\'b5 truy\'d2n \'ae\'b9o \'ae\'dfi n\'ab
ng d\'a9n ph\'b6i \'aeem ru\'e9ng \'ae\'cat ra b\'b6o \'ae\'b6m. Th\'d5 
\par }\pard \s15\qj \li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 l\'b5 khi \'ae\'d5n th\'eai h\'b9n tr\'b6 n\'ee, th\'d7 to\'b5n b\'e9 ru\'e9ng \'ae\'cat c\'f1a n\'abng d\'a9n \'ae\'d2u r\'aci v
\'b5o tay c\'b8c nh\'b5 truy\'d2n \'ae\'b9o.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 C\'b8c \'ae\'e5ng ch\'dd \'ae\'b7 th\'cay b\'e4n th\'f9c d
\'a9n b\'e3c l\'e9t n\'abng d\'a9n nh\'ad th\'d5 n\'b5o v\'b5 c\'b8c gi\'b8o s\'dc t\'ad\'edc \'aeo\'b9t n\'abng d\'a9n nh\'ad th\'d5 n\'b5o.
\par B\'a9y gi\'ea, c\'dfn c\'e3 nh\'f7ng k\'ce b\'e3c l\'e9t kh\'b8c n\'f7a, ch\'bcng h\'b9n nh\'ad Nh\'b5 n\'ad\'edc. D\'ef m\'efa m\'b5ng c\'e3 x\'cau \'ae\'d5n m\'f8c n\'b5o \'aei n\'f7a, n\'abng d\'a9n An Nam v\'c9n c\'f8 ph\'b6i \'ae\'e3ng thu\'d5; \'ae
\'d3 \'ae\'e3ng \'ae\'ad\'eec thu\'d5, n\'abng d\'a9n ph\'b6i b\'b8n m\'efa m\'b5ng c\'f1a m\'d7nh \'aei; \'ae\'d3 kh\'e1i b\'de b\'e1 t\'ef (h\'d4 \'ae\'e3ng thu\'d5 ch\'cbm l\'b5 h\'e4 b\'de b\'e1 t\'ef), h\'e4 ph\'b6i b\'b8n non m\'efa m\'b5ng c\'f1a h
\'e4, ngh\'dca l\'b5 b\'b8n tr\'ad\'edc khi g\'c6t; h\'e4 b\'b8n cho b\'e4n l\'b8i bu\'abn theo c\'b8ch \'ad\'edc l\'ad\'eeng b\'bbng m\'bet. B\'bbng c\'b8ch \'ae\'e3 b\'e4n l\'b8i bu\'abn mua \'ae\'ad\'eec l\'f3a tr\'ad\'edc khi g\'c6t b\'bbng m\'e9t gi
\'b8 r\'cat r\'ce v\'b5 sau \'ae\'e3 \'aeem b\'b8n l\'b9i r\'cat \'ae\'bet. Nh\'ad v\'cby l\'b5 ng\'ad\'eai n\'abng d\'a9n An Nam kh\'abng ph\'b6i ch\'d8 b\'de tr\'e3i v\'b5o m\'e9t chi\'d5c c\'e9t nh\'ad t\'abi \'ae\'b7 tr\'d7nh b\'b5y v\'edi c\'b8c \'ae
\'e5ng ch\'dd, m\'b5 h\'e4 b\'de \'ae\'e3ng \'aeinh c\'a9u r\'f3t b\'ebi b\'e8n th\'d5 l\'f9c li\'aan h\'eep l\'b5: Nh\'b5 n\'ad\'edc, t\'aan th\'f9c d\'a9n, nh\'b5 th\'ea v\'b5 t\'aan l\'b8i bu\'abn.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Ch\'bec l\'b5 c\'b8c \'ae\'e5ng ch\'dd s\'cf h\'e1i r\'bb
ng t\'b9i sao n\'abng d\'a9n An Nam kh\'abng t\'e6 ch\'f8c nhau l\'b9i, kh\'abng l\'b5m nh\'ad c\'b8c \'ae\'e5ng ch\'dd l\'b5 th\'b5nh l\'cbp h\'eep t\'b8c x\'b7. Ch\'d8 l\'b5 v\'d7 h\'e4 kh\'abng c\'e3 th\'d3 l\'b5m nh\'ad v\'cby \'ae\'ad\'eec.
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 T\'abi ph\'b6i n\'e3i v\'edi c\'b8c \'ae\'e5ng ch
\'dd r\'bbng ch\'f3ng t\'abi b\'de cai tr\'de b\'ebi m\'e9t ch\'d5 \'ae\'e9 n\'ab l\'d6. Ch\'f3ng t\'abi kh\'abng \'ae\'ad\'eec quy\'d2n xu\'cat b\'b6n b\'b8o. Ch\'f3ng t\'abi kh\'abng \'ae\'ad\'eec quy\'d2n t\'f9 do \'aei l\'b9i; ch\'bcng h\'b9n nh\'ad
 ch\'f3ng t\'abi kh\'abng th\'d3 \'aei t\'f5 M\'b8txc\'acva \'ae\'d5n P\'aat\'acr\'abgr\'b8t \'ae\'ad\'eec, ch\'f3ng t\'abi ph\'b6i xin \'ae\'ad\'eec m\'e9t t\'ea gi\'cay th\'abng h\'b5nh, n\'d5u kh\'abng h\'e4 s\'cf b\'bet gi\'f7 v\'b5 n\'d0m ch\'f3ng t
\'abi v\'b5o t\'ef. C\'f2ng v\'cby, ch\'f3ng t\'abi kh\'abng \'ae\'ad\'eec quy\'d2n h\'e9i h\'e4p ngh\'dca l\'b5 ch\'f3ng t\'abi kh\'abng \'ae\'ad\'eec quy\'d2n h\'e4p v\'edi nhau tr\'aan 4 ho\'c6c 5 ng\'ad\'eai n\'d5u kh\'abng c\'e3 m\'e9t gi\'cay ph\'d0
p \'ae\'c6c bi\'d6t c\'f1a c\'ac quan cai tr\'de Ph\'b8p.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 T\'abi c\'f2ng xin nh\'bec l\'b9i r\'bbng c\'b8c \'ae\'e5
ng ch\'dd \'ae\'b7 l\'aan ti\'d5ng ch\'e8ng chi\'d5n tranh, \'ae\'dfi ho\'b5 b\'d7nh; c\'b8c \'ae\'e5ng ch\'dd \'ae\'b7 n\'e3i \'ae\'d5n m\'e9t ch\'ddnh quy\'d2n v\'ab s\'b6n v\'b5 vi\'d6c l\'cbt \'ae\'e6 ch\'f1 ngh\'dca t\'ad b\'b6n. Nh\'adng t\'cat c
\'b6 nh\'f7ng \'aei\'d2u c\'b8c \'ae\'e5ng ch\'dd n\'e3i \'eb \'ae\'a9y s\'cf tr\'eb th\'b5nh v\'ab \'ddch, n\'d5u c\'b8c \'ae\'e5ng ch\'dd qu\'aan m\'cat c\'b8i y\'d5u t\'e8 qu\'a9n phi\'d6t th\'f9c d\'a9n. C\'b8c \'ae\'e5ng ch\'dd \'ae\'d2u bi\'d5t nh
\'f7ng s\'f9 ki\'d6n. Trong chi\'d5n tranh th\'d5 gi\'edi, ch\'d8 ri\'aang \'eb n\'ad\'edc Ph\'b8p, ng\'ad\'eai ta \'ae\'b7 \'ae\'ada t\'f5 c\'b8c thu\'e9c \'ae\'dea v\'d2 g\'c7n m\'e9t tri\'d6u ng\'ad\'eai b\'b6n x\'f8 \'ae\'d3 tham gia chi\'d5
n tranh. Trong nh\'f7ng n\'a8m 1916-1917, ng\'ad\'eai ta \'ae\'b7 ch\'eb v\'d2 2 t\'fb t\'can ng\'f2 c\'e8c}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0
\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1)  S\'e8 li\'d6u n\'b5y ch\'ada \'ae\'ad\'eec ki\'d3m tra l\'b9i. Ch\'f3ng t\'abi d\'dech \'ae\'f3ng theo b\'b6
n ti\'d5ng Ph\'b8p.}})}{\f37\fs20\insrsid1378858 , trong khi nh\'f7ng d\'a9n b\'b6n x\'f8 \'eb ch\'a9u Phi v\'b5 \'eb \'a7\'abng D\'ad\'acng \'aeang ch\'d5t \'ae\'e3i.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Th\'ada c\'b8c \'ae\'e5ng ch\'dd, \'ae\'d3 k\'d5t th\'f3c, t\'abi ph\'b6i nh\'bec l\'b9i v\'edi c\'b8c \'ae\'e5ng ch\'dd
 r\'bbng Qu\'e8c t\'d5 c\'f1a c\'b8c \'ae\'e5ng ch\'dd ch\'d8 tr\'eb th\'b5nh m\'e9t Qu\'e8c t\'d5 th\'cbt s\'f9 khi m\'b5 kh\'abng nh\'f7ng n\'abng d\'a9n ph\'ad\'acng T\'a9y, m\'b5 c\'b6 n\'abng d\'a9n \'eb ph\'ad\'acng \'a7\'abng, nh\'cat l\'b5 n\'ab
ng d\'a9n \'eb c\'b8c thu\'e9c \'ae\'dea l\'b5 nh\'f7ng ng\'ad\'eai b\'de b\'e3c l\'e9t v\'b5 b\'de \'b8p b\'f8c nhi\'d2u h\'acn c\'b8c \'ae\'e5ng ch\'dd, \'ae\'d2u tham gia Qu\'e8c t\'d5 c\'f1a c\'b8c \'ae\'e5ng ch\'dd }{\i\f37\fs20\insrsid1378858 (v\'e7
 tay).}{\f37\fs20\insrsid1378858 
\par 
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Ph\'b8t bi\'d3u chi\'d2u 13-10-1923.
\par T\'b5i li\'d6u ti\'d5ng Ph\'b8p, b\'b6n ch\'f4p l\'adu
\par t\'b9i C\'f4c l\'adu tr\'f7 V\'a8n ph\'dfng\line Trung \'ad\'acng \'a7\'b6ng.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par \~
\par \~
\par 
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 "CH\'ddNH S\'b8CH TH\'f9C D\'a2N" ANH
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~Ch\'f1 ngh\'dca t\'ad b\'b6n Anh, tuy th\'ccm mu\'e8n c
\'f1a c\'b6i v\'ab t\'cbn c\'f1a Trung Qu\'e8c, nh\'adng v\'d7 t\'f5 tr\'ad\'edc \'ae\'d5n gi\'ea, v\'c9n \'ae\'b5nh ch\'d8 chi\'d5m H\'ad\'acng C\'b6ng}{\f37\fs20\super\insrsid1378858 37}{\f37\fs20\insrsid1378858  l\'b5m thu\'e9c \'ae\'dea v\'b5 th\'f9
c hi\'d6n tr\'aan n\'e9i \'ae\'dea Trung Qu\'e8c ch\'ddnh s\'b8ch m\'eb c\'f6a, m\'e9t ch\'ddnh s\'b8ch gi\'f3p cho h\'e4 c\'e3 th\'d3 b\'e3c l\'e9t \'ae\'cat n\'ad\'edc n\'b5y m\'b5 kh\'abng l\'b5m cho nh\'a9n d\'a9n n\'e6i d\'cby. Ng\'b5y nay, \'ae\'e8
i v\'edi h\'e4 nh\'ad th\'d5 kh\'abng \'ae\'f1 n\'f7a. H\'e4 mu\'e8n l\'b5m h\'acn th\'d5 n\'f7a kia: h\'e4 mu\'e8n chi\'d5m c\'b6 Trung Qu\'e8c l\'b5m thu\'e9c \'ae\'dea.
\par }{\f37\fs20\expnd0\expndtw-2\insrsid1378858 L\'eei d\'f4ng chuy\'d6n r\'bec r\'e8i \'eb L\'a9m Th\'b5nh}{\f37\fs20\expnd0\expndtw-2\super\insrsid1378858 38}{\f37\fs20\expnd0\expndtw-2\insrsid1378858  , v\'b5 vin c\'ed b\'b6o \'ae\'b6m an ninh cho \'ae\'e5
ng b\'b5o c\'f1a m\'d7nh, \'ae\'b9i s\'f8 Anh \'eb B\'bec Kinh v\'f5a m\'edi ti\'d5n h\'b5nh giai \'aeo\'b9n \'ae\'c7u ti\'aan c\'f1a ch\'ddnh s\'b8ch th\'f9c d\'a9n \'ae\'e3. \'a4ng ta b\'bet \'ae\'c7u t\'f5 \'ae\'ad\'eang s\'bet. \'a7\'a9y l\'b5 nh\'f7
ng \'aei\'d2u \'abng ta \'ae\'d2 ngh\'de v\'edi Trung Qu\'e8c:
\par }{\i\f37\fs20\insrsid1378858 1. T\'cat c\'b6 nh\'f7ng con \'ae\'ad\'eang x\'a9y d\'f9ng b\'bbng v\'e8n c\'f1a Anh, ho\'c6c v\'cbt li\'d6u mua c\'f1a Anh m\'b5 hi\'d6n nay ch\'ada tr\'b6 h\'d5t, \'ae\'d2u s\'cf \'ae\'c6t d\'ad\'edi s\'f9 ki\'d3m so\'b8t c
\'f1a Anh;
\par 2. \'a7\'cat \'aeai v\'efng l\'a9n c\'cbn nh\'f7ng con \'ae\'ad\'eang \'ae\'e3 c\'f2ng \'ae\'d2u s\'cf thu\'e9c ph\'b9m vi ki\'d3m so\'b8t \'cay;
\par 3. Ngo\'b5i ch\'ddnh s\'b8ch \'ae\'ad\'eang s\'bet ra, n\'ad\'edc Anh c\'dfn c\'e3 quy\'d2n can thi\'d6p v\'b5o ch\'ddnh s\'b8ch \'ae\'e8i n\'e9i c\'f1a Trung Qu\'e8c;
\par 4. Trong tr\'ad\'eang h\'eep x\'b6y ra nh\'f7ng v\'f4 xung \'ae\'e9t v\'f2 trang gi\'f7a c\'b8c \'ae\'b6ng ph\'b8i ch\'ddnh tr\'de Trung Qu\'e8c, ng\'ad\'eai Anh c\'e3 quy\'d2n \'ae\'e5ng \'fd hay t\'f5 ch\'e8i cho \'ae\'b6ng ph\'b8i n\'b5y hay \'ae\'b6
ng ph\'b8i n\'e4 s\'f6 d\'f4ng nh\'f7ng con \'ae\'ad\'eang \'cay;
\par }\pard \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\i\f37\fs20\expnd0\expndtw-4\insrsid1378858 5. \'a6u ti\'aan \'ae\'ad\'eec tr\'b6 d\'c7n nh\'f7ng s\'e8 ti\'d2n vay m\'b5 ng\'ad\'eai Anh \'ae
\'b7 b\'e1 ra b\'bbng c\'b8ch \'ae\'ad\'eec s\'f6 d\'f4ng nh\'f7ng s\'e8 thu nh\'cbp c\'f1a ng\'b5nh \'ae\'ad\'eang s\'bet.
\par }{\f37\fs20\insrsid1378858 Ngo\'b5i ra \'abng ta c\'dfn y\'aau c\'c7u:
\par }{\i\f37\fs20\insrsid1378858 a) \'a7\'c6t t\'b9i B\'e9 Giao th\'abng \'eb B\'bec Kinh, m\'e9t ph\'dfng ki\'d3m so\'b8t ng\'b5nh \'ae\'ad\'eang s\'bet, tr\'ad\'ebng ph\'dfng l\'b5 m\'e9t nh\'a9n vi\'aan ng\'ad\'eai ngo\'b9i qu\'e8c (n\'aan hi\'d3u: m\'e9
t nh\'a9n vi\'aan Anh) c\'e3 to\'b5n quy\'d2n \'ae\'e8i v\'edi t\'cat c\'b6 m\'e4i ho\'b9t \'ae\'e9ng c\'f1a ng\'b5nh \'ae\'ad\'eang s\'bet tr\'aan to\'b5n c\'e2i Trung Qu\'e8c;
\par b) Vi\'d6c qu\'b6n tr\'de ng\'b5nh \'ae\'ad\'eang s\'bet c\'f2ng ph\'b6i giao cho c\'b8c \'ae\'b9i di\'d6n n\'ad\'edc ngo\'b5i;
\par c) T\'e6 ch\'f8c m\'e9t \'ae\'e9i tu\'c7n tra ng\'b5nh \'ae\'ad\'eang s\'bet d\'ad\'edi s\'f9 ch\'d8 huy c\'f1a c\'b8c s\'dc quan n\'ad\'edc ngo\'b5i;
\par d) C\'b8c ch\'f8c v\'f4 k\'d5 to\'b8n v\'b5 qu\'b6n tr\'de ng\'b5nh \'ae\'ad\'eang s\'bet \'ae\'d2u ph\'b6i do ng\'ad\'eai n\'ad\'edc ngo\'b5i \'ae\'b6m nhi\'d6m.
\par }{\f37\fs20\insrsid1378858 Ng\'ad\'eai Anh \'ae\'b7 n\'bem \'ae\'ad\'eec thu\'d5 mu\'e8i v\'b5 thu\'d5 quan Trung Qu\'e8c, b\'a9y gi\'ea h\'e4 l\'b9i mu\'e8n chi\'d5m l\'cay \'ae\'ad\'eang s\'bet. Khi ng\'ad\'eai ta bi\'d5t r\'bbng tr\'f5 
\par nh\'f7ng con \'ae\'ad\'eang Nam M\'b7n Ch\'a9u, B\'bec Kinh - H\'b8n Kh\'c8u v\'b5 L\'f2ng H\'b6i ra, - t\'cat c\'b6 nh\'f7ng con \'ae\'ad\'eang kh\'b8c \'ae\'d2u \'ae\'b7 \'ae\'ad\'eec x\'a9y d\'f9ng ho\'c6c b\'bbng v\'e8n c\'f1a Anh, ho\'c6c b\'bbng v
\'cbt li\'d6u mua ch\'deu c\'f1a c\'b8c h\'b7ng bu\'abn Anh, ng\'ad\'eai ta s\'cf hi\'d3u r\'bbng k\'d5 ho\'b9ch \'ae\'e3 n\'d5u \'ae\'ad\'eec th\'f9c hi\'d6n, th\'d7 s\'cf l\'b5m thi\'d6t h\'b9i cho Trung Qu\'e8c nh\'ad th\'d5 n\'b5o.
\par T\'cat c\'b6 m\'e4i ng\'ad\'eai Trung Qu\'e8c, kh\'abng ph\'a9n bi\'d6t ch\'ddnh ki\'d5n, \'ae\'d2u ph\'b6n \'ae\'e8i ch\'ddnh s\'b8ch th\'f9c d\'a9n tr\'b8 h\'d7nh \'ae\'e3. H\'e9i Li\'aan hi\'d6p sinh vi\'aan B\'bec Kinh \'ae\'b7 l\'aan ti\'d5ng k\'aa
u g\'e4i giai c\'cap c\'abng nh\'a9n t\'cat c\'b6 c\'b8c n\'ad\'edc h\'b7y d\'efng \'b6nh h\'ad\'ebng c\'f1a m\'d7nh \'ae\'d3 ng\'a8n ch\'c6n h\'b5nh \'ae\'e9ng \'ae\'e3, vi ph\'b9m t\'edi n\'d2n \'ae\'e9c l\'cbp c\'f1a nh\'a9n d\'a9n Trung Qu\'e8c.

\par Mong r\'bbng, tr\'ad\'edc s\'f9 \'aee do\'b9 c\'f1a ch\'f1 ngh\'dca t\'ad b\'b6n Anh, nh\'f7ng ng\'ad\'eai con c\'f1a Trung Qu\'e8c s\'cf bi\'d5t \'aeo\'b5n k\'d5t v\'edi nhau \'ae\'d3 ph\'b6n kh\'b8ng th\'beng l\'eei.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb120\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 NGUY\'d4N \'b8I QU\'e8C
\par }\pard\plain \ql \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858\charrsid10837566 B\'b8o }{
\i\f37\fs20\insrsid1378858\charrsid10837566 La Vie Ouvri\'ccre,}{\f37\fs20\insrsid1378858\charrsid10837566 \line \~ng\'b5y 9-11-1923.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 PHONG TR\'b5O C\'a4NG NH\'a2N
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa240\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Theo nh\'f7ng s\'e8 li\'d6u th\'e8ng k\'aa cu\'e8i c\'ef
ng th\'d7 s\'e8 l\'ad\'eeng nh\'f7ng ng\'ad\'eai v\'ab s\'b6n \'eb Trung Qu\'e8c l\'b5 5050 ngh\'d7n ng\'ad\'eai. G\'c7n 15 t\'e6 ch\'f8c th\'e8ng nh\'cat giai c\'cap v\'ab s\'b6n \'eb Trung Qu\'e8c, t\'ddnh ra kho\'b6ng 300 ngh\'d7n \'aeo\'b5n vi\'aan. H
\'e4 \'ae\'ad\'eec ph\'a9n b\'e8 nh\'ad sau:
\par }\trowd \ts11\trgaph56\trleft0\trbrdrt\brdrs\brdrw10 \trbrdrl\brdrs\brdrw10 \trbrdrb\brdrs\brdrw10 \trbrdrr\brdrs\brdrw10 \trbrdrh\brdrs\brdrw10 \trbrdrv\brdrs\brdrw10 \trftsWidth1\trpaddl56\trpaddr56\trpaddfl3\trpaddfr3 \clvertalt\clbrdrt\brdrs\brdrw10 
\clbrdrl\brdrs\brdrw10 \clbrdrb\brdrs\brdrw10 \clbrdrr\brdrs\brdrw10 \cltxlrtb\clftsWidth3\clwWidth2977\clshdrawnil \cellx2977\clvertalt\clbrdrt\brdrs\brdrw10 \clbrdrl\brdrs\brdrw10 \clbrdrb\brdrs\brdrw10 \clbrdrr\brdrs\brdrw10 
\cltxlrtb\clftsWidth3\clwWidth1616\clshdrawnil \cellx4593\clvertalt\clbrdrt\brdrs\brdrw10 \clbrdrl\brdrs\brdrw10 \clbrdrb\brdrs\brdrw10 \clbrdrr\brdrs\brdrw10 \cltxlrtb\clftsWidth3\clwWidth1616\clshdrawnil \cellx6209\pard\plain 
