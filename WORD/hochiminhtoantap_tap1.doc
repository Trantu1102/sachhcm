\par 
\par }\pard \qj \fi397\li0\ri0\sa80\sl-284\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa360\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\lang1053\langfe1033\langnp1053\insrsid1378858 \'a7\'a4NG D\'a6\'a5NG V
\'b5 TRI\'d2U TI\'a3N
\par }\pard\plain \qj \li0\ri0\sa120\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs20\insrsid1378858 M\'e9T S\'f9 SO S\'b8NH TH\'f3 V\'de
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Th\'d5 gi\'edi s\'cf ch\'d8 c\'e3 n\'d2n ho\'b5 b\'d7nh cu
\'e8i c\'efng khi t\'cat c\'b6 c\'b8c d\'a9n t\'e9c t\'f9 m\'d7nh tho\'b6 thu\'cbn v\'edi nhau c\'efng ti\'aau di\'d6t con qu\'b8i v\'cbt \'ae\'d5 qu\'e8c ch\'f1 ngh\'dca \'eb kh\'bep m\'e4i n\'aci m\'b5 h\'e4 g\'c6p n\'e3. Trong khi ch\'ea \'ae\'eei ng
\'b5y \'ae\'e3, hi\'d6n nay h\'e4 c\'dfn l\'b5 n\'b9n nh\'a9n c\'f1a con qu\'b8i v\'cbt \'cay, \'ae\'dfi h\'e1i m\'e9t c\'b8ch nghi\'aam kh\'bec, nh\'a9n danh nguy\'aan t\'bec c\'f1a d\'a9n t\'e9c \'ae\'ad\'eec quy\'d2n t\'f9 quy\'d5t v\'b5 h\'e4 r\'cat x
\'f8ng \'ae\'b8ng \'ae\'d3 l\'adu \'fd ti\'d5ng n\'e3i c\'f1a h\'e4 ph\'b6i \'ae\'ad\'eec l\'beng nghe v\'edi t\'d7nh c\'b6m \'ae\'cbm \'ae\'b5 trong nh\'a9n d\'a9n c\'b8c n\'ad\'edc ch\'a9u \'a2u v\'b5 ch\'a9u M\'fc. D\'ad lu\'cbn th\'d5 gi\'edi \'ae\'e8
i v\'edi c\'b8c n\'ad\'edc \'aeang r\'aan xi\'d5t d\'ad\'edi \'b8ch th\'e8ng tr\'de c\'f1a n\'ad\'edc ngo\'b5i kh\'abng ph\'b6i kh\'abng l\'b5m cho nh\'f7ng k\'ce \'aei b\'e3c l\'e9t c\'b8c d\'a9n t\'e9c lo s\'ee. Ch\'ddnh ph\'f1 Nh\'cbt B\'b6n nh\'d7n th
\'cay tr\'ad\'edc h\'cbu qu\'b6 \'ae\'b8ng bu\'e5n khi \'ae\'b7 m\'eb m\'e9t cu\'e9c chinh ph\'b9t r\'cat l\'edn c\'f1a ch\'f1 ngh\'dca qu\'a9n phi\'d6t, \'aeang th\'f5a nh\'cbn ph\'b6i c\'b6i c\'b8ch ch\'d5 \'ae\'e9 \'eb Tri\'d2u Ti\'aan theo m\'e9
t tinh th\'c7n khoan dung.
\par }\pard\plain \qj \li0\ri0\sb200\sa120\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs20\insrsid1378858 T\'f9 TR\'de \'eb TRI\'d2U TI\'a3N
\par }\pard \qj \fi397\li0\ri0\sa80\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 M\'e9t s\'bec l\'d6nh c\'f1a Ho\'b5ng tri\'d2u, c\'abng b\'e8 \'eb \'a7\'abng Kinh, ng\'b5y 19-8-1919, th\'f5a nh\'cbn t
\'f9 tr\'de cho Tri\'d2u Ti\'aan, v\'b5 tuy\'aan b\'e8 nh\'f7ng ng\'ad\'eai Tri\'d2u Ti\'aan v\'b5 Nh\'cbt B\'b6n v\'d2 m\'c6t ph\'b8p lu\'cbt \'ae\'d2u b\'d7nh \'ae\'bcng v\'b5 \'ae\'d2u \'ae\'ad\'eec h\'ad\'ebng nh\'f7ng quy\'d2n h\'b9n ngang nhau, kh
\'abng ph\'a9n bi\'d6t l\'b5}{\f37\fs20\expnd0\expndtw-4\insrsid1378858  ng\'ad\'eai n\'ad\'edc n\'b5o. Ch\'f3ng ta c\'f2ng ph\'b6i th\'cay tr\'ad\'edc r\'bbng nh\'f7ng ng\'ad\'eai y\'aau n\'ad\'edc Tri\'d2u Ti\'aan s\'cf kh\'abng v\'d7 th\'d5 m\'b5 l\'ca
y l\'b5m tho\'b6 m\'b7n v\'b5 h\'e4 c\'dfn ti\'d5p t\'f4c \'ae\'dfi cho \'ae\'ad\'eec \'ae\'e9c l\'cbp ho\'b5n to\'b5n, b\'ebi v\'d7 ph\'b6i ch\'a8ng h\'e4 ph\'b6n \'ae\'e8i \'ae\'b9o s\'bec l\'d6nh \'cay v\'edi l\'fd do l\'b5 n\'e3 c\'f2ng nh\'ad t\'ca
t c\'b6 c\'b8c quy}{\f37\fs20\insrsid1378858  \'ae\'denh lu\'cbt ph\'b8p kh\'b8c c\'e3 gi\'b8 tr\'de nhi\'d2u hay \'ddt c\'dfn tu\'fa \'eb s\'f9 th\'f9c hi\'d6n ra sao n\'f7a.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 R\'e2 r\'b5ng l\'b5 ch\'f3ng t\'abi kh\'abng h\'d2 \'ae\'e3
ng vai tr\'df \'ae\'b8ng khinh b\'d8 l\'b5m ng\'ad\'eai bi\'d6n h\'e9 cho ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c Nh\'cbt, m\'b5 l\'b5 ch\'f3ng t\'abi l\'aan \'b8n n\'e3 c\'f2ng nh\'ad l\'aan \'b8n t\'cat c\'b6 c\'b8c th\'f8 ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c. Ch
\'f3ng t\'abi c\'f2ng kh\'abng so s\'b8nh m\'e9t c\'b8ch c\'f4 th\'d3 chi ti\'d5t gi\'f7a ch\'d5 \'ae\'e9 cai tr\'de c\'f1a Nh\'cbt v\'edi ch\'d5 \'ae\'e9 cai tr\'de c\'f1a Ph\'b8p, m\'c6c d\'c7u v\'d2 nhi\'d2u m\'c6t, s\'f9 so s\'b8nh \'cay c\'f2ng s\'cf
 l\'b5m l\'eei cho Nh\'cbt B\'b6n, m\'b5 hi\'d3n nhi\'aan n\'ad\'edc n\'b5y ch\'ada bao gi\'ea c\'e3 \'fd \'ae\'denh \'ae\'c7u \'ae\'e9c ng\'ad\'eai Tri\'d2u Ti\'aan b\'bbng c\'b8ch b\'bet bu\'e9c h\'e4 ph\'b6i u\'e8ng r\'ad\'eeu v\'b5 h\'f3t thu\'e8c phi
\'d6n; nh\'adng ng\'b5y nay, ch\'ddnh ph\'f1 \'a7\'abng Kinh \'ae\'b7 tuy\'aan b\'e8 ch\'ddnh th\'f8c gi\'b6i ph\'e3ng ng\'ad\'eai Tri\'d2u Ti\'aan b\'bbng c\'b8ch \'ae\'e5ng ho\'b8 h\'e4 ho\'b5n to\'b5n nh\'ad nh\'f7ng c\'abng d\'a9n Nh\'cbt B\'b6n. Th
\'cbt \'ae\'b8ng bu\'e5n thay khi th\'cay r\'bbng sau 50 n\'a8m th\'e8ng tr\'de m\'b5 nh\'f7ng ng\'ad\'eai \'ae\'b9i di\'d6n cho n\'ad\'edc C\'e9ng ho\'b5 Ph\'b8p \'eb \'a7\'abng D\'ad\'acng v\'c9n c\'f8 ngoan c\'e8 k\'d7m ch\'a9n ng\'ad\'eai b\'b6n x\'f8
 trong v\'dfng n\'ab l\'d6, kh\'abng cho h\'e4 h\'ad\'ebng m\'e9t ch\'f3t quy\'d2n t\'f9 do n\'b5o c\'f2ng nh\'ad c\'b8c quy\'d2n kh\'b8c theo lu\'cbt ph\'b8p quy \'ae\'denh, th\'d5 m\'b5 \'eb c\'b8i \'ae\'d5 qu\'e8c m\'c6t tr\'eai m\'e4c kia l\'b9i tr
\'denh tr\'e4ng tuy\'aan b\'e8 cho c\'b6 m\'e9t d\'a9n t\'e9c \'ae\'ad\'eec h\'ad\'ebng to\'b5n b\'e9 c\'b8c quy\'d2n
\par }\pard \s15\qj \li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 c\'abng d\'a9n, c\'b8i d\'a9n t\'e9c m\'b5 h\'e4 ch\'d8 m\'edi th\'e8ng tr\'de ch\'ada \'ae\'c7y 15 n\'a8m, \'ae\'d3 m\'adu c\'c7
u tr\'b8nh \'ae\'ad\'eec c\'b8i tai ho\'b9 Nga d\'ad\'edi tri\'d2u \'ae\'b9i Nga ho\'b5ng.
\par }\pard\plain \s25\qj \li0\ri0\sb200\sa120\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 S\'f9 NH\'e5I S\'e4 NH\'f7NG NG\'a6\'eaI DA V\'b5NG
\par }\pard\plain \s15\qj \fi397\li0\ri0\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Trong nh\'f7ng n\'a8m chi\'d5n tranh, nhi\'d2u phong tr\'b5o qu
\'e8c gia quan tr\'e4ng \'ae\'b7 n\'e6 ra \'eb Tri\'d2u Ti\'aan c\'f2ng nh\'ad \'eb \'a7\'abng D\'ad\'acng \'ae\'d3 l\'cbt \'ae\'e6 \'b8ch th\'e8ng tr\'de c\'f1a ng\'ad\'eai n\'ad\'edc ngo\'b5i. Nh\'adng li\'d2n sau khi \'ae\'b7 d\'cbp t\'bet \'ae\'ad\'ee
c c\'b8c phong tr\'b5o phi\'d5n lo\'b9n, th\'d7 ch\'ddnh ph\'f1 Nh\'cbt B\'b6n \'ae\'b7 c\'e3 ngay bi\'d6n ph\'b8p xo\'b8 b\'e1 c\'b8i d\'dc v\'b7ng c\'f1a nh\'f7ng bi\'d5n c\'e8 \'aeau th\'ad\'acng \'cay b\'bbng nh\'f7ng c\'b6i c\'b8ch ti\'d5n b\'e9 v
\'b5 t\'d7m c\'b8ch ho\'b5 h\'eep d\'a9n t\'e9c b\'de tr\'de v\'edi d\'a9n t\'e9c th\'e8ng tr\'de b\'bbng c\'b8ch th\'f5a nh\'cbn h\'e4 c\'e3 nh\'f7ng quy\'d2n ngang nhau theo lu\'cbt ph\'b8p quy \'ae\'denh. C\'dfn nh\'ad ch\'ddnh ph\'f1 thu\'e9c \'ae\'de
a Ph\'b8p th\'d7
\par }\pard \s15\qj \li0\ri0\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858  v\'c9n ngoan c\'e8 m\'e9t c\'b8ch ng\'a9y th\'ac cho r\'bbng \'eb \'a7\'abng D\'ad\'acng n\'b5y mu\'e8n r\'b5ng bu\'e9c nh\'f7ng ng\'ad
\'eai b\'b6n x\'f8 th\'d7 ch\'d8 c\'c7n v\'e7 v\'d2 h\'e4 m\'b7i m\'b7i b\'bbng nh\'f7ng b\'b5i di\'d4n v\'a8n long tr\'e4ng, nh\'f7ng lu\'cbn \'aei\'d6u tuy\'aan truy\'d2n gian ngoan v\'b5 b\'bbng nh\'f7ng l\'eai th\'d2 nguy\'d6n trung th\'b5nh m\'b5 n
\'e3 ch\'d8 \'ae\'b8ng
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\expnd0\expndtw-2\insrsid1378858 gi\'b8 \'eb ch\'e7 ng\'ad\'eai ta \'ae\'c6
t v\'b5o \'ae\'cay: trong c\'b8i x\'f8 n\'b5y do thi\'d5u s\'e3t hay n\'e3i cho \'ae\'f3ng h\'acn, l\'b5 do \'fd \'ae\'denh c\'f1a ch\'ddnh ph\'f1, n\'aan \'ae\'a9u \'ae\'a9u t\'f5 tr\'aan xu\'e8ng d\'ad\'edi c\'f2ng \'ae\'d2u c\'e3 c\'b8i n\'b9n tham nh
\'f2ng mua quan b\'b8n ch\'f8c, nh\'f7ng b\'e4n ng\'ad\'eai mua b\'b8n \'ae\'ad\'eec b\'bbng ti\'d2n th\'d7 kh\'abng ph\'b6i l\'b5 nh\'f7ng th\'f8 h\'b5ng ho\'b8 hi\'d5m. V\'b5 \'ae\'d3 nh\'e5i s\'e4 nh\'f7ng ng\'ad\'eai da v\'b5ng, ch\'ddnh ph\'f1 thu
\'e9c \'ae\'dea \'ae\'b7 s\'bdn s\'b5ng nh\'f7ng bi\'d6n ph\'b8p v\'b5 ph\'ad\'acng ti\'d6n c\'f9c k\'fa m\'b9nh.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 V\'d2 m\'c6t b\'b8o ch\'dd, xu\'cat b\'b6n b\'bbng ti\'d5
ng ph\'ad\'acng \'a7\'abng, ch\'ddnh ph\'f1 gi\'b5nh l\'cay c\'b8i quy\'d2n h\'b9n b\'d8 \'e6i ch\'d8 cho ph\'d0p xu\'cat b\'b6n nh\'f7ng lo\'b9i n\'b5o ca ng\'eei m\'d7nh v\'b5 sau khi \'ae\'b7 c\'e3 ki\'d3m duy\'d6t r\'e5i. Ch\'ddnh ph\'f1 l\'eei d\'f4
ng c\'b8i \'ae\'c6c quy\'d2n \'ae\'e9c \'aeo\'b8n \'cay \'ae\'d3 l\'cbp ra nh\'f7ng t\'ea b\'b8o ti\'d5ng An Nam theo \'fd m\'d7nh \'ae\'ad\'eec h\'ad\'ebng tr\'ee c\'cap b\'dd m\'cbt c\'f1a Nh\'b5 n\'ad\'edc v\'b5 chuy\'aan vi\'d6c l\'b5m qu\'b6ng c\'b8
o tuy\'aan truy\'d2n cho ch\'ddnh ph\'f1 v\'b5 th\'ad\'eang k\'fa vi\'d5t nh\'f7ng b\'b5i ph\'d8nh n\'denh c\'b8c quan tr\'aan c\'e3 th\'d5 l\'f9c \'eb thu\'e9c \'ae\'dea.
\par }{\f38\fs20\expnd0\expndtw-4\insrsid1378858 \'ca}{\f37\fs20\expnd0\expndtw-4\insrsid1378858 y th\'d5 m\'b5, Ch\'ddnh ph\'f1 \'a7\'abng D\'ad\'acng l\'b9i mu\'e8n bi\'d5n ch\'ddnh h\'d6 th\'e8ng nh\'e5i s\'e4 n\'b5y th\'b5nh ch\'d5 \'ae\'e9 t\'f9 do b\'b8
o ch\'dd c\'f1a ng\'ad\'eai b\'b6n x\'f8 \'ae\'cay!
\par }\pard\plain \s25\qj \li0\ri0\sb200\sa120\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 NH\'f7NG S\'f9 HY SINH C\'f1A NG\'a6\'eaI AN NAM TRONG CHI
\'d5N TRANH
\par }\pard\plain \s15\qj \li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 N\'d5u ng\'ad\'eai ta l\'b5m m\'e9t b\'b6n th\'e8ng k\'aa nh\'f7
ng s\'f9 hy sinh b\'bet bu\'e9c cho n\'ad\'edc Ph\'b8p m\'b5 nh\'a9n d\'a9n An Nam ph\'b6i ch\'deu \'ae\'f9ng t\'f5 khi c\'e3 chi\'d5n tranh, th\'d7 ng\'ad\'eai ta s\'cf th\'cay, v\'d2 m\'c6t t\'b5i ch\'ddnh, nh\'a9n d\'a9n An Nam \'ae\'b7 ph\'b6i g\'b8
nh v\'b8c m\'e9t ph\'c7n l\'edn, c\'e3 \'ae\'d5n h\'b5ng tr\'a8m h\'b5ng ng\'b5n tri\'d6u phr\'a8ng, do \'ae\'e3ng g\'e3p t\'f9 do hay b\'bet bu\'e9c, m\'b5 ch\'f1 y\'d5u th\'d7 b\'bet bu\'e9c h\'acn l\'b5 t\'f9 do; v\'d2 m\'c6t \'ae\'e3ng g\'e3p s\'f8
c ng\'ad\'eai, th\'d7 m\'e9t ngu\'e5n nh\'a9n  l\'f9c r\'ce ti\'d2n \'ae\'b7 l\'aan t\'edi con s\'e8 h\'acn 100 ng\'b5n ng\'ad\'eai lao \'ae\'e9ng v\'b5 r\'cat nhi\'d2u ti\'d3u \'aeo\'b5n l\'ddnh chi\'d5n \'ae\'cau, k\'ce tr\'ad\'edc ng\'ad\'eai sau, h
\'e4 \'ae\'d2u b\'de tr\'adng t\'cbp v\'b5 b\'bet bu\'e9c \'ae\'ada sang Ph\'b8p hay \'aei c\'b8c n\'aci kh\'b8c, c\'dfn s\'e8 ng\'ad\'eai \'aei t\'d7nh nguy\'d6n th\'d7 kh\'abng sao k\'d3 xi\'d5t. Trong s\'e8 nh\'f7ng ng\'ad\'eai lao \'ae\'e9ng v\'b5
 binh l\'ddnh An Nam \'cay, \'ae\'b7 c\'e3 h\'b5ng m\'cay ch\'f4c ng\'b5n ng\'ad\'eai ra \'aei m\'b5 kh\'abng bao gi\'ea c\'dfn tr\'eb l\'b9i qu\'aa h\'ad\'acng \'ae\'cat n\'ad\'edc c\'f1a h\'e4 n\'f7a, ch\'d8 v\'d7 m\'e9t l\'fd do r\'cat \'ae\'acn gi\'b6
n l\'b5 h\'e4 \'ae\'b7 ch\'d5t. K\'ce n\'b5y th\'d7 ch\'d5t v\'d7 b\'de tai n\'b9n \'aei \'ae\'ad\'eang, v\'d7 c\'abng vi\'d6c n\'c6ng nh\'e4c qu\'b8 s\'f8c, v\'d7 ch\'ada th\'b9o ngh\'d2 \'eb trong c\'b8c c\'abng binh x\'ad\'ebng ho\'c6c v\'d7 nh\'f7ng s
\'f9 h\'b5nh h\'b9 t\'b5n b\'b9o trong c\'b8c tr\'b9i l\'ddnh; ng\'ad\'eai kia th\'d7 b\'de ch\'d5t trong cu\'e9c ch\'d0m gi\'d5t kh\'e6ng l\'e5 c\'f1a ch\'a9u \'a2u tr\'aan \'ae\'cat Ph\'b8p v\'b5 tr\'aan nh\'f7ng c\'b8nh \'ae\'e5ng \'ae\'c7y b\'d6nh 
\'abn d\'dech c\'f1a c\'b8c n\'ad\'edc v\'efng Banc\'a8ng. Trong gi\'ea ph\'f3t n\'b5y, ch\'d8 c\'c7n ch\'f3ng ta \'aei qua mi\'d2n B\'bec n\'ad\'edc Ph\'b8p l\'b5 s\'cf g\'c6p ngay h\'b5ng ng\'b5n ng\'ad\'eai An Nam x\'cau s\'e8 \'ae\'ad\'acng ph\'b6i l
\'b5m nh\'f7ng c\'abng vi\'d6c \'ae\'b5o v\'b5 \'ae\'bep \'ae\'cat. H\'e4
\par }\pard\plain \qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 ch\'bcng kh\'b8c g\'d7 nh\'f7ng \'aeo\'b5n ng\'ad\'eai n\'ab l
\'d6 t\'ef \'ae\'b5y th\'cbt s\'f9, ch\'d8 c\'dfn thi\'d5u c\'e3 xi\'d2ng x\'ddch \'eb ch\'a9n m\'b5 th\'abi, b\'ebi v\'d7 ng\'ad\'eai ta kh\'abng s\'ee h\'e4 b\'e1 tr\'e8n.
\par }\pard\plain \s15\qj \li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Li\'d6u n\'ad\'edc Ph\'b8p s\'cf l\'b5m \'ae\'ad\'eec g\'d7 \'ae
\'e8i v\'edi \'a7\'abng D\'ad\'acng \'ae\'d3 c\'e3 th\'d3 so v\'edi l\'dfng h\'b5o hi\'d6p c\'f1a n\'ad\'edc Nh\'cbt \'ae\'e8i v\'edi Tri\'d2u Ti\'aan?
\par }\pard \s15\qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 NGUY\'d4N \'b8I QU\'e8C
