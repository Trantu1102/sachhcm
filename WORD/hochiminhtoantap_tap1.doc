\par }\pard\plain \qc \li0\ri0\sa240\sl-400\slmult0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\b\f38\insrsid1378858 B\'e9}{\b\i\f38\insrsid1378858  H\'e5 CH\'dd MINH TO\'b5N T\'cbP

\par }\pard\plain \s15\qj \fi397\li0\ri0\sl-280\slmult0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 
\par }\pard \s15\qj \fi397\li0\ri0\sa80\sl-250\slmult0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\fs18\insrsid1378858 Ng\'b5y 22-12-1994, Ban B\'dd th\'ad Trung \'ad\'acng \'a7\'b6ng C\'e9ng s\'b6n Vi\'d6t Nam \'ae\'b7 ra quy\'d5t \'ae\'de
nh v\'d2 vi\'d6c xu\'cat b\'b6n l\'c7n th\'f8 hai b\'e9 }{\i\fs18\insrsid1378858 H\'e5 Ch\'dd Minh To\'b5n t\'cbp.}{\fs18\insrsid1378858  B\'b6n quy\'d5t \'ae\'denh n\'aau r\'e2: "Tr\'ad\'edc nh\'f7ng di\'d4n bi\'d5n m\'edi c\'f1a th\'d5 gi\'edi v\'b5 nh
\'f7ng nhi\'d6m v\'f4 to l\'edn c\'f1a s\'f9 nghi\'d6p x\'a9y d\'f9ng v\'b5 b\'b6o v\'d6 T\'e6 qu\'e8c, h\'acn bao gi\'ea h\'d5t, vi\'d6c th\'cam nhu\'c7n v\'b5 l\'b5m \'ae\'f3ng theo t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh c\'e3 t\'c7m quan tr\'e4ng \'ae\'c6
c bi\'d6t. Ngh\'de quy\'d5t \'a7\'b9i h\'e9i l\'c7n th\'f8 VII c\'f1a \'a7\'b6ng kh\'bcng \'ae\'denh c\'b8ch m\'b9ng n\'ad\'edc ta l\'cay ch\'f1 ngh\'dca M\'b8c - L\'aanin v\'b5 t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh l\'b5m n\'d2n t\'b6ng t\'ad t\'ad\'eb
ng, kim ch\'d8 nam cho h\'b5nh \'ae\'e9ng".
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-250\slmult0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\expnd0\expndtw2\insrsid1378858 Thi h\'b5nh quy\'d5t \'ae\'denh c\'f1a Ban B
\'dd th\'ad, Vi\'d6n Nghi\'aan c\'f8u ch\'f1 ngh\'dca M\'b8c - L\'aanin v\'b5 t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh c\'efng v\'edi Nh\'b5 xu\'cat b\'b6n Ch\'ddnh tr\'de qu\'e8c gia, sau m\'e9t th\'eai gian t\'ddch c\'f9c, kh\'c8n tr\'ad\'acng chu\'c8n b\'de
, \'ae\'b7 ho\'b5n th\'b5nh vi\'d6c s\'adu t\'c7m, b\'e6 sung v\'b5 ho\'b5n ch\'d8nh b\'b6n th\'b6o. Nh\'a9n d\'dep k\'fb ni\'d6m l\'c7n th\'f8 105 ng\'b5y sinh c\'f1a Ch\'f1 t\'dech H\'e5 Ch\'dd Minh v\'b5 chu\'c8n b\'de ti\'d5n t\'edi \'a7\'b9i h\'e9i 
\'ae\'b9i bi\'d3u to\'b5n qu\'e8c l\'c7n th\'f8 VIII c\'f1a \'a7\'b6ng, b\'e9 }{\i\f37\fs18\expnd0\expndtw2\insrsid1378858 H\'e5 Ch\'dd Minh To\'b5n t\'cbp}{\f37\fs18\expnd0\expndtw2\insrsid1378858 , xu\'cat b\'b6n l\'c7n th\'f8 hai, g\'e5m nhi\'d2u t\'cb
p l\'c7n l\'ad\'eet ra m\'bet b\'b9n \'ae\'e4c.
\par }\pard \qc \li0\ri0\sb160\sa80\sl-250\slmult0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs18\insrsid1378858 * 
\par }\pard \qc \li0\ri0\sa160\sl-250\slmult0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs18\insrsid1378858 *     *
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa80\sl-250\slmult0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'e9 }{\i\insrsid1378858 H\'e5 Ch\'dd Minh To\'b5n t\'cbp}{
\insrsid1378858 , xu\'cat b\'b6n l\'c7n th\'f8 hai, t\'cbp h\'eep ph\'c7n l\'edn nh\'f7ng t\'b8c ph\'c8m, b\'b5i n\'e3i, b\'b5i vi\'d5t quan tr\'e4ng c\'f1a Ch\'f1 t\'dech H\'e5 Ch\'dd Minh t\'f5 n\'a8m 1919 \'ae\'d5n n\'a8m 1969 \'ae\'b7 s\'adu t\'c7m v
\'b5 x\'b8c minh \'ae\'ad\'eec. \'a7\'a9y l\'b5 m\'e9t t\'b5i s\'b6n tinh th\'c7n v\'ab gi\'b8 c\'f1a to\'b5n \'a7\'b6ng, to\'b5n d\'a9n ta, l\'b5 s\'f9 ph\'b6n \'b8nh sinh \'ae\'e9ng, s\'a9u s\'bec qu\'b8 tr\'d7nh Ch\'f1 t\'dech H\'e5 Ch\'dd Minh t\'d7m 
\'ae\'ad\'eang c\'f8u n\'ad\'edc v\'b5 v\'b9ch ra
\par }\pard \s16\qj \li0\ri0\sa80\sl-250\slmult0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\lang1024\langfe1024\noproof\insrsid1378858 
{\shp{\*\shpinst\shpleft40\shptop-834\shpright940\shpbottom-474\shpfhdr0\shpbxcolumn\shpbxignore\shpbypara\shpbyignore\shpwr3\shpwrk0\shpfblwtxt0\shpz3\shplid1029{\sp{\sn shapeType}{\sv 1}}{\sp{\sn fFlipH}{\sv 0}}{\sp{\sn fFlipV}{\sv 0}}
{\sp{\sn lTxid}{\sv 131072}}{\sp{\sn dxTextLeft}{\sv 0}}{\sp{\sn dyTextTop}{\sv 0}}{\sp{\sn dxTextRight}{\sv 0}}{\sp{\sn dyTextBottom}{\sv 0}}{\sp{\sn fRecolorFillAsPicture}{\sv 0}}
{\sp{\sn fUseShapeAnchor}{\sv 0}}{\sp{\sn fLine}{\sv 0}}{\sp{\sn fLayoutInCell}{\sv 1}}{\shptxt \pard\plain \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 
VIII
\par }}}{\shprslt{\*\do\dobxcolumn\dobypara\dodhgt8195\dptxbx\dptxlrtb{\dptxbxtext\pard\plain \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 VIII
\par }}\dpx40\dpy-834\dpxsize900\dpysize360\dpfillfgcr255\dpfillfgcg255\dpfillfgcb255\dpfillbgcr255\dpfillbgcg255\dpfillbgcb255\dpfillpat1\dplinehollow}}}}{\insrsid1378858  \'ae\'ad\'eang l\'e8i chi\'d5n l\'ad\'eec, s\'b8ch l\'ad\'eec cho c\'b8ch m\'b9ng Vi
\'d6t Nam, \'ae\'e5ng th\'eai ph\'b6n \'b8nh qu\'b8 tr\'d7nh Ng\'ad\'eai c\'efng v\'edi \'a7\'b6ng ta t\'e6 ch\'f8c, l\'b7nh \'ae\'b9o c\'b8ch m\'b9ng Vi\'d6t Nam \'aei t\'f5 th\'beng l\'eei n\'b5y \'ae\'d5n th\'beng l\'eei kh\'b8c.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-256\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 Ch\'f1 t\'dech H\'e5 Ch\'dd Minh l\'b5 nh\'b5 t\'ad t\'ad
\'ebng v\'dc \'ae\'b9i, nh\'b5 l\'fd lu\'cbn thi\'aan t\'b5i c\'f1a c\'b8ch m\'b9ng Vi\'d6t Nam. Ng\'ad\'eai \'ae\'b7 n\'aau m\'e9t t\'cam g\'ad\'acng s\'b8ng trong vi\'d6c ti\'d5p thu v\'b5 v\'cbn d\'f4ng ch\'f1 ngh\'dca M\'b8c - L\'aanin tr\'aan tinh th
\'c7n \'ae\'e9c l\'cbp, t\'f9 ch\'f1 v\'b5 s\'b8ng t\'b9o. Ng\'ad\'eai \'ae\'b7 "n\'bem b\'bet s\'a9u s\'bec b\'b6n ch\'cat c\'b8ch m\'b9ng v\'b5 khoa h\'e4c, tinh th\'c7n bi\'d6n ch\'f8ng v\'b5 nh\'a9n \'ae\'b9o c\'f1a h\'e4c thuy\'d5t M\'b8c - L\'aa
nin, v\'cbn d\'f4ng m\'e9t c\'b8ch s\'b8ng t\'b9o h\'e4c thuy\'d5t \'cay ph\'ef h\'eep v\'edi ho\'b5n c\'b6nh th\'f9c t\'d5 n\'ad\'edc ta; \'ae\'e5ng th\'eai, Ng\'ad\'eai \'ae\'b7 k\'d5 th\'f5a, ph\'b8t huy ch\'f1 ngh\'dca y\'aau n\'ad\'edc, truy\'d2n th
\'e8ng t\'e8t \'ae\'d1p c\'f1a d\'a9n t\'e9c v\'b5 tinh hoa c\'f1a nh\'a9n lo\'b9i. T\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh \'ae\'ad\'eec h\'d7nh th\'b5nh t\'f5 nh\'f7ng ngu\'e5n g\'e8c \'ae\'e3. Vi\'d6c \'a7\'b9i h\'e9i VII kh\'bcng \'ae\'denh ch\'f1 ngh\'dc
a M\'b8c - L\'aanin, t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh l\'b5 n\'d2n t\'b6ng t\'ad t\'ad\'ebng c\'f1a \'a7\'b6ng v\'b5 kim ch\'d8 nam cho h\'b5nh \'ae\'e9ng l\'b5 m\'e9t b\'ad\'edc ph\'b8t tri\'d3n h\'d5t s\'f8c quan tr\'e4ng trong nh\'cbn th\'f8c v\'b5
 t\'ad duy l\'fd lu\'cbn c\'f1a \'a7\'b6ng ta.
\par Trong khi gi\'b6i quy\'d5t nh\'f7ng v\'can \'ae\'d2 c\'f1a c\'b8ch m\'b9ng Vi\'d6t Nam, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'b7 g\'e3p ph\'c7n ph\'b8t tri\'d3n ch\'f1 ngh\'dca M\'b8c - L\'aanin tr\'aan nhi\'d2u v\'can \'ae\'d2 quan tr\'e4ng, \'ae\'c6
c bi\'d6t l\'b5 l\'fd lu\'cbn v\'d2 c\'b8ch m\'b9ng gi\'b6i ph\'e3ng d\'a9n t\'e9c v\'b5 ti\'d5n l\'aan ch\'f1 ngh\'dca x\'b7 h\'e9i \'eb c\'b8c n\'ad\'edc thu\'e9c \'ae\'dea v\'b5 ph\'f4 thu\'e9c. T\'ad t\'ad\'ebng c\'f1a Ng\'ad\'eai \'ae\'b7 v\'b5 \'ae
ang soi \'ae\'ad\'eang cho cu\'e9c \'ae\'cau tranh c\'f1a nh\'a9n d\'a9n ta gi\'b5nh th\'beng l\'eei, tr\'eb th\'b5nh nh\'f7ng gi\'b8 tr\'de b\'d2n v\'f7ng c\'f1a d\'a9n t\'e9c Vi\'d6t Nam v\'b5 lan to\'b6 ra th\'d5 gi\'edi"}{
\cs17\f37\fs18\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) Ngh\'de
 quy\'d5t c\'f1a B\'e9 Ch\'ddnh tr\'de s\'e8 09-NQ/TW, ng\'b5y 18-2-1995: }{\i\insrsid1378858 V\'d2 m\'e9t s\'e8 \'ae\'denh h\'ad\'edng l\'edn trong c\'abng t\'b8c t\'ad t\'ad\'ebng hi\'d6n nay.}})}{\f37\fs18\insrsid1378858 .
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa80\sl-256\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Ng\'b5y nay, khi s\'f9 nghi\'d6p \'ae\'e6i m\'edi \'eb n
\'ad\'edc ta ng\'b5y c\'b5ng \'aei v\'b5o chi\'d2u s\'a9u, nh\'f7ng bi\'d5n chuy\'d3n tr\'aan th\'d5 gi\'edi ng\'b5y c\'b5ng l\'edn, nh\'f7ng v\'can \'ae\'d2 m\'edi \'ae\'c6t ra trong \'ae\'eai s\'e8ng x\'b7 h\'e9i ng\'b5y c\'b5ng nhi\'d2u, \'ae\'dfi h
\'e1i ph\'b6i l\'b5m s\'b8ng t\'e1 \'ae\'d3 t\'d7m ra s\'f9 gi\'b6i \'ae\'b8p, th\'d7 vi\'d6c nghi\'aan c\'f8u, b\'b6o v\'d6, v\'cbn d\'f4ng v\'b5 ph\'b8t tri\'d3n t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh v\'b5o th\'f9c t\'d5 cu\'e9c s\'e8ng, tr\'eb th\'b5
nh nhi\'d6m v\'f4 quan tr\'e4ng, c\'cap b\'b8ch trong c\'abng t\'b8c ch\'ddnh tr\'de, t\'ad t\'ad\'ebng, l\'fd lu\'cbn c\'f1a to\'b5n \'a7\'b6ng, to\'b5n d\'a9n ta.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-256\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 Nh\'f7ng t\'ad t\'ad\'ebng l\'edn c\'f1a Ch\'f1 t\'de
ch H\'e5 Ch\'dd Minh \'ae\'ad\'eec ph\'b6n \'b8nh trong }{\i\fs18\insrsid1378858 H\'e5 Ch\'dd Minh To\'b5n t\'cbp.}{\fs18\insrsid1378858  
\par Sau g\'c7n m\'ad\'eai n\'a8m t\'d7m \'ae\'ad\'eang c\'f8u n\'ad\'edc, \'ae\'c6t ch\'a9n l\'aan nhi\'d2u ch\'a9u l\'f4c,
\par }\pard \s15\qj \li0\ri0\sa80\sl-256\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\lang1024\langfe1024\noproof\insrsid1378858 
