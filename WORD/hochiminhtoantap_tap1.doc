\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 Theo phong t\'f4c c\'e6 truy\'d2n th\'d7 ng
\'ad\'eai An Nam coi r\'ce ngh\'d2 nh\'b5 binh. Cho n\'aan, c\'efng m\'e9t c\'cap b\'cbc nh\'ad nhau m\'b5 quan v\'e2 l\'f3c n\'b5o c\'f2ng b\'de x\'d5p h\'b9ng sau quan v\'a8n. S\'e8ng trong tr\'b9i l\'ddnh Ph\'b8p, ph\'b6i l\'b5m nh\'f7ng c\'abng vi\'d6
c lao d\'dech n\'c6ng n\'d2, ph\'b6i t\'cbp luy\'d6n v\'cat v\'b6, h\'e4c t\'cbp nh\'f7ng l\'fd thuy\'d5t ngu xu\'c8n v\'edi nh\'f7ng t\'aan ch\'d8 huy t\'b5n b\'b9o, v\'b5 ph\'b6i ch\'deu m\'e9t th\'f8 k\'fb lu\'cbt kh\'bet khe, l\'f3c n\'b5o c\'f2ng c
\'e3 th\'d3 b\'de tr\'f5ng ph\'b9t v\'b5 lu\'abn lu\'abn b\'de to\'b5 \'b8n binh \'aee do\'b9, th\'cbt kh\'abng c\'e3 g\'d7 h\'b5o h\'f8ng \'ae\'d3 c\'e3 th\'d3 l\'abi k\'d0o \'ae\'ad\'eec thanh ni\'aan An Nam v\'b5 khuy\'d5n kh\'ddch h\'e4 t\'cbp t\'b5
nh c\'b8i ngh\'d2 gi\'d5t ng\'ad\'eai \'cay. Thanh ni\'aan b\'b6n x\'f8 gh\'d0t cay gh\'d0t \'ae\'beng vi\'d6c b\'e4n qu\'a9n phi\'d6t Ph\'b8p b\'bet h\'e4 ph\'b6i \'aei l\'ddnh. H\'e4 t\'d7m m\'e4i c\'b8ch \'ae\'d3 l\'c8n tr\'b8nh: ng\'ad\'eai gi\'b5u c
\'e3 th\'d7 \'ae\'f3t l\'e3t c\'dfn ng\'ad\'eai ngh\'cco kh\'e3 th\'d7 tr\'e8n tr\'b8nh. C\'e3 th\'cay nh\'f7ng k\'ce kh\'e8n c\'efng kh\'abng c\'e3 ti\'d2n \'ae\'d3 \'ae\'f3t l\'e3t v\'b5 c\'f2ng kh\'abng bi\'d5t tr\'e8n \'aei \'ae\'a9u \'ae\'ad\'eec, b
\'de c\'ad\'ecng b\'b8ch d\'e5n v\'d2 tr\'b9i l\'ddnh bu\'e5n b\'b7 nh\'ad nh\'f7ng con v\'cbt m\'b5 ng\'ad\'eai ta \'aeem t\'edi l\'df m\'e6; c\'e3 th\'cay nh\'f7ng ng\'ad\'eai cha m\'d1, ch\'de em, nh\'f7ng ng\'ad\'eai v\'ee s\'bep c\'ad\'edi v\'f5a kh
\'e3c l\'e3c v\'f5a k\'aau van th\'b6m thi\'d5t \'aei theo nh\'f7ng ng\'ad\'eai l\'ddnh m\'e9 v\'d2 "c\'b8i \'ae\'b9i gia \'ae\'d7nh" \'cay nh\'ad l\'b5 \'aei theo nh\'f7ng t\'e9i ph\'b9m b\'de \'aeem l\'aan m\'b8y ch\'d0m, m\'edi hi\'d3u \'ae\'ad\'eec c
\'b8i vinh d\'f9 to l\'edn c\'f1a ng\'ad\'eai d\'a9n An Nam \'aei l\'b5m c\'b8i ngh\'dca v\'f4 qu\'a9n s\'f9 cay nghi\'d6t kia. Cho n\'aan h\'e4 t\'d7m m\'e4i c\'ac h\'e9i \'ae\'d3 t\'f9 c\'f8u l\'cay m\'d7nh.
\par Nh\'adng nh\'f7ng t\'aan ch\'d8 huy Ph\'b8p l\'b9i r\'cat x\'b6o quy\'d6t. \'a7\'d3 \'ae\'d2 ph\'dfng l\'ddnh An Nam b\'e1 tr\'e8n, m\'e9t vi\'aan t\'ad l\'d6nh ch\'d8 huy qu\'a9n \'ae\'e9i \'eb \'a7\'abng D\'ad\'acng cho th\'ddch s\'e8 hi\'d6u v\'b5o c
\'b8nh tay m\'e7i ng\'ad\'eai l\'ddnh b\'bbng nit\'acr\'b8t b\'b9c. Nh\'f7ng t\'aan ch\'f1 \'ae\'e5n \'aei\'d2n ng\'b5y x\'ada d\'efng s\'bet nung \'ae\'e1 \'ae\'b8nh d\'cau n\'ab l\'d6 th\'d7 nh\'f7ng vi\'aan t\'ad\'edng t\'b5i ng\'b5y nay \'ae\'b8nh d
\'cau l\'ddnh b\'b6n x\'f8 b\'bbng ch\'cat ho\'b8 h\'e4c, th\'cbt l\'b5 m\'e9t ti\'d5n b\'e9 c\'f1a m\'abn ho\'b8 h\'e4c v\'b5 c\'f1a n\'d2n v\'a8n minh! C\'b8ch l\'b5m c\'e3 kh\'b8c, nh\'adng k\'d5t qu\'b6 th\'d7 nh\'ad nhau: Khi c\'e3 m\'e9t ng\'ad\'ea
i l\'ddnh \'ae\'b5o ng\'f2 ng\'ad\'eai ta b\'bet t\'cat c\'b6 \'ae\'b5n \'abng \'eb n\'aci nghi c\'e3 ng\'ad\'eai tr\'e8n, r\'e5i \'aeem l\'e9t tr\'c7n \'ae\'d3 kh\'b8m c\'b8nh tay. N\'d5u ng\'ad\'eai \'ae\'b5o ng\'f2 l\'c8n tr\'e8n \'eb \'ae\'a9y, th\'d7
 b\'de t\'d7m ra ngay; ng\'ad\'eai \'cay b\'de b\'bet \'aeem v\'d2 nh\'b5 lao v\'b5 \'ae\'ada ra to\'b5 \'b8n binh. H\'c7u h\'d5t c\'b8c phi\'aan to\'b5 \'b8n binh, kh\'abng tr\'f5 m\'e9t phi\'aan n\'b5o, \'ae\'d2u c\'e3 nh\'f7ng v\'f4 \'ae\'b5o ng\'f2 b
\'de \'ae\'ada ra x\'d0t x\'f6.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-264\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Khi ta \'ae\'b7 bi\'d5t ng\'ad\'eai l\'ddnh b\'b6n x\'f8 b\'de \'ae\'e8i x\'f6 nh\'ad th\'d5 n\'b5o th\'d7
 ng\'ad\'eai ta kh\'abng c\'dfn ng\'b9c nhi\'aan h\'e1i t\'b9i sao ng\'ad\'eai l\'ddnh m\'e9 l\'b9i th\'ddch nh\'b5 lao h\'acn l\'b5 tr\'b9i l\'ddnh. T\'abi tr\'ddch d\'c9n m\'e9t \'aeo\'b9n trong b\'b5i b\'b8o m\'edi vi\'d5t g\'c7n \'ae\'a9y:
\par "Th\'f8 s\'b8u v\'f5a qua, m\'e9t vi\'d6c nghi\'aam tr\'e4ng \'ae\'b7 x\'b6y ra \'eb trung \'aeo\'b5n ph\'b8o th\'f1 ng\'ad\'eai b\'b6n x\'f8 th\'f8 5. Chi\'d2u ng\'b5y th\'f8 s\'b8u \'ae\'e3, trong khi duy\'d6t m\'e9t \'ae\'e9i t\'a9n binh b\'b6n x\'f8 }
{\i\f37\fs20\cgrid0\insrsid1378858 cu\'e8i c\'efng, }{\f37\fs20\cgrid0\insrsid1378858 m\'e9t vi\'aan h\'b9 s\'dc quan \'ae\'b7 \'ae\'b8nh ng\'ad\'eai m\'e9t c\'b8ch d\'b7 man, }{\i\f37\fs20\cgrid0\insrsid1378858 h\'b5nh \'ae\'e9ng \'ae\'e3 l\'b9i \'ae\'ad
\'eec n\'aau l\'b5 
\par g\'ad\'acng m\'c9u }{\f37\fs20\cgrid0\insrsid1378858 trong trung \'aeo\'b5n. T\'aan \'ae\'e9i \'ae\'b8nh ng\'ad\'eai \'cay l\'b9i \'ae\'ad\'eec }{\i\f37\fs20\cgrid0\insrsid1378858 c\'cap tr\'aan c\'f1a n\'e3 xem l\'b5 m\'e9t h\'b9 s\'dc t\'e8t nh\'cat, }{
\f37\fs20\cgrid0\insrsid1378858 h\'acn n\'f7a, l\'b9i c\'dfn \'ae\'ad\'eec \'ae\'d2 ngh\'de th\'a8ng ch\'f8c. Th\'cbt \'ae\'b8ng ti\'d5c r\'bbng nh\'f7ng ng\'ad\'eai \'ae\'ad\'eec n\'ad\'edc Ph\'b8p g\'f6i sang \'ae\'a9y nh\'a9n danh l\'b5 nh\'f7ng ng\'ad
\'eai khai ho\'b8 ki\'aan nh\'c9n, \'ae\'b7 d\'b9y ngh\'d2 nh\'b5 binh cho \'ae\'e5ng b\'b5o ch\'f3ng t\'abi - }{\i\f37\fs20\cgrid0\insrsid1378858 m\'edi s\'e8ng chung ch\'ada \'ae\'c7y hai th\'b8ng v\'edi nh\'f7ng ng\'ad\'eai b\'b6o h\'e9 cho m\'d7nh }{
\f37\fs20\cgrid0\insrsid1378858 - l\'b9i t\'f9 ti\'d6n "h\'b5nh \'ae\'e9ng m\'e9t c\'b8ch b\'d8 \'e6i" \'ae\'b8nh \'ae\'cbp }{\i\f37\fs20\cgrid0\insrsid1378858 b\'bbng n\'dfng s\'f3ng v\'b5 b\'b8ng s\'f3ng }{\f37\fs20\cgrid0\insrsid1378858 m\'e9t ng\'ad
\'eai l\'ddnh b\'b6n x\'f8 \'ae\'b8ng th\'ad\'acng }{\i\f37\fs20\cgrid0\insrsid1378858 kh\'abng hi\'d3u qua m\'e9t ti\'d5ng Ph\'b8p}{\f37\fs20\cgrid0\insrsid1378858 , }{\i\f37\fs20\cgrid0\insrsid1378858 vi\'d6n c\'ed l\'b5 ng\'ad\'eai n\'b5y kh\'abng tr
\'b6 l\'eai nh\'f7ng c\'a9u h\'e1i b\'bbng ti\'d5ng Ph\'b8p}{\f37\fs20\cgrid0\insrsid1378858  "gi\'b6 c\'c7y" c\'f1a t\'aan \'aeao ph\'f1. Ng\'ad\'eai l\'ddnh \'ae\'b8ng th\'ad\'acng \'cay \'ae\'b7 ng\'b7 ch\'d5t ng\'cat, kh\'abng th\'eb \'ae\'ad\'eec n
\'f7a. B\'b8c s\'dc c\'f1a trung \'aeo\'b5n \'ae\'ada anh v\'b5o nh\'b5 th\'ad\'acng, anh l\'ddnh ph\'b8o th\'f1 An Nam }{\i\f37\fs20\cgrid0\insrsid1378858 \'ae\'b7 b\'de g\'b7y m\'e9t x\'ad\'acng s\'ad\'ean v\'d7 b\'de \'ae\'b8nh qu\'b8 t\'b5n nh\'c9n.}{
\f37\fs20\cgrid0\insrsid1378858 
\par "Khi b\'b8o s\'bep l\'aan khu\'abn th\'d7 ch\'f3ng t\'abi \'ae\'ad\'eec tin kho\'b6ng hai m\'ad\'aci ng\'ad\'eai l\'ddnh An Nam \'ae\'c6t d\'ad\'edi quy\'d2n ch\'d8 huy tr\'f9c ti\'d5p c\'f1a b\'e4n v\'f2 phu qu\'a9n phi\'d6t, \'ae\'b7 b\'e1 tr\'b9i ra 
\'aei, kh\'abng bao gi\'ea tr\'eb l\'b9i...". V\'b5 nh\'f7ng th\'dd d\'f4 nh\'ad v\'cby kh\'abng c\'dfn l\'b5 hi\'d5m.}{\i\f37\fs20\cgrid0\insrsid1378858 
\par }\pard \qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858   
\par  Trong chi\'d5n tranh d\'ef Nh\'b5 n\'ad\'edc c\'e3 t\'b8n d\'ad\'acng v\'b5 l\'f5a b\'dep r\'cat nhi\'d2u, nh\'f7ng ng\'ad\'eai An Nam c\'f2ng kh\'abng h\'b5o h\'f8ng g\'d7 \'ae\'d3 \'aei th\'dd m\'b9ng cho c\'b8i b\'b6 v\'a8n minh v\'b5 cho n\'ad\'edc m
\'d1. Kh\'abng ch\'f3t n\'b5o nh\'ad v\'cby \'ae\'a9u! S\'f9 th\'cbt kh\'b8c h\'bcn v\'b5 ch\'bcng \'ae\'d1p \'ae\'cf g\'d7. Ng\'ad\'eai ta ra l\'d6nh cho c\'b8c x\'b7 ph\'b6i cung c\'cap \'ae\'f1 m\'e9t s\'e8 ng\'ad\'eai n\'b5o \'ae\'cay. Nh\'f7ng ng\'ad
\'eai n\'b5y b\'de b\'bet v\'d2 nh\'e8t \'eb c\'b8c \'ae\'d7nh l\'b5ng, r\'e5i sau \'ae\'e3 b\'de tr\'e3i t\'f5ng x\'a9u \'aeem l\'aan t\'d8nh l\'fe. Ng\'ad\'eai ta \'aeem nh\'d0t h\'e4 v\'b5o trong c\'b8c tr\'ad\'eang h\'e4c hay trong c\'b8c tr\'b9i 
giam c\'e3 l\'ddnh canh g\'b8c, l\'ad\'eci l\'aa tu\'e8t tr\'c7n v\'b5 s\'f3ng n\'b9p \'ae\'b9n s\'bdn. Ti\'d5p \'ae\'e3 ng\'ad\'eai ta x\'d5p h\'e4 xu\'e8ng h\'c7m t\'b5u t\'e8i om v\'b5 ng\'e9t ng\'b9t nh\'ad nh\'f7ng con v\'cbt \'ae\'d3 ch\'eb sang Ph
\'b8p.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Ch\'ddnh b\'bbng nh\'f7ng ph\'ad\'acng ph\'b8p gh\'aa t\'ebm \'cay m\'b5 ng\'ad\'eai ta \'ae\'b7 bi\'d5n m
\'ad\'eai v\'b9n ng\'ad\'eai An Nam th\'b5nh nh\'f7ng ng\'ad\'eai "t\'d7nh nguy\'d6n" b\'aanh v\'f9c cho ch\'ddnh ngh\'dca, cho c\'abng l\'fd, v.v.. Trong s\'e8 \'ae\'e3, 51.000 ng\'ad\'eai l\'b5m vi\'d6c ch\'d5 thu\'e8c s\'f3ng, \'ae\'b5o h\'c7m, v\'cb
n chuy\'d3n, c\'f8u th\'ad\'acng v\'b5 l\'b5m nhi\'d2u vi\'d6c kh\'b8c n\'f7a.
\par 49.000 ng\'ad\'eai ra m\'c6t tr\'cbn \'eb Ph\'b8p, \'eb Xal\'abn\'ddch v\'b5 \'eb}{\i\f37\fs20\cgrid0\insrsid1378858  }{\f37\fs20\cgrid0\insrsid1378858 Xib\'aari. 20.000}{\i\f37\fs20\cgrid0\insrsid1378858  }{\f37\fs20\cgrid0\insrsid1378858 ng\'ad\'eai 
\'ae\'b7 ch\'d5t.
\par }{\f37\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 C\'b8ch "m\'e9 l\'ddnh t\'d7nh nguy\'d6n" c\'ad\'ecng b\'f8c \'cay kh\'abng ph\'b6i \'ae\'b7 l\'b5m \'ae\'ad\'eec tr\'abi ch\'b6y m\'b5 kh\'abng g\'c6p tr\'eb ng\'b9i g\'d7. Khi c\'e3 l\'d6nh g\'e4i t\'df
ng qu\'a9n, s\'e8 l\'ddnh tr\'ef b\'de v\'beng m\'c6t l\'aan t\'edi 30%, s\'e8 \'ae\'b5o ng\'f2 50%. Nh\'f7ng cu\'e9c bi\'d3u t\'d7nh, n\'e6i d\'cby, b\'b9o \'ae\'e9ng n\'e6 ra \'eb h\'c7u kh\'bep c\'b8c t\'d8nh. \'a7\'ad\'acng nhi\'aan l\'b5 nh\'f7ng cu
\'e9c \'ae\'cau tranh \'cay \'ae\'d2u b\'de \'ae\'b5n \'b8p kh\'abng g\'edm tay. T\'ef \'ae\'b5y, b\'ben gi\'d5t, t\'b5n s\'b8t, t\'cat c\'b6 b\'e9 m\'b8y \'ae\'b5n \'b8p \'ae\'d2u \'ae\'ad\'eec huy \'ae\'e9ng. Ai ch\'e8ng l\'b9i b\'de x\'f6 b\'ben ngay t
\'b9i ch\'e7. N\'b9n nh\'a9n k\'d3 c\'e3 \'ae\'d5n h\'b5ng ngh\'d7n ng\'ad\'eai. 
\par }{\f37\fs20\cgrid0\insrsid1378858 Khi \'ae\'ad\'eec gi\'b6i ng\'f2, nh\'f7ng ng\'ad\'eai "anh h\'efng" An Nam \'ae\'ad\'eec n\'ad\'edc m\'d1 bi\'d5t \'acn \'a9n c\'c7n \'ae\'e8i \'ae\'b7i th\'cbt l\'b5 c\'b6m \'ae\'e9ng. Tr\'ad\'edc khi l\'aan t\'b5u v
\'d2 n\'ad\'edc, ng\'ad\'eai ta \'ae\'b7 l\'e9t l\'b9i t\'cat c\'b6 c\'f1a c\'b6i c\'f1a h\'e4: n\'b5o ti\'d2n \'ae\'d3 d\'b5nh \'ae\'ad\'eec, n\'b5o \'ae\'e5 \'ae\'b9c, n\'b5o qu\'c7n \'b8o m\'b5 h\'e4 t\'f9 s\'bem l\'cay. C\'f2ng nh\'ad khi \'aei, h\'e4
 l\'b9i \'ae\'ad\'eec x\'d5p xu\'e8ng h\'c7m t\'b5u t\'e8i t\'a8m, \'a8n nh\'f7ng b\'f7a c\'acm thi\'d5u th\'e8n, kh\'e3 nu\'e8t tr\'abi v\'b5 b\'de ng\'ad\'eec \'ae\'b7i. Ng\'ad\'eai ta s\'ee nh\'f7ng ng\'ad\'eai l\'ddnh n\'b5y mang v\'d2 nh\'f7ng t\'ad
 t\'ad\'ebng ti\'d5n b\'e9 v\'b5 nh\'f7ng th\'e3i quen th\'ddch \'ae\'e9c l\'cbp ti\'aam nhi\'d4m \'ae\'ad\'eec \'eb n\'ad\'edc Ph\'b8p, n\'aan ng\'ad\'eai ta \'ae\'b7 giao h\'e4 cho b\'e4n th\'f9c d\'a9n \'ae\'d3u gi\'b6 t\'b5n b\'b9o nh\'cat ki\'d3m so
\'b8t. B\'e4n n\'b5y d\'efng g\'cby \'ae\'b8nh, \'ae\'b8 ng\'ad\'eai v\'ab c\'ed. V\'d2 \'ae\'d5n n\'ad\'edc nh\'b5, nh\'f7ng ng\'ad\'eai l\'ddnh \'cay \'ae\'d2u b\'de n\'d0m ra \'ae\'ad\'eang m\'e9t c\'b8ch \'ae\'acn gi\'b6n th\'d5 th\'abi.
\par Tr\'ad\'edc khi \'aei chi\'d5n \'ae\'cau, ng\'ad\'eai ta h\'f8a tr\'eai h\'f8a bi\'d3n v\'edi h\'e4, th\'d7 \'ae\'d5n nay tr\'eb v\'d2 ng\'ad\'eai ta l\'b9i r\'f3t b\'e1 h\'d5t m\'e4i quy\'d2n l\'eei m\'b5 x\'ada nay nh\'f7ng ng\'ad\'eai An Nam \'aei t
\'dfng qu\'a9n \'ae\'d2u \'ae\'ad\'eec h\'ad\'ebng, nh\'ad mi\'d4n thu\'d5 th\'a9n, mi\'d4n sai d\'dech, v.v.. Nhi\'d2u ng\'ad\'eai \'ae\'b7 ph\'b6i \'aei \'a8n xin t\'f5 l\'b5ng n\'b5y qua l\'b5ng kh\'b8c, ph\'b6i \'aei b\'e9 h\'b5ng tu\'c7n l\'d4 \'ae
\'d3 tr\'eb v\'d2 qu\'aa h\'ad\'acng, n\'aci m\'b5 ng\'ad\'eai ta \'ae\'b7 d\'efng v\'f2 l\'f9c bu\'e9c h\'e4 ph\'b6i r\'f8t ra \'aei.
\par Hi\'d6n nay ng\'ad\'eai ta k\'d0o d\'b5i th\'eai h\'b9n t\'dfng qu\'a9n c\'f1a ng\'ad\'eai b\'b6n x\'f8 t\'f5 2 \'ae\'d5n 4 n\'a8m. Ngo\'b5i s\'e8 25.000 \'ae\'d5n 30.000 l\'ddnh kh\'e8 \'ae\'e1 \'ae\'e3ng qu\'a9n trong n\'ad\'edc d\'efng \'ae\'d3 b\'be
n gi\'d5t \'ae\'e5ng b\'b5o c\'f1a h\'e4, x\'f8 \'a7\'abng D\'ad\'acng c\'dfn ph\'b6i cung c\'cap th\'aam 40.000 l\'ddnh m\'e9 \'ae\'d3 ph\'f4ng s\'f9 \'eb ch\'ddnh qu\'e8c v\'b5 \'eb c\'b8c thu\'e9c \'ae\'dea kh\'b8c.
\par C\'b8c b\'b9n \'ae\'b7 th\'cay \'ae\'cay, n\'ad\'edc Ph\'b8p ch\'bcng ph\'b6i qu\'a9n phi\'d6t ch\'f3t n\'b5o \'ae\'a9u!
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\b\f37\fs20\cgrid0\insrsid1378858 
