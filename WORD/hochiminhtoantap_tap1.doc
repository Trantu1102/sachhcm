\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 \'a7\'abng D\'ad\'acng c\'e3 nh\'f7ng ngu
\'e5n kho\'b8ng s\'b6n \'ae\'b8ng k\'d3. Ng\'ad\'eai ta \'ad\'edc l\'ad\'eeng m\'e1 than \'eb B\'bec K\'fa c\'e3 \'ae\'d5n 12 t\'fb t\'can. C\'b6 c\'b8i kho nhi\'aan li\'d6u \'cay c\'e3 th\'d3 ho\'b5n to\'b5n d\'b5nh ri\'aang cho c\'abng nghi\'d6p, v\'d7 
\'eb \'a7\'abng D\'ad\'acng kh\'abng c\'c7n ti\'aau th\'f4 m\'e9t s\'e8 l\'ad\'eeng than l\'edn \'ae\'d3 \'aeun n\'cau nh\'ad \'eb c\'b8c n\'ad\'edc kh\'b8c.
\par N\'a8m 1920, 63 c\'abng ty khai th\'b8c 19 m\'e1 \'ae\'ad\'eec 7.000.000 t\'b9 than \'ae\'b8 tr\'de gi\'b8 45.000.000 phr\'a8ng.
\par Ri\'aang m\'e1 than H\'b9 Long \'ae\'b7 cung c\'cap \'ae\'ad\'eec 5.500.000 t\'b9.
\par C\'abng ty l\'edn nh\'cat l\'b5 c\'abng ty than \'ae\'b8 B\'bec K\'fa. C\'abng ty n\'b5y khai th\'b8c h\'bbng n\'a8m \'ae\'ad\'eec 150.000 t\'can. C\'abng ty th\'ad\'acng m\'b9i v\'b5 khai th\'b8c Vi\'d4n \'a7\'abng s\'b6n xu\'cat \'ae\'ad\'ee
c 2.600.000 t\'b9.
\par N\'a8m 1920, \'a7\'abng D\'ad\'acng s\'b6n xu\'cat \'ae\'ad\'eec:
