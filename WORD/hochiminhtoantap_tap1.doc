\clbrdrr\brdrs\brdrw10 \cltxlrtb\clftsWidth3\clwWidth1616\clshdrawnil \cellx6209\row }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Trong c\'b8c y\'aau s\'b8ch c\'f1
a giai c\'cap v\'ab s\'b6n c\'e3 t\'e6 ch\'f8c c\'f1a Trung Qu\'e8c, ch\'f3ng t\'abi th\'cay c\'e3 nh\'f7ng \'aei\'d3m sau \'ae\'a9y:
\par 1. T\'f9 do h\'e9i h\'e4p. 2. Quy\'d2n t\'e6 ch\'f8c c\'b8c c\'abng \'aeo\'b5n v\'b5 c\'b8c cu\'e9c \'ae\'d7nh c\'abng. 3. Ng\'b5y lao \'ae\'e9ng 8 gi\'ea cho ng\'ad\'eai l\'edn v\'b5 6 gi\'ea cho thi\'d5u ni\'aan v\'b5 nh\'f7ng ng\'ad\'eai l\'b5m vi\'d6
c n\'c6ng. 4. B\'b6o v\'d6 nh\'f7ng ng\'ad\'eai ti\'d3u n\'abng. 5. C\'cam l\'b5m vi\'d6c qu\'b8 gi\'ea trong nh\'f7ng x\'dd nghi\'d6p \'ae\'e9c h\'b9i v\'b5 c\'cam s\'f6 d\'f4ng lao \'ae\'e9ng tr\'ce em v\'b5 ph\'f4 n\'f7 v\'b5o vi\'d6c l\'b5m ban \'ae
\'aam. 6. H\'bbng n\'a8m c\'abng nh\'a9n \'ae\'ad\'eec ngh\'d8 hai tu\'c7n, \'ae\'e8i v\'edi ph\'f4 n\'f7 l\'b5m c\'abng vi\'d6c n\'c6ng nh\'e4c th\'d7 \'ae\'ad\'eec ngh\'d8 8 tu\'c7n tr\'ad\'edc khi \'ae\'ce v\'b5 8 tu\'c7n sau khi \'ae\'ce; 6 tu\'c7
n ngh\'d8 \'ae\'ce \'ae\'e8i v\'edi ph\'f4 n\'f7 l\'b5m c\'abng ch\'f8c v\'b5 l\'b5m c\'b8c c\'abng vi\'d6c nh\'d1. 7. Ban ki\'d3m tra c\'f1a c\'abng nh\'a9n. 8. Lu\'cbt b\'b6o hi\'d3m \'ae\'e8i v\'edi c\'abng nh\'a9n. 9. Nh\'b5 n\'ad\'edc c\'e3 tr\'b8
ch nhi\'d6m gi\'f3p \'ae\'ec c\'b8c t\'e6 ch\'f8c c\'abng nh\'a9n c\'f1a nh\'f7ng ng\'ad\'eai lao \'ae\'e9ng \'ae\'ad\'eec h\'e4c h\'b5nh.
\par Ch\'d8 sau khi chi\'d5n tranh th\'d5 gi\'edi k\'d5t th\'f3c, giai c\'cap v\'ab s\'b6n Trung Qu\'e8c m\'edi b\'bet \'ae\'c7u \'ae\'ad\'eec t\'e6 ch\'f8c m\'e9t c\'b8ch ch\'c6t ch\'cf, song h\'e4 \'ae\'b7 thu \'ae\'ad\'eec m\'e9t s\'e8 th\'beng l\'eei to l
\'edn trong c\'b8c cu\'e9c \'ae\'d7nh c\'abng. M\'c6c d\'ef b\'de b\'e4n qu\'a9n phi\'d6t \'ae\'b5n \'b8p v\'b5 b\'e4n th\'e8ng tr\'de ngo\'b9i lai c\'b6n tr\'eb, c\'b8c t\'e6 ch\'f8c c\'f1a h\'e4 v\'c9n ph\'b8t tri\'d3n b\'d7nh th\'ad\'eang v\'b5 c\'e3
 th\'d3 n\'e3i l\'b5 nhanh n\'f7a. Hi\'d6n nay nh\'f7ng ng\'ad\'eai thu\'fb th\'f1, c\'abng nh\'a9n luy\'d6n kim, c\'abng nh\'a9n \'ae\'ad\'eang s\'bet l\'b5 nh\'f7ng l\'f9c l\'ad\'eeng th\'cbt s\'f9 m\'b5 b\'e4n t\'ad b\'b6n bu\'e9c ph\'b6i coi tr\'e4ng.

\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa200\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~}{\insrsid1378858 Nguy\'d4n \'b8i Qu
\'e8c
\par }\trowd \lastrow \ts11\trleft0\trftsWidth1 \clvertalt\clbrdrt\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3828\clshdrawnil \cellx3828\clvertalt\clbrdrt\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr
