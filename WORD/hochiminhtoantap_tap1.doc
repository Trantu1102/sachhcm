\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-294\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~Tin sau \'ae\'a9y ch\'f3ng t\'abi tr\'ddch \'eb t\'ea }{
\i\f37\fs20\insrsid1378858 Journal Officiel}{\f37\fs20\super\insrsid1378858 31}{\f37\fs20\insrsid1378858 , n\'e3i v\'d2 bu\'e6i h\'e4p th\'f8 nh\'cat ng\'b5y 22-12-1922:
\par "Trong th\'eai k\'fa chi\'d5n tranh, nhi\'d2u l\'ddnh Phi g\'f6i ng\'a9n phi\'d5u cho gia \'ae\'d7nh v\'edi nh\'f7ng s\'e8 ti\'d2n nhi\'d2u khi r\'cat l\'edn. }{\i\f37\fs20\insrsid1378858 Nh\'adng c\'b8c ng\'a9n phi\'d5u \'cay kh\'abng bao gi\'ea \'ae\'d5
n tay ng\'ad\'eai nh\'cbn c\'b6".
\par }{\f37\fs20\insrsid1378858 M\'e9t b\'b9n \'ae\'e5ng nghi\'d6p l\'b9i v\'f5a cho ch\'f3ng t\'abi bi\'d5t m\'e9t hi\'d6n t\'ad\'eeng t\'ad\'acng t\'f9 nh\'ad th\'d5. L\'c7n n\'b5y, s\'f9 vi\'d6c x\'b6y ra \'eb \'ae\'b6o R\'aauyni\'abng. \'a7\'b7 nhi\'d2u th
\'b8ng nay, nh\'a9n d\'a9n tr\'aan \'ae\'b6o kh\'abng h\'d2 nh\'cbn \'ae\'ad\'eec m\'e9t b\'adu ki\'d6n n\'b5o g\'f6i \'ae\'d5n cho h\'e4 c\'b6. T\'ea }{\i\f37\fs20\insrsid1378858 Journal}{\f37\fs20\insrsid1378858  vi\'d5t:
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-294\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 "Hi\'d6n t\'ad\'eeng \'cay l\'b5m cho c\'b6 ng\'ad\'eai g
\'f6i h\'b5ng l\'c9n ng\'ad\'eai kh\'abng nh\'cbn \'ae\'ad\'eec h\'b5ng \'ae\'d2u ph\'b6i l\'cay l\'b5m l\'b9.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-294\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 "Nhi\'d2u ng\'ad\'eai khi\'d5u n\'b9i. Cu\'e9c \'aei\'d2
u tra m\'edi m\'eb \'ae\'b7 r\'e4i ngay \'ae\'ad\'eec \'b8nh s\'b8ng v\'b5o \'aei\'d2u b\'dd m\'cbt n\'e3i tr\'aan, v\'b5 ph\'b8t hi\'d6n \'ae\'ad\'eec m\'e9t lo\'b9t v\'f4 \'ae\'b8nh c\'bep \'ae\'ad\'eec ti\'d5n h\'b5nh m\'e9t c\'b8ch chu \'ae\'b8o v\'b5
 ki\'aan tr\'d7 l\'b9 th\'ad\'eang.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-294\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 "Ng\'ad\'eai ta b\'bet m\'e9t nh\'a9n vi\'aan, r\'e5i m\'e9
t nh\'a9n vi\'aan n\'f7a, r\'e5i \'ae\'d5n l\'ad\'eet \'abng "x\'d5p", v\'b5 cu\'e8i c\'efng, khi t\'cat c\'b6 nh\'a9n vi\'aan b\'de c\'dfng tay th\'d7 \'ae\'d5n phi\'aan \'abng gi\'b8m \'ae\'e8c ng\'b5nh b\'adu \'aei\'d6n c\'f2ng theo h\'e4 v\'b5o t\'ef
 n\'e8t.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-294\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 "M\'e7i ng\'b5y, cu\'e9c \'aei\'d2u tra l\'b9i \'ae\'ad
a ra \'b8nh s\'b8ng v\'b5i s\'f9 vi\'d6c m\'edi. S\'e8 b\'adu ki\'d6n b\'de \'ae\'b8nh c\'bep tr\'de gi\'b8 tr\'aan 125.000 phr\'a8ng. Gi\'cay t\'ea, k\'d5 to\'b8n \'ae\'d2u l\'b5m gian c\'b6. S\'e6 s\'b8ch gian l\'cbn r\'e8i beng \'ae\'d5n n\'e7i ph\'b6
i m\'cat h\'acn 6 th\'b8ng m\'edi g\'ec ra \'ae\'ad\'eec.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 "}{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  trong m\'e9t ng\'b5nh n\'b5o \'ae\'e3, \'ae\'abi khi c\'e3
 th\'d3 c\'e3 m\'e9t v\'b5i vi\'aan ch\'f8c gian tham, song r\'cat \'ddt khi l\'b9i c\'e3 c\'b6 m\'e9t ng\'b5nh su\'e8t t\'f5 tr\'aan xu\'e8ng d\'ad\'edi nhi\'d4m ph\'b6i b\'d6nh \'a8n c\'bep \'ae\'d5n nh\'ad v\'cby; \'aei\'d2u l\'b9 k\'fa h\'acn n\'f7a l
\'b5 }{\i\f37\fs20\insrsid1378858 t\'b9i sao t\'cat c\'b6 b\'e4n \'a8n c\'bep \'cay l\'b9i c\'e3 th\'d3 ho\'b5nh h\'b5nh \'ae\'ad\'eec trong m\'cay n\'a8m r\'dfng m\'b5 v\'c9n \'ae\'ad\'eec b\'d7nh y\'aan v\'ab s\'f9}{\f37\fs20\insrsid1378858 ".
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 nguy\'d4n \'b8i qu\'e8c
