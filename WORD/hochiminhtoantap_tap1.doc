\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~"C\'b5ng h\'e4c c\'b5ng th\'cay m\'d7nh d\'e8t", \'ae
\'e3 l\'b5 c\'a9u ng\'b9n ng\'f7 ch\'a9u }{\f38\fs20\insrsid1378858 \'b8}{\f37\fs20\insrsid1378858 , c\'a9u ng\'b9n ng\'f7 \'ae\'e3 tr\'b8i v\'edi th\'abng th\'ad\'eang, kh\'abng ph\'b6i l\'b5 m\'e9t tr\'df T\'b5u, m\'b5 l\'b5 m\'e9t ch\'a9n l\'fd chung r
\'e9ng.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 V\'dd nh\'ad \'abng Gi\'abd\'d0p Cai\'ab, c\'f9u Th\'f1 t
\'ad\'edng, m\'e9t nh\'b5 l\'fd t\'b5i ngo\'b9i ng\'b9ch, m\'e9t nh\'b5 v\'a8n kh\'abng ph\'b6i t\'e5i, kh\'abng ph\'b6i t\'ad\'acng \'ae\'e8i t\'e5i nh\'ad Anhxtanh n\'e3i, sau khi \'ae\'b7 cai tr\'de 40 tri\'d6u d\'a9n Ph\'b8p, \'ae\'b7 r\'ecn v\'edi h
\'b5ng tri\'d6u, h\'b5ng t\'fb b\'b9c, \'ae\'b7 vi\'d5t s\'b8ch vi\'d5t v\'eb, r\'e5i m\'e9t bu\'e6i s\'b8ng n\'e4, b\'e7ng g\'b7i \'aei\'aan cu\'e5ng - kh\'abng ph\'b6i l\'b5 g\'b7i t\'e3c, v\'d7 \'abng ta kh\'abng c\'e3 t\'e3c - m\'b5 l\'b5 g\'b7i tai, 
\'ae\'e5ng th\'eai t\'f9 h\'e1i v\'b5 h\'e1i ng\'ad\'eai kh\'b8c: ch\'a9u \'a2u s\'cf \'aei t\'edi \'ae\'a9u \'ae\'a9y? N\'ad\'edc Ph\'b8p s\'cf \'aei t\'edi \'ae\'a9u \'ae\'a9y? C\'a9u h\'e1i tuy c\'e3 v\'ce qu\'b8 gi\'b6n \'ae\'acn, nh\'adng cho \'ae
\'d5n nay v\'c9n ch\'ada \'ae\'ad\'eec gi\'b6i \'ae\'b8p. V\'b5 c\'e3 th\'d3 c\'dfn ph\'b6i ch\'ea l\'a9u m\'edi gi\'b6i \'ae\'b8p \'ae\'ad\'eec, tr\'f5 phi...
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 N\'b5y, ng\'b5i Th\'f1 t\'ad\'edng, xin ng\'b5i cho t\'ab
i bi\'d5t ch\'a9n c\'f1a ch\'a9u \'a2u v\'b5 ch\'a9n c\'f1a n\'ad\'edc Ph\'b8p \'eb ch\'e7 n\'b5o, t\'abi s\'cf n\'e3i ng\'b5i hay ch\'a9u \'a2u v\'b5 n\'ad\'edc Ph\'b8p \'aei t\'edi \'ae\'a9u!
\par \'a7\'b8cuyn, nh\'b5 c\'f9c th\'abng th\'b8i \'a7\'b8cuyn, t\'f5ng bi\'d5t r\'bbng con ng\'ad\'aci c\'f1a \'d5ch x\'f8 \'a4v\'d0cnh\'ac}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0
\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) }{\i\insrsid1378858 Auvergne:}{\insrsid1378858  M\'e9t t\'d8nh mi\'d2n trung n\'ad\'edc Ph\'b8p.}})}{
\f37\fs20\insrsid1378858  tr\'dfn h\'acn con ng\'ad\'aci c\'f1a \'d5ch v\'efng N\'e8ttinhham, v\'b5 \'aeu\'abi b\'e5 c\'a9u M\'aahic\'ab c\'e3 nhi\'d2u h\'acn \'aeu\'abi b\'e5 c\'a9u \'eb Thu\'fe \'a7i\'d3n ba c\'b8i l\'abng t\'ac, nh\'adng \'abng l\'b9
i ho\'b5n to\'b5n kh\'abng bi\'d5t g\'d7 \'ae\'d5n m\'e9t lo\'b5i \'ae\'e9ng v\'cbt r\'cat \'ae\'abng \'ae\'f3c ng\'b5y nay \'ae\'ad\'eec bi\'d5t r\'cat r\'e2 r\'b5ng; c\'b8i lo\'b5i \'ae\'e9ng v\'cbt m\'b5 do s\'e8 l\'ad\'eeng, do ch\'cat l\'ad\'eeng c
\'f1a n\'e3, c\'e3 th\'d3 li\'d6t v\'b5o h\'b5ng \'ae\'c7u 
\par }\pard \qj \li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 trong gi\'edi \'ae\'e9ng v\'cbt. V\'d7 hi\'d6n t\'ad\'eeng n\'b5y c\'f2ng kh\'b8 th\'f3 v\'de, n\'aan ch\'f3ng t\'abi th\'f6
 tr\'d7nh b\'b5y c\'efng b\'b9n \'ae\'e4c b\'b8o}{\i\f37\fs20\insrsid1378858  Le Paria}{\f37\fs20\super\insrsid1378858 17}{\f37\fs20\insrsid1378858 .
\par }\pard \qj \fi397\li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 K\'d5t qu\'b6 c\'f1a nh\'f7ng cu\'e9c nghi\'aan c\'f8u k\'fc, c\'b5ng cho ph\'d0p ch\'f3ng t\'abi kh\'bcng \'ae\'denh r
\'bbng ngu\'e5n g\'e8c lo\'b5i \'ae\'e9ng v\'cbt n\'b5y c\'f2ng l\'a9u \'ae\'eai nh\'ad ngu\'e5n g\'e8c lo\'b5i ng\'ad\'eai, n\'d5u kh\'abng ph\'b6i l\'b5 l\'a9u \'ae\'eai h\'acn n\'f7a. C\'cau t\'b9o th\'d3 ch\'cat c\'f1a n\'e3 h\'d5t s\'f8c k\'fa l\'b9
: \'eb t\'cat c\'b6 c\'b8c lo\'b5i \'ae\'e9ng v\'cbt, s\'f9 sinh s\'b6n ra l\'abng l\'b8 th\'ad\'eang l\'b5 \'eb \'ae\'bbng \'aeu\'abi... \'eb lo\'b5i \'ae\'e9ng v\'cbt n\'b5y... l\'b9i \'eb tr\'aan \'ae\'c7u. Ch\'d8 \'eb tr\'aan \'ae\'c7u, ch\'f8 kh\'ab
ng \'eb c\'e6 nh\'ad b\'eam con ng\'f9a. L\'abng l\'b8 n\'b5y m\'den nh\'ad len v\'b5 hung hung, ho\'c6c c\'f8ng v\'b5 \'aeen, tu\'fa theo kh\'dd h\'cbu n\'aci n\'e3 s\'e8ng. Kh\'dd h\'cbu c\'e3 \'b6nh h\'ad\'ebng r\'cat nhi\'d2u \'ae\'d5n n\'ad\'edc da n
\'e3, m\'b5u da \'ae\'e3 \'aei t\'f5 v\'b5ng \'ae\'d5n \'aeen, ch\'f8 \'ddt khi tr\'beng. D\'ef c\'e3 nh\'f7ng s\'f9 k\'fa qu\'c6c \'ae\'e3, di\'d6n m\'b9o c\'f1a n\'e3 \'ae\'abi khi c\'f2ng kh\'b8 d\'d4 th\'ad\'acng. N\'e3 \'aei hai ch\'a9n. Nh\'ad
ng, theo t\'b5i li\'d6u quan s\'b8t \'ae\'ad\'eec t\'b9i nh\'f7ng v\'efng ch\'a9u }{\f38\fs20\insrsid1378858 \'b8}{\f37\fs20\insrsid1378858 , th\'d7 nhi\'d2u khi n\'e3 l\'b9i \'ae\'ad\'eec coi nh\'ad lo\'b5i b\'e8n ch\'a9n}{
\cs17\f37\fs20\super\insrsid1378858 *{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 * Lo\'b5
i quan l\'b9i trong t\'ad th\'d5 Xalamal\'d5ch}{\super\insrsid1378858 1) }{\insrsid1378858 (ch\'f3 th\'ddch c\'f1a t\'b8c gi\'b6).
\par }{\expnd0\expndtw-2\insrsid1378858 1) }{\i\expnd0\expndtw-2\insrsid1378858 Xalamal\'d5ch}{\expnd0\expndtw-2\insrsid1378858 : t\'f5 ti\'d5ng ch\'b5o Ar\'cbp c\'e3 ngh\'dca l\'b5 "ch\'f3c thanh b\'d7nh", ti\'d5ng Ph\'b8p \'ae\'c6t ra t\'f5 ng\'f7 n\'b5y 
\'ae\'d3 ch\'d8 l\'e8i ch\'b5o c\'c7u k\'fa, qu\'b8 m\'f8c l\'d4 ph\'d0p v\'b5 l\'c6p \'aei l\'c6p l\'b9i (cho n\'aan th\'ad\'eang d\'efng \'eb s\'e8 nhi\'d2u). T\'b8c gi\'b6 n\'e3i "lo\'b5i b\'e8n ch\'a9n" v\'edi ng\'f4 \'fd ph\'aa ph\'b8n l\'e8i ch\'b5
o }{\f38\expnd0\expndtw-2\insrsid1378858 \'b8 }{\expnd0\expndtw-2\insrsid1378858 \'a7\'abng x\'ada qu\'fa g\'e8i ch\'e8ng tay, r\'b9p m\'d7nh t\'cbn \'ae\'cat.}}}{\f37\fs20\insrsid1378858 . N\'e3i chung, c\'e3 th\'d3 li\'d6t n\'e3 v\'b5o lo\'b5i hai tay. 
\'a7i\'d2u l\'b5m cho lo\'b5i \'ae\'e9ng v\'cbt n\'b5y r\'cat \'ae\'abng \'ae\'f3c v\'b5 c\'e3 th\'d3 s\'e8ng \'eb m\'e9t \'ae\'dea b\'b5n r\'cat r\'e9ng tr\'aan tr\'b8i \'ae\'cat, ch\'ddnh l\'b5 \'eb ch\'e7 n\'e3 r\'cat d\'d4 d\'b5ng th\'ddch nghi v\'ed
i nhi\'d2u th\'f8 \'ae\'e5 \'a8n h\'d5t s\'f8c kh\'b8c nhau. N\'e3 \'a8n th\'det, \'a8n c\'e1, \'a8n g\'b9o v\'b5 \'a8n c\'b6 ng\'a9n s\'b8ch n\'f7a. C\'c7n ch\'f3 \'fd r\'bbng khi c\'e3 th\'d3 \'ae\'b7 ti\'d5n \'ae\'d5n tr\'d7nh \'ae\'e9 \'a8n ng\'a9n s
\'b8ch th\'d7 th\'ad\'eang b\'de coi l\'b5 tho\'b8i ho\'b8, v\'d7 n\'e3 \'ae\'b7 m\'cat h\'d5t \'ae\'c6c t\'ddnh tinh th\'c7n c\'f1a n\'dfi gi\'e8ng n\'e3 r\'e5i.
\par }{\f38\fs20\insrsid1378858 \'e3}{\f37\fs20\insrsid1378858 c b\'bet ch\'ad\'edc c\'f1a n\'e3 r\'cat ph\'b8t tri\'d3n v\'b5 \'e3c \'ae\'e3 kh\'abng ph\'b6i n\'abng c\'b9n nh\'ad \'eb lo\'b5i kh\'d8 hay lo\'b5i v\'d1t, v\'d7 ng\'ad\'eai ta nh\'cbn th\'cay r
\'bbng t\'b5i b\'bet ch\'ad\'edc c\'f1a n\'e3 th\'ad\'eang \'ae\'b9t t\'edi ch\'e7 tuy\'d6t kh\'d0o v\'b5 \'ae\'abi khi c\'dfn h\'acn c\'b6 c\'b8i m\'b5 n\'e3 b\'bet ch\'ad\'edc n\'f7a.
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 M\'e9t v\'b5i \'ae\'f8c t\'ddnh th\'f9c d\'f4ng c
\'f1a n\'e3 c\'dfn cao h\'acn c\'b6 nh\'f7ng \'ae\'f8c t\'ddnh th\'f9c d\'f4ng c\'f1a c\'b8c lo\'b5i gia s\'f3c c\'f1a ch\'f3ng ta n\'f7a kia. M\'e9t khi thu\'c7n d\'ad\'ecng r\'e5i, th\'d7 n\'e3 t\'f9 \'ae\'d3 cho ng\'ad\'eai ta h\'edt l\'abng nh\'ad
 con c\'f5u, ch\'cat \'ae\'e5 l\'aan l\'adng nh\'ad con l\'f5a, v\'b5 \'ae\'ada v\'b5o l\'df s\'b8t sinh nh\'ad con b\'aa. N\'e3 r\'cat d\'d4 th\'abi mi\'aan. N\'d5u b\'bet ra m\'e9t con, to nh\'cat hay m\'b9nh nh\'cat trong b\'c7y, v\'b5 \'aeeo v\'b5o c
\'e6 n\'e3 m\'e9t v\'cbt g\'d7 l\'e3ng l\'b8nh, m\'e9t \'ae\'e5ng v\'b5ng hay m\'e9t th\'cbp \'b8c ch\'bcng h\'b9n, th\'d7 n\'e3 li\'d2n tr\'eb th\'b5nh ho\'b5n to\'b5n ngoan ngo\'b7n, l\'f3c \'ae\'e3 c\'e3 th\'d3 sai n\'e3 l\'b5m b\'cat c\'f8 vi\'d6c g
\'d7, b\'b6o n\'e3 \'aei b\'cat c\'f8 \'ae\'a9u c\'f2ng \'ae\'ad\'eec, v\'b5 c\'b8c con kh\'b8c c\'f8 vi\'d6c theo n\'e3 m\'e9t c\'b8ch ngu \'ae\'c7n nh\'ad lo\'b5i th\'f3 v\'cbt - n\'d5u c\'e3 th\'d3 n\'e3i nh\'ad th\'d5 \'ae\'ad\'eec.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 C\'b8c nh\'b5 b\'b8c h\'e4c c\'f1
a B.I.Z.A (British Imperial Zoological Association)}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) H\'e9i \'ae\'e9ng v\'cbt h\'e4c \'ae\'d5 qu\'e8c Anh,
\par 2) Phi\'d5m ch\'d8 v\'efng \'a7\'dea Trung H\'b6i gi\'b8p B\'bec Phi (th\'eai c\'e6 \'ae\'b9i c\'e3 khi g\'e4i phi\'d5m ch\'d8 l\'b5 Libi).
\par 3) Ph\'e1ng theo c\'b8ch c\'f1a c\'b8c nh\'b5 sinh v\'cbt h\'e4c d\'efng ti\'d5ng latinh \'ae\'d3 \'ae\'c6t t\'aan khoa h\'e4c cho nh\'f7ng gi\'e8ng, lo\'b5i \'ae\'e9ng v\'cbt v\'b5 th\'f9c v\'cbt.}})}{\f37\fs20\insrsid1378858  v\'f5a cho bi\'d5t r\'bb
ng lo\'b5i th\'e1 tr\'ad\'edc b\'aan b\'ea }{\f38\fs20\insrsid1378858 \'ca}{\f37\fs20\insrsid1378858 n \'a7\'e9 D\'ad\'acng v\'b5 B\'ea bi\'d3n Libi}{\f37\fs20\super\insrsid1378858 2)}{\f37\fs20\insrsid1378858  v\'efng Bi\'d3n \'a7\'e1, b\'bet \'ae\'c7u t
\'e1 ra c\'e3 nh\'f7ng ti\'d5n ho\'b8 r\'e2 r\'d6t: n\'e3 kh\'abng ch\'deu \'ae\'d3 ng\'ad\'eai ta b\'bet m\'e9t c\'b8ch d\'d4 d\'b5ng n\'f7a v\'b5 tr\'e8n tr\'b8nh c\'b6nh l\'b5m gia s\'f3c. Hi\'d6n t\'ad\'eeng m\'edi \'ae\'e3 kh\'abng kh\'e1i g\'a9
y lo ng\'b9i cho c\'b8c gi\'edi c\'abng nghi\'d6p - khoa h\'e4c tr\'aan th\'d5 gi\'edi, v\'b5 \'ae\'c6c bi\'d6t l\'b5 cho nh\'f7ng gi\'edi \'ae\'e3 \'eb \'ae\'ab th\'de, v\'d7 tuy th\'det lo\'b5i v\'cbt n\'b5y kh\'abng \'a8n \'ae\'ad\'eec v\'d7 kh\'abng 
\'ad\'edp l\'b9nh \'ae\'ad\'eec, nh\'adng m\'b8u v\'b5 m\'e5 h\'abi c\'f1a n\'e3 l\'b9i \'ae\'b7 tr\'eb th\'b5nh nh\'f7ng th\'f8 kh\'abng th\'d3 thi\'d5u \'ae\'d3 l\'b5m b\'d0o nh\'f7ng c\'b8i m\'b8y l\'b5m d\'e5i th\'det.
\par \'a7\'d3 t\'e3m t\'bet b\'b6n tr\'d7nh b\'b5y ng\'ben n\'b5y, ch\'f3ng t\'abi xin n\'e3i r\'bbng t\'aan ch\'f1ng lo\'b9i c\'f1a c\'b8i gi\'e8ng v\'cbt d\'de k\'fa \'ae\'e3 l\'b5 D\'a9n b\'b6n x\'f8 thu\'e9c \'ae\'dea }{\i\f37\fs20\insrsid1378858 
(Colonial Indig\'d0na)}{\f37\fs20\super\insrsid1378858 3)}{\f37\fs20\insrsid1378858  nh\'adng tu\'fa theo t\'f5ng v\'efng m\'b5 n\'e3 c\'e3 t\'aan g\'e4i kh\'b8c nhau: ng\'ad\'eai An Nam, ng\'ad\'eai Mang\'b8t, ng\'ad\'eai Angi\'aari, ng\'ad\'eai }{
\f38\fs20\insrsid1378858 \'ca}{\f37\fs20\insrsid1378858 n \'a7\'e9, v.v..
