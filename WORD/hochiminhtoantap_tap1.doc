\par 
\par 
\par 
\par 
\par 
\par CH\'f3 TH\'ddCH
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~}{\f37\fs18\insrsid1378858 1. Ngay sau khi Nguy\'d4n }{
\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 i Qu\'e8c g\'f6i b\'b6}{\i\f37\fs18\insrsid1378858 n Y\'aau s\'b8ch c\'f1a nh\'a9n d\'a9n An Nam }{\f37\fs18\insrsid1378858 t\'edi tr\'ad\'ebng \'aeo\'b5n c\'b8c n\'ad\'edc d\'f9 H\'e9i ngh\'de V\'d0
cx\'a9y, b\'e4n b\'e5i b\'f3t th\'f9c d\'a9n l\'e5ng l\'e9n. Tr\'aan t\'ea }{\i\f37\fs18\insrsid1378858 Courrier Colonial}{\f37\fs18\insrsid1378858  ra ng\'b5y 27-6 c\'e3 m\'e9t b\'b5i nhan \'ae\'d2 }{\i\f37\fs18\insrsid1378858 Gi\'ea ph\'f3t nghi\'aam tr
\'e4ng}{\f37\fs18\insrsid1378858  ch\'d8 tr\'ddch b\'b6n y\'aau s\'b8ch : "L\'b5m sao m\'e9t ng\'ad\'eai d\'a9n thu\'e9c \'ae\'dea l\'b9i c\'e3 th\'d3 d\'efng b\'b6n y\'aau s\'b8ch c\'f1a nh\'a9n d\'a9n \'ae\'d3 c\'abng k\'ddch Ch\'ddnh ph\'f1 Ph\'b8p. Th
\'cbt l\'b5 qu\'b8 qu\'bet. C\'f8 theo \'ae\'b5 n\'b5y th\'d7 b\'e4n d\'a9n thu\'e9c \'ae\'dea s\'cf l\'aan ngang h\'b5ng v\'edi ng\'ad\'eai Ph\'b8p ch\'f3ng ta v\'b5 s\'edm tr\'eb th\'b5nh \'abng ch\'f1 c\'f1a ch\'f3ng ta. Kh\'abng \'ae\'ad\'eec, ph\'b6
i k\'d7m gi\'f7 ch\'f3ng m\'b7i m\'b7i trong v\'dfng n\'ab l\'d6". Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 i Qu\'e8c vi\'d5t b\'b5i n\'b5y l\'b5 \'ae\'d3 tr\'b6 l\'eai b\'b5i b\'b8o s\'c6c m\'efi th\'f9c d\'a9n tr\'aan. Tr. 1.

\par 2. B\'b6n }{\i\f37\fs18\insrsid1378858 Y\'aau s\'b8ch c\'f1a nh\'a9n d\'a9n An Nam}{\f37\fs18\insrsid1378858 : N\'a8m 1918, Chi\'d5n tranh th\'d5 gi\'edi th\'f8 nh\'cat k\'d5t th\'f3c. Ng\'b5y 18-1-1919, \'ae\'b9i bi\'d3u c\'b8c n\'ad\'edc \'ae\'d5 qu\'e8
c tham gia chi\'d5n tranh h\'e4p h\'e9i ngh\'de \'eb V\'d0cx\'a9y (Ph\'b8p). H\'e9i ngh\'de n\'b5y (c\'dfn g\'e4i l\'b5 H\'e9i ngh\'de ho\'b5 b\'d7nh Pari) nh\'bbm x\'b8c \'ae\'denh s\'f9 th\'cat b\'b9i c\'f1a \'a7\'f8c v\'b5 c\'b8c n\'ad\'edc \'ae\'e5
ng minh c\'f1a \'a7\'f8c, chia l\'b9i th\'de tr\'ad\'eang th\'d5 gi\'edi cho c\'b8c n\'ad\'edc \'ae\'d5 qu\'e8c th\'beng tr\'cbn, ch\'f1 y\'d5u l\'b5 M\'fc, Anh, Ph\'b8p.
\par Nh\'a9n danh nh\'e3m ng\'ad\'eai y\'aau n\'ad\'edc Vi\'d6t Nam, Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 i Qu\'e8c \'ae\'b7 g\'f6i \'ae\'d5n H\'e9i ngh\'de b\'b6n }{\i\f37\fs18\insrsid1378858 Y\'aau s\'b8ch c\'f1a nh\'a9n d\'a9
n An Nam}{\f37\fs18\insrsid1378858 . Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 i Qu\'e8c c\'dfn thu\'aa in th\'b5nh truy\'d2n \'ae\'acn, \'ae\'a8ng tr\'aan c\'b8c b\'b8o, g\'f6i \'ae\'d5n c\'b8c nh\'b5 ho\'b9t \'ae\'e9ng ch\'dd
nh tr\'de c\'e3 t\'aan tu\'e6i, ph\'a9n ph\'b8t trong c\'b8c bu\'e6i h\'e9i h\'e4p, m\'ddt tinh, g\'f6i cho Vi\'d6t ki\'d2u \'eb Ph\'b8p v\'b5 g\'f6i v\'d2 n\'ad\'edc. Tr.1.
\par 3. B\'b8o }{\i\f37\fs18\insrsid1378858 Le Courrier d'Hai Phong}{\f37\fs18\insrsid1378858 : B\'b8o xu\'cat b\'b6n h\'bbng ng\'b5y \'eb H\'b6i Ph\'dfng, n\'a8m 1887, do To\'b5 \'ae\'e8c l\'fd c\'f1a ch\'ddnh quy\'d2n thu\'e9c \'ae\'dea ph\'f4 tr\'b8
ch. Tr.4.
\par 4. B\'b8o }{\i\f37\fs18\insrsid1378858 L'Humanit\'d0}{\f37\fs18\insrsid1378858 : T\'ea b\'b8o h\'bbng ng\'b5y c\'f1a \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p do Gi\'a8ng Gi\'abr\'d0t s\'b8ng l\'cbp n\'a8m 1904. Sau \'a7\'b9i h\'e9i l\'c7n th\'f8 XVIII (\'a7\'b9i h
\'e9i Tua), \'a7\'b6ng C\'e9ng s\'b6n Ph\'b8p th\'b5nh l\'cbp, b\'b8o }{\i\f37\fs18\insrsid1378858 L'Humanit\'d0}{\f37\fs18\insrsid1378858  tr\'eb th\'b5nh c\'ac quan ng\'abn lu\'cbn ch\'ddnh th\'f8c c\'f1a \'a7\'b6ng C\'e9ng s\'b6n Ph\'b8p. Tr.6.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs18\insrsid1378858 5. }{\i\f37\fs18\insrsid1378858 H\'e9i ngh\'de H\'dfa b\'d7nh:}{\f37\fs18\insrsid1378858  Xem ch\'f3 th\'ddch s\'e8 1 v
\'d2 b\'b6n }{\i\f37\fs18\insrsid1378858 Y\'aau s\'b8ch c\'f1a nh\'a9n d\'a9n An Nam}{\f37\fs18\insrsid1378858 . Tr.6.
\par 6. }{\i\f37\fs18\insrsid1378858 Journal officiel de l'Indochine - Francaise}{\f37\fs18\insrsid1378858 : C\'abng b\'b8o do Ph\'f1 to\'b5n quy\'d2n \'a7\'abng D\'ad\'acng xu\'cat b\'b6n t\'f5 n\'a8m 1889 \'ae\'d5n n\'a8m 1950. Tr.17.
\par 7. B\'b8o }{\i\f37\fs18\insrsid1378858 Le Populaire}{\f37\fs18\insrsid1378858  : B\'b8o xu\'cat b\'b6n h\'bbng ng\'b5y \'eb Pari t\'f5 th\'b8ng 5-1916, l\'b5 c\'ac quan trung \'ad\'acng c\'f1a \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p. T\'f5 sau \'a7\'b9i h\'e9
i Tua (12-1920), }{\i\f37\fs18\insrsid1378858 Le Populaire}{\f37\fs18\insrsid1378858  ti\'d5p t\'f4c l\'b5 c\'ac quan trung \'ad\'acng c\'f1a \'a7\'b6ng X\'b7 h\'e9i (S.F.I.O.). B\'de gi\'b8n \'aeo\'b9n trong nh\'f7ng n\'a8m Ph\'b8p b\'de \'a7\'f8c chi
\'d5m \'ae\'e3ng. Th\'b8ng 8-1944, b\'b8o t\'f4c b\'b6n v\'b5 \'ae\'d7nh b\'b6n v\'b5o th\'b8ng 2-1970. Tr.17.
\par 8. V\'f4 m\'adu kh\'ebi ngh\'dca \'eb Hu\'d5 (3-5-1916) do hai s\'dc phu y\'aau n\'ad\'edc Th\'b8i Phi\'aan v\'b5 Tr\'c7n Cao V\'a9n l\'b7nh \'ae\'b9o d\'ad\'edi danh ngh\'dca c\'f1a vua Duy T\'a9n. Tuy n\'e6 ra \'eb Hu\'d5 nh\'adng kh\'ebi ngh\'dca c\'e3
 quan h\'d6 m\'cbt thi\'d5t v\'edi phong tr\'b5o Vi\'d6t Nam Quang ph\'f4c h\'e9i \'eb c\'b8c t\'d8nh Nam Trung K\'fa. L\'f9c l\'ad\'eeng kh\'ebi ngh\'dca l\'b5 binh l\'ddnh ng\'ad\'eai Vi\'d6t, ph\'c7n l\'edn s\'bep b\'de \'ae\'ada sang chi\'d5n tr\'ad
\'eang ch\'a9u \'a2u. K\'d5 ho\'b9ch b\'b9i l\'e9, nh\'f7ng ng\'ad\'eai l\'b7nh \'ae\'b9o b\'de hy sinh, vua Duy T\'a9n b\'de th\'f9c d\'a9n Ph\'b8p b\'bet v\'b5 \'ae\'b5y ra \'ae\'b6o R\'aauyni\'abng. Tr.18.
\par }\pard\plain \s28\qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 9. \'a7\'aam 30-8-1917, d\'ad\'edi s\'f9 l\'b7nh \'ae\'b9
o c\'f1a \'a7\'e9i C\'can (t\'f8c Tr\'denh V\'a8n C\'can) v\'b5 L\'ad\'acng Ng\'e4c Quy\'d5n, binh l\'ddnh ng\'ad\'eai Vi\'d6t trong qu\'a9n \'ae\'e9i Ph\'b8p \'eb Th\'b8i Nguy\'aan \'ae\'b7 n\'e6i d\'cby \'ae\'b8nh chi\'d5m t\'d8nh l\'fe. Sau 6 ng\'b5
y chi\'d5n \'ae\'cau v\'edi qu\'a9n Ph\'b8p \'ae\'ad\'eec t\'a8ng vi\'d6n t\'f5 H\'b5 N\'e9i v\'b5 nhi\'d2u n\'aci kh\'b8c l\'aan, L\'ad\'acng Ng\'e4c Quy\'d5n hy sinh, ngh\'dca qu\'a9n r\'f3t kh\'e1i t\'d8nh l\'fe, chuy\'d3n v\'d2 ho\'b9t \'ae\'e9ng \'eb
 v\'efng r\'f5ng n\'f3i c\'b8c t\'d8nh Th\'b8i Nguy\'aan, V\'dcnh Y\'aan, Ph\'f3c Y\'aan, Ho\'b5 B\'d7nh, S\'acn T\'a9y. Do b\'de truy n\'b7 r\'b8o ri\'d5t, cu\'e9c kh\'ebi ngh\'dca y\'d5u d\'c7n, ng\'b5y 11-1-1918, \'a7\'e9i C\'can t\'f9 s\'b8t \'ae\'d3
 gi\'f7 tr\'e4n kh\'dd ti\'d5t. Cu\'e9c kh\'ebi ngh\'dca b\'de th\'cat b\'b9i. Tr.18.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 10. }{\i\f37\fs18\insrsid1378858 \'a7\'b9i h\'e9i to\'b5
n qu\'e8c l\'c7n th\'f8 XVIII \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p:}{\f37\fs18\insrsid1378858  \'a7\'b9i h\'e9i h\'e4p t\'b9i th\'b5nh ph\'e8 Tua (Ph\'b8p) t\'f5 ng\'b5y 25 \'ae\'d5n ng\'b5y 30-12-1920, th\'b6o lu\'cbn v\'can \'ae\'d2 \'a7\'b6ng n\'aan gia nh
\'cbp Qu\'e8c t\'d5 th\'f8 ba hay \'eb l\'b9i Qu\'e8c t\'d5 th\'f8 hai. V\'edi \'aea s\'e8 phi\'d5u tuy\'d6t \'ae\'e8i (3.208 t\'b8n th\'b5nh; 1.022 phi\'d5u ch\'e8ng), \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p t\'b8n th\'b5nh gia nh\'cbp Qu\'e8c t\'d5 th\'f8 ba.

\par }\pard \qj \fi397\li0\ri0\sa80\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs18\insrsid1378858 Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 i Qu\'e8c tham gia \'a7\'b9i h\'e9i v\'edi t\'ad c
