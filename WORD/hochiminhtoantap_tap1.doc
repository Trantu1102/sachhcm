\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'d7NH C\'b6NH N\'a4NG D\'a2N AN NAM
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-288\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~Ng\'ad\'eai An Nam n\'e3i chung, ph\'b6i \'cc c\'e6 ra m
\'b5 ch\'deu nh\'f7ng c\'abng \'acn b\'b6o h\'e9 c\'f1a n\'ad\'edc Ph\'b8p. Ng\'ad\'eai n\'abng d\'a9n An Nam n\'e3i ri\'aang, l\'b9i c\'b5ng ph\'b6i \'cc c\'e6 ra m\'b5 ch\'deu s\'f9 b\'b6o h\'e9 \'cay m\'e9t c\'b8ch th\'b6m h\'b9i h\'acn: l\'b5 ng\'ad
\'eai An Nam, h\'e4 b\'de \'b8p b\'f8c; l\'b5 ng\'ad\'eai n\'abng d\'a9n, h\'e4 b\'de ng\'ad\'eai ta \'a8n c\'bep, c\'ad\'edp b\'e3c, t\'ad\'edc \'aeo\'b9t, l\'b5m ph\'b8 s\'b6n. Ch\'ddnh h\'e4 l\'b5 nh\'f7ng ng\'ad\'eai ph\'b6i l\'b5m m\'e4i c\'abng vi
\'d6c n\'c6ng nh\'e4c, m\'e4i th\'f8 lao d\'dech. Ch\'ddnh h\'e4 l\'b5m ra cho l\'f2 ng\'ad\'eai \'a8n b\'b8m, l\'f2 ng\'ad\'eai l\'ad\'eai bi\'d5ng, l\'f2 ng\'ad\'eai \'aei khai ho\'b8 v\'b5 nh\'f7ng b\'e4n kh\'b8c h\'ad\'ebng m\'b5 ch\'ddnh h\'e4 th\'d7
 l\'b9i ph\'b6i s\'e8ng c\'efng kh\'e6 trong khi nh\'f7ng t\'aan \'aeao ph\'f1 c\'f1a h\'e4 s\'e8ng r\'cat th\'f5a th\'b7i; h\'d4 m\'cat m\'efa th\'d7 h\'e4 ch\'d5t \'ae\'e3i. \'a7\'e3 l\'b5 v\'d7 h\'e4 b\'de \'a8n c\'bep kh\'bep m\'e4i ph\'dda, b\'bbng m
\'e4i c\'b8ch, do c\'b8c quan cai tr\'de, do b\'e4n phong ki\'d5n t\'a9n th\'eai v\'b5 Nh\'b5 th\'ea. X\'ada kia, d\'ad\'edi ch\'d5 \'ae\'e9 An Nam, ru\'e9ng \'ae\'cat chia th\'b5nh nhi\'d2u h\'b9ng tu\'fa theo t\'e8t x\'cau. Thu\'d5 \'ae\'b8nh theo s\'f9
 ph\'a9n h\'b9ng \'cay. D\'ad\'edi ch\'d5 \'ae\'e9 thu\'e9c \'ae\'dea hi\'d6n nay, t\'cat c\'b6 nh\'f7ng c\'b8i \'ae\'e3 \'ae\'d2u thay \'ae\'e6i. Khi c\'c7n ki\'d5m ti\'d2n c\'b8c quan cai tr\'de ng\'ad\'eai Ph\'b8p ch\'d8 vi\'d6c b\'bet thay \'ae\'e6i h
\'b9ng ru\'e9ng. Ch\'d8 m\'e9t n\'d0t b\'f3t th\'c7n k\'fa l\'b5 h\'e4 bi\'d5n m\'e9t \'ae\'b8m ru\'e9ng x\'cau th\'b5nh ru\'e9ng t\'e8t. Th\'d5 l\'b5 ng\'ad\'eai d\'a9n c\'b5y An Nam bu\'e9c ph\'b6i n\'e9p thu\'d5 cho \'ae\'b8m ru\'e9ng c\'f1a m\'d7
nh nhi\'d2u h\'acn s\'e8 h\'e4 thu ho\'b9ch \'ae\'ad\'eec.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-288\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Nh\'ad th\'d5 v\'c9n ch\'ada h\'d5t. Ng\'ad\'eai ta c\'df
n t\'a8ng di\'d6n t\'ddch ru\'e9ng \'ae\'cat m\'e9t c\'b8ch gi\'b6 t\'b9o b\'bbng c\'b8ch r\'f3t ng\'ben \'ae\'acn v\'de \'aeo \'ae\'b9c. B\'bbng c\'b8ch \'ae\'e3, thu\'d5 l\'cbp t\'f8c t\'a8ng l\'aan, n\'aci th\'d7 m\'e9t ph\'c7n ba, n\'aci th\'d7 hai ph
\'c7n ba. \'a7i\'d2u \'ae\'e3 ch\'ada \'ae\'f1 \'ae\'d3 tho\'b6 m\'b7n l\'dfng tham kh\'abng \'ae\'b8y c\'f1a Nh\'b5 n\'ad\'edc b\'b6o h\'e9 c\'f8 m\'e7i n\'a8m l\'b9i t\'a8ng m\'b7i thu\'d5 l\'aan. Th\'dd d\'f4, t\'f5 n\'a8m 1890 \'ae\'d5n n\'a8
m 1896, thu\'d5 \'ae\'b7 t\'a8ng g\'cap \'ae\'abi. T\'f5 n\'a8m 1896 \'ae\'d5n n\'a8m 1898 l\'b9i t\'a8ng l\'aan m\'e9t n\'f6a v\'b5 c\'f8 nh\'ad th\'d5 m\'b5 t\'a8ng l\'aan m\'b7i. Ng\'ad\'eai An Nam c\'f8 ch\'deu r\'e3c th\'det m\'b7i nh\'ad v\'cby v
\'b5 c\'b8c quan l\'edn b\'b6o h\'e9 nh\'b5 ta th\'d7 quen \'a8n b\'d0n m\'efi c\'f8 ti\'d5p t\'f4c gi\'eb tr\'df xoay x\'eb m\'b7i.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 C\'e3 khi, t\'d6 \'ae\'e9c \'aeo\'b8n \'aei \'ae\'abi v\'edi t\'d6 c\'ad\'edp \'aeo\'b9t. Th\'dd d\'f4 n\'a8m 1895, vi
\'aan c\'abng s\'f8 m\'e9t t\'d8nh \'eb B\'bec K\'fa \'ae\'b7 t\'ad\'edc m\'cat c\'f1a m\'e9t l\'b5ng n\'e4 h\'b5ng bao nhi\'aau h\'d0cta ru\'e9ng \'ae\'cat \'ae\'d3 \'aeem c\'cap cho m\'e9t l\'b5ng kh\'b8c, l\'b5 m\'e9t l\'b5ng theo \'ae\'b9o Kit\'ab. Nh
\'f7ng ng\'ad\'eai m\'cat ru\'e9ng khi\'d5u n\'b9i th\'d7 ng\'ad\'eai ta b\'bet b\'e1 t\'ef. C\'b8c b\'b9n \'ae\'f5ng t\'ad\'ebng ch\'d5 \'ae\'e9 cai tr\'de v\'ab li\'aam s\'d8 \'cay ch\'d8 c\'e3 nh\'ad th\'d5 th\'abi. Ng\'ad\'eai ta c\'dfn b\'bet nh\'f7
ng k\'ce x\'cau s\'e8 b\'de m\'cat ru\'e9ng ph\'b6i n\'e9p thu\'d5 cho m\'b7i \'ae\'d5n n\'a8m 1910, m\'c6c d\'ef ru\'e9ng \'ae\'cat c\'f1a h\'e4 \'ae\'b7 b\'de t\'ad\'edc \'aeo\'b9t t\'f5 n\'a8m 1895!
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 H\'d5t c\'b8c quan cai tr\'de \'a8n c\'bep, \'ae\'d5n b\'e4
n ch\'f1 \'ae\'e5n \'aei\'d2n \'a8n c\'bep. Ng\'ad\'eai ta c\'cap cho ng\'ad\'eai \'a2u nh\'f7ng \'ae\'e5n \'aei\'d2n nhi\'d2u khi v\'ad\'eet qu\'b8 20.000 h\'d0cta; m\'b5 nh\'f7ng ng\'ad\'eai \'a2u n\'b5y th\'d7 ngo\'b5i c\'b8i b\'f4ng ph\'d6 v\'b5 c\'b8
i m\'b5u da tr\'beng ra, kh\'abng c\'e3 m\'b6y may ki\'d5n th\'f8c g\'d7 v\'d2 n\'abng nghi\'d6p v\'b5 k\'fc thu\'cbt.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Nh\'f7ng \'ae\'e5n \'aei\'d2n \'cay ph\'c7n nhi\'d2u \'ae
\'ad\'eec l\'cbp ra b\'bbng l\'e8i \'a8n c\'bep h\'eep ph\'b8p ho\'b8. Trong th\'eai k\'fa x\'a9m l\'ad\'eec, ng\'ad\'eai d\'a9n c\'b5y An Nam, c\'f2ng nh\'ad ng\'ad\'eai And\'b8tx\'ac n\'a8m 1870, \'ae\'b7 b\'e1 ru\'e9ng \'ae\'cat c\'f1a m\'d7nh l\'b8
nh sang nh\'f7ng v\'efng c\'dfn t\'f9 do. Khi h\'e4 tr\'eb v\'d2 th\'d7 ru\'e9ng \'ae\'cat c\'f1a h\'e4 \'ae\'b7 "th\'b5nh \'ae\'e5n \'aei\'d2n" m\'cat r\'e5i. H\'b5ng bao nhi\'aau l\'b5ng \'ae\'b7 b\'de t\'ad\'edc \'aeo\'b9t \'aei nh\'ad th\'d5, v\'b5 ng
\'ad\'eai b\'b6n x\'f8 l\'a9m v\'b5o c\'b6nh ph\'b6i lao \'ae\'e9ng cho b\'e4n ch\'f3a phong ki\'d5n t\'a9n th\'eai, b\'e4n n\'b5y chi\'d5m \'aeo\'b9t c\'e3 khi \'ae\'d5n 90% thu ho\'b9ch.
\par L\'cay c\'ed khuy\'d5n kh\'ddch vi\'d6c khai kh\'c8n thu\'e9c \'ae\'dea, ng\'ad\'eai ta mi\'d4n thu\'d5 \'aei\'d2n th\'e6 cho r\'cat nhi\'d2u ch\'f1 \'ae\'e5n \'aei\'d2n l\'edn.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'a7\'b7 \'ae\'ad\'eec kh\'abng ru\'e9ng \'ae\'cat r\'e5
i, b\'e4n ch\'f1 \'ae\'e5n \'aei\'d2n l\'b9i c\'dfn \'ae\'ad\'eec kh\'abng, ho\'c6c g\'c7n nh\'ad \'ae\'ad\'eec kh\'abng c\'b6 nh\'a9n c\'abng n\'f7a. B\'e4n quan cai tr\'de cung c\'cap cho h\'e4 m\'e9t s\'e8 t\'ef kh\'e6 sai l\'b5m kh\'abng c\'ab
ng, hay d\'efng uy quy\'d2n c\'f1a ch\'f3ng \'ae\'d3 m\'e9 cho b\'e4n ch\'f1 \'ae\'e5n \'aei\'d2n nh\'f7ng nh\'a9n c\'abng l\'b5m vi\'d6c v\'edi m\'e9t \'ae\'e5ng l\'ad\'acng ch\'d5t \'ae\'e3i. N\'d5u nh\'f7ng ng\'ad\'eai An Nam \'ae\'d5n kh\'abng \'ae
\'f1 s\'e8 ho\'c6c h\'e4 kh\'abng b\'bbng l\'dfng th\'d7 ng\'ad\'eai ta li\'d2n d\'efng \'ae\'d5n v\'f2 l\'f9c; b\'e4n ch\'f1 \'ae\'e5n \'aei\'d2n li\'d2n b\'bet b\'e4n h\'ad\'acng l\'fd, n\'d6n v\'b5o c\'e6 h\'e4, h\'b5nh h\'b9
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 cho \'ae\'d5n khi nh\'f7ng k\'ce kh\'e8n kh\'e6 n\'b5y ch\'de
u k\'fd gi\'cay cam \'aeoan n\'e9p \'ae\'f1 s\'e8 nh\'a9n c\'abng c\'c7n thi\'d5t m\'edi th\'abi.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 B\'aan c\'b9nh c\'b8i th\'d5 l\'f9c ph\'c7n \'ae\'eai \'ca
y c\'dfn c\'e3 nh\'f7ng \'ae\'cang c\'f8u th\'d5 ph\'c7n h\'e5n n\'f7a, c\'b8c \'ae\'cang n\'b5y trong khi truy\'d2n b\'b8 \'ae\'f8c ngh\'cco cho ng\'ad\'eai An Nam, c\'f2ng kh\'abng qu\'aan t\'d7m c\'b8ch l\'b5m gi\'b5u b\'bbng m\'e5 h\'abi v\'b5 m\'b8
u c\'f1a ng\'ad\'eai b\'b6n x\'f8. }{\f38\fs20\insrsid1378858 \'eb }{\f37\fs20\insrsid1378858 Nam K\'fa, ch\'d8 ri\'aang H\'e9i Th\'b8nh truy\'d2n gi\'b8o c\'f2ng \'ae\'b7 chi\'d5m 1/5 ru\'e9ng \'ae\'cat trong v\'efng. M\'c6c d\'c7u trong kinh Th\'b8nh kh
\'abng c\'e3 d\'b9y, song th\'f1 \'aeo\'b9n chi\'d5m \'aeo\'b9t nh\'f7ng \'ae\'cat \'aeai n\'b5y c\'f2ng th\'cbt r\'cat gi\'b6n \'ae\'acn: \'ae\'e3 l\'b5 th\'f1 \'aeo\'b9n cho vay n\'c6ng l\'b7i v\'b5 h\'e8i l\'e9. H\'e9i Th\'b8nh l\'eei d\'f4ng l\'f3c m
\'cat m\'efa \'ae\'d3 cho n\'abng d\'a9n vay ti\'d2n v\'b5 bu\'e9c h\'e4 ph\'b6i c\'c7m c\'e8 ru\'e9ng \'ae\'cat. V\'d7 l\'eei su\'cat t\'ddnh theo l\'e8i c\'bet c\'e6, n\'aan ng\'ad\'eai An Nam kh\'abng th\'d3 tr\'b6 n\'ee \'ae\'f3ng h\'b9n; th\'d5 l\'b5
 t\'cat c\'b6 ru\'e9ng \'ae\'cat c\'c7m c\'e8 b\'de r\'aci v\'b5o tay H\'e9i truy\'d2n gi\'b8o.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'b8c quan cai tr\'de c\'b6 l\'edn l\'c9n b\'d0, \'ae\'ad
\'eec n\'ad\'edc m\'d1 giao v\'cbn m\'d6nh x\'f8 \'a7\'abng D\'ad\'acng cho, n\'e3i chung \'ae\'d2u l\'b5 nh\'f7ng b\'e4n ngu xu\'c8n v\'b5 \'ae\'d3u c\'b8ng. H\'e9i Th\'b8nh ch\'d8 c\'c7n n\'bem \'ae\'ad\'eec trong tay m\'e9t v\'b5i gi\'cay t\'ea b\'dd m
\'cbt, thu\'e9c \'ae\'eai ri\'aang, c\'e3 t\'ddnh ch\'cat nguy h\'b9i \'ae\'d5n thanh danh, \'ae\'dea v\'de c\'f1a c\'b8c quan, l\'b5 c\'e3 th\'d3 l\'b5m c\'b8c quan ho\'b6ng s\'ee v\'b5 ph\'b6i chi\'d2u theo \'fd h\'e4 mu\'e8n. Ch\'ddnh v\'d7 th\'d5 m
\'b5 m\'e9t vi\'aan to\'b5n quy\'d2n \'ae\'b7 nh\'ad\'eang cho Nh\'b5 chung 7.000 h\'d0cta ru\'e9ng \'ae\'cat sa b\'e5i c\'f1a nh\'f7ng ng\'ad\'eai b\'b6n x\'f8, \'cay th\'d5 l\'b5 nh\'f7ng ng\'ad\'eai b\'b6n x\'f8 n\'b5y tr\'eb th\'b5nh nh\'f7ng ng\'ad
\'eai \'aei \'a8n xin.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ph\'b8c qua nh\'ad th\'d5, ch\'f3ng ta th\'cay r\'bbng d
\'ad\'edi chi\'aau b\'b5i d\'a9n ch\'f1, \'ae\'d5 qu\'e8c Ph\'b8p \'ae\'b7 \'aeem v\'b5o An Nam t\'cat c\'b6 c\'b8i ch\'d5 \'ae\'e9 trung c\'e6 \'ae\'b8ng nguy\'d2n r\'f1a, k\'d3 c\'b6 ch\'d5 \'ae\'e9 thu\'d5 mu\'e8i; r\'bbng ng\'ad\'eai n\'abng d\'a9
n An Nam b\'de h\'b5nh h\'d7nh v\'f5a b\'bbng l\'ad\'eci l\'aa c\'f1a n\'d2n v\'a8n minh t\'ad b\'b6n ch\'f1 ngh\'dca, v\'f5a b\'bbng c\'a9y th\'b8nh gi\'b8 c\'f1a H\'e9i Th\'b8nh \'ae\'dc b\'eem.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~Nguy\'d4n \'b8i Qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 La Vie Ouvri\'ccre,}{\insrsid1378858 

\par ng\'b5y 4-1-1924.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'d7NH C\'b6NH N\'a4NG D\'a2N TRUNG QU\'e8C
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~Trung Qu\'e8c c\'a8n b\'b6n l\'b5 m\'e9t n\'ad\'edc n
\'abng nghi\'d6p, 85% s\'e8 d\'a9n l\'b5 n\'abng d\'a9n. C\'e3 th\'d3 chia h\'e4 ra l\'b5m b\'e8n h\'b9ng: \'ae\'dea ch\'f1 h\'b9ng l\'edn, \'ae\'dea ch\'f1 h\'b9ng v\'f5a, ng\'ad\'eai c\'e3 \'ddt ru\'e9ng \'ae\'cat, b\'c7n n\'abng v\'b5 c\'e8 n\'abng.

\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Trong n\'ad\'edc c\'e3 t\'f5 250 \'ae\'d5n 300 
\'ae\'b9i \'ae\'dea ch\'f1 h\'b9ng l\'edn c\'e3 h\'acn 10.000 m\'c9u}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) C\'b8c ch\'f7 }{\i\insrsid1378858 "m\'c9u" }{\insrsid1378858 trong nguy\'aan b\'b6n vi\'d5t b\'bbng ti\'d5ng Vi\'d6t.}})}{\f37\fs20\super\insrsid1378858  }{
\f37\fs20\insrsid1378858 ru\'e9ng \'ae\'cat. Ph\'c7n nhi\'d2u l\'b5 nh\'f7ng quan to hay qu\'fd t\'e9c. Ch\'f5ng \'ae\'e9 30.000 \'ae\'dea ch\'f1 c\'e3 h\'acn 1.000 m\'c9u v\'b5 300.000 c\'e3 h\'acn 100 m\'c9u.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \'a7\'dea v\'de x\'b7 h\'e9i c\'f1a nh\'f7ng ng\'ad\'ea
i ch\'f1 s\'eb h\'f7u nh\'e1 c\'e3 t\'f5 10 \'ae\'d5n 100 m\'c9u th\'d7 kh\'b8 ph\'f8c t\'b9p v\'b5 thay \'ae\'e6i lu\'abn. C\'f2ng c\'e3 ch\'f5ng \'cay ru\'e9ng \'ae\'cat, m\'e9t ng\'ad\'eai n\'abng d\'a9n c\'e3 th\'d3 l\'b5 k\'ce b\'e3c l\'e9t, l\'b5 ng
\'ad\'eai b\'de b\'e3c l\'e9t, ho\'c6c l\'b5 "trung gian".
\par N\'d5u gia \'ae\'d7nh c\'e3 kh\'b8 \'ae\'abng ng\'ad\'eai \'ae\'d3 c\'b5y c\'cay l\'cay ru\'e9ng \'ae\'cat, th\'d7 ng\'ad\'eai n\'abng d\'a9n \'ae\'e3 tr\'eb th\'b5nh l\'edp "trung gian".
\par N\'d5u gia \'ae\'d7nh neo ng\'ad\'eai, ng\'ad\'eai n\'abng d\'a9n \'ae\'b5nh bu\'e9c ph\'b6i cho thu\'aa r\'cf s\'e8 ru\'e9ng \'ae\'cat m\'b5 anh ta kh\'abng th\'d3 l\'b5m \'ae\'ad\'eec; th\'d5 l\'b5 anh tr\'eb th\'b5nh k\'ce b\'e3c l\'e9t.
\par N\'d5u gia \'ae\'d7nh qu\'b8 \'ae\'abng ng\'ad\'eai m\'b5 mu\'e8n \'ae\'f1 chi d\'efng, th\'d7 ngo\'b5i ru\'e9ng \'ae\'cat c\'f1a m\'d7nh ra, ng\'ad\'eai n\'abng d\'a9n c\'dfn b\'bet bu\'e9c ph\'b6i thu\'aa th\'aam ru\'e9ng \'ae\'cat c\'f1a ng\'ad\'eai kh
\'b8c; th\'d5 l\'b5 anh ta b\'de v\'ab s\'b6n ho\'b8 v\'b5 chuy\'d3n th\'b5nh ng\'ad\'eai b\'de b\'e3c l\'e9t.
\par }\pard \qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Theo t\'b5i li\'d6u c\'f1a B\'e9 Canh n\'abng, th\'d7 n\'a8m 1918 c\'e3 43.935.478 gia \'ae\'d7nh \'eb trong t\'d7nh tr\'b9
ng kh\'abng \'e6n \'ae\'denh \'ae\'e3.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 C\'e3 hai l\'e8i l\'cay t\'ab: t\'ab \'aeong v\'b5 t\'ab r\'cf. Theo l\'e8i th\'f8 nh\'cat, ng\'ad\'eai c\'e3 \'ddt ru
\'e9ng \'ae\'cat hay ng\'ad\'eai b\'c7n n\'abng l\'dcnh canh ru\'e9ng v\'b5 \'ae\'e3ng m\'e9t s\'e8 ti\'d2n t\'ab n\'b5o \'ae\'e3 trong m\'e9t th\'eai gian nh\'cat \'ae\'denh. N\'d5u \'ae\'ad\'eec m\'efa th\'d7 ng\'ad\'eai l\'dcnh canh c\'f2ng ch\'bcng 
\'ae\'ad\'eec d\'abi ra l\'b5 bao, v\'d7 ng\'ad\'eai ch\'f1 ru\'e9ng t\'ddnh r\'cat s\'b8t v\'b5 kh\'abng bao gi\'ea ch\'deu thi\'d6t c\'b6. Tr\'b8i l\'b9i, n\'d5u m\'cat m\'efa, th\'d7 ng\'ad\'eai l\'dcnh canh b\'de ho\'b5n to\'b5n ph\'b8 s\'b6n, c\'df
n ng\'ad\'eai ch\'f1 th\'d7 ch\'bcng m\'cat g\'d7 c\'b6.
\par V\'edi l\'e8i l\'cay t\'ab r\'cf, ng\'ad\'eai ch\'f1 ru\'e9ng thu t\'f5 35 \'ae\'d5n 50% hoa l\'eei c\'f1a m\'e7i v\'f4.
\par V\'d7 ch\'d5 \'ae\'e9 ru\'e9ng \'ae\'cat Trung Qu\'e8c l\'b5 ch\'d5 \'ae\'e9 ph\'a9n t\'b8n t\'f5ng m\'b6nh, cho n\'aan h\'c7u h\'d5t t\'cat c\'b6 m\'e4i ng\'ad\'eai n\'abng d\'a9n d\'ef ngh\'cco \'ae\'d5n \'ae\'a9u \'aei n\'f7a th\'d7 tr\'ad\'edc kia c
\'f2ng \'ae\'d2u c\'e3 \'ae\'ad\'eec m\'e9t m\'b6nh \'ae\'cat \'ae\'d3 c\'e3 th\'d3 }{\i\f37\fs20\insrsid1378858 "ki\'d5m l\'cay n\'d0n h\'ad\'acng c\'f3ng t\'e6 ti\'aan".}{\f37\fs20\insrsid1378858  Song, ng\'b5y nay, r\'cat nhi\'d2u ng\'ad\'eai tuy\'d6t 
\'ae\'e8i kh\'abng c\'e3 g\'d7, th\'cbm ch\'dd kh\'abng c\'e3 l\'cay }{\i\f37\fs20\insrsid1378858 "m\'e9t mi\'d5ng \'ae\'cat \'ae\'d3 c\'bem d\'efi"}{\f37\fs20\insrsid1378858  n\'f7a. H\'e4 ch\'d8 c\'e3 hai c\'b8nh tay kh\'abng th\'abi. Mu\'e8n ki\'d5m l
\'cay b\'b8t c\'acm, h\'e4 \'aei \'eb hay \'aei l\'b5m m\'efa. Nh\'f7ng ng\'ad\'eai \'aei l\'b5m m\'efa kh\'abng c\'e3 c\'abng x\'b8 nh\'cat \'ae\'denh, c\'f2ng kh\'abng c\'e3 vi\'d6c l\'b5m th\'ad\'eang xuy\'aan: h\'d5t v\'f4 g\'c6t, h\'e4 ra th\'b5nh th
\'de l\'b5m hay \'aei ch\'b5i l\'ad\'edi. Nh\'f7ng ng\'ad\'eai l\'edn \'aei \'eb th\'d7 h\'bbng n\'a8m ki\'d5m \'ae\'ad\'eec m\'e9t s\'e8 ti\'d2n t\'ddnh ra kho\'b6ng t\'f5 25 \'ae\'d5n 40 \'ae\'abla, c\'acm nu\'abi v\'b5 \'b8o m\'c6c; c\'b8c tr\'ce em 
\'aei \'eb ch\'a8n tr\'a9u b\'df th\'d7 \'ae\'ad\'eec t\'f5 3 \'ae\'d5n 5 \'ae\'abla m\'e9t n\'a8m.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 S\'f9 th\'a9m nh\'cbp c\'f1a ch\'f1 ngh\'dca t\'ad b\'b6n n
\'ad\'edc ngo\'b5i l\'b5m m\'cat th\'a8ng b\'bbng gi\'b8 c\'b6 gi\'f7a c\'b8c h\'b5ng ch\'d5 bi\'d5n v\'b5 n\'abng s\'b6n ph\'c8m. Ng\'ad\'eai n\'abng d\'a9n lu\'abn lu\'abn b\'bet bu\'e9c ph\'b6i b\'b8n r\'ce th\'e3c l\'f3a hay khoai c\'f1a h\'e4 \'ae
\'d3 mua nh\'f7ng d\'f4ng c\'f4 hi\'d6n nay \'ae\'bet h\'acn tr\'ad\'edc kia r\'cat nhi\'d2u. Ch\'f1 ngh\'dca t\'ad b\'b6n c\'f2ng l\'b5m cho ng\'ad\'eai ch\'f1 ru\'e9ng m\'cat c\'b8i \'ae\'c7u \'e3c t\'cbp truy\'d2n v\'b5 gia tr\'ad\'ebng v\'b5 \'ae
em thay b\'bbng t\'ddnh h\'b8m l\'eei r\'cat d\'f7 t\'een. C\'e8 noi theo g\'ad\'acng c\'b8c \'ae\'e5ng nghi\'d6p c\'f1a ch\'f3ng \'eb th\'b5nh th\'de, b\'e4n \'ae\'dea ch\'f1 t\'d7m c\'b8ch \'ae\'d3 ng\'b5y c\'b5ng n\'bem \'ae\'e9c quy\'d2n ru\'e9ng \'ae
\'cat. Nhi\'d2u c\'abng ty khai kh\'c8n \'ae\'b7 \'ae\'ad\'eec th\'b5nh l\'cbp, bao g\'e5m nh\'f7ng \'ae\'cat \'aeai v\'ab c\'efng r\'e9ng l\'edn, v\'b5 h\'cat m\'e9t s\'e8 l\'edn ti\'d3u n\'abng ra ngo\'b5i. Nh\'f7ng c\'abng ty nh\'ad }{
\i\insrsid1378858 C\'abng ty h\'f7u h\'b9n Phulilan}{\insrsid1378858  c\'e3 h\'acn 300.000 m\'c9u ru\'e9ng \'ae\'cat.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 L\'f4t l\'e9i, b\'b7o t\'b8p, n\'b9n \'ae\'e3i, n\'e9i chi
\'d5n \'ae\'d2u g\'a9y ra c\'b6nh c\'efng kh\'e6 cho n\'abng d\'a9n.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'e4n quan li\'aau tham nh\'f2ng c\'f1a ch\'d5 \'ae\'e9
 quan l\'b9i c\'f2ng ch\'deu ph\'c7n tr\'b8ch nhi\'d6m g\'a9y ra c\'b6nh \'ae\'e3i kh\'e6 \'cay. Ch\'ddnh ph\'f1 \'ae\'b7 l\'cbp nh\'f7ng tr\'b9m th\'dd nghi\'d6m \'ae\'d3 t\'d7m c\'b8ch c\'b6i ti\'d5n n\'abng nghi\'d6p. Nh\'f7ng c\'ac quan \'cay v\'f5
a th\'b5nh l\'cbp ra l\'b5 \'ae\'b7 tr\'eb ngay th\'b5nh nh\'f7ng mi\'d5ng ph\'e3 m\'b8t cho b\'e4n quan l\'b9i, ch\'f8 kh\'abng ph\'b6i l\'b5 nh\'f7ng c\'ac quan \'ae\'d3 ph\'f4c v\'f4 nh\'a9n d\'a9n.
\par M\'e9t tai ho\'b9 kh\'b8c n\'f7a l\'b5 ch\'f1 ngh\'dca qu\'a9n phi\'d6t. T\'cat c\'b6 b\'e4n t\'ad\'edng t\'b8 l\'edn nh\'e1, ki\'d3u Nap\'abl\'aa\'abng, \'ae\'d2u l\'b5m gi\'b5u cho b\'b6n th\'a9n h\'e4, l\'b5m gi\'b5u cho b\'cc \'ae\'b6ng v\'b5 cho b
\'e4n tay ch\'a9n c\'f1a h\'e4, b\'bbng m\'e5 h\'abi n\'ad\'edc m\'bet c\'f1a n\'abng d\'a9n l\'b5 nh\'f7ng ng\'ad\'eai h\'b5ng n\'a8m ph\'b6i \'ae\'e3ng v\'b5o kho\'b6ng 225.000.000 \'ae\'abla. S\'adu thu\'d5 \'ae\'cc l\'aan ng\'ad\'eai ti\'d3u n\'abng n
\'c6ng n\'d2 h\'acn b\'e4n gi\'b5u c\'e3, v\'d7 b\'e4n n\'b5y ph\'c7n nhi\'d2u l\'b5 vi\'aan ch\'f8c v\'b5 b\'b9n b\'cc c\'f1a b\'e4n vi\'aan 
\par ch\'f8c.
\par Sau h\'d5t, ph\'ad\'acng ph\'b8p l\'b5m vi\'d6c c\'e6 s\'ac v\'b5 n\'d2n gi\'b8o d\'f4c l\'b9c h\'cbu l\'b9i c\'dfn l\'b5m cho \'ae\'eai s\'e8ng c\'f1a qu\'c7n ch\'f3ng c\'c7n lao c\'b5ng th\'aam c\'f9c kh\'e6. N\'a8m 1918, h\'acn 15.500.000 n\'abng d\'a9
n v\'b5 th\'ee thuy\'d2n \'ae\'b7 b\'e1 n\'abng th\'abn ra th\'b5nh th\'de, l\'b5m cho s\'e8 ng\'ad\'eai b\'de b\'e3c l\'e9t v\'b5 \'ae\'b9o qu\'a9n th\'cat nghi\'d6p \'eb th\'b5nh th\'de t\'a8ng l\'aan.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Mu\'e8n xo\'b8 b\'e1 t\'cat c\'b6 nh\'f7ng \'aei\'d2u \'ae
\'e3, c\'b8c \'ae\'e5ng ch\'dd Trung Qu\'e8c c\'f1a ch\'f3ng ta ph\'b6i ti\'d5n h\'b5nh m\'b9nh m\'cf m\'e9t cu\'e9c v\'cbn \'ae\'e9ng kh\'c8n tr\'ad\'acng \'ae\'d3 gi\'b8o d\'f4c qu\'c7n ch\'f3ng, l\'b5m cho qu\'c7n ch\'f3ng th\'cay th\'cbt r\'e2 s\'f8
c m\'b9nh c\'f1a m\'d7nh, quy\'d2n l\'eei c\'f1a m\'d7nh, v\'b5 c\'e3 \'ae\'f1 kh\'b6 n\'a8ng th\'f9c hi\'d6n \'ae\'ad\'eec kh\'c8u hi\'d6u }{\i\f37\fs20\insrsid1378858 "T\'cat c\'b6 ru\'e9ng \'ae\'cat v\'d2 tay n\'abng d\'a9n".}{\f37\fs20\insrsid1378858 

\par }\pard\plain \s24\qr \fi397\li0\ri567\sb240\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nguy\'d4n \'b8i Qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 La Vie Ouvri\'ccre,}{\insrsid1378858 
\line ng\'b5y 4-1-1924.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 PHONG TR\'b5O C\'a4NG NH\'a2N \'eb VI\'d4N \'a7\'a4NG

\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd0\expndtw-2\insrsid1378858 \'a4xaca l\'b5 m\'e9t trong nh\'f7
ng trung t\'a9m c\'abng nghi\'d6p l\'edn c\'f1a n\'ad\'edc Nh\'cbt, kh\'abng b\'de thi\'d6t h\'b9i g\'d7 trong n\'b9n \'ae\'e9ng \'ae\'cat v\'f5a qua. Tai ho\'b9 c\'f1a nh\'f7ng ng\'ad\'eai Nh\'cbt kh\'b8c \'ae\'b7 t\'b9o n\'aan h\'b9nh ph\'f3c cho b\'e4
n ch\'f1 nh\'b5 m\'b8y \'eb th\'b5nh ph\'e8 n\'b5y, hi\'d6n nay ch\'f3ng \'aeang ph\'b8t t\'b5i ch\'ada t\'f5ng th\'cay. Th\'d5 m\'b5 ti\'d2n l\'ad\'acng c\'f1a c\'abng nh\'a9n v\'c9n gi\'f7 nguy\'aan nh\'ad m\'f8c tr\'ad\'edc khi x\'b6y ra tai ho\'b9 
\'ae\'e3, m\'c6c d\'ef gi\'b8 sinh ho\'b9t \'ae\'b7 t\'a8ng l\'aan kh\'abng k\'d0m ph\'c7n nhanh ch\'e3ng, \'b6nh h\'ad\'ebng n\'c6ng n\'d2 \'ae\'d5n t\'f3i ti\'d2n \'ddt \'e1i c\'f1a c\'abng nh\'a9n. B\'de l\'a9m v\'b5o t\'d7nh c\'b6nh kh\'abng th\'d3 ch
\'deu n\'e6i \'cay v\'b5 tr\'ad\'edc s\'f9 t\'f5 ch\'e8i c\'f1a b\'e4n ch\'f1 kh\'abng ch\'deu th\'f9c hi\'d6n nh\'f7ng y\'aau s\'b8ch c\'b6i thi\'d6n \'ae\'eai s\'e8ng, c\'abng nh\'a9n c\'b8c x\'ad\'ebng b\'abng v\'b6i \'ae\'b7 \'ae\'d7nh c\'abng t\'f5
 cu\'e8i th\'b8ng 11.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 C\'b8c y\'aau s\'b8ch n\'aau ra l\'b5:
\par 1. T\'a8ng l\'ad\'acng th\'aam 20%;
\par 2. Gi\'b6m gi\'b8 nh\'f7ng th\'f9c ph\'c8m do nh\'b5 m\'b8y cung c\'cap;
\par 3. C\'b6i thi\'d6n nh\'b5 \'a8n v\'b5 bu\'e5ng t\'bem;
\par 4. Tr\'b6 n\'f6a l\'ad\'acng cho c\'b8c c\'abng nh\'a9n v\'d7 \'e8m \'aeau kh\'abng \'aei l\'b5m \'ae\'ad\'eec;
\par 5. Thu nh\'cbn l\'b9i nh\'f7ng c\'abng nh\'a9n v\'f5a m\'edi b\'de \'aeu\'e6i.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Tr\'ad\'edc \'ae\'a9y \'ddt l\'a9u, c\'abng nh\'a9n c\'b8
c c\'abng ty "Gai Vi\'d4n \'a7\'abng" v\'b5 "Nag\'abxai" do \'ae\'d7nh c\'abng m\'b5 \'ae\'b7 \'ae\'ad\'eec t\'a8ng l\'ad\'acng. C\'abng nh\'a9n \'eb c\'abng ty "Xensu" c\'f2ng \'ae\'b7 \'ae\'ad\'eec t\'a8ng l\'ad\'acng ngay sau khi g\'f6i b\'b6n quy\'d5
t ngh\'de \'ae\'d7nh c\'abng cho ban gi\'b8m \'ae\'e8c. C\'b8c c\'abng ty kh\'b8c th\'d7 ch\'e8ng l\'b9i. H\'e4 l\'cay c\'ed r\'bbng, tuy c\'e3 r\'cat nhi\'d2u \'ae\'acn \'ae\'c6t h\'b5ng \'ae\'cay, nh\'adng h\'e4 c\'f2ng kh\'abng \'ae\'ad\'eec l\'eai l
\'b7i g\'d7 nhi\'d2u l\'bem, v\'d7 gi\'b8 nguy\'aan li\'d6u \'ae\'b7 t\'a8ng l\'aan; v\'b5 n\'e3i r\'bbng m\'c6t kh\'b8c, v\'d7 kh\'abng c\'e3 \'ae\'f1 b\'abng x\'ac n\'aan h\'e4 ch\'bcng ch\'f3t g\'d7 lo ng\'b9i \'ae\'d7nh c\'abng c\'b6.
\par }\pard\plain \qj \fi397\li0\ri0\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Th\'f9c ra, h\'e4 \'aeang s\'ee cu\'e8ng l\'aan. H\'e4 \'ae\'b7
 cho c\'b6nh s\'b8t \'ae\'dea ph\'ad\'acng, \'ae\'e5ng th\'eai g\'e4i c\'b6 c\'b6nh s\'b8t \'eb c\'b8c th\'b5nh ph\'e8 l\'a9n c\'cbn \'ae\'d5n \'ae\'e3ng ngay trong th\'b5nh ph\'e8. H\'e4 \'ae\'b7 cho b\'bet t\'e6ng th\'ad k\'fd Li\'aan \'aeo\'b5n lao 
\'ae\'e9ng v\'b5 m\'e9t s\'e8 l\'edn c\'b8n b\'e9 c\'efng nh\'f7ng ng\'ad\'eai \'aei bi\'d3u t\'d7nh \'ae\'d3 h\'dfng l\'b5m y\'d5u phong tr\'b5o. M\'adu toan c\'f1a b\'e4n ch\'f1 ch\'bcng \'ae\'b9t k\'d5t qu\'b6 g\'d7, v\'d7 cu\'e9c \'ae\'d7nh c\'abng v
\'c9n \'ae\'ad\'eec l\'b7nh \'ae\'b9o ki\'aan quy\'d5t nh\'ad h\'abm m\'edi \'ae\'c7u, v\'b5 c\'abng nh\'a9n th\'d7 quy\'d5t t\'a9m \'ae\'cau tranh \'ae\'d5n c\'efng.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Anh em th\'ee \'aei\'d6n v\'b5 th\'ee m\'b8y \'ae\'b7 tuy\'aan b\'e8 \'ae\'d7nh c\'abng h\'ad\'ebng \'f8ng. C\'abng nh
\'a9n c\'b8c c\'abng x\'ad\'ebng nh\'b5 n\'ad\'edc h\'f8a s\'cf d\'efng \'ae\'f1 m\'e4i c\'b8ch \'ae\'d3 \'f1ng h\'e9 c\'b8c \'ae\'e5ng ch\'dd c\'f1a h\'e4 \'aeang \'ae\'cau tranh. \'a7\'ad\'eec \'f1ng h\'e9 nh\'ad th\'d5, n\'aan nh\'f7ng ng\'ad\'eai \'ae
\'d7nh c\'abng \'ae\'d2u h\'d5t s\'f8c h\'a8ng h\'b8i v\'b5 tin ch\'bec s\'cf 
\par }\pard \qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 nh\'cat \'ae\'denh th\'beng l\'eei.
\par }\pard \qj \fi397\li0\ri0\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Trong cu\'e9c \'ae\'cau tranh gi\'f7a t\'ad b\'b6n v\'b5 lao \'ae\'e9ng \'eb Vi\'d4n \'a7\'abng, c\'e3 nh\'f7ng chuy\'d6n th
\'f3 v\'de m\'b5 \'eb ph\'ad\'acng T\'a9y ng\'ad\'eai ta s\'cf kh\'abng hi\'d3u \'ae\'ad\'eec, nh\'adng \'eb \'ae\'a9y l\'b9i l\'b5 nh\'f7ng chuy\'d6n ho\'b5n to\'b5n c\'e3 th\'f9c. Ch\'bcng h\'b9n nh\'ad, mu\'e8n ng\'a8n c\'b6n kh\'abng cho c\'abng nh
\'a9n li\'aan k\'d5t v\'edi c\'b8c \'ae\'e5ng ch\'dd c\'f1a h\'e4 \'aeang \'ae\'cau tranh, c\'abng ty Kisioa\'aea \'ae\'b7 cho kho\'b8 ch\'c6t c\'b8c c\'f6a ra v\'b5o. Nh\'b5 m\'b8y C\'acnaoa\'aea ch\'d5 t\'b9o c\'b8c m\'b8y \'aei\'d6n, kh\'abng th\'d3
 tho\'b6 thu\'cbn \'ae\'ad\'eec v\'edi c\'abng nh\'a9n vi\'aan c\'f1a h\'e4 v\'d2 v\'can \'ae\'d2 c\'abng s\'b8, n\'aan \'ae\'b7 quy\'d5t \'ae\'denh cho ngh\'d8 vi\'d6c. Nh\'adng tr\'ad\'edc khi th\'b6i c\'abng nh\'a9n, nh\'b5 m\'b8y \'ae\'e3 \'ae\'b7 tr
\'b6 h\'e4 \'ae\'f1 b\'e8n ng\'b5y c\'abng v\'b5 ti\'d2n ph\'f4 c\'cap trong hai tu\'c7n!
\par }\pard \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\i\f37\fs20\insrsid1378858 \'a7\'d7nh c\'abng ch\'e8ng ch\'d5 \'ae\'e9 qu\'a9n phi\'d6t .
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 \'a7\'d3 ph\'b8 v\'ec t\'e6 ch\'f8c c\'f1a c\'abng nh\'a9n v\'f5a m\'edi g\'a9y d\'f9ng l\'aan, b\'e4n ch\'f1 c\'b8c h
\'c7m m\'e1 \'eb }{\i\f37\fs20\insrsid1378858 Suicaosun}{\f37\fs20\insrsid1378858  (Trung Qu\'e8c), \'ae\'b7 cho \'aei\'d2u binh l\'ddnh c\'f1a t\'ad\'edng }{\i\f37\fs20\insrsid1378858 Chao}{\f37\fs20\insrsid1378858  \'ae\'d5n. B\'e4n n\'b5y v\'f5a t\'ed
i n\'aci l\'b5 chi\'d5m \'ae\'e3ng ngay c\'a9u l\'b9c b\'e9 c\'f1a c\'abng nh\'a9n. \'a7\'d3 ch\'e8ng l\'b9i h\'b5nh \'ae\'e9ng b\'b9o ng\'ad\'eec \'ae\'e3, ba ngh\'d7n th\'ee m\'e1 \'ae\'b7 t\'f9 \'ae\'e9ng \'ae\'d7nh c\'abng. H\'e4 bao v\'a9y b\'e4n l
\'ddnh v\'b5 t\'d7m c\'b8ch t\'ad\'edc v\'f2 kh\'dd c\'f1a ch\'f3ng. B\'e4n l\'ddnh n\'e6 s\'f3ng, l\'b5m b\'de th\'ad\'acng nhi\'d2u ng\'ad\'eai \'ae\'d7nh c\'abng. T\'d7nh h\'d7nh \'ae\'b7 di\'d4n ra qu\'b8 \'fd mu\'e8n c\'f1a b\'e4n ch\'f1 v\'b5
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 Ch\'f3ng hi\'d6n \'aeang ra c\'abng d\'b5n x\'d5p cho \'e6n.

\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Nh\'adng anh em th\'ee m\'e1 \'ae\'b7 tr\'b6 l\'eai r\'bb
ng h\'e4 ch\'d8 tr\'eb l\'b9i l\'b5m vi\'d6c khi n\'b5o nh\'f7ng ng\'ad\'eai b\'de n\'b9n \'ae\'b7 \'ae\'ad\'eec b\'e5i th\'ad\'eang v\'b5 c\'b8c y\'aau s\'b8ch c\'f1a h\'e4 - g\'e5m 9 \'aei\'d2u - \'ae\'b7 \'ae\'ad\'eec tho\'b6 m\'b7n.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~Nguy\'d4n \'b8i Qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 La Vie Ouvri\'ccre,}{\insrsid1378858 

\par ng\'b5y 25-1-1924.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \column 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 L\'a3NIN V\'b5 C\'b8C D\'a2N T\'e9C THU\'e9C \'a7\'deA

\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs16\insrsid1378858 \~}{\f37\fs20\insrsid1378858 "L\'aanin \'ae\'b7 m\'ca
t!". Tin n\'b5y \'ae\'d5n v\'edi m\'e4i ng\'ad\'eai nh\'ad s\'d0t \'ae\'b8nh ngang tai, truy\'d2n \'aei kh\'bep c\'b8c b\'d7nh nguy\'aan ph\'d7 nhi\'aau \'eb ch\'a9u Phi v\'b5 c\'b8c c\'b8nh \'ae\'e5ng xanh t\'ad\'aci \'eb ch\'a9u }{
\f38\fs20\insrsid1378858 \'b8}{\f37\fs20\insrsid1378858 . \'a7\'f3ng, nh\'f7ng ng\'ad\'eai da \'aeen v\'b5 da v\'b5ng c\'e3 th\'d3 ch\'ada bi\'d5t r\'e2 L\'aanin l\'b5 ai, n\'ad\'edc Nga \'eb \'ae\'a9u. B\'e4n \'ae\'d5 qu\'e8c th\'f9c d\'a9n c\'e8 \'fd b
\'adng b\'ddt kh\'abng cho h\'e4 bi\'d5t. S\'f9 ngu d\'e8t l\'b5 m\'e9t trong nh\'f7ng ch\'e7 d\'f9a ch\'f1 y\'d5u c\'f1a ch\'d5 \'ae\'e9 t\'ad b\'b6n ch\'f1 ngh\'dca. Nh\'adng t\'cat c\'b6 h\'e4, t\'f5 nh\'f7ng ng\'ad\'eai n\'abng d\'a9n An Nam \'ae\'d5
n ng\'ad\'eai d\'a9n s\'a8n b\'ben trong c\'b8c r\'f5ng \'a7ah\'abm\'a9y, c\'f2ng \'ae\'b7 th\'c7m nghe n\'e3i r\'bbng \'eb m\'e9t g\'e3c tr\'eai xa x\'a8m c\'e3 m\'e9t d\'a9n t\'e9c \'ae\'b7 \'ae\'b8nh \'aeu\'e6i \'ae\'ad\'eec b\'e4n ch\'f1 b\'e3c l\'e9
t h\'e4 v\'b5 hi\'d6n \'aeang t\'f9 qu\'b6n l\'fd l\'cay \'ae\'cat n\'ad\'edc m\'d7nh m\'b5 kh\'abng c\'c7n t\'edi b\'e4n ch\'f1 v\'b5 b\'e4n to\'b5n quy\'d2n. H\'e4 c\'f2ng \'ae\'b7 nghe n\'e3i r\'bbng n\'ad\'edc \'ae\'e3 g\'e4i l\'b5 n\'ad\'edc Nga, r
\'bbng c\'e3 nh\'f7ng ng\'ad\'eai d\'f2ng c\'b6m, }{\i\f37\fs20\insrsid1378858 m\'b5 ng\'ad\'eai d\'f2ng c\'b6m nh\'cat l\'b5 L\'aanin.}{\f37\fs20\insrsid1378858  Ch\'d8 nh\'ad th\'d5 c\'f2ng \'ae\'f1 l\'b5m cho h\'e4 ng\'ad\'ecng m\'e9 s\'a9u s\'bec v
\'b5 \'ae\'c7y nhi\'d6t t\'d7nh \'ae\'e8i v\'edi n\'ad\'edc \'ae\'e3 v\'b5 l\'b7nh t\'f4 c\'f1a n\'ad\'edc \'ae\'e3.
\par Nh\'adng kh\'abng ph\'b6i ch\'d8 c\'e3 th\'d5. H\'e4 c\'dfn \'ae\'ad\'eec bi\'d5t r\'bbng ng\'ad\'eai l\'b7nh t\'f4 v\'dc \'ae\'b9i n\'b5y sau khi gi\'b6i ph\'e3ng nh\'a9n d\'a9n m\'d7nh, c\'dfn mu\'e8n gi\'b6i ph\'e3ng c\'b8c d\'a9n t\'e9c kh\'b8c n\'f7
a. Ng\'ad\'eai \'ae\'b7 k\'aau g\'e4i c\'b8c d\'a9n t\'e9c da tr\'beng gi\'f3p \'ae\'ec c\'b8c d\'a9n t\'e9c da v\'b5ng v\'b5 da \'aeen tho\'b8t kh\'e1i \'b8ch \'b8p b\'f8c c\'f1a b\'e4n rumi}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain 
\s30\ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f42\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) Ti\'d5ng }{\f38\insrsid1378858 \'b6}{\insrsid1378858 r\'cbp, ngh\'dca l\'b5 ng\'ad\'eai n\'ad\'ed
c ngo\'b5i, k\'ce \'aei n\'ab d\'dech.}})}{\f37\fs20\insrsid1378858 , c\'f1a t\'cat c\'b6 b\'e4n }{\i\f37\fs20\insrsid1378858 rumi:}{\f37\fs20\insrsid1378858  to\'b5n quy\'d2n, c\'abng s\'f8, v.v.. V\'b5 \'ae\'d3 th\'f9c hi\'d6n m\'f4c \'ae\'ddch \'ca
y, Ng\'ad\'eai \'ae\'b7 v\'b9ch ra m\'e9t c\'ad\'acng l\'dcnh c\'f4 th\'d3.
\par L\'f3c \'ae\'c7u h\'e4 t\'ad\'ebng l\'b5 tr\'aan \'ae\'eai kh\'abng th\'d3 c\'e3 m\'e9t ng\'ad\'eai nh\'ad th\'d5 v\'b5 c\'ad\'acng l\'dcnh nh\'ad th\'d5 \'ae\'ad\'eec. Nh\'adng v\'d2 sau h\'e4 \'ae\'ad\'eec bi\'d5t tin, tuy l\'ea 
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 m\'ea, v\'d2 \'ae\'b6ng c\'e9ng s\'b6n, v\'d2 t\'e6 ch\'f8c g
\'e4i l\'b5 Qu\'e8c t\'d5 C\'e9ng s\'b6n \'aeang \'ae\'cau tranh v\'d7 nh\'f7ng ng\'ad\'eai b\'de b\'e3c l\'e9t, v\'d7 t\'cat c\'b6 nh\'f7ng ng\'ad\'eai b\'de b\'e3c l\'e9t, trong \'ae\'e3 c\'e3 c\'b6 h\'e4 n\'f7a, h\'e4 bi\'d5t r\'bbng ch\'ddnh L\'aa
nin l\'b5 ng\'ad\'eai l\'b7nh \'ae\'b9o t\'e6 ch\'f8c n\'b5y.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 V\'b5 ch\'d8 nh\'ad th\'d5 c\'f2ng \'ae\'f1 \'ae\'d3
 cho nh\'f7ng ng\'ad\'eai \'ae\'e3 tuy v\'a8n ho\'b8 k\'d0m c\'e1i nh\'adng l\'b5 nh\'f7ng ng\'ad\'eai c\'e3 thi\'d6n ch\'dd v\'b5 bi\'d5t \'acn, h\'d5t l\'dfng t\'abn k\'ddnh L\'aanin. H\'e4 coi L\'aanin l\'b5 ng\'ad\'eai gi\'b6i ph\'e3ng cho h\'e4. L
\'aanin \'ae\'b7 m\'cat r\'e5i th\'d7 ch\'f3ng ta bi\'d5t l\'b5m th\'d5 n\'b5o? Li\'d6u c\'e3 nh\'f7ng ng\'ad\'eai d\'f2ng c\'b6m v\'b5 r\'e9ng l\'ad\'eeng nh\'ad L\'aanin \'ae\'d3 kh\'abng qu\'b6n th\'eai gian v\'b5 s\'f8c l\'f9c ch\'a8m lo \'ae\'d5n s
\'f9 nghi\'d6p gi\'b6i ph\'e3ng c\'f1a ch\'f3ng ta kh\'abng? \'a7\'e3 l\'b5 nh\'f7ng \'aei\'d2u m\'b5 qu\'c7n ch\'f3ng nh\'a9n d\'a9n b\'de \'b8p b\'f8c \'eb c\'b8c thu\'e9c \'ae\'dea b\'a8n kho\'a8n t\'f9 h\'e1i.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'dfn ch\'f3ng t\'abi, nh\'f7ng ng\'ad\'eai c\'e9ng s\'b6
n, nh\'f7ng ng\'ad\'eai sinh ra \'eb c\'b8c thu\'e9c \'ae\'dea, ch\'f3ng t\'abi v\'ab c\'efng \'aeau \'ae\'edn tr\'ad\'edc s\'f9 t\'e6n th\'cat kh\'abng th\'d3 n\'b5o \'ae\'d2n b\'ef \'ae\'ad\'eec v\'b5 chia s\'ce n\'e7i bu\'e5n chung c\'f1a nh\'a9n d\'a9
n c\'b8c n\'ad\'edc v\'edi nh\'f7ng ng\'ad\'eai anh ng\'ad\'eai ch\'de c\'f1a ch\'f3ng t\'abi. Song ch\'f3ng t\'abi tin t\'ad\'ebng r\'bbng Qu\'e8c t\'d5 C\'e9ng s\'b6n v\'b5 c\'b8c ph\'a9n b\'e9 c\'f1a n\'e3, trong \'ae\'e3 c\'e3 c\'b8c chi b\'e9 \'eb c
\'b8c n\'ad\'edc thu\'e9c \'ae\'dea, s\'cf th\'f9c hi\'d6n \'ae\'ad\'eec nh\'f7ng b\'b5i h\'e4c v\'b5 nh\'f7ng l\'eai gi\'b8o hu\'can m\'b5 v\'de l\'b7nh t\'f4 \'ae\'b7 \'ae\'d3 l\'b9i cho ch\'f3ng ta. L\'b5m nh\'f7ng \'aei\'d2u m\'b5 Ng\'ad\'eai \'ae\'b7
 c\'a8n d\'c6n ch\'f3ng ta, \'ae\'e3 ch\'bcng ph\'b6i l\'b5 ph\'ad\'acng ph\'b8p t\'e8t nh\'cat \'ae\'d3 t\'e1 t\'d7nh y\'aau m\'d5n c\'f1a ch\'f3ng ta \'ae\'e8i v\'edi Ng\'ad\'eai hay sao?
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Khi c\'dfn s\'e8ng, Ng\'ad\'eai l\'b5 ng\'ad\'eai cha, th
\'c7y h\'e4c, \'ae\'e5ng ch\'dd v\'b5 c\'e8 v\'can c\'f1a ch\'f3ng ta. Ng\'b5y nay, Ng\'ad\'eai l\'b5 ng\'abi sao s\'b8ng ch\'d8 \'ae\'ad\'eang cho ch\'f3ng ta \'aei t\'edi cu\'e9c c\'b8ch m\'b9ng x\'b7 h\'e9i.
\par L\'aanin b\'cat di\'d6t s\'cf s\'e8ng m\'b7i trong s\'f9 nghi\'d6p c\'f1a ch\'f3ng ta.
\par }\pard\plain \s24\qc \li3686\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin3686\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 NGUY\'d4N \'b8I QU\'e8C\line }{
\i\f37\fs20\insrsid1378858 (\'a7\'abng D\'ad\'acng)}{\f37\fs20\insrsid1378858 
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 Prav\'aea,}{\insrsid1378858  ti\'d5
ng Nga,
\par ng\'b5y 27-1-1924.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\b\f37\fs20\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'a4NG ANBE XAR\'a4 V\'b5 B\'b6N TUY\'a3N NG\'a4N\line 
NH\'a2N QUY\'d2N
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-294\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ch\'ddnh v\'d7 quy\'d2n con ng\'ad\'eai m\'b5 h\'b5ng tri
\'d6u con ng\'ad\'eai \'ae\'b7 b\'de gi\'d5t h\'b9i trong th\'eai \'ae\'b9i chi\'d5n. C\'b8i quy\'d2n m\'b5 h\'e4 \'ae\'b7 hy sinh v\'d7 n\'e3, c\'efng v\'edi nh\'f7ng x\'b8c ch\'d5t th\'b6m th\'ad\'acng c\'f1a h\'e4, nay b\'de v\'efi s\'a9u v\'b5o l\'b7
ng qu\'aan.
\par H\'e5i \'ae\'e3, c\'b8c ch\'ddnh kh\'b8ch c\'dfn g\'b5o to h\'acn c\'b6 ti\'d5ng \'ae\'b9i b\'b8c cho kh\'bep b\'e8n ph\'ad\'acng g\'c7m tr\'eai nghe: quy\'d2n! quy\'d2n! quy\'d2n! Nh\'adng l\'cbp t\'f8c, sau khi cu\'e9c ch\'d0m gi\'d5t \'ae\'b7 ch\'cam d
\'f8t, l\'cbp t\'f8c sau khi tai ho\'b9 \'ae\'b7 
\par }\pard \qj \li0\ri0\sa80\sl-294\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 qua, th\'d7 kh\'abng c\'dfn ai nghe th\'cay n\'e3i \'ae\'d5n c\'b8i con v\'cbt \'cay n\'f7a. }{\f38\fs20\insrsid1378858 \'eb }
{\f37\fs20\insrsid1378858 V\'d0cx\'a9y, \'eb Gi\'acnev\'ac, \'eb Bul\'abnh\'ac c\'f2ng nh\'ad \'eb Oasinht\'acn quy\'d2n con ng\'ad\'eai \'ae\'b7 \'ae\'ad\'eec thay th\'d5 b\'bbng than \'aeen, than \'ae\'b8, d\'c7u ho\'b6, thu\'e9c \'ae\'dea.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-294\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 M\'e9t c\'b8i quy\'d2n kh\'b8c ra \'ae\'eai, d\'ad\'edi m\'e9t d\'b9ng kh\'b8c, c\'dfn x\'cau xa h\'acn, gh\'aa t\'ebm h
\'acn: quy\'d2n c\'f1a k\'ce m\'b9nh. B\'bbng c\'b8i quy\'d2n n\'b5y ng\'ad\'eai ta mu\'e8n hu\'fb di\'d6t n\'ad\'edc Nga c\'b8ch m\'b9ng. B\'bbng c\'b8i quy\'d2n n\'b5y ng\'ad\'eai ta mu\'e8n bi\'d5n n\'ad\'edc \'a7\'f8c th\'b5nh m\'e9t ngh\'dca \'ae\'de
a v\'b5 m\'e9t b\'b7i hoang. B\'bbng c\'b8i quy\'d2n n\'b5y ng\'ad\'eai ta t\'d7m c\'b8ch chia nhau Trung Qu\'e8c. V\'b5 c\'f2ng b\'bbng c\'b8i quy\'d2n n\'b5y ng\'ad\'eai ta d\'d7m th\'cbt s\'a9u nh\'f7ng d\'a9n c\'b8c thu\'e9c \'ae\'dea v\'b5o v\'dfng n
\'ab l\'d6, nh\'f7ng thu\'e9c \'ae\'dea, v\'d7 b\'b6o v\'d6 quy\'d2n con ng\'ad\'eai, \'ae\'b7 c\'e8ng hi\'d5n 978.000 con em m\'d7nh, trong s\'e8 \'ae\'e3 340.000 \'ae\'b7 b\'e1 m\'d7nh tr\'aan chi\'d5n \'ae\'dea, nh\'f7ng thu\'e9c \'ae\'dea m\'b5 ng\'ad
\'eai ta b\'dfn r\'f3t \'ae\'d5n t\'cbn x\'ad\'acng tu\'fb \'ae\'d3 "v\'b7n h\'e5i s\'f9 th\'denh v\'ad\'eeng c\'f1a m\'c9u qu\'e8c", nh\'f7ng thu\'e9c \'ae\'dea m\'b5 ng\'b5y nay ng\'ad\'eai ta c\'dfn l\'cay \'aei 300.000 con em tr\'ce trung
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-294\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 nh\'cat, tr\'f4 c\'e9t c\'ad\'eang tr\'b8ng nh\'cat, \'ae\'d3
 l\'b5m m\'e5i d\'f9 tr\'f7 cho \'ae\'b9i b\'b8c trong cu\'e9c chi\'d5n tranh r\'e5i s\'cf t\'edi v\'d7 quy\'d2n con ng\'ad\'eai.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 D\'ef r\'bbng s\'f9 th\'f9c \'aeau l\'dfng nh\'ad v\'cb
y, nh\'adng th\'d5 gi\'edi r\'e5i c\'f2ng quen \'aei v\'edi c\'b8i tri\'d5t l\'fd, c\'b8i t\'ddnh tr\'d7 \'ae\'e9n v\'e8n d\'dc, m\'e7i khi ng\'ad\'eai ta khu\'cay l\'aan c\'b8i t\'ad t\'ad\'ebng \'ae\'denh m\'d6nh c\'f1a n\'e3. \'a7\'b7 th\'d5, \'ab
ng Anbe Xar\'ab, B\'e9 tr\'ad\'ebng B\'e9 Thu\'e9c \'ae\'dea, l\'b7nh t\'f4 b\'b6o v\'d6 quy\'d2n ng\'ad\'eai b\'b6n x\'f8 \'eb thu\'e9c \'ae\'dea, l\'b9i c\'dfn, v\'edi c\'b8i gi\'e4ng l\'ad\'eci b\'cat kh\'b6 tri c\'f1a \'abng v\'f5a x\'edi l\'aan c\'b8
i t\'ddnh cu\'e5ng t\'ddn c\'f1a b\'e4n "m\'e4i" c\'f1a \'abng. Mu\'e8n cho b\'b5i di\'d4n v\'a8n c\'f1a \'abng \'eb Tr\'ad\'eang thu\'e9c \'ae\'dea \'ae\'ad\'eec n\'e6i l\'aan h\'acn n\'f7a sau khi \'ae\'b7 bi\'d3u di\'d4n v\'c9n nh\'f7ng m\'f3a may k
\'dech t\'ddnh c\'f1a \'abng, v\'c9n c\'b8i ng\'abn phong k\'aau v\'b5 r\'e7ng tu\'d5ch c\'f1a \'abng, v\'c9n nh\'f7ng s\'b8o ng\'f7 c\'f2 r\'ddch l\'c6p \'aei l\'c6p l\'b9i c\'f1a \'abng n\'e3 \'aei \'ae\'d5n ch\'e7 (...)}{
\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) B\'b8o }{
\i\insrsid1378858 Le Paria}{\insrsid1378858  b\'b6n g\'e8c, l\'adu \'eb Th\'ad vi\'d6n qu\'e8c gia Ph\'b8p, k\'fd hi\'d6u BN.Jo 35859, b\'de r\'b8ch m\'cat m\'e9t s\'e8 ch\'f7 \'eb 5 d\'dfng li\'d2n nhau. Ch\'f3ng t\'abi ch\'ada t\'d7m \'ae\'ad\'eec t\'ea
 l\'b5nh c\'e3 \'ae\'f1 ch\'f7 \'ae\'d3 b\'e6 sung.}})}{\f37\fs20\insrsid1378858  c\'f1a nh\'f7ng k\'ce b\'e3c l\'e9t v\'b5 \'b8p b\'f8c t\'ad\'acng lai \'eb c\'b8c thu\'e9c \'ae\'dea. B\'b6n Tuy\'aan ng\'abn nh\'a9n quy\'d2n, nh\'b5 \'b6o thu\'cbt tu t
\'f5 h\'e4c n\'b5y, h\'abm \'ae\'e3, ch\'bec l\'b5 \'ae\'b7 ho\'b5n to\'b5n lo\'b9n th\'c7n kinh.
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Tr\'ad\'edc \'abng v\'b5 c\'f2ng nh\'ad \'abng th
\'abi, ng\'ad\'eai ta \'ae\'b7 t\'f5ng che \'ae\'cby nh\'f7ng t\'e9i \'b8c, nh\'f7ng v\'f4 xo\'b8y, nh\'f7ng v\'f4 t\'b5n s\'b8t d\'ad\'edi c\'b8i \'b8o kho\'b8c khai ho\'b8 hay d\'ad\'edi danh ngh\'dca quy\'d2n con ng\'ad\'eai, nh\'adng ng\'ad\'eai ta c
\'dfn l\'b5m nh\'f7ng vi\'d6c \'ae\'e3 v\'edi m\'e9t s\'f9 d\'cc d\'c6t n\'b5o \'ae\'e3, v\'edi m\'e9t ch\'f3t li\'aam s\'d8 n\'b5o \'ae\'e3. \'a7\'bbng n\'b5y c\'b8i con ng\'ad\'eai c\'f1a r\'ad\'eeu v\'b5 thu\'e8c phi\'d6n \'cay, c\'b8i \'ab che cho nh
\'f7ng b\'a8ng c\'f1a Phu\'e8c v\'b5 c\'f1a B\'ab\'aeoanh \'cay, tr\'ac tr\'cfn tuy\'d6t v\'eai, l\'b9i \'ae\'b7 n\'e3i \'ae\'d5n b\'b6n v\'a8n thi\'aang li\'aang nh\'cat, cao qu\'fd nh\'cat c\'f1a \'a7\'b9i c\'b8ch m\'b9ng Ph\'b8p. Kh\'abng c\'dfn l\'b5
 m\'e9t s\'f9 gi\'b6 nh\'a9n gi\'b6 ngh\'dca n\'f7a. \'a7\'a9y l\'b5 m\'e9t t\'e9i \'ae\'b9i b\'cat k\'ddnh.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 .............................................}{
\cs17\f37\fs20\super\insrsid1378858 2{\footnote \pard\plain \s30\ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f42\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 2) D\'dfng ch\'cam n\'b5y l\'b5 c\'f1
a nguy\'aan b\'b6n b\'b8o }{\i\insrsid1378858 Le Paria.}})}{\f37\fs20\insrsid1378858  .
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ngh\'dc cho lung, c\'e3 khi t\'abi \'ae\'b7 m\'be
c sai l\'c7m kh\'abng nh\'cbn ra t\'cam l\'dfng cao c\'b6 v\'b5 tinh th\'c7n qu\'b6ng \'ae\'b9i c\'f1a ng\'b5i B\'e9 tr\'ad\'ebng c\'f1a ch\'f3ng ta. Bi\'d5t \'ae\'a9u \'ae\'cay, khi nh\'bec l\'b9i B\'b6n tuy\'aan ng\'abn \'ae\'b7 l\'b5m cho C\'e9ng ho
\'b5 Ph\'b8p b\'cat t\'f6, \'abng Anbe Xar\'ab l\'b9i ch\'b6 mu\'e8n d\'efng m\'e9t chi\'d5n thu\'cbt \'ae\'ad\'eang v\'dfng \'ae\'d3 nh\'bec nh\'eb d\'a9n ch\'f3ng c\'b8c thu\'e9c \'ae\'dea tr\'eb v\'d2 v\'edi nh\'f7ng ngh\'dca v\'f4 ch\'a9n ch\'ddnh c
\'f1a m\'d7nh? T\'f5 \'ae\'b9i l\'e9 Thi\'aan V\'a8n \'a7\'b5i kh\'abng ch\'f5ng ng\'b5i c\'e3 \'fd \'ae\'denh, qua l\'eai n\'e3i h\'efng m\'b9nh c\'f1a m\'d7nh, k\'aau g\'e4i nh\'f7ng d\'a9n t\'e9c thu\'e9c \'ae\'dea h\'b7y \'aei theo v\'d5t ch\'a9
n vinh quang c\'f1a t\'e6 ti\'aan ng\'b5i m\'b5 chi\'d5n \'ae\'cau, nh\'ad t\'e6 ti\'aan ng\'b5i \'ae\'b7 chi\'d5n \'ae\'cau cho c\'abng cu\'e9c gi\'b6i ph\'e3ng m\'d7nh v\'b5 cho quy\'d2n con ng\'ad\'eai c\'f1a m\'d7nh. Ng\'ad\'eai ta sinh ra v\'b5 m\'b7
i m\'b7i t\'f9 do v\'b5 b\'d7nh \'ae\'bcng v\'d2 quy\'d2n. C\'b8c quy\'d2n \'cay l\'b5: t\'f9 do, t\'ad h\'f7u, an ninh v\'b5 ch\'e8ng \'b8p b\'f8c.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'f9 do, ch\'e8ng \'b8p b\'f8c, \'ae\'e3 l\'b5 nh\'f7ng 
\'aei\'d2u m\'b5 ng\'b5i b\'e9 tr\'ad\'ebng mu\'e8n l\'b5m cho "nh\'f7ng ng\'ad\'eai anh em da m\'c7u c\'f1a ng\'b5i" hi\'d3u, nh\'f7ng ng\'ad\'eai anh em n\'b5y tuy \'aeang b\'de m\'e9t \'ae\'d5 qu\'e8c gh\'aa t\'ebm nh\'cat \'b8p b\'f8c m\'e9t c\'b8ch t
\'b5n t\'d6 nh\'cat, nh\'adng v\'c9n c\'dfn c\'f8 l\'dem \'aei trong m\'e9t gi\'cac m\'aa man tri\'d2n mi\'aan.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ch\'f3ng ta, nh\'f7ng ng\'ad\'eai con c\'f1a c\'b8c thu
\'e9c \'ae\'dea, ch\'f3ng ta s\'cf l\'b5 nh\'f7ng t\'aan th\'cbt h\'ccn nh\'b8t, n\'d5u ch\'f3ng ta kh\'abng nh\'cat t\'d2 \'ae\'b8p \'f8ng l\'eai k\'aau g\'e4i c\'f1a "\'abng anh c\'b6 c\'f1a ch\'f3ng ta": c\'e3 t\'abi \'ae\'a9y!
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~N.
