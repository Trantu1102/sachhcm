\par Tuy kh\'abng mu\'e8n qu\'b8 l\'b9m d\'f4ng l\'dfng ki\'aan nh\'c9n c\'f1a c\'b8c b\'b9n, t\'abi c\'f2ng kh\'abng th\'d3 b\'e1 qua vi\'d6c l\'b9c quy\'aan v\'b5 c\'abng th\'b6i n\'b5y m\'b5 kh\'abng n\'e3i s\'ac qua v\'d2 c\'b8ch th\'f8c Ch\'ddnh ph\'f1 Ph
\'b8p \'ae\'b7 d\'efng \'ae\'d3 b\'bet d\'a9n An Nam "kh\'b9c" ra ti\'d2n.
\par C\'f2ng nh\'ad \'ae\'d3 \'ae\'e9ng vi\'aan thanh ni\'aan An Nam \'aei l\'ddnh cho h\'e4, c\'b8c ng\'b5i Ph\'b8p d\'efng ch\'d5 \'ae\'e9 "t\'d7nh nguy\'d6n b\'bet bu\'e9c" \'ae\'d3 \'ae\'e9ng vi\'aan c\'b8c m\'e3n ti\'d2n d\'cc s\'cen nh\'e1 c\'f1a ng\'ad
\'eai d\'a9n b\'b6n x\'f8 n\'ddch v\'b5o t\'f3i m\'d7nh.
\par V\'d2 v\'can \'ae\'d2 l\'b9c quy\'aan, m\'e9t t\'ea b\'b8o Ph\'b8p \'eb \'a7\'abng D\'ad\'acng, t\'ea b\'b8o n\'b5y ch\'bcng y\'aau th\'ad\'acng g\'d7 d\'a9n b\'b6n x\'f8 \'ae\'a9u, \'ae\'b7 vi\'d5t nh\'ad th\'d5 n\'b5y: "D\'a9n ch\'f3ng \'ae\'b7 nhi\'d2
u l\'c7n b\'bet bu\'e9c ph\'b6i \'ae\'e3ng g\'e3p, ho\'c6c \'ae\'d3 c\'adu mang nh\'f7ng k\'ce b\'cat h\'b9nh, ho\'c6c \'ae\'d3 x\'a9y d\'f9ng nh\'f7ng c\'abng cu\'e9c \'ddch l\'eei chung, ho\'c6c \'ae\'d3 t\'e1 l\'dfng t\'abn k\'ddnh \'ae\'e8i v\'edi c
\'b8c b\'cbc v\'dc nh\'a9n.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 "V\'d2 vi\'d6c n\'b5y, th\'ad\'eang th\'ad\'eang ng\'ad\'eai ta m\'eb nh\'f7ng l\'b9c quy\'aan do ch\'dd
nh quy\'d2n b\'b5y tr\'df ra. }{\f38\fs20\cgrid0\insrsid1378858 \'eb}{\f37\fs20\cgrid0\insrsid1378858  c\'b8c t\'d8nh, tr\'df \'cay di\'d4n ra nh\'ad th\'d5 n\'b5y: Vi\'aan c\'abng s\'f8 cho quan An Nam bi\'d5t c\'e3 m\'e9t cu\'e9c l\'b9c quy\'aan v\'b5 }
{\i\f37\fs20\cgrid0\insrsid1378858 quy \'ae\'denh ph\'e1ng ch\'f5ng s\'e8 ti\'d2n m\'b5 \'abng ta mu\'e8n thu \'ae\'ad\'eec. }{\f37\fs20\cgrid0\insrsid1378858 S\'f9 \'ad\'edc l\'ad\'eeng c\'f1a \'abng ta \'ae\'b9i th\'d3 l\'b5 d\'f9a tr\'aan d\'a9n s\'e8
, s\'f9 gi\'b5u c\'e3 trong v\'efng v\'b5 l\'eei \'ddch c\'f1a c\'abng cu\'e9c l\'b9c quy\'aan. \'a7\'d5n l\'ad\'eet m\'d7nh, c\'b8c quan An Nam t\'d8nh h\'b9 l\'d6nh cho c\'b8c quan ph\'f1 huy\'d6n, ch\'d8 d\'c9n s\'ac qua v\'d2 m\'f4c ti\'aau c\'c7n ph
\'b6i \'ae\'b9t t\'edi. C\'b8c quan ph\'f1 huy\'d6n l\'b9i h\'b9 l\'d6nh cho c\'b8c vi\'aan ch\'b8nh t\'e6ng, l\'fd tr\'ad\'ebng }{\i\f37\fs20\cgrid0\insrsid1378858 ph\'b6i \'aeem n\'e9p cho h\'e4 \'ae\'f3ng k\'fa h\'b9n m\'e9t }{
\f37\fs20\cgrid0\insrsid1378858 s\'e8 }{\i\f37\fs20\cgrid0\insrsid1378858 ti\'d2n nh\'cat \'ae\'denh do c\'b8c quan Ph\'b8p}{\f37\fs20\cgrid0\insrsid1378858  }{\i\f37\fs20\cgrid0\insrsid1378858 \'ae\'dfi. }{\f37\fs20\cgrid0\insrsid1378858 S\'e8 ti\'d2
n do quan \'ae\'c7u t\'d8nh d\'f9 ki\'d5n th\'ad\'eang th\'ad\'eang \'ae\'ad\'eec n\'e9p \'ae\'d5n to\'b5 s\'f8 \'ae\'c7y \'ae\'f1, }{\i\f37\fs20\cgrid0\insrsid1378858 nh\'f7ng k\'ce \'ae\'e3ng thu\'d5 l\'b5 ng\'ad\'eai An Nam \'ae\'b7 ph\'b6i n\'e9p \'dd
t nh\'cat g\'cap ba s\'e8 ti\'d2n nh\'ad th\'d5 }{\f37\fs20\cgrid0\insrsid1378858 v\'d7 kh\'abng bi\'d5t do ph\'d0p ma qu\'fb bi\'d5n ho\'b8 th\'d5 n\'b5o, d\'a9n ch\'f3ng \'eb \'ae\'cat n\'ad\'edc hi\'d2n l\'b5nh n\'b5y ph\'b6i n\'e9p \'ddt ra ba b\'e8
n ng\'b5n \'ae\'e5ng \'ae\'d3 ch\'d8 c\'dfn \'ae\'ad\'eec m\'e9t ng\'b5n \'ae\'d5n n\'aci \'ae\'d5n ch\'e8n. Th\'ad\'eang th\'ad\'eang ng\'ad\'eai An Nam c\'f8 ph\'b6i c\'bem c\'e6 n\'e9p ti\'d2n m\'b5 ch\'bcng bi\'d5t v\'d7 sao ph\'b6i n\'e9p c\'b6, v
\'b6 l\'b9i h\'e4 c\'f2ng th\'f5a hi\'d3u r\'bbng k\'aau ca hay mu\'e8n kh\'b8ng c\'f9 l\'b9i th\'d7 s\'cf mang v\'b5o th\'a9n nh\'f7ng tai v\'b9 g\'d7".
\par }\pard \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 V\'d2 c\'abng th\'b6i, ng\'ad\'eai ta c\'f2ng h\'b5nh \'ae\'e9ng theo ki\'d3u \'ae\'e3 nh\'adng c\'b8ch l
\'b5m ng\'ad\'eec l\'b9i. Kh\'abng ng\'e5i tr\'aan m\'b5 h\'b9 l\'d6nh xu\'e8ng n\'f7a, ng\'b5i c\'abng s\'f8 \'aei h\'d5t l\'b5ng n\'b5y sang l\'b5ng kh\'b8c, cho g\'e4i h\'b5o l\'fd v\'b5 ch\'f1 gia \'ae\'d7nh \'ae\'d5n, di\'d4n thuy\'d5t h\'f8a h\'d1
n v\'c8n v\'ac, do\'b9 n\'b9t th\'cbt s\'f9 v\'b5 tr\'beng tr\'een, ph\'a9n ph\'b8t cho h\'e4 nh\'f7ng bi\'aan lai k\'fd s\'bdn v\'edi s\'e8 ti\'d2n \'ae\'b7 \'ae\'denh v\'b5 ghi tr\'ad\'edc r\'e5i. Sau \'ae\'e3, mu\'e8n tho\'b8t kh\'e1i Nh\'b5 n\'ad\'ed
c h\'b5nh h\'b9, d\'a9n b\'b6n x\'f8 ch\'d8 c\'dfn c\'e3 vi\'d6c m\'b5 xoay x\'eb l\'cay cho ra; v\'b5 ng\'b5i c\'abng s\'f8 ch\'d8 c\'e3 vi\'d6c ng\'e5i ch\'ea nh\'cbn ti\'d2n.
\par Nh\'b5 n\'ad\'edc c\'dfn t\'d7m c\'b8ch c\'ad\'edp \'aeo\'b9t t\'b5i t\'d7nh h\'acn nhi\'d2u n\'f7a. Ng\'ad\'eai ta s\'b8ng ch\'d5 ra "c\'b8i phi\'d5u l\'b9c quy\'aan chung" \'ae\'d3 cho ph\'d0p \'ae\'d5n c\'b6 d\'a9n ngh\'cco v\'c9n c\'e3 th\'d3 b\'b6o v
\'ee con nh\'den c\'acm \'aei \'ae\'d3 g\'e3p ph\'c7n nh\'e1 b\'d0 c\'f1a m\'d7nh v\'b5o c\'abng th\'b6i, t\'e1 l\'dfng quy\'d5n luy\'d5n thi\'d5t tha v\'edi n\'ad\'edc m\'d1. Th\'dd d\'f4: m\'e7i phi\'d5u quy \'ae\'denh tr\'ad\'edc l\'b5 l0 \'ae\'e5
ng. Nh\'adng nh\'f7ng ng\'ad\'eai culi v\'b5 l\'b5m thu\'aa c\'abng nh\'cbt l\'b5m sao \'ae\'f1 s\'f8c n\'e9p \'ae\'ad\'eec m\'e9t s\'e8 ti\'d2n to nh\'ad v\'cby? Ng\'ad\'eai ta g\'e4i h\'e4 \'ae\'d5n t\'f5ng t\'e8p 5, l0 ng\'ad\'eai m\'e9t, \'can cho c
\'b6 b\'e4n m\'e9t c\'b8i bi\'aan lai chung, b\'b6o h\'e4 c\'efng k\'fd v\'b5o \'ae\'e3. Th\'d5 r\'e5i nh\'f7ng k\'ce b\'c7n c\'efng c\'f8 thu x\'d5p v\'edi nhau m\'b5 n\'e9p cho \'ae\'f1 s\'e8. N\'d5u c\'e3 k\'ce tr\'e8n tr\'b8nh m\'b5 ch\'d8 thu \'ae
\'ad\'eec c\'e3 8, 9 \'ae\'e5ng th\'abi, th\'d7 t\'cat c\'b6 nh\'f7ng k\'ce kh\'b8c ph\'b6i li\'aan \'ae\'edi ch\'deu tr\'b8ch nhi\'d6m. V\'d7 ch\'bcng ai l\'b9i mu\'e8n \'aei t\'ef thay cho k\'ce kh\'b8c, n\'aan h\'e4 ph\'b6i l\'b5m m\'cbt th\'b8m t\'e8
 c\'b8o l\'c9n nhau \'ae\'d3 v\'f5a l\'dfng Nh\'b5 n\'ad\'edc.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 V\'d7 m\'adu th\'c7n ch\'ad\'edc qu\'fb \'cay m\'b5 n\'a8m 1922, ng\'ad\'eai ta b\'e1 v\'b5o k\'d0t \'ae
\'ad\'eec nh\'f7ng 10.289.000 \'ae\'e5ng b\'b9c, tuy c\'abng th\'b6i tr\'ad\'edc kia \'ae\'denh m\'f8c c\'e3 6.180.000 \'ae\'e5ng.
\par Ch\'bcng c\'c7n ph\'b6i n\'e3i, d\'a9n An Nam kh\'abng bao gi\'ea \'ae\'ad\'eec th\'cay l\'b9i \'ae\'e5ng b\'b9c c\'f1a m\'d7nh tr\'beng \'aeen ra sao c\'b6.
\par 
\par 
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par 
