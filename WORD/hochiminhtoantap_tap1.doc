\par 
\par TR\'b6 L\'eaI PH\'e1NG V\'caN C\'f1A PH\'e3NG VI\'a3N\line B\'b8O }{\b0\i\cgrid0\insrsid1378858 YI CH\'a3 PAO}{\cgrid0\insrsid1378858 
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 Cu\'e9c trao \'ae\'e6i gi\'f7a N.A.Q, Phan V\'a8
n Tr\'ad\'eang, 1 \'ae\'b9i bi\'d3u Tri\'d2u Ti\'aan l\'b5 Kim Tchong Wen v\'b5 1 ph\'e3ng vi\'aan M\'fc t\'b9i nh\'b5 ph\'e3ng vi\'aan: 
\par PV: \'a4ng \'ae\'d5n Ph\'b8p v\'edi m\'f4c \'ae\'ddch g\'d7?
\par }{\i\f37\fs20\cgrid0\insrsid1378858 \'a7\'b8p: }{\f37\fs20\cgrid0\insrsid1378858 \'a7\'d3 \'ae\'dfi nh\'f7ng quy\'d2n t\'f9 do m\'b5 ch\'f3ng t\'abi ph\'b6i \'ae\'ad\'eec h\'ad\'ebng.
\par PV: Ch\'ad\'acng tr\'d7nh c\'f1a \'abng l\'b5 g\'d7?
\par }{\i\f37\fs20\cgrid0\insrsid1378858 \'a7\'b8p}{\f37\fs20\cgrid0\insrsid1378858 : Lu\'abn lu\'abn ti\'d5n l\'aan ph\'dda tr\'ad\'edc, tu\'fa theo s\'f8c m\'b9nh c\'f1a ch\'f3ng t\'abi.
\par H\'e1i v\'d2 nh\'f7ng c\'abng vi\'d6c c\'f1a \'ae\'b6ng \'eb \'a7\'abng D\'ad\'acng v\'b5 nh\'f7ng cu\'e9c kh\'ebi ngh\'dca n\'e6 ra t\'f5 \'ae\'c7u chi\'d5n tranh, Nguy\'d4n }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 i Qu\'e8
c \'ae\'b8p:
\par "M\'f4c \'ae\'ddch c\'f1a ch\'ddnh quy\'d2n Ph\'b8p ho\'b5n to\'b5n kh\'b8c v\'edi m\'f4c \'ae\'ddch c\'f1a ng\'ad\'eai Nh\'cbt \'eb Tri\'d2u Ti\'aan. Ng\'ad\'eai Nh\'cbt mu\'e8n Nh\'cbt B\'b6n ho\'b8 ho\'b5n to\'b5n ng\'ad\'eai Tri\'d2u Ti\'aan. C\'dfn n
\'ad\'edc Ph\'b8p, th\'d7 ng\'ad\'eec l\'b9i, mu\'e8n duy tr\'d7 v\'dcnh vi\'d4n s\'f9 b\'cat b\'d7nh \'ae\'bcng gi\'f7a ng\'ad\'eai An Nam v\'b5 ng\'ad\'eai Ph\'b8p, n\'e3 mu\'e8n, b\'bbng c\'b8ch l\'eei d\'f4ng lao \'ae\'e9ng c\'f1a ng\'ad\'ea
i An Nam, b\'dfn r\'f3t v\'ab t\'cbn c\'b8c s\'b6n ph\'c8m \'ae\'f1 lo\'b9i m\'b5 \'a7\'abng D\'ad\'acng r\'cat s\'bdn v\'b5 c\'e8 g\'beng kh\'abng cho ng\'ad\'eai An Nam t\'f9 t\'b9o cho m\'d7nh m\'e9t v\'de tr\'dd kinh t\'d5 \'ae\'e9c l\'cbp. C\'b8c th
\'f8 thu\'d5 \'ae\'f1 lo\'b9i c\'f2ng nh\'ad nh\'f7ng bi\'d6n ph\'b8p h\'b9n ch\'d5 v\'b5 ch\'d5 \'ae\'e9 gi\'b8o d\'f4c c\'abng c\'e9ng \'ae\'d2u xu\'cat ph\'b8t t\'f5 nh\'f7ng toan t\'ddnh \'ae\'e3. B\'bbng c\'b8ch c\'b6n tr\'eb v\'a8n minh v\'b5 ti\'d5
n b\'e9 c\'f1a d\'a9n t\'e9c An Nam, ng\'ad\'eai Ph\'b8p v\'dcnh vi\'d4n \'ae\'c6t d\'a9n t\'e9c n\'b5y ra ngo\'b5i l\'d2 c\'f1a n\'d2n v\'a8n minh th\'d5 gi\'edi v\'b5 bu\'e9c h\'e4 ph\'b6i \'ae\'b8p \'f8ng v\'ab c\'efng t\'cbn nh\'f7ng \'ae\'dfi h\'e1
i kh\'abng ng\'f5ng thay \'ae\'e6i c\'f1a ch\'f3ng. Trong nh\'f7ng n\'a8m g\'c7n \'ae\'a9y, \'aei\'d2u ki\'d6n s\'e8ng \'eb \'a7\'abng D\'ad\'acng tr\'eb n\'aan th\'b6m h\'b9i ch\'ada t\'f5ng th\'cay".
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 H\'e1i v\'d2 nh\'f7ng ho\'b9t \'ae\'e9ng t\'f5 khi \'ae\'d5n Ph\'b8p, Nguy\'d4n }{
\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 i Qu\'e8c tr\'b6 l\'eai:
\par "Ngo\'b5i vi\'d6c v\'cbn \'ae\'e9ng c\'b8c th\'b5nh vi\'aan Ngh\'de vi\'d6n, t\'abi \'ae\'b7 t\'d7m c\'b8ch nhen nh\'e3m thi\'d6n c\'b6m m\'e7i n\'aci m\'e9t ch\'f3t, trong \'ae\'e3 \'a7\'b6ng X\'b7 h\'e9i \'ae\'b7 t\'e1 ra \'ddt tho\'b6 m\'b7n v\'edi c
\'b8c bi\'d6n ph\'b8p c\'f1a ch\'ddnh ph\'f1 v\'b5 \'ae\'b7 s\'bdn l\'dfng \'f1ng h\'e9 ch\'f3ng t\'abi. }{\f38\fs20\cgrid0\insrsid1378858 \'eb}{\f37\fs20\cgrid0\insrsid1378858  Ph\'b8p, \'ae\'e3 l\'b5 hy v\'e4ng duy nh\'cat c\'f1a ch\'f3ng t\'abi. }{
\i\f37\fs20\cgrid0\insrsid1378858 V\'d2}{\f37\fs20\cgrid0\insrsid1378858  }{\i\f37\fs20\cgrid0\insrsid1378858 ho\'b9t \'ae\'e9ng c\'f1a ch\'f3ng t\'abi \'eb c\'b8c n\'ad\'edc kh\'b8c, ch\'ddnh \'eb n\'ad\'edc \'abng (M\'fc) ch\'f3ng t\'abi c\'e3 nhi\'d2
u th\'b5nh c\'abng h\'acn. }{\f37\fs20\cgrid0\insrsid1378858 C\'dfn \'eb ch\'e7 kh\'b8c, \'eb \'ae\'a9u ch\'f3ng t\'abi c\'f2ng ch\'d8 g\'c6p kh\'e3 kh\'a8n".
\par Nguy\'d4n }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 i Qu\'e8c ti\'d5p t\'f4c tr\'d7nh b\'b5y th\'cbt c\'b6m \'ae\'e9ng v\'d2 t\'d7nh h\'d7nh kinh t\'d5, t\'d7nh tr\'b9ng gi\'b8o d\'f4c, \'ae\'eai s\'e8ng kh\'e6 s\'eb c\'f1
a ng\'ad\'eai An Nam \'eb \'a7\'abng D\'ad\'acng. \'a4ng Phan c\'f2ng k\'d3 r\'cat t\'d8 m\'d8 v\'d2 cu\'e9c \'ae\'eai gian nan c\'f1a \'abng tr\'ad\'edc m\'c6t Kim Tchong Wen v\'b5 m\'e4i ng\'ad\'eai trong h\'b7ng th\'abng t\'can c\'f1a \'abng.
\par 
\par }\trowd \lastrow \ts11\trgaph108\trleft-108\trftsWidth1\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3 \clvertalt\clbrdrt\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3936\clshdrawnil \cellx3828\clvertalt\clbrdrt
