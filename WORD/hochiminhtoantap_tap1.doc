\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 H\'e9I LI\'a3N HI\'d6P THU\'e9C \'a7\'deA
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-300\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~}{\i\f37\fs20\insrsid1378858 \'a7\'e5ng b\'b5o th\'a9n m
\'d5n,
\par }{\f37\fs20\insrsid1378858 N\'d5u c\'a9u ph\'ad\'acng ng\'abn "\'a7o\'b5n k\'d5t l\'b5m ra s\'f8c m\'b9nh" kh\'abng ph\'b6i l\'b5 m\'e9t c\'a9u n\'e3i su\'abng,
\par N\'d5u \'ae\'e5ng b\'b5o mu\'e8n gi\'f3p \'ae\'ec l\'c9n nhau,
\par N\'d5u \'ae\'e5ng b\'b5o mu\'e8n b\'aanh v\'f9c cho quy\'d2n l\'eei c\'f1a b\'b6n th\'a9n m\'d7nh, c\'f2ng nh\'ad quy\'d2n l\'eei c\'f1a t\'cat c\'b6 \'ae\'e5ng b\'b5o \'eb c\'b8c x\'f8 thu\'e9c \'ae\'dea,
\par H\'b7y gia nh\'cbp }{\i\f37\fs20\insrsid1378858 H\'e9i li\'aan hi\'d6p thu\'e9c \'ae\'dea.}{\f37\fs20\insrsid1378858 
\par }\pard\plain \s25\qc \li0\ri0\sb400\sa300\sl-300\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'a7I\'d2U L\'d6 TR\'ddCH Y\'d5U
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-300\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\b\f37\fs20\insrsid1378858 \'a7i\'d2u 2 -}{\f37\fs20\insrsid1378858  M\'f4
c \'ae\'ddch c\'f1a H\'e9i l\'b5 t\'cbp h\'eep v\'b5 h\'ad\'edng d\'c9n cho m\'e4i ng\'ad\'eai d\'a9n c\'b8c x\'f8 thu\'e9c \'ae\'dea hi\'d6n s\'e8ng tr\'aan \'ae\'cat Ph\'b8p \'ae\'d3; soi s\'b8ng cho nh\'f7ng ng\'ad\'eai d\'a9n \'eb thu\'e9c \'ae\'dea v
\'d2 t\'d7nh h\'d7nh m\'e4i m\'c6t \'eb n\'ad\'edc Ph\'b8p nh\'bbm m\'f4c \'ae\'ddch }{\i\f37\fs20\insrsid1378858 \'aeo\'b5n k\'d5t}{\f37\fs20\insrsid1378858  h\'e4; th\'b6o lu\'cbn v\'b5 nghi\'aan c\'f8u t\'cat c\'b6 nh\'f7ng v\'can \'ae\'d2 ch\'ddnh tr
\'de v\'b5 kinh t\'d5 c\'f1a thu\'e9c \'ae\'dea.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-300\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\b\f37\fs20\insrsid1378858 \'a7i\'d2u 4 -}{\f37\fs20\insrsid1378858  T\'cat c\'b6 h
\'e9i vi\'aan ph\'b6i \'ae\'e3ng h\'e9i ph\'dd 3 th\'b8ng m\'e9t k\'fa l\'b5 9 phr\'a8ng.
\par }{\b\f37\fs20\insrsid1378858 \'a7i\'d2u 10 -}{\f37\fs20\insrsid1378858  T\'cat c\'b6 h\'e9i vi\'aan b\'cat k\'fa l\'f3c n\'b5o, \'ae\'d2u c\'e3 th\'d3 g\'f6i th\'ad \'ae\'d5n tr\'f4 s\'eb c\'f1a H\'e9i \'ae\'d3 y\'aau c\'c7u nh\'f7ng \'aei\'d2u l\'eei 
\'ddch m\'b5 H\'e9i d\'b5nh ri\'aang cho c\'b8c h\'e9i vi\'aan c\'f1a m\'d7nh.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\b\f37\fs20\insrsid1378858 \'a7i\'d2u 13}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0
\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1), 2). C\'e3 b\'b6n ch\'f4p c\'b8c \'aei\'d2u 13 v\'b5 14 tr\'aan \'ae\'a9y, nh\'adng \'ae\'b8nh s\'e8 l\'b5 }{
\i\insrsid1378858 \'aei\'d2u 15 v\'b5 19,}{\insrsid1378858  n\'e9i dung c\'b8c \'aei\'d2u \'ae\'d2u gi\'e8ng nhau.}})}{\f37\fs20\insrsid1378858  - H\'e9i s\'bdn s\'b5ng gi\'f3p \'ae\'ec v\'b5 c\'f8u tr\'ee cho m\'e4i h\'e9i vi\'aan c\'f1a c\'b8c nh\'e3m 
\'ae\'b7 gia nh\'cbp H\'e9i.
\par }{\b\f37\fs20\insrsid1378858 \'a7i\'d2u 14}{\f37\fs20\super\insrsid1378858 2)}{\f37\fs20\insrsid1378858  - Trong ph\'b9m vi t\'b5i ch\'ddnh s\'bdn c\'e3, H\'e9i c\'e3 th\'d3 cung c\'cap cho t\'cat c\'b6 h\'e9i vi\'aan nh\'f7ng b\'b8o ch\'dd v\'b5 t\'b5
i li\'d6u c\'e3 li\'aan quan \'ae\'d5n sinh ho\'b9t c\'f1a c\'b8c thu\'e9c \'ae\'dea, ho\'c6c chuy\'aan lo b\'aanh v\'f9c cho c\'b8c thu\'e9c \'ae\'dea.
\par }\pard\plain \s25\qc \li0\ri0\sb440\sa300\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 BAN CH\'caP H\'b5NH:
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \'a7\'b9i di\'d6n:
\par \'a7\'abng D\'ad\'acng: Nguy\'d4n }{\f38\fs20\insrsid1378858 \'b8}{\f37\fs20\insrsid1378858 i Qu\'e8c (th\'ee s\'f6a \'b6nh)
\par \'a7\'b6o R\'aauyni\'abng: B\'b8ck\'ddtx\'ab (tr\'b9ng s\'ad)
\par \'a7ah\'abm\'a9y: M.Bl\'abngcua (tr\'b9ng s\'ad)
\par Goa\'ae\'acl\'f3p: Gi\'a8ng B\'b8ptixt\'ac (nh\'b5 bu\'abn)
\par Qu\'c7n \'ae\'b6o \'a1ngti\'ac: M\'abranh\'ae\'ac (nh\'b5 bu\'abn)
\par M\'b8ctin\'ddch: M\'abngn\'d0cvin (\'ae\'b9i di\'d6n th\'ad\'acng m\'b9i)
\par Guyan: \'a4n\'abri\'a8ng (Ch\'f1 nhi\'d6m) , Gi\'b8m \'ae\'e8c H\'e9i ch\'f7 th\'cbp \'ae\'e1.
\par \'a7\'e5ng b\'b5o h\'b7y g\'f6i \'ae\'acn xin v\'b5o h\'e9i cho M\'abngn\'d0cvin, 9, Ph\'e8 Val\'d0tt\'ac, qu\'cbn 5, Pari; ho\'c6c cho Nguy\'d4n }{\f38\fs20\insrsid1378858 \'b8}{\f37\fs20\insrsid1378858 i Qu\'e8c, 9, Ng\'e2 C\'abngpoanh, qu\'cb
n 17, Pari.
\par 
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'b5i li\'d6u ti\'d5ng Ph\'b8p, b\'b6n ch\'f4p
\par l\'adu t\'b9i Vi\'d6n H\'e5 Ch\'dd Minh.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par 
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 L\'eaI K\'a3U G\'e4I C\'f1A BAN NGHI\'a3N C\'f8U\line 
THU\'e9C \'a7\'deA C\'f1A \'a7\'b6NG C\'e9NG S\'b6N PH\'b8P
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-300\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ch\'f3ng t\'abi hi\'d3u n\'e7i \'aeau kh\'e6 c\'f1a c\'b8
c b\'b9n, nh\'adng c\'b8c b\'b9n ch\'ada hi\'d3u n\'e7i \'aeau kh\'e6 c\'f1a ch\'f3ng t\'abi. C\'e3 l\'cf c\'b8c b\'b9n cho r\'bbng t\'cat c\'b6 m\'e4i ng\'ad\'eai \'eb Ph\'b8p \'ae\'d2u c\'e3 quy\'d2n h\'b5nh v\'b5 ai c\'f2ng mu\'e8n gi\'f7 c\'b8c b\'b9
n trong v\'dfng n\'ab l\'d6.
\par Th\'cbt ra nh\'f7ng ng\'ad\'eai g\'a9y ra s\'f9 l\'c7m than cho c\'b8c b\'b9n v\'b5 gi\'f7 c\'b8c b\'b9n trong c\'b6nh kh\'e6 \'ae\'e3 \'ae\'d3 l\'eei d\'f4ng ch\'d8 l\'b5 m\'e9t s\'e8 \'ddt, ch\'f3ng c\'e3 quy\'d2n h\'b5nh v\'d7 ch\'f3ng gi\'b5u. Ch\'f3
ng t\'abi l\'b5 s\'e8 \'ae\'abng v\'b5 \'aeang \'ae\'cau tranh ch\'e8ng l\'b9i ch\'f3ng v\'d7 ch\'f3ng t\'abi c\'f2ng nh\'ad c\'b8c b\'b9n l\'b5 n\'b9n nh\'a9n s\'f9 t\'b5n b\'b9o c\'f1a ch\'f3ng. C\'b8c anh em ng\'ad\'eai b\'b6n x\'f8 th\'cay r\'e2 ch
\'f3ng t\'abi c\'efng v\'edi anh em c\'e3 chung m\'e9t k\'ce th\'ef l\'b5 b\'e4n ch\'f1 c\'f1a ch\'f3ng t\'abi. Ch\'f3ng t\'abi th\'b5nh l\'cbp \'eb \'ae\'a9y m\'e9t ch\'ddnh \'ae\'b6ng l\'edn \'ae\'cau tranh \'ae\'d3 gi\'b6i ph\'e3ng nh\'f7ng ng\'ad\'ea
i kh\'abng c\'e3 quy\'d2n h\'b5nh \'eb ch\'ddnh qu\'e8c v\'b5 c\'f2ng mu\'e8n \'ae\'cau tranh \'ae\'d3 gi\'b6i ph\'e3ng nh\'f7ng ng\'ad\'eai b\'b6n x\'f8 \'eb thu\'e9c \'ae\'dea b\'de b\'bet l\'b5m n\'ab l\'d6.
\par Ch\'f3ng t\'abi y\'aau c\'c7u c\'b8c b\'b9n gi\'f3p \'ae\'ec ch\'f3ng t\'abi trong nhi\'d6m v\'f4 \'ae\'e3, v\'d7 c\'b8c b\'b9n v\'b5 ch\'f3ng t\'abi, ch\'f3ng ta c\'efng chung m\'e9t l\'eei \'ddch. Ch\'f3ng t\'abi y\'aau c\'c7u c\'b8c b\'b9n coi ch\'f3
ng t\'abi nh\'ad b\'b9n v\'b5 anh em c\'f1a c\'b8c b\'b9n. Ch\'f3ng t\'abi s\'b8t c\'b8nh v\'edi c\'b8c b\'b9n trong cu\'e9c kh\'b8ng chi\'d5n v\'b5 \'ae\'cau tranh c\'f1a c\'b8c b\'b9n ch\'e8ng s\'f9 tham t\'b5n c\'f1a b\'e4n th\'f9c d\'a9n, s\'f9 hung b
\'b9o c\'f1a b\'e4n cai tr\'de v\'b5 binh l\'ddnh, b\'e4n n\'b5y c\'e3 nh\'f7ng t\'aan \'ae\'e5ng lo\'b7 l\'b5 b\'e4n quan l\'b9i b\'b6n x\'f8.
\par }\pard \qj \fi397\li0\ri0\sa160\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ng\'b5y m\'b5 ch\'f3ng ta s\'cf \'ae\'ad\'eec t\'f9 do nh\'ea \'eb th\'b5nh c\'abng c\'f1a s\'f9 thay \'ae\'e6i m\'b5
 ch\'f3ng ta \'aeang chu\'c8n b\'de \'ae\'a9y, s\'f9 l\'c7m than kh\'e6 c\'f9c c\'f1a c\'b8c b\'b9n s\'cf ch\'cam d\'f8t. L\'f3c \'ae\'e3 c\'b8c b\'b9n s\'cf c\'e3 th\'d3 t\'f9 \'aei\'d2u khi\'d3n l\'cay c\'abng vi\'d6c c\'f1a m\'d7nh v\'b5 k\'d5t qu\'b6
 lao \'ae\'e9ng c\'f1a c\'b8c b\'b9n s\'cf thu\'e9c v\'d2 c\'b8c b\'b9n. M\'e8i quan h\'d6 gi\'f7a ch\'f3ng t\'abi v\'edi c\'b8c b\'b9n s\'cf l\'b5 nh\'f7ng m\'e8i quan h\'d6 \'aeo\'b5n k\'d5t v\'b5 li\'aan minh.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 
\par }\trowd \lastrow \ts11\trgaph108\trleft-108\trftsWidth1\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3 \clvertalt\clbrdrt\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3936\clshdrawnil \cellx3828\clvertalt\clbrdrt
