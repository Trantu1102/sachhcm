 thu\'e9c \'ae\'dea
\par }\pard\plain \s8\qc \li0\ri0\sl-274\slmult0\keepn\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel7\adjustright\rin0\lin0\itap0 \i\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 G\'f6i ng\'ad\'eai b\'b6n x\'f8 c\'b8c thu\'e9c 
\'ae\'dea,
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 H\'eci nh\'f7ng ng\'ad\'eai lao \'ae\'e9ng b\'b6n x
\'f8 ! Nh\'f7ng ng\'ad\'eai c\'e9ng s\'b6n \'eb ch\'ddnh qu\'e8c bi\'d5t \'ae\'ad\'eec n\'e7i kh\'e6 c\'f1a c\'b8c b\'b9n. H\'e4 bi\'d5t r\'bbng t\'f5 ng\'b5y c\'b8c x\'f8 s\'eb c\'f1a c\'b8c b\'b9n b\'de nh\'f7ng qu\'a9n nh\'a9n x\'a9m chi\'d5m, c\'b8c b
\'b9n m\'cat h\'d5t t\'f9 do, r\'bbng ng\'ad\'eai ta \'ae\'b7 s\'f6 d\'f4ng nh\'f7ng bi\'d6n ph\'b8p t\'b5n b\'b9o \'ae\'d3 bu\'e9c c\'b8c b\'b9n ph\'b6i lao \'ae\'e9ng m\'b5 kh\'abng \'ae\'ad\'eec thu g\'c6t th\'b5nh qu\'b6. Nh\'f7ng quan cai tr\'de, d
\'a9n s\'f9 hay qu\'a9n s\'f9, kh\'f1ng b\'e8 c\'b8c b\'b9n, \'b8p d\'f4ng nh\'f7ng lu\'cbt l\'d6 t\'b5n kh\'e8c v\'edi c\'b8c b\'b9n.
\par }{\f37\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 Ch\'f3ng \'ae\'b7 t\'b9o n\'aan hai lo\'b9i to\'b5 \'b8n: m\'e9t cho b\'b9n th\'a9n c\'f1a h\'e4, hi\'d2n l\'b5nh, khoan ho\'b5, v\'b5 to\'b5 \'b8n kia l\'b5 cho c\'b8c b\'b9n, kh\'bet khe v\'b5 \'ae\'c9
m m\'b8u.
\par }{\f37\fs20\cgrid0\insrsid1378858 C\'b8c b\'b9n b\'de b\'e3c l\'e9t hai l\'c7n: tr\'aan t\'ad c\'b8ch l\'b5 ng\'ad\'eai lao \'ae\'e9ng v\'b5 tr\'aan t\'ad c\'b8ch l\'b5 ng\'ad\'eai b\'b6n x\'f8. Ch\'f1 c\'f1a c\'b8c b\'b9n, xu\'cat ph\'b8t t\'f5 m\'c9u qu
\'e8c, kh\'abng h\'b5nh \'ae\'e9ng \'ae\'acn \'ae\'e9c. Nh\'f7ng ng\'ad\'eai c\'e3 quy\'d2n l\'f9c \'eb n\'ad\'edc c\'b8c b\'b9n, nh\'f7ng nghi\'d6p ch\'f1 l\'edn v\'b5 c\'b8c \'abng ch\'f1 mu\'e8n b\'b6o v\'d6 c\'f1a c\'b6i v\'b5 quy\'d2n th\'d5 c\'f1a m
\'d7nh, li\'aan minh v\'edi nhau \'ae\'d3 b\'e3c l\'e9t c\'b8c b\'b9n, li\'aan minh v\'edi ch\'ddnh quy\'d2n, v\'edi b\'e4n th\'f9c d\'a9n v\'b5 c\'b8c c\'abng ty ch\'a9u \'a2u.
\par Trong chi\'d5n tranh, thanh ni\'aan n\'ad\'edc c\'b8c b\'b9n b\'de b\'f8t ra kh\'e1i nh\'b5; ho\'c6c b\'bbng c\'b8c l\'eai h\'f8a h\'b7o, ho\'c6c b\'bbng \'aee do\'b9 v\'b5 v\'f2 l\'f9c, v\'b5 ng\'ad\'eai ta \'ae\'b7 \'ae\'ada ch\'f3ng \'ae\'d5n l\'df m
\'e6 t\'f8c l\'b5 chi\'d5n tranh \'ae\'d3 b\'b6o v\'d6 l\'eei quy\'d2n v\'b5 nh\'f7ng h\'cbn th\'ef c\'f1a ch\'ddnh nh\'f7ng k\'ce gi\'b5u c\'e3 \'ae\'b7 chinh ph\'f4c \'ae\'cat n\'ad\'edc c\'b8c b\'b9n. Nhi\'d2u ng\'ad\'eai \'ae\'b7 b\'e1 m\'b9ng, nh\'f7
ng ng\'ad\'eai kh\'b8c b\'de th\'ad\'acng t\'cbt su\'e8t \'ae\'eai. Ng\'ad\'eai ta kh\'abng gi\'f7 l\'eai h\'f8a n\'aau ra trong chi\'d5n tranh, l\'b5 
\par 
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\cgrid0\insrsid1378858 nh\'ad\'eeng l\'b9i cho c\'b8c b\'b9n nh\'f7ng quy\'d2
n tr\'e4n v\'d1n v\'d2 con ng\'ad\'eai v\'b5 v\'d2 c\'abng d\'a9n.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 Ngo\'b5i ra, c\'b8c \'abng ch\'f1 n\'b5y ti\'d5p t
\'f4c \'d0p c\'b8c b\'b9n cung c\'cap cho h\'e4 binh l\'ddnh cho m\'e9t cu\'e9c chi\'d5n tranh n\'e6 ra nay mai th\'abi m\'b5 l\'dfng tham c\'f1a c\'b8c \'abng ch\'f1 \'aeang chu\'c8n b\'de v\'b5 v\'edi hy v\'e4ng d\'efng c\'b8c b\'b9n \'ae\'d3 \'ae\'b5n 
\'b8p c\'b8ch m\'b9ng m\'b5 ch\'f3ng t\'abi chu\'c8n b\'de \'ae\'d3 gi\'b6i ph\'e3ng chung ch\'f3ng ta.
\par C\'e3 l\'cf c\'b8c b\'b9n t\'ad\'ebng r\'bbng t\'cat c\'b6 m\'e4i ng\'ad\'eai s\'e8ng \'eb Ph\'b8p c\'f2ng \'ae\'d2u c\'e3 quy\'d2n l\'f9c c\'b6 v\'b5 \'ae\'d2u \'ae\'e5ng t\'d7nh \'ae\'d3 duy tr\'d7 c\'b8c b\'b9n trong v\'dfng n\'ab l\'d6. Kh\'abng. }{
\f38\fs20\cgrid0\insrsid1378858 \'eb }{\f37\fs20\cgrid0\insrsid1378858 n\'ad\'edc Ph\'b8p m\'c9u qu\'e8c c\'f2ng c\'e3 v\'b5 c\'e3 nhi\'d2u nh\'f7ng ng\'ad\'eai kh\'b8c ch\'bcng c\'e3 t\'b5i s\'b6n g\'d7 c\'b6, ph\'b6i lao \'ae\'e9ng \'ae\'d3 s\'e8ng, d
\'ad\'edi quy\'d2n c\'f2ng nh\'f7ng \'abng ch\'f1 \'cay, v\'b5 ch\'deu \'ae\'d3 ng\'ad\'eai gi\'b5u b\'e3c l\'e9t.
\par Nh\'f7ng ng\'ad\'eai g\'a9y n\'aan n\'e7i th\'e8ng kh\'e6 c\'f1a c\'b8c b\'b9n v\'b5 duy tr\'d7 n\'e3 v\'d7 \'aei\'d2u \'ae\'e3 c\'e3 l\'eei cho h\'e4, nh\'f7ng ng\'ad\'eai \'cay l\'b5 thi\'d3u s\'e8 \'eb m\'c9u qu\'e8c, nh\'adng h\'e4 c\'e3 quy\'d2n l
\'f9c v\'d7 h\'e4 r\'cat gi\'b5u; v\'b5 ch\'f3ng t\'abi, l\'b5 nh\'f7ng ng\'ad\'eai thu\'e9c \'aea s\'e8, ch\'f3ng t\'abi l\'b5 n\'b9n nh\'a9n c\'f1a nh\'f7ng b\'b9o ng\'ad\'eec c\'f1a h\'e4, ch\'f3ng t\'abi \'ae\'cau tranh ch\'e8ng l\'b9i h\'e4. H\'e4 c
\'f2ng \'ae\'ada ch\'f3ng t\'abi - nh\'ad c\'b8c b\'b9n - ra m\'c6t tr\'cbn v\'b5 h\'e4 d\'efng b\'b9o l\'f9c b\'f8t con c\'b8i ch\'f3ng t\'abi ra, bi\'d5n ch\'f3ng th\'b5nh l\'ddnh tr\'b8ng \'ae\'d3 ch\'f3ng b\'b6o v\'d6 nh\'f7ng c\'f1a c\'b6i kh\'ab
ng thu\'e9c v\'d2 ch\'f3ng t\'abi.
\par \'a7\'ad\'eec t\'f9 do ch\'f3t \'ddt h\'acn c\'b8c b\'b9n, ch\'f3ng t\'abi \'ae\'b7 c\'e3 th\'d3 li\'aan hi\'d6p l\'b9i \'ae\'d3 \'ae\'cau tranh ch\'e8ng l\'b9i ch\'f1 c\'f1a ch\'f3ng t\'abi v\'b5 ch\'f3ng t\'abi chu\'c8n b\'de l\'cbt \'ae\'e6 h\'e4 \'ae
\'d3 t\'e6 ch\'f8c, ch\'d8 nh\'bbm l\'eei \'ddch c\'f1a m\'e4i ng\'ad\'eai, m\'e9t x\'b7 h\'e9i to\'b5n c\'c7u t\'f9 do h\'acn v\'b5 c\'abng b\'bbng h\'acn, \'eb \'ae\'e3 lao \'ae\'e9ng l\'b5 t\'e8i cao. V\'d7 th\'d5 ch\'f3ng t\'abi \'ae\'b7 th\'b5nh l
\'cbp, nh\'ad \'eb m\'e4i n\'aci tr\'aan th\'d5 gi\'edi, m\'e9t \'a7\'b6ng c\'e9ng s\'b6n v\'dc \'ae\'b9i, \'ae\'cau tranh \'ae\'d3 gi\'b6i ph\'e3ng m\'e4i ng\'ad\'eai lao \'ae\'e9ng.
\par \'a7\'b6ng ch\'f1 tr\'ad\'acng n\'e7 l\'f9c \'ae\'d3 c\'f8u v\'edt t\'cat c\'b6 nh\'f7ng anh em \'eb c\'b8c thu\'e9c \'ae\'dea, \'ae\'b6ng y\'aau c\'c7u c\'b8c b\'b9n th\'abng tin cho \'ae\'b6ng bi\'d5t v\'d2 t\'cat c\'b6 nh\'f7ng ng\'ad\'eec \'ae\'b7i m
\'b5 c\'b8c b\'b9n m\'e7i l\'f3c l\'b9i l\'b5 n\'b9n nh\'a9n; \'ae\'b6ng s\'bdn s\'b5ng \'ae\'d3 c\'b8c b\'b9n tuy\'aan truy\'d2n tr\'aan b\'b8o ch\'dd c\'f1a \'ae\'b6ng v\'b5 s\'bdn s\'b5ng \'ae\'d3 c\'b8c nh\'a9n v\'cbt ch\'ddnh tr\'de c\'f1a \'ae\'b6
ng gi\'f3p \'ae\'ec c\'b8c b\'b9n. \'a7\'b6ng y\'aau c\'c7u c\'b8c b\'b9n th\'a9n thi\'d6n v\'edi \'ae\'b6ng v\'b5, \'eb trong c\'b8c thu\'e9c \'ae\'dea m\'b5 c\'e3 t\'e5n t\'b9i c\'b8c chi nh\'b8nh c\'f1a \'ae\'b6ng ch\'f3ng t\'abi, c\'b8c b\'b9n h\'b7
y coi c\'b8c chi nh\'b8nh \'cay l\'b5 nh\'f7ng c\'ac quan b\'b6o v\'d6 c\'b8c b\'b9n. \'a7\'b6ng y\'aau c\'c7u nh\'cat l\'b5 c\'b8c b\'b9n \'aeo\'b5n k\'d5t l\'b9i, gi\'f7a lao \'ae\'e9ng \'eb x\'dd nghi\'d6p, \'eb n\'abng th\'abn... v\'b5 duy tr\'d7 nh
\'f7ng quan h\'d6 anh em v\'edi nh\'f7ng ng\'ad\'eai lao \'ae\'e9ng t\'f5 m\'c9u qu\'e8c \'ae\'d5n - ng\'b5y c\'b5ng nhi\'d2u - h\'e4 c\'efng giai c\'cap v\'edi c\'b8c b\'b9n: h\'e4 l\'b5 c\'abng nh\'a9n, c\'abng ch\'f8c, n\'abng d\'a9n, ti\'d3u vi\'aa
n ch\'f8c, thu\'fb th\'f1.
\par V\'d7 ho\'b5 b\'d7nh th\'d5 gi\'edi, v\'d7 t\'f9 do v\'b5 s\'f9 no \'cam c\'f1a m\'e4i ng\'ad\'eai, nh\'f7ng ng\'ad\'eai b\'de b\'e3c l\'e9t thu\'e9c m\'e4i n\'dfi gi\'e8ng, ch\'f3ng ta h\'b7y \'aeo\'b5n k\'d5t l\'b9i v\'b5 \'ae\'cau tranh ch\'e8ng b\'e4
n \'b8p b\'f8c!
\par }\pard\plain \s24\qc \li2977\ri283\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin283\lin2977\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 Ban nghi\'aan c\'f8u thu\'e9c \'ae\'dea
\line c\'f1a ph\'a9n b\'e9 ph\'b8p\line c\'f1a qu\'e8c t\'d5 c\'e9ng s\'b6n\line }{\f37\cgrid0\insrsid1378858 120 ph\'e8 Phay\'d0tt\'ac, Pari.
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 B\'b8o }{\i\cgrid0\insrsid1378858 Le Paria}{
\cgrid0\insrsid1378858 , s\'e8 8,\line ng\'b5y 1-11-1922.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\b\f37\fs20\insrsid1378858 
\par 
