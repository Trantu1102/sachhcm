\par }\pard \qj \fi397\li0\ri0\sa80\sl-267\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 M\'e9t t\'aan l\'ddnh kh\'b8c mu\'e8n \'d0p m\'e9t ng\'ad\'eai \'ae\'b5n b\'b5 An Nam hi\'d5n th\'a9
n cho con ch\'e3 c\'f1a n\'e3, ch\'de \'cay kh\'abng ch\'deu. T\'aan l\'ddnh d\'efng l\'ad\'eci l\'aa \'ae\'a9m v\'b5o b\'f4ng ch\'de.
\par }\pard \qc \li0\ri0\sb120\sl-267\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *
\par }\pard \qc \li0\ri0\sa80\sl-267\slmult0\nowidctlpar\tx-2268\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *     *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-267\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 M\'e9t t\'aan l\'ddnh \'ae\'f3 m\'ec nh\'b6y x\'e6 ra v\'ab c\'ed \'ae\'a9m ch\'d5t m\'e9t b\'b5 gi\'b5
 An Nam.
\par }\pard \qc \li0\ri0\sb120\sl-267\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *
