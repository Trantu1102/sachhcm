\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 TH\'a6 G\'f6I C\'b8C B\'b9N C\'efNG HO\'b9T \'a7\'e9NG
\line \'eb PH\'b8P
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i\f37\fs20\insrsid1378858 C\'b8c b\'b9n th\'a9n m\'d5n,
\par }{\f37\fs20\insrsid1378858 Bao l\'a9u nay ch\'f3ng ta l\'b5m vi\'d6c v\'edi nhau.
\par M\'c6c d\'c7u ch\'f3ng ta l\'b5 nh\'f7ng ng\'ad\'eai kh\'b8c gi\'e8ng, kh\'b8c n\'ad\'edc, kh\'b8c t\'abn gi\'b8o, ch\'f3ng ta \'ae\'b7 th\'a9n y\'aau nhau nh\'ad anh em.
\par Ch\'f3ng ta c\'efng ch\'deu chung m\'e9t n\'e7i \'aeau kh\'e6: s\'f9 b\'b9o ng\'ad\'eec c\'f1a ch\'d5 \'ae\'e9 th\'f9c d\'a9n. Ch\'f3ng ta \'ae\'cau tranh v\'d7 m\'e9t l\'fd t\'ad\'ebng chung: gi\'b6i ph\'e3ng \'ae\'e5ng b\'b5o ch\'f3ng ta v\'b5 gi\'b5nh 
\'ae\'e9c l\'cbp cho T\'e6 qu\'e8c ch\'f3ng ta.
\par Trong cu\'e9c chi\'d5n \'ae\'cau c\'f1a ch\'f3ng ta, ch\'f3ng ta kh\'abng c\'ab \'ae\'e9c, v\'d7 ch\'f3ng ta c\'e3 t\'cat c\'b6 d\'a9n t\'e9c c\'f1a ch\'f3ng ta \'f1ng h\'e9 v\'b5 v\'d7 nh\'f7ng ng\'ad\'eai Ph\'b8p d\'a9n ch\'f1, nh\'f7ng ng\'ad\'eai Ph
\'b8p ch\'a9n ch\'ddnh, \'ae\'f8ng b\'aan c\'b9nh ch\'f3ng ta.
\par C\'abng vi\'d6c chung c\'f1a ch\'f3ng ta "H\'e9i Li\'aan hi\'d6p thu\'e9c \'ae\'dea"}{\f37\fs20\super\insrsid1378858 34}{\f37\fs20\insrsid1378858  v\'b5 t\'ea b\'b8o }{\f38\fs20\insrsid1378858 NG\'a6\'eaI C\'efNG KH\'e6}{
\cs17\f38\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) B\'b8o }{
\i\insrsid1378858 Le Paria.}})}{\f38\fs20\super\insrsid1378858  }{\f37\fs20\insrsid1378858 \'ae\'b7 c\'e3 nh\'f7ng k\'d5t qu\'b6 t\'e8t. N\'e3 \'ae\'b7 l\'b5m cho n\'ad\'edc Ph\'b8p, n\'ad\'edc Ph\'b8p ch\'a9n ch\'ddnh hi\'d3u r\'e2 nh\'f7ng vi\'d6c x\'b6
y ra trong c\'b8c thu\'e9c \'ae\'dea. L\'b5m cho n\'ad\'edc Ph\'b8p hi\'d3u r\'e2 b\'e4n c\'b8 m\'cbp th\'f9c d\'a9n \'ae\'b7 l\'eei d\'f4ng t\'aan tu\'e6i v\'b5 danh d\'f9 c\'f1a n\'ad\'edc Ph\'b8p \'ae\'d3 g\'a9y n\'aan nh\'f7ng t\'e9i \'b8c kh\'abng th
\'d3 t\'ad\'ebng t\'ad\'eeng \'ae\'ad\'eec. N\'e3 \'ae\'b7 th\'f8c t\'d8nh \'ae\'e5ng b\'b5o ch\'f3ng ta. \'a7\'e5ng th\'eai n\'e3 c\'f2ng khi\'d5n cho \'ae\'e5ng b\'b5o ch\'f3ng ta nh\'cbn r\'e2 n\'ad\'edc Ph\'b8p, n\'ad\'edc Ph\'b8p t\'f9 do b\'d7nh 
\'ae\'bcng v\'b5 b\'b8c \'b8i. Nh\'adng ch\'f3ng ta c\'dfn ph\'b6i l\'b5m nhi\'d2u h\'acn.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ch\'f3ng ta ph\'b6i l\'b5m g\'d7 ?
\par Ch\'f3ng ta kh\'abng th\'d3 \'ae\'c6t v\'can \'ae\'d2 \'cay m\'e9t c\'b8ch m\'b8y m\'e3c.
\par \'a7i\'d2u \'ae\'e3 tu\'fa ho\'b5n c\'b6nh c\'f1a m\'e7i d\'a9n t\'e9c ch\'f3ng ta.
\par \'a7\'e8i v\'edi t\'abi, c\'a9u tr\'b6 l\'eai \'ae\'b7 r\'e2 r\'b5ng: tr\'eb v\'d2 n\'ad\'edc, \'aei v\'b5o qu\'c7n ch\'f3ng, th\'f8c t\'d8nh h\'e4, t\'e6 ch\'f8c h\'e4, \'aeo\'b5n k\'d5t h\'e4, hu\'can luy\'d6n h\'e4, \'ae\'ada h\'e4 ra \'ae\'ca
u tranh gi\'b5nh t\'f9 do \'ae\'e9c l\'cbp.
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 C\'e3 l\'cf m\'e9t v\'b5i ng\'ad\'eai trong c\'b8
c b\'b9n c\'f2ng ph\'b6i v\'b5 c\'e3 th\'d3 l\'b5m nh\'ad t\'abi. C\'dfn c\'b8c b\'b9n kh\'b8c th\'d7 ti\'d5p t\'f4c c\'abng vi\'d6c hi\'d6n th\'eai c\'f1a ch\'f3ng ta: c\'f1ng c\'e8 "}{\i\f37\fs20\insrsid1378858 H\'e9i li\'aan hi\'d6p thu\'e9c \'ae\'dea}
{\f37\fs20\insrsid1378858 " v\'b5 ph\'b8t tri\'d3n t\'ea b\'b8o }{\f38\fs20\insrsid1378858 NG\'a6\'eaI C\'efNG KH\'e6 }{\f37\fs20\insrsid1378858 c\'f1a ch\'f3ng ta.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }{\i\f37\fs20\insrsid1378858 C\'b8c b\'b9n th\'a9n m\'d5n,
\par }{\f37\fs20\insrsid1378858 T\'abi t\'f5 gi\'b7 c\'b8c b\'b9n. T\'abi xa c\'b8c b\'b9n, nh\'adng l\'dfng t\'abi lu\'abn lu\'abn g\'c7n c\'b8c b\'b9n.
\par C\'b8c b\'b9n tha l\'e7i cho t\'abi kh\'abng h\'abn c\'b8c b\'b9n tr\'ad\'edc khi \'aei. C\'b8c b\'b9n bi\'d5t r\'bbng t\'abi b\'de theo d\'e2i ri\'d5t.
\par Khi c\'b8c b\'b9n \'ae\'ad\'eec th\'ad n\'b5y, Nguy\'d4n c\'f1a c\'b8c b\'b9n \'ddt nh\'cat c\'f2ng \'ae\'b7 xa n\'ad\'edc Ph\'b8p 24 gi\'ea r\'e5i.
\par \'a7\'b9i, ng\'ad\'eai \'ae\'e5ng h\'ad\'acng c\'f1a t\'abi, s\'cf giao l\'b9i cho \'abng B. th\'d7a kho\'b8 c\'f1a to\'b5 b\'b8o, gi\'cay t\'ea v\'b5 t\'b5i li\'d6u c\'f1a H\'e9i v\'b5 c\'f1a t\'ea b\'b8o, c\'f2ng nh\'ad qu\'fc c\'f1a t\'ea b\'b8o. T\'ab
i \'ae\'b7 tr\'b6 ti\'d2n thu\'aa nh\'b5 cho to\'b5 b\'b8o \'ae\'d5n cu\'e8i n\'a8m. Ti\'d2n in c\'f2ng \'ae\'b7 thanh to\'b8n. Ch\'f3ng ta kh\'abng m\'bec n\'ee ai. S\'e6 th\'ad vi\'d6n \'ae\'d3 \'eb trong ng\'a8n k\'d0o b\'aan ph\'b6i. S\'b8ch cho m\'ad
\'een \'ae\'b7 l\'cay v\'d2, tr\'f5 nh\'f7ng s\'b8ch cho nh\'f7ng h\'e9i vi\'aan \'aei ngh\'d8 m\'ad\'een.
\par N\'e3i t\'e3m l\'b9i, c\'b8c vi\'d6c \'ae\'d2u \'ae\'a9u v\'b5o \'ae\'cay tr\'ad\'edc khi t\'abi \'aei.
\par T\'abi s\'cf vi\'d5t th\'ad cho c\'b8c b\'b9n. Nh\'adng t\'abi kh\'abng d\'b8m h\'f8a v\'edi c\'b8c b\'b9n, v\'d7 kh\'abng ph\'b6i d\'d4 vi\'d5t th\'ad khi ng\'ad\'eai ta ho\'b9t \'ae\'e9ng b\'dd m\'cbt. D\'ef t\'abi c\'e3 vi\'d5t th\'ad cho c\'b8c b\'b9
n hay kh\'abng, c\'b8c b\'b9n h\'b7y tin ch\'bec r\'bbng l\'dfng t\'abi lu\'abn lu\'abn y\'aau c\'b8c b\'b9n. Nh\'ea c\'b8c b\'b9n b\'bet tay nh\'f7ng ng\'ad\'eai b\'b9n Ph\'b8p c\'f1a ch\'f3ng ta.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 B\'a9y gi\'ea, m\'e9t v\'b5i l\'eai v\'edi ch\'b8u trai v\'b5 ch\'b8u g\'b8i.
\par C\'b8c ch\'b8u r\'cat y\'aau ch\'f3 v\'b5 ch\'f3 c\'f2ng r\'cat y\'aau c\'b8c ch\'b8u, ph\'b6i kh\'abng c\'b8c ch\'b8u ? Ch\'f3 s\'cf n\'e3i v\'edi nh\'f7ng ng\'ad\'eai b\'b9n nh\'e1 Vi\'d6t Nam l\'b5 c\'b8c ch\'b8u r\'cat ngoan. Ch\'f3 s\'cf thay m\'c6
t c\'b8c ch\'b8u b\'bet tay c\'b8c b\'b9n nh\'e1 Vi\'d6t Nam.
\par C\'e3 l\'cf r\'cat l\'a9u, c\'b8c ch\'b8u s\'cf kh\'abng \'ae\'ad\'eec th\'cay ch\'f3 Nguy\'d4n, kh\'abng \'ae\'ad\'eec leo l\'aan \'ae\'efi, l\'aan l\'adng ch\'f3 nh\'ad c\'b8c ch\'b8u th\'ad\'eang l\'b5m. V\'b5 c\'f2ng r\'cat l\'a9u ch\'f3 s\'cf kh\'ab
ng th\'cay c\'ab Al\'ddtx\'ac (Alice) v\'b5 c\'cbu P\'abn (Paul) c\'f1a ch\'f3. Khi ch\'f3 ch\'b8u m\'d7nh g\'c6p nhau, c\'e3 l\'cf ch\'f3 \'ae\'b7 gi\'b5, c\'b8c ch\'b8u \'ae\'b7 l\'edn b\'bbng ba v\'b5 m\'b8. \'a7i\'d2u \'ae\'e3 kh\'abng ng\'b9i g\'d7
. Ch\'f3 s\'cf lu\'abn lu\'abn nh\'ed \'ae\'d5n c\'b8c ch\'b8u. C\'b8c ch\'b8u lu\'abn lu\'abn v\'c9n l\'b5 c\'ab b\'d0 Al\'ddtx\'ac v\'b5 c\'cbu b\'d0 P\'abn th\'a9n y\'aau c\'f1a ch\'f3.
\par C\'b8c ch\'b8u ngoan. H\'e4c thu\'e9c b\'b5i. V\'a9ng l\'eai cha m\'d1. \'a7\'f5ng \'ae\'b8nh con ch\'e3 nh\'e1 Mariu\'fdt (Marius) c\'f1a c\'b8c ch\'b8u. Khi c\'b8c ch\'b8u \'ae\'b7 h\'aci l\'edn, c\'b8c ch\'b8u s\'cf \'ae\'cau tranh cho T\'e6 qu\'e8c c
\'f1a c\'b8c ch\'b8u c\'f2ng nh\'ad ba m\'b8, ch\'f3 Nguy\'d4n v\'b5 nh\'f7ng ch\'f3 kh\'b8c.
\par C\'b8c ch\'b8u nh\'e1 th\'a9n y\'aau c\'f1a ch\'f3, ch\'f3 h\'abn c\'b8c ch\'b8u r\'cat k\'aau. C\'b8c ch\'b8u h\'abn m\'d1 h\'e9 ch\'f3.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa240\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~Ch\'f3 Nguy\'d4n
\par }\trowd \lastrow \ts11\trgaph108\trleft-108\trftsWidth1\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3 \clvertalt\clbrdrt\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3794\clshdrawnil \cellx3686\clvertalt\clbrdrt
\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3118\clshdrawnil \cellx6804\pard\plain \s26\ql \li0\ri176\sl-260\slmult0\nowidctlpar\intbl\tx3402\aspalpha\aspnum\faauto\adjustright\rin176\lin0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 In trong s\'b8ch }{\i\insrsid1378858 Nh\'f7ng m\'c8u chuy\'d6n\line v\'d2 \'ae\'eai ho\'b9t \'ae\'e9ng c\'f1a H\'e5 Ch\'f1 t\'dech}{\insrsid1378858 ,\line Nxb. S\'f9 th\'cbt, H
\'b5 N\'e9i, 1976, tr. 51-54.\cell }\pard \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\intbl\aspalpha\aspnum\faauto\adjustright\rin567\lin0 {\insrsid1378858 Theo b\'b5i in trong s\'b8ch }{\i\insrsid1378858 Nh\'f7ng m\'c8u chuy\'d6n v\'d2 \'ae\'eai ho\'b9
t \'ae\'e9ng c\'f1a H\'e5 Ch\'f1 t\'dech}{\insrsid1378858 
\par \cell }\pard\plain \ql \li0\ri0\widctlpar\intbl\aspalpha\aspnum\faauto\adjustright\rin0\lin0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \trowd \lastrow 
\ts11\trgaph108\trleft-108\trftsWidth1\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3 \clvertalt\clbrdrt\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3794\clshdrawnil \cellx3686\clvertalt\clbrdrt\brdrtbl \clbrdrl
\brdrtbl \clbrdrb\brdrtbl \clbrdrr\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3118\clshdrawnil \cellx6804\row }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 
