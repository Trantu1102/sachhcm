\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~Lo l\'beng v\'d7 giai c\'cap c\'abng nh\'a9n \'eb ch\'dd
nh qu\'e8c \'ae\'b7 th\'f8c t\'d8nh, ch\'f1 ngh\'dca t\'ad b\'b6n Ph\'b8p t\'d7m c\'b8ch d\'efng c\'b8c thu\'e9c \'ae\'dea \'ae\'d3 c\'f1ng c\'e8 n\'d2n th\'e8ng tr\'de \'aeang l\'a9m nguy c\'f1a n\'e3. N\'e3 b\'dfn r\'f3t \'eb \'ae\'e3 c\'b6 nguy\'aan li
\'d6u cho c\'b8c nh\'b5 m\'b8y c\'f1a n\'e3, l\'c9n nh\'a9n l\'f9c \'ae\'d3 ch\'e8ng l\'b9i c\'b8ch m\'b9ng. B\'b8o ch\'dd t\'ad s\'b6n \'eb Pari v\'b5 c\'b8c t\'d8nh th\'ad\'eang xuy\'aan d\'b5nh h\'b5ng trang cho m\'f4c thu\'e9c \'ae\'dea. C\'b8c t\'ad
\'edng l\'dcnh v\'b5 c\'b8c ngh\'de s\'dc \'ae\'b7 \'aei kh\'bep c\'b6 n\'ad\'edc \'ae\'d3 t\'e6 ch\'f8c c\'b8c cu\'e9c n\'e3i chuy\'d6n v\'d2 thu\'e9c \'ae\'dea. Nh\'f7ng c\'a9y b\'f3t \'ae\'b9o \'ae\'f8c \'cay v\'b5 nh\'f7ng \'abng chuy\'aan ngh\'d2 kho
\'b8c l\'b8c \'cay kh\'abng t\'d7m \'ae\'a9u ra cho \'ae\'f1 l\'eai l\'cf \'ae\'d3 ca ng\'eei l\'dfng trung th\'b5nh c\'f1a ng\'ad\'eai b\'b6n x\'f8 v\'b5 \'a9n hu\'d6 c\'f1a 
\par c\'abng cu\'e9c khai ho\'b8 "c\'f1a h\'e4".
\par \'a7\'abi khi, c\'b8c ng\'b5i \'cay tr\'ac tr\'b8o \'ae\'d5n m\'f8c \'aeem so s\'b8nh s\'f9 c\'ad\'edp b\'e3c c\'f1a ng\'ad\'eai Anh \'eb thu\'e9c \'ae\'dea v\'edi s\'f9 cao c\'b6 c\'f1a ri\'aang h\'e4: h\'e4 cho ch\'ddnh s\'b8ch c\'f1a ng\'ad\'eai Anh l
\'b5 "ph\'ad\'acng ph\'b8p t\'b5n nh\'c9n" ho\'c6c "th\'b8i \'ae\'e9 th\'ab b\'b9o" v\'b5 qu\'b6 quy\'d5t r\'bbng c\'b8ch l\'b5m c\'f1a ng\'ad\'eai Ph\'b8p \'ae\'c7y ch\'ddnh ngh\'dca v\'b5 d\'deu d\'b5ng!
\par Ch\'d8 c\'c7n gh\'d0 m\'bet nh\'d7n qua c\'b8c thu\'e9c \'ae\'dea m\'e9t ch\'f3t c\'f2ng \'ae\'f1 th\'cay c\'abng cu\'e9c khai ho\'b8 \'ae\'e3 l\'b5 "\'ae\'d1p \'ae\'cf v\'b5 d\'deu d\'b5ng" bi\'d5t l\'b5 ch\'f5ng n\'b5o.
\par }\pard \qj \fi397\li0\ri0\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  \'a7\'abng D\'ad\'acng, d\'b9o v\'f5a r\'e5i, c\'e3 m\'e9t g\'b7 th\'f9c d\'a9n Ph\'b8p tr
\'ce tu\'e6i \'ae\'b7 tr\'e3i m\'e9t ng\'ad\'eai An Nam, \'ae\'c6t n\'bbm s\'cap xu\'e8ng \'ae\'cat, ch\'a9n v\'b5 \'ae\'c7u bu\'e9c v\'b5o hai c\'b8i c\'e4c \'ae\'e3ng xu\'e8ng \'ae\'cat, r\'e5i gi\'b8ng cho ng\'ad\'eai \'ae\'e3 }{
\i\f37\fs20\insrsid1378858 m\'e9t tr\'a8m s\'b8u m\'ad\'aci g\'cby.}{\f37\fs20\insrsid1378858  N\'b9n nh\'a9n, m\'d7nh m\'b6y n\'b8t nh\'f5, l\'b9i b\'de b\'e1 v\'b5o nh\'b5 giam su\'e8t m\'e9t \'ae\'aam. S\'b8ng h\'abm sau, g\'b7 tr\'ce tu\'e6i \'ae
i khai ho\'b8 \'ae\'e3
\par }\pard \qj \li0\ri0\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 l\'b9i }{\i\f37\fs20\insrsid1378858 cho\'b6ng s\'adng \'ae\'c7u n\'b9n nh\'a9n}{\f37\fs20\insrsid1378858  v\'b5 l\'cay chu\'abi s
\'f3ng l\'f4c }{\i\f37\fs20\insrsid1378858 \'ae\'cbp v\'ec m\'e9t m\'bet }{\f37\fs20\insrsid1378858 c\'f1a ng\'ad\'eai \'cay}{\i\f37\fs20\insrsid1378858 . T\'aan s\'f3c sinh \'ae\'e3 \'ae\'b7 \'ae\'ad\'eec to\'b5 \'b8n Ph\'b8p tha b\'e6ng}{
\f37\fs20\insrsid1378858 .
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  \'a7ah\'abm\'a9y, ng\'ad\'eai ta t\'a8ng th\'aam thu\'d5 m\'b8 v\'e8n \'ae\'b7 qu\'b8 n
\'c6ng n\'d2 \'ae\'e8i v\'edi ng\'ad\'eai d\'a9n b\'b6n x\'f8. Ng\'ad\'eai ta b\'bet thanh ni\'aan ph\'b6i b\'e1 nh\'b5 c\'f6a v\'b5 ru\'e9ng n\'ad\'acng \'aei l\'b5m "nh\'f7ng ng\'ad\'eai b\'b6o v\'d6 v\'a8n minh". Ng\'ad\'eai ta c\'cam d\'a9n b\'b6n x
\'f8 gi\'f7 v\'f2 kh\'dd \'ae\'d3 t\'f9 v\'d6 ch\'e8ng th\'f3 d\'f7 v\'c9n th\'ad\'eang ph\'b8 ho\'b9i h\'b5ng x\'b7 m\'e9t. Gi\'b8o d\'f4c, y t\'d5 \'ae\'d2u kh\'abng c\'e3. Tr\'b8i l\'b9i, ng\'ad\'eai ta kh\'abng t\'f5 m\'e9t th\'f1 \'aeo\'b9n n\'b5o 
\'ae\'d3 b\'bet ng\'ad\'eai \'a7ah\'abm\'a9y "\'ae\'ad\'eec b\'b6o h\'e9" ph\'b6i ch\'deu c\'b8i ki\'d5p l\'c7m than c\'f1a ng\'ad\'eai d\'a9n b\'b6n x\'f8, c\'b8i ch\'d5 \'ae\'e9 \'ae\'b7 h\'b9 con ng\'ad\'eai xu\'e8ng h\'b5ng con v\'cbt v\'b5 l\'b5m 
\'aei\'d5m nh\'f4c cho c\'b8i g\'e4i l\'b5 th\'d5 gi\'edi v\'a8n minh. D\'a9n b\'b6n x\'f8, kh\'abng nh\'den nh\'f4c \'ae\'ad\'eec n\'f7a, v\'efng l\'aan. Th\'d5 l\'b5 cu\'e9c \'ae\'b5n \'b8p \'ae\'c9m m\'b8u \'ae\'ad\'eec ti\'d5n h\'b5nh. Ng\'ad\'ea
i ta d\'efng nh\'f7ng bi\'d6n ph\'b8p c\'ad\'acng quy\'d5t. Ng\'ad\'eai ta \'ae\'ada qu\'a9n \'ae\'e9i, s\'f3ng li\'aan thanh, s\'f3ng c\'e8i v\'b5 t\'b5u chi\'d5n \'ae\'d5n; ng\'ad\'eai ta h\'b9 l\'d6nh gi\'edi nghi\'aam. Ng\'ad\'eai ta b\'bet b\'ed v
\'b5 b\'e1 t\'ef h\'b5ng lo\'b9t. \'a7\'cay, \'ae\'f8c nh\'a9n t\'f5 c\'f1a c\'abng cu\'e9c khai ho\'b8 nh\'ad th\'d5 \'ae\'cay.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 nguy\'d4n \'b8i qu\'e8c
