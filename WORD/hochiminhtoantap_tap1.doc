\par }\pard\plain \qj \fi397\li0\ri0\sl-280\slmult0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\lang1043\langfe1033\langnp1043\insrsid1378858 
\par }\pard \qj \fi397\li0\ri0\sa60\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\i\f37\fs18\expnd0\expndtw-4\lang1043\langfe1033\langnp1043\insrsid1378858 H\'e5 Ch\'dd Minh To\'b5n t\'cbp}{
\f37\fs18\expnd0\expndtw-4\lang1043\langfe1033\langnp1043\insrsid1378858 , t\'cbp 1 g\'e5m nh\'f7ng b\'b5i vi\'d5t v\'b5 t\'b8c ph\'c8m c\'f1a Ch\'f1 t\'dech H\'e5 Ch\'dd Minh t\'f5 n\'a8m 1919 \'ae\'d5n th\'b8ng 11 n\'a8m 1924, m\'eb \'ae\'c7u l\'b5 b
\'b5i }{\i\f37\fs18\expnd0\expndtw-4\lang1043\langfe1033\langnp1043\insrsid1378858 T\'a9m \'ae\'dea th\'f9c d\'a9n}{\f37\fs18\expnd0\expndtw-4\lang1043\langfe1033\langnp1043\insrsid1378858  v\'b5 k\'d5t th\'f3c v\'b5o th\'eai \'aei\'d3m Ng\'ad\'eai r\'ea
i M\'b8txc\'acva (Nga) \'ae\'d5n Qu\'b6ng Ch\'a9u (Trung Qu\'e8c). C\'b8c t\'b8c ph\'c8m c\'f1a Ch\'f1 t\'dech H\'e5 Ch\'dd Minh trong t\'cbp 1 ph\'b6n \'b8nh s\'f9 chuy\'d3n bi\'d5n trong t\'ad t\'ad\'ebng c\'f1a Ng\'ad\'eai t\'f5 ch\'f1 ngh\'dca y\'aa
u n\'ad\'edc \'ae\'d5n ch\'f1 ngh\'dca x\'b7 h\'e9i khoa h\'e4c, \'ae\'b8nh d\'cau s\'f9 h\'d7nh th\'b5nh t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh v\'d2 gi\'b6i ph\'e3ng d\'a9n t\'e9c, gi\'b6i ph\'e3ng x\'b7 h\'e9i v\'b5 gi\'b6i ph\'e3ng con ng\'ad\'eai, v\'d2
 \'aeo\'b5n k\'d5t d\'a9n t\'e9c v\'b5 \'aeo\'b5n k\'d5t qu\'e8c t\'d5, v\'d2 ph\'ad\'acng ph\'b8p c\'b8ch m\'b9ng... C\'b8c t\'b8c ph\'c8m trong t\'cbp n\'b5y \'ae\'b7 kh\'bcng \'ae\'denh con \'ae\'ad\'eang \'ae\'f3ng \'ae\'ben \'ae\'d3 gi\'b6i ph\'e3
ng d\'a9n t\'e9c Vi\'d6t Nam v\'b5 c\'b8c d\'a9n t\'e9c b\'de \'b8p b\'f8c kh\'b8c tr\'aan th\'d5 gi\'edi l\'b5 \'aei theo con \'ae\'ad\'eang c\'b8ch m\'b9ng v\'ab s\'b6n. T\'b8c gi\'b6 \'ae\'b7 t\'cbp trung t\'e8 c\'b8o t\'e9i \'b8c, v\'b9ch tr\'c7n b
\'b6n ch\'cat c\'f1a ch\'f1 ngh\'dca th\'f9c d\'a9n \'ae\'d5 qu\'e8c; b\'ad\'edc \'ae\'c7u \'ae\'d2 ra chi\'d5n l\'ad\'eec, s\'b8ch l\'ad\'eec c\'f1a c\'b8ch m\'b9ng gi\'b6i ph\'e3ng d\'a9n t\'e9c v\'b5 kh\'bcng \'ae\'denh b\'ad\'edc ph\'b8t tri\'d3n t
\'cat y\'d5u c\'f1a n\'e3 s\'cf l\'b5 ti\'d5n t\'edi c\'b8ch m\'b9ng x\'b7 h\'e9i ch\'f1 ngh\'dca. Ng\'ad\'eai vi\'d5t: "Ch\'d8 c\'e3 ch\'f1 ngh\'dca c\'e9ng s\'b6n m\'edi c\'f8u nh\'a9n lo\'b9i, \'aeem l\'b9i cho m\'e4i ng\'ad\'eai kh\'abng ph\'a9n bi
\'d6t ch\'f1ng t\'e9c v\'b5 ngu\'e5n g\'e8c s\'f9 t\'f9 do, b\'d7nh \'ae\'bcng, b\'b8c \'b8i, \'aeo\'b5n k\'d5t, \'cam no tr\'aan qu\'b6 \'ae\'cat, vi\'d6c l\'b5m cho m\'e4i ng\'ad\'eai v\'b5 v\'d7 m\'e4i ng\'ad\'eai, ni\'d2m vui, ho\'b5 b\'d7nh, h\'b9
nh ph\'f3c..." (Tr.461).   
\par }{\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 V\'b5o nh\'f7ng n\'a8m \'ae\'c7u th\'d5 k\'fb XX, phong tr\'b5o y\'aau n\'ad\'edc c\'f1a nh\'a9n d\'a9n Vi\'d6t Nam r\'cat s\'abi n\'e6i, nh\'adng l\'b9i l\'a9m v\'b5o t\'d7nh tr\'b9ng kh\'f1ng ho
\'b6ng s\'a9u s\'bec v\'d2 \'ae\'ad\'eang l\'e8i ch\'ddnh tr\'de. Trong ho\'b5n c\'b6nh \'cay, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'b7 ra \'aei t\'d7m \'ae\'ad\'eang c\'f8u n\'ad\'edc, gi\'b6i ph\'e3ng d\'a9n t\'e9c kh\'e1i \'b8ch \'b8p b\'f8c c\'f1a ch
\'f1 ngh\'dca th\'f9c d\'a9n Ph\'b8p. Ng\'ad\'eai \'ae\'b7 tham gia ho\'b9t \'ae\'e9ng, \'ae\'cau tranh trong phong tr\'b5o c\'b8ch m\'b9ng c\'f1a giai c\'cap c\'abng nh\'a9n v\'b5 nh\'a9n d\'a9n b\'de \'b8p b\'f8c c\'b8c n\'ad\'edc ch\'a9u }{
\f38\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 \'b8,}{\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858  ch\'a9u Phi, ch\'a9u \'a2u, ch\'a9u M\'fc.   
\par }\pard \qj \fi397\li0\ri0\sa60\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\lang1024\langfe1024\noproof\insrsid1378858 
{\shp{\*\shpinst\shpleft-27\shptop-814\shpright873\shpbottom-454\shpfhdr0\shpbxcolumn\shpbxignore\shpbypara\shpbyignore\shpwr3\shpwrk0\shpfblwtxt0\shpz20\shplid1046{\sp{\sn shapeType}{\sv 1}}{\sp{\sn fFlipH}{\sv 0}}{\sp{\sn fFlipV}{\sv 0}}
