\par }\pard\plain \s18\qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs20\insrsid1378858 Phi\'aan h\'e4p s\'b8ng h\'abm qua \'ae\'b8ng l\'cf b
\'bet \'ae\'c7u t\'f5 8 gi\'ea, nh\'adng \'ae\'d5n gi\'ea \'ae\'e3 c\'dfn v\'beng nhi\'d2u \'ae\'b9i bi\'d3u \'eb ph\'dfng h\'e4p. V\'d7 v\'cby, \'ae\'d5n 9 gi\'ea, ch\'f1 to\'b9 Giuynl\'ac Bl\'a8ng m\'edi cho b\'bet \'ae\'c7u cu\'e9c tranh lu\'cbn v\'d2
 lu\'cbn c\'ad\'acng ph\'dfng th\'f1 qu\'e8c gia.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 Giuynl\'ac Bl\'a8ng c\'e3 hai ng\'ad\'eai tr\'ee l
\'fd: Nguy\'d4n }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 i Qu\'e8c (\'a7\'abng D\'ad\'acng) v\'b5 Raym\'abng O\'e3cli\'a8nggi\'ac (Cored\'ac)}{\cs17\f37\fs20\super\cgrid0\insrsid1378858 1{\footnote \pard\plain 
\s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 1) }{\i\cgrid0\insrsid1378858 Cored\'ac: }{
\cgrid0\insrsid1378858 m\'e9t qu\'cbn \'eb ph\'dda T\'a9y n\'ad\'edc Ph\'b8p.}})}{\f37\fs20\cgrid0\insrsid1378858 .
\par \'a7\'e5ng ch\'dd Nguy\'d4n }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 i Qu\'e8c c\'b6m \'acn \'a7\'b9i h\'e9i \'ae\'b7 d\'b5nh m\'e9t ch\'e7 cho c\'b8c \'ae\'e5ng ch\'dd da m\'b5u, ch\'f8ng t\'e1 r\'bbng \'ae\'e3 l\'b5 ch\'f1
 ngh\'dca qu\'e8c t\'d5 ch\'a9n ch\'ddnh.
\par Phi\'aan h\'e4p bu\'e6i chi\'d2u do Barab\'a8ng ch\'f1 to\'b9.
\par Nguy\'d4n }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 i Qu\'e8c y\'aau c\'c7u \'a7\'b6ng nghi\'aan c\'f8u v\'b5 t\'e6 ch\'f8c m\'e9t ch\'ddnh s\'b8ch thu\'e9c \'ae\'dea c\'e3 t\'ddnh c\'e9ng s\'b6n. Ng\'ad\'eai \'ae\'d2 ngh\'de
 th\'b5nh l\'cbp m\'e9t ban nghi\'aan c\'f8u thu\'e9c \'ae\'dea c\'f1a \'a7\'b6ng. Ban s\'cf tr\'d7nh b\'b5y m\'e9t b\'b6n b\'b8o c\'b8o tr\'ad\'edc \'a7\'b9i h\'e9i trong n\'a8m t\'edi.
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 
\par B\'b8o }{\i\cgrid0\insrsid1378858 L'Humanit\'d0,}{\cgrid0\insrsid1378858 
\par ng\'b5y 30-12-1921.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\b\f37\fs20\cgrid0\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb960\sa360\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 
\par 
\par TH\'a1M M\'e9T CHI\'d5N S\'dc QU\'e8C T\'d5 C\'e9NG S\'b6N - NGUY\'d4N \'b8I Qu\'e8C}{\cs17\super\cgrid0\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 1) B\'b5i vi\'d5t c\'f1a nh\'b5 b\'b8o Li\'aan X\'ab \'a4x\'ddp Man\'aeenxtam.}})}{\super\cgrid0\insrsid1378858 
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-256\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 T\'b9i \'a7\'abng D\'ad\'acng, \'b6nh h\'ad\'eb
ng phong tr\'b5o G\'a8ng\'aei nh\'ad th\'d5 n\'b5o? Ti\'d5ng vang, l\'b5n s\'e3ng c\'f1a phong tr\'b5o \'ae\'e3 c\'e3 lan \'ae\'d5n \'ae\'cay ch\'f3t n\'b5o kh\'abng ? - T\'abi h\'e1i Nguy\'d4n }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{
\f37\fs20\cgrid0\insrsid1378858 i Qu\'e8c.
\par - Kh\'abng. - Nguy\'d4n }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 i Qu\'e8c tr\'b6 l\'eai - Nh\'a9n d\'a9n An Nam ch\'f3ng t\'abi l\'b5 nh\'f7ng ng\'ad\'eai n\'abng d\'a9n b\'de nh\'can ch\'d7m trong b\'e3ng \'ae\'aam h\'d5
t s\'f8c t\'e8i t\'a8m. Kh\'abng m\'e9t t\'ea b\'b8o n\'b5o, kh\'abng ai hi\'d3u b\'a9y gi\'ea tr\'aan th\'d5 gi\'edi \'ae\'ad\'acng di\'d4n ra nh\'f7ng g\'d7; \'ae\'aam t\'e8i, th\'f9c s\'f9 l\'b5 \'ae\'aam t\'e8i.
\par Nguy\'d4n }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 i Qu\'e8c hi\'d6n l\'b5 ng\'ad\'eai An Nam duy nh\'cat \'eb M\'b8txc\'acva, \'ae\'b9i di\'d6n c\'f1a ch\'f1ng t\'e9c M\'b7 Lai c\'e6 x\'ada. \'a7\'e3 l\'b5 m\'e9t thanh ni
\'aan g\'c7y g\'df, linh ho\'b9t, m\'c6c c\'b8i \'b8o len \'aean. \'a7\'e5ng ch\'dd n\'e3i ti\'d5ng Ph\'b8p - ti\'d5ng c\'f1a nh\'f7ng k\'ce \'b8p b\'f8c, nh\'adng m\'b5 nh\'f7ng ch\'f7 Ph\'b8p t\'f5 mi\'d6ng \'ae\'e5ng ch\'dd Nguy\'d4n }{
\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 i Qu\'e8c nghe tr\'c7m tr\'c7m, l\'beng xu\'e8ng nh\'ad h\'e5i \'a9m c\'f1a ti\'d5ng m\'d1 \'ae\'ce qu\'aa h\'ad\'acng \'ae\'e5ng ch\'dd.
\par }{\f37\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 Nguy\'d4n }{\f38\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 \'b8}{\f37\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 i Qu\'e8c \'ae\'b7 n\'e3i \'ae\'d5n hai ch\'f7 "v\'a8n minh" m\'e9t c\'b8ch \'ae\'c7
y khinh b\'d8. \'a7\'e5ng th\'eai \'ae\'b7 \'ae\'c6t ch\'a9n qua h\'c7u h\'d5t c\'b8c n\'ad\'edc thu\'e9c \'ae\'dea tr\'aan th\'d5 gi\'edi, \'ae\'b7 t\'edi mi\'d2n B\'bec v\'b5 mi\'d2n Trung ch\'a9u Phi, \'ae\'b7 th\'cay r\'cat nhi\'d2u c\'b6nh \'aeau kh
\'e6. Khi n\'e3i chuy\'d6n, \'ae\'e5ng ch\'dd th\'ad\'eang hay d\'efng ch\'f7 "anh em". Anh em c\'f1a Nguy\'d4n }{\f38\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 \'b8}{\f37\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 i Qu\'e8c \'eb \'ae\'a9y l\'b5 nh\'f7
ng ng\'ad\'eai da \'aeen, nh\'f7ng ng\'ad\'eai }{\f38\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 \'ca}{\f37\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 n \'a7\'e9, nh\'f7ng ng\'ad\'eai Xyri, nh\'f7ng ng\'ad\'eai Trung Qu\'e8c...
\par }{\f37\fs20\cgrid0\insrsid1378858 Nguy\'d4n }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 i Qu\'e8c \'ae\'b7 c\'e3 l\'c7n g\'f6i th\'ad t\'edi nh\'b5 v\'a8n R\'acn\'aa Mar\'a8ng, ng\'ad\'eai da \'aeen c\'e3 qu\'e8c t\'dech Ph\'b8
p, l\'b5 t\'b8c gi\'b6 cu\'e8n ti\'d3u thuy\'d5t }{\i\f37\fs20\cgrid0\insrsid1378858 Batuala }{\f37\fs20\cgrid0\insrsid1378858 v\'b5 \'ae\'b7 \'ae\'c6t m\'e9t c\'a9u h\'e1i m\'e9t c\'b8ch th\'bcng th\'ben: }{\f38\fs20\cgrid0\insrsid1378858 "\'ab}{
\f37\fs20\cgrid0\insrsid1378858 ng Mar\'a8ng, \'abng mu\'e8n hay kh\'abng mu\'e8n gi\'f3p \'ae\'ec c\'abng cu\'e9c gi\'b6i ph\'e3ng c\'b8c n\'ad\'edc anh 
\par 
\par }\pard \qj \li0\ri0\sa80\sl-256\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 em \'eb thu\'e9c \'ae\'dea?". R\'acn\'aa Mar\'a8ng, ng\'ad\'eai \'ae\'ad\'eec Vi\'d6n H\'b5n l\'a9m Ph\'b8p qu\'b5
ng cho m\'e9t v\'dfng hoa danh d\'f9, \'ae\'b7 tr\'b6 l\'eai Nguy\'d4n }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 i Qu\'e8c m\'e9t c\'b8ch d\'cc d\'c6t v\'b5 quanh co.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-258\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 - }{\f37\fs20\expnd0\expndtw-4\cgrid0\insrsid1378858 T\'abi sinh ra trong m\'e9t gia \'ae\'d7nh nh\'b5
 nho An Nam. Nh\'f7ng gia \'ae\'d7nh nh\'ad th\'d5 \'eb n\'ad\'edc ch\'f3ng t\'abi kh\'abng ph\'b6i l\'b5m vi\'d6c g\'d7. Thanh ni\'aan trong nh\'f7ng gia \'ae\'d7nh \'cay th\'ad\'eang h\'e4c Kh\'e6ng gi\'b8o, \'ae\'e5ng ch\'dd ch\'bec bi\'d5t Kh\'e6ng gi
\'b8o kh\'abng ph\'b6i l\'b5 t\'abn gi\'b8o m\'b5 l\'b5 m\'e9t th\'f8 khoa h\'e4c v\'d2 kinh nghi\'d6m \'ae\'b9o \'ae\'f8c v\'b5 ph\'d0p \'f8ng x\'f6. V\'b5 tr\'aan c\'ac s\'eb \'ae\'e3 ng\'ad\'eai ta \'ae\'ada ra kh\'b8i ni\'d6m v\'d2 "th\'d5 gi\'edi 
\'ae\'b9i \'ae\'abng". Khi t\'abi \'ae\'e9 m\'ad\'eai ba tu\'e6i, l\'c7n \'ae\'c7u ti\'aan t\'abi \'ae\'ad\'eec nghe ba ch\'f7 Ph\'b8p: T\'f9 do, B\'d7nh \'ae\'bcng, B\'b8c \'b8i. \'a7\'e8i v\'edi ch\'f3ng t\'abi, ng\'ad\'eai da tr\'beng n\'b5o c\'f2ng l
\'b5 ng\'ad\'eai Ph\'b8p. Ng\'ad\'eai Ph\'b8p \'ae\'b7 n\'e3i th\'d5. V\'b5 t\'f5 thu\'eb \'cay, t\'abi r\'cat mu\'e8n l\'b5m quen v\'edi n\'d2n v\'a8n minh Ph\'b8p, mu\'e8n t\'d7m xem nh\'f7ng g\'d7 \'c8n \'ae\'bbng sau nh\'f7ng ch\'f7 \'cay. Nh\'ad
ng trong nh\'f7ng tr\'ad\'eang h\'e4c cho ng\'ad\'eai b\'b6n x\'f8, b\'e4n Ph\'b8p d\'b9y ng\'ad\'eai nh\'ad d\'b9y con v\'d1t. Ch\'f3ng gi\'cau kh\'abng cho ng\'ad\'eai n\'ad\'edc t\'abi xem s\'b8ch b\'b8o. Kh\'abng ph\'b6i ch\'d8 s\'b8ch c\'f1a c\'b8
c nh\'b5 v\'a8n m\'edi, m\'b5 c\'b6 R\'f3tx\'ab v\'b5 M\'abngtexki\'ac c\'f2ng b\'de c\'cam. V\'cby th\'d7 ph\'b6i l\'b5m th\'d5 n\'b5o b\'a9y gi\'ea ? T\'abi quy\'d5t \'ae\'denh t\'d7m c\'b8ch \'aei ra n\'ad\'edc ngo\'b5i. Th\'a9n ph\'cbn ng\'ad\'ea
i An Nam ch\'d8 l\'b5 th\'a9n ph\'cbn ng\'ad\'eai n\'abng n\'ab. Ch\'f3ng t\'abi b\'de c\'cam, kh\'abng ph\'b6i ch\'d8 l\'b5 b\'de c\'cam \'aei du l\'dech ra n\'ad\'edc ngo\'b5i m\'b5 c\'b6 \'aei trong n\'ad\'edc c\'f2ng kh\'abng \'ae\'ad\'eec. \'a7\'ad
\'eang s\'bet \'ae\'ad\'eec x\'a9y d\'f9ng v\'edi m\'f4c \'ae\'ddch "chi\'d5n l\'ad\'eec" ri\'aang. Theo con m\'bet c\'f1a b\'e4n th\'f9c d\'a9n, ch\'f3ng t\'abi ch\'ada \'ae\'f1 tr\'d7nh \'ae\'e9 \'ae\'d3 s\'f6 d\'f4ng lo\'b9i \'ae\'ad\'eang n\'b5y. T
\'abi lang thang ra b\'ea bi\'d3n v\'b5 t\'abi \'ae\'b7 v\'ad\'eet bi\'d3n ra n\'ad\'edc ngo\'b5i. N\'a8m \'cay t\'abi 19 tu\'e6i. }{\f38\fs20\expnd0\expndtw-4\cgrid0\insrsid1378858 \'eb}{\f37\fs20\expnd0\expndtw-4\cgrid0\insrsid1378858  Ph\'b8p l\'f3c 
\'ae\'e3 \'aeang c\'e3 t\'e6ng tuy\'d3n c\'f6. B\'e4n t\'ad s\'b6n Ph\'b8p \'ae\'b7 d\'efng nh\'f7ng th\'f1 \'aeo\'b9n b\'c8n th\'d8u nh\'cat \'ae\'d3 b\'abi nh\'e4 l\'c9n nhau.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 G\'ad\'acng m\'c6t Nguy\'d4n }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 i Qu\'e8c nh
\'a8n l\'b9i m\'e9t c\'b8ch khinh b\'d8. \'a7\'abi m\'bet n\'c6ng n\'d2, u \'b8m b\'e7ng b\'f5ng l\'aan. Trong \'ae\'abi m\'bet m\'eb to, \'f8a l\'d6, anh nh\'d7n v\'d2 xa x\'a8m: 
\par - Khi b\'e4n Ph\'b8p \'ae\'d5n c\'ad\'edp n\'ad\'edc t\'abi, nh\'f7ng gia \'ae\'d7nh n\'d2n n\'d5p, gia gi\'b8o \'ae\'b7 b\'e1 ch\'b9y h\'d5t kh\'abng c\'e9ng t\'b8c v\'edi ch\'f3ng. B\'e4n v\'ab l\'b9i quen th\'e3i xu n\'denh \'ae\'b7 chi\'d5m h\'d5t nh
\'b5 c\'f6a v\'b5 v\'ad\'ean ru\'e9ng, ch\'f3ng tr\'eb n\'aan nh\'f7ng t\'aan t\'ad s\'b6n m\'edi gi\'b5u s\'f4, v\'b5 ch\'f3ng c\'e3 kh\'b6 n\'a8ng gi\'b8o d\'f4c con c\'b8i theo ki\'d3u Ph\'b8p. B\'aan ch\'f3ng t\'abi coi nh\'f7ng ng\'ad\'eai thanh ni
\'aan \'aei h\'e4c c\'b8c tr\'ad\'eang d\'dfng c\'f1a b\'e4n Ph\'b8p l\'b5 b\'e4n ng\'ad\'eai b\'e1 \'aei, l\'b5 nh\'f7ng \'ae\'e5 c\'c6n b\'b7. Th\'d5 m\'b5 ng\'ad\'eai ta \'ae\'b7 tr\'b6 ti\'d2n \'ae\'d3 l\'b5m vi\'d6c \'ae\'e3. V\'b5 d\'ef nh\'f7ng k
\'ce h\'e4c \'eb c\'b8c tr\'ad\'eang \'ae\'e3 c\'e3 \'ae\'c7n \'ae\'e9n \'ae\'d5n m\'f8c n\'b5o ch\'f3ng c\'f2ng c\'e8 \'ae\'d3 \'ae\'ad\'eec \'aei l\'b5m c\'b6nh s\'b8t, l\'b5m sen \'ae\'c7m. B\'e4n c\'e8 \'ae\'b9o \'eb n\'ad\'edc t\'abi chi\'d5m t\'ed
i m\'e9t ph\'c7n n\'a8m t\'e6ng s\'e8 ru\'e9ng \'ae\'cat c\'b6 n\'ad\'edc. Ch\'d8 c\'e3 nh\'f7ng ch\'f1 \'ae\'e5n \'aei\'d2n m\'edi so s\'b8nh \'ae\'ad\'eec v\'edi h\'e4.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Th\'f9c d\'a9n Ph\'b8p l\'b5 g\'d7? }{\f38\fs20\cgrid0\insrsid1378858 \'e5}{\f37\fs20\cgrid0\insrsid1378858 , 
\'ae\'e3 l\'b5 nh\'f7ng k\'ce b\'cat t\'b5i v\'b5 thi\'d3n c\'cbn. Vi\'d6c quan t\'a9m \'ae\'c7u ti\'aan c\'f1a ch\'f3ng l\'b5 h\'d7nh th\'b5nh nh\'e3m ng\'ad\'eai th\'a9n thu\'e9c. Sau \'ae\'e3, l\'b5 chi\'d5m \'aeo\'b9t v\'b5 c\'ad\'edp b\'e3c th\'d5 n
\'b5o cho th\'cbt nhi\'d2u v\'b5 th\'cbt nhanh. M\'f4c \'ae\'ddch c\'f1a to\'b5n b\'e9 ch\'ddnh s\'b8ch n\'b5y l\'b5 c\'e3 \'ae\'ad\'eec m\'e9t ng\'abi nh\'b5 nh\'e1, "ng\'abi nh\'b5 nh\'e1 c\'f1a m\'d7nh" \'eb Ph\'b8p.
\par - Th\'f9c d\'a9n Ph\'b8p \'ae\'c7u \'ae\'e9c nh\'a9n d\'a9n ch\'f3ng t\'abi. Ch\'f3ng b\'bet m\'e4i ng\'ad\'eai ph\'b6i u\'e8ng r\'ad\'eeu. Ch\'f3ng t\'abi c\'e3 phong t\'f4c l\'cay g\'b9o ngon l\'b5m ra r\'ad\'eeu u\'e8ng, khi c\'e3 b\'b9n t\'edi ch\'ac
i ho\'c6c khi c\'e3 ng\'b5y gi\'e7 t\'e6 ti\'aan. B\'e4n th\'f9c d\'a9n Ph\'b8p \'ae\'b7 l\'cay g\'b9o x\'cau, r\'ce ti\'d2n n\'cau r\'ad\'eeu. Kh\'abng ai th\'ccm mua c\'f1a ch\'f3ng. Kh\'e8n thay r\'ad\'eeu l\'b5m ra l\'b9i qu\'b8 nhi\'d2u. Sau \'ae\'e3
, ng\'ad\'eai ta h\'b9 l\'d6nh cho c\'b8c vi\'aan t\'d8nh tr\'ad\'ebng c\'f8 theo \'ae\'c7u ng\'ad\'eai m\'b5 b\'bet bu\'e9c ph\'b6i \'aei mua th\'f8 r\'ad\'eeu kh\'abng ai u\'e8ng.
\par T\'abi \'ae\'b7 h\'d7nh dung ra \'ae\'ad\'eec m\'e9t c\'b8ch r\'cat c\'f4 th\'d3 b\'e4n th\'f9c d\'a9n \'aeang d\'efng r\'ad\'eeu \'ae\'c7u \'ae\'e9c nh\'ad th\'d5 n\'b5o d\'a9n t\'e9c An Nam \'ae\'b8ng y\'aau, m\'e9t d\'a9n t\'e9c r\'cat l\'dech thi\'d6
p v\'b5 \'ae\'e9 l\'ad\'eeng, r\'cat gh\'d0t nh\'f7ng g\'d7 th\'b8i qu\'b8. D\'b8ng d\'cap c\'f1a con ng\'ad\'eai \'aeang ng\'e5i tr\'ad\'edc m\'c6t t\'abi \'ae\'a9y, Nguy\'d4n }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 i Qu
\'e8c, c\'f2ng \'aeang to\'b6 ra m\'e9t c\'b8i g\'d7 th\'cbt l\'dech thi\'d6p v\'b5 t\'d5 nh\'de. V\'a8n minh ch\'a9u \'a2u tr\'aan \'ae\'cat n\'ad\'edc \'cay d\'efng l\'ad\'eci l\'aa v\'b5 r\'ad\'eeu \'ae\'e9c v\'b5 che gi\'cau t\'cat c\'b6 nh\'f7ng c
\'b8i \'ae\'e3 d\'ad\'edi t\'b5 \'b8o d\'b5i \'aeen c\'f1a b\'e4n c\'e8 \'ae\'b9o. T\'f5 Nguy\'d4n }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 i Qu\'e8c \'ae\'b7 to\'b6 ra m\'e9t th\'f8 v\'a8n ho\'b8, kh\'abng ph\'b6i v\'a8n ho
\'b8 \'a2u ch\'a9u, m\'b5 c\'e3 l\'cf l\'b5 m\'e9t n\'d2n v\'a8n ho\'b8 t\'ad\'acng lai.
\par - Hi\'d6n nay, \'eb Pari, m\'e9t nh\'e3m c\'b8c \'ae\'e5ng ch\'dd t\'f5 c\'b8c n\'ad\'edc thu\'e9c \'ae\'dea c\'f1a Ph\'b8p, 5-6 ng\'ad\'eai Nam K\'fa, Xu\'ae\'a8ng, Ma\'aeag\'b8txca, Haiti \'aeang xu\'cat b\'b6n t\'ea b\'b8o }{
\i\f37\fs20\cgrid0\insrsid1378858 Le Paria }{\f37\fs20\cgrid0\insrsid1378858 \'ae\'d3 ch\'e8ng l\'b9i ch\'ddnh s\'b8ch thu\'e9c \'ae\'dea c\'f1a Ph\'b8p. \'a7\'e3 l\'b5 t\'ea b\'b8o nh\'e1. C\'b8c c\'e9ng t\'b8c vi\'aan ph\'b6i b\'e1 ti\'d2n t\'f3i ra 
\'ae\'d3 xu\'cat b\'b6n, thay cho vi\'d6c nh\'cbn ti\'d2n nhu\'cbn b\'f3t.
\par C\'a9y g\'cby tre v\'edi l\'eai hi\'d6u tri\'d6u in tr\'aan b\'b8o \'ae\'b7 b\'dd m\'cbt \'ae\'d5n kh\'bep c\'b8c l\'b5ng m\'b9c. N\'e3 \'ae\'ad\'eec chuy\'d3n t\'f5 v\'efng n\'b5y sang v\'efng kh\'b8c, v\'b5 \'ae\'b7 c\'e3 s\'f9 \'ae\'e5ng t\'d7nh v\'ed
i nhau. Nh\'adng ng\'ad\'eai An Nam \'ae\'b7 ph\'b6i tr\'b6 gi\'b8 \'ae\'bet \sect }\sectd \lndscpsxn\marglsxn1928\margtsxn1588\margbsxn1021\psz9\linex0\headery680\footery510\cols2\colsx1134\endnhere\sectdefaultcl\sftnbj {\header \trowd \lastrow 
