\insrsid1378858 
\par }}\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 Ch\'ddnh ph\'f1 li\'aan bang th\'beng l\'eei v\'f5
a gi\'b6i ph\'e3ng nh\'f7ng ng\'ad\'eai da \'aeen v\'b5 l\'b5m cho h\'e4 tr\'eb th\'b5nh nh\'f7ng ng\'ad\'eai c\'abng d\'a9n. N\'abng nghi\'d6p mi\'d2n Nam, thi\'d5u nh\'a9n c\'abng ng\'ad\'eai da \'aeen, n\'aan kh\'abng c\'e3 ng\'ad\'eai l\'b5m. B\'e4n 
\'ae\'dea ch\'f1 c\'f2 l\'a9m v\'b5o nguy c\'ac ph\'b8 s\'b6n. Gi\'f7a khi \'ae\'e3 th\'d7 }{\i\f37\fs20\cgrid0\insrsid1378858 nh\'f7ng \'ae\'b6ng vi\'aan c\'f1a Klan }{\f37\fs20\cgrid0\insrsid1378858 tuy\'aan b\'e8 nguy\'aan t\'bec }{
\i\f37\fs20\cgrid0\insrsid1378858 quy\'d2n t\'e8i cao c\'f1a gi\'e8ng ng\'ad\'eai da tr\'beng. }{\f37\fs20\cgrid0\insrsid1378858 Ch\'e8ng ng\'ad\'eai da \'aeen, \'ae\'e3 l\'b5 ch\'ddnh s\'b8ch duy nh\'cat c\'f1a h\'e4. Giai c\'cap t\'ad s\'b6n n\'abng th
\'abn v\'b5 ch\'f1 n\'ab th\'cay ngay \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan }{\f37\fs20\cgrid0\insrsid1378858 l\'b5 m\'e9t tr\'ee th\'f1 \'ae\'bec l\'f9c, h\'c7u nh\'ad l\'b5 m\'e9t c\'f8u tinh. N\'e3 li\'d2n h\'d5t s\'f8c gi\'f3p \'ae\'ec 
\'ae\'b6ng \'ae\'e3. Bi\'d6n ph\'b8p h\'b5nh \'ae\'e9ng c\'f1a \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan }{\f37\fs20\cgrid0\insrsid1378858 \'aei t\'f5 do\'b9 n\'b9t \'ae\'d5n \'b8m s\'b8t. Ch\'f3ng \'ae\'b7 g\'a9y ra - trong 3 n\'a8m tr\'eai - c
\'ac man n\'b5o l\'b5 t\'e9i \'b8c v\'b5 th\'b6m ho\'b9 \'ae\'d5n n\'e7i nhi\'d2u ng\'ad\'eai v\'c9n \'f1ng h\'e9 ch\'f3ng, c\'f2ng ph\'b6i kh\'f1ng khi\'d5p m\'b5 xa l\'d7a ch\'f3ng.
\par V\'b5o kho\'b6ng n\'a8m 1869, \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan }{\f37\fs20\cgrid0\insrsid1378858 - tr\'ad\'edc \'b8p l\'f9c c\'f1a d\'ad lu\'cbn c\'abn}{\f37\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 g ch\'f3ng - \'ae\'b7 b\'de "Ho
\'b5ng \'ae\'d5" c\'f1a n\'e3 gi\'b6i t\'b8n. \'a7\'b6ng \'ae\'e3 c\'e3 m\'e9t Ho\'b5ng \'ae\'d5, song \'abng ta ch\'d8 c\'e3 m\'e9t uy quy\'d2n thu\'c7n tu\'fd v\'d2 danh ngh\'dca m\'b5 th\'abi. Nh\'f7ng \'ae\'b6ng }{
\i\f37\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 Klan }{\f37\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 \'eb c\'b8c \'ae\'dea ph\'ad\'acng ti\'d5p t\'f4c t\'e5n t\'b9i v\'b5 g\'a9y ra nh\'f7ng t\'e9i \'b8c. Gi\'b8o s\'ad M\'d5clin - ng\'ad\'eai \'ae
\'b7 cung c\'cap cho ch\'f3ng t\'abi nh\'f7ng t\'b5i li\'d6u n\'b5y - n\'e3i r\'bbng m\'e7i trang trong m\'ad\'eai ba cu\'e8n s\'b8ch d\'c7y c\'e9p \'aei\'d2u tra v\'d2 nh\'f7ng h\'b5nh \'ae\'e9ng c\'f1a \'ae\'b6ng }{
\i\f37\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 Klan }{\f37\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 h\'e5i 1871-1872, \'ae\'d2u c\'e3 ghi l\'b9i m\'e9t v\'f4 \'ae\'b8nh \'ae\'cbp ng\'ad\'eai da \'aeen ho\'c6c ng\'ad\'eai da tr\'beng. Nh\'f7ng vi
\'d6c t\'b5n b\'b9o \'ae\'e3, th\'ad\'eang ch\'d8 l\'b5 do th\'e3i t\'b5n b\'b9o m\'b5 th\'abi. \'a7\'e8i v\'edi ch\'f3ng, nh\'f7ng h\'b5nh \'ae\'e9ng \'ae\'e3 l\'b5 m\'e9t l\'e8i ti\'aau khi\'d3n th\'ddch th\'f3.}{\f37\fs20\cgrid0\insrsid1378858 
\par \'a7\'d3 bi\'d5t r\'e2 h\'acn, v\'b5 ph\'b8n \'aeo\'b8n \'ae\'ad\'eec \'ae\'f3ng h\'acn v\'d2 \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan, }{\f37\fs20\cgrid0\insrsid1378858 th\'d7 kh\'abng g\'d7 b\'bbng l\'b5 tr\'ddch d\'c9n ngay b\'b5i di\'d4n v
\'a8n c\'f1a nguy\'aan l\'b7o ngh\'de vi\'d6n S\'d0cman, \'eb \'a4hai\'ab, \'ae\'e4c tr\'ad\'edc Th\'ad\'eeng ngh\'de vi\'d6n h\'e5i th\'b8ng 3-1871. S\'d0cman h\'e1i: "Li\'d6u c\'e3 m\'e9t ngh\'de vi\'aan n\'b5o c\'e3 th\'d3 n\'aau ra cho t\'abi bi\'d5
t- sau khi l\'f4c l\'b9i nh\'f7ng t\'e9i \'b8c trong t\'cat c\'b6 c\'b8c th\'eai \'ae\'b9i - m\'e9t h\'e9i n\'b5o ho\'c6c m\'e9t b\'cc \'ae\'b6ng n\'b5o m\'b5 l\'b9i c\'e3 nh\'f7ng h\'b5nh \'ae\'e9ng v\'b5 nh\'f7ng \'fd \'ae\'denh t\'b5n kh\'e8c h\'ac
n, hung \'b8c h\'acn \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Ku Klux Klan }{\f37\fs20\cgrid0\insrsid1378858 kh\'abng ? \'a7\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Ku Klux Klan }{\f37\fs20\cgrid0\insrsid1378858 l\'b5 m\'e9t h\'e9i k\'ddn: th\'b5
nh l\'cbp b\'bbng c\'b8ch tuy\'aan th\'d6, \'ae\'b6ng vi\'aan c\'f1a n\'e3 \'aei \'b8m s\'b8t, tr\'e9m c\'bep, c\'ad\'edp ph\'b8, h\'b5nh hung, ch\'f6i b\'edi, do\'b9 n\'b9t. B\'e4n ch\'f3ng ph\'b9m nh\'f7ng t\'e9i \'b8c \'ae\'e3 kh\'abng ph\'b6i l\'b5 
\'ae\'e8i v\'edi nh\'f7ng k\'ce m\'b9nh v\'b5 k\'ce gi\'b5u, m\'b5 l\'b5 \'ae\'e8i v\'edi nh\'f7ng ng\'ad\'eai ngh\'cco, nh\'f7ng ng\'ad\'eai y\'d5u \'aeu\'e8i, nh\'f7ng ng\'ad\'eai hi\'d2n l\'b5nh, nh\'f7ng ng\'ad\'eai kh\'abng c\'e3 kh\'b6 n\'a8ng t\'f9
 v\'d6!".
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Tuy nhi\'aan, \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan }{\f37\fs20\cgrid0\insrsid1378858 c\'f2ng \'ae
\'b7 s\'e8ng v\'b5 "ho\'b9t \'ae\'e9ng" trong b\'e8n ch\'f4c n\'a8m tr\'eai m\'e9t c\'b8ch kh\'abng v\'ce vang g\'d7 cho l\'bem.
\par }\pard\plain \s25\qj \fi426\li0\ri0\sb200\sa120\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 \'a7\'b6NG Klan M\'edI
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-288\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 Th\'b8ng 10 n\'a8m 1915, trong t\'d7nh h\'d7nh m
\'edi c\'f1a n\'ad\'edc M\'fc, Uyliam Gi\'abd\'d0p Ximm\'abn, "Ho\'b5ng \'ae\'d5" m\'edi c\'f1a \'ae\'b6ng Klan, \'ae\'b7 c\'efng v\'edi 34 ng\'ad\'eai b\'b9n ph\'f4c h\'e5i l\'b9i \'ae\'b6ng K.K.K. C\'ad\'acng l\'dcnh c\'f1a \'ae\'b6ng \'ae\'e3 l\'b5
: theo l\'e8i M\'fc 100%, t\'f8c l\'b5 ch\'e8ng Kit\'ab gi\'b8o, ch\'e8ng ng\'ad\'eai da v\'b5ng, ch\'e8ng c\'abng nh\'a9n, ch\'e8ng ng\'ad\'eai da \'aeen.
\par C\'c7n ch\'f3 \'fd l\'b5 sau cu\'e9c chi\'d5n tranh Nam - B\'bec v\'b5 vi\'d6c gi\'b6i ph\'e3ng ng\'ad\'eai da \'aeen, \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Ku Klux Klan }{\f37\fs20\cgrid0\insrsid1378858 c\'f2 \'ae\'b7 ra \'ae\'eai v\'edi m\'f4c 
\'ae\'ddch c\'b6n b\'ad\'edc \'ae\'ad\'eang ho\'b9t \'ae\'e9ng x\'b7 h\'e9i c\'f1a nh\'f7ng ng\'ad\'eai \'ae\'ad\'eec gi\'b6i ph\'e3ng. Trong cu\'e9c chi\'d5n tranh th\'d5 gi\'edi, M\'fc tuy\'d3n m\'e9 v\'b5o l\'f4c qu\'a9n v\'b5 thu\'fb qu\'a9n c\'f1a m
\'d7nh h\'b5ng tr\'a8m ngh\'d7n ng\'ad\'eai da \'aeen; ng\'ad\'eai ta h\'f8a v\'edi h\'e4 l\'b5 s\'cf th\'f9c hi\'d6n nh\'f7ng c\'b6i c\'b8ch v\'d2 m\'c6t x\'b7 h\'e9i v\'b5 ch\'ddnh tr\'de; sau khi \'ae\'b7 c\'efng hy sinh nh\'ad ng\'ad\'eai da tr\'be
ng, h\'e4 \'ae\'b7 r\'f4t r\'cc y\'aau c\'c7u \'ae\'ad\'eec h\'ad\'ebng nh\'f7ng quy\'d2n l\'eei nh\'ad ng\'ad\'eai da tr\'beng. T\'d7nh h\'d7nh \'ae\'e3 c\'f2ng ngang nh\'ad m\'e9t phong tr\'b5o "gi\'b6i ph\'e3ng l\'c7n th\'f8 hai". Th\'d5 l\'b5 \'ae\'b6
ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan }{\f37\fs20\cgrid0\insrsid1378858 m\'edi xu\'cat hi\'d6n.
\par "Ho\'b5ng \'ae\'d5" Ximm\'abn c\'f2ng l\'b9i th\'b5nh l\'cbp c\'b8i "v\'ad\'acng qu\'e8c v\'ab h\'d7nh" \'eb mi\'d2n Nam n\'ad\'edc M\'fc - x\'f8 s\'eb c\'f1a nh\'f7ng t\'aan ch\'f1 \'ae\'e5n \'aei\'d2n l\'edn v\'b5 nh\'f7ng t\'aan ph\'b6n \'ae\'e8i vi
\'d6c gi\'b6i ph\'e3ng n\'ab l\'d6, qu\'aa h\'ad\'acng c\'f1a ch\'d5 \'ae\'e9 n\'ab d\'dech v\'b5 vi\'d6c h\'b5nh h\'d7nh theo ki\'d3u Lins\'ac, t\'e6 qu\'e8c c\'f1a \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan }{\f37\fs20\cgrid0\insrsid1378858 c
\'f2. Tr\'b6 l\'eai m\'e9t ng\'ad\'eai \'ae\'d5n ph\'e1ng v\'can, Uyliam Gi\'abd\'d0p Ximm\'abn \'ae\'b7 n\'e3i v\'d2 nh\'f7ng m\'f4c \'ae\'ddch c\'f1a m\'d7nh nh\'ad sau: "Ch\'f3ng t\'abi th\'cay r\'e2 r\'bbng ph\'b6i b\'b6o \'ae\'b6m quy\'d2n t\'e8
i cao c\'f1a gi\'e8ng ng\'ad\'eai da tr\'beng, ph\'b6i t\'ad\'edc nh\'f7ng quy\'d2n t\'f9 tr\'de \'ae\'b7 ban b\'e8 cho b\'e4n da \'aeen. }{\f38\fs20\cgrid0\insrsid1378858 \'fd}{\f37\fs20\cgrid0\insrsid1378858  tr\'eai mu\'e8n r\'bbng gi\'e8ng ng\'ad\'ea
i da tr\'beng ph\'b6i cao h\'acn; v\'b5 l\'d6nh tr\'eai \'ae\'b7 \'ae\'denh r\'bbng ng\'ad\'eai da \'aeen sinh ra l\'b5 \'ae\'d3 l\'b5m n\'ab l\'d6".
\par }\pard \qj \fi397\li0\ri0\sa80\sl-284\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Ngay sau khi \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan }{\f37\fs20\cgrid0\insrsid1378858 xu\'cat hi\'d6
n l\'b9i, th\'d7 ch\'d8 ri\'aang \'eb x\'f8 T\'d5cd\'b8t, ng\'ad\'eai ta \'ae\'b7 \'ae\'d5m \'ae\'ad\'eec h\'acn 80 v\'f4 \'ae\'b8nh \'ae\'cbp, trong m\'e9t n\'a8m, v\'b5 96 v\'f4 h\'b5nh h\'d7nh theo ki\'d3u Lins\'ac.
\par \'a7\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan }{\f37\fs20\cgrid0\insrsid1378858 \'ae\'c6c bi\'d6t th\'denh h\'b5nh \'eb Gio\'e3cgia, M\'ddtxixipi, T\'d5cd\'b8t, Alabama v\'b5 }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 cc
\'a8ngdax\'ac. Trong c\'b8c x\'f8 \'ae\'e3 c\'e3 nhi\'d2u n\'b9n nh\'a9n b\'de h\'b5nh h\'d7nh theo ki\'d3u Lins\'ac nh\'cat.
\par N\'a8m 1919, \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Ku Klux Klan }{\f37\fs20\cgrid0\insrsid1378858 \'ae\'b7 thi\'aau s\'e8ng: 4 ng\'ad\'eai da \'aeen \'eb Gio\'e3cgia, 2 \'eb M\'ddtxixipi, 1 \'eb T\'d5cd\'b8t.
\par Ch\'f3ng \'ae\'b7 h\'b5nh h\'d7nh: 22 ng\'ad\'eai da \'aeen \'eb Gio\'e3cgia, 12 \'eb M\'ddtxixipi, 10 \'eb }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 cc\'a8ngdax\'ac, 8 \'eb Alabama, 3 \'eb T\'d5cd\'b8t.
\par Ch\'f3ng \'ae\'b7 x\'abng v\'b5o v\'b5 ph\'b8 hu\'fb c\'b8c nh\'b5 t\'ef \'ae\'d3 h\'b5nh h\'d7nh nh\'f7ng ng\'ad\'eai da \'aeen b\'de giam \'eb \'ae\'cay: 5 l\'c7n \'eb Gio\'e3cgia, 3 l\'c7n \'eb Alabama, 3 l\'c7n \'eb M\'ddtxixipi, 3 l\'c7n \'eb T\'d5cd
\'b8t, 2 l\'c7n \'eb }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 cc\'a8ngdax\'ac.
\par Ch\'f3ng \'ae\'b7 h\'b5nh h\'d7nh: 12 ph\'f4 n\'f7 \'eb M\'ddtxixipi, 7 \'eb Alabama, 6 \'eb T\'d5cd\'b8t, 5 \'eb }{\f38\fs20\cgrid0\insrsid1378858 \'b8}{\f37\fs20\cgrid0\insrsid1378858 cc\'a8ngdax\'ac, 5 \'eb Gio\'e3cgia.
\par Ch\'f3ng \'ae\'b7 thi\'aau, treo c\'e6, d\'d7m xu\'e8ng n\'ad\'edc cho ch\'d5t ho\'c6c b\'ben 9 c\'f9u binh s\'dc da \'aeen.
\par \'a7\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan }{\f37\fs20\cgrid0\insrsid1378858 c\'dfn can ph\'b9m nhi\'d2u v\'f4 h\'b5nh h\'d7nh theo ki\'d3u Lins\'ac \'eb c\'b8c x\'f8 kh\'b8c n\'f7a, nh\'adng \'eb \'ae\'a9y ch\'f3ng t\'abi ch\'d8 n\'aau nh\'f7
ng con s\'e8 \'ae\'b7 ch\'bec ch\'ben m\'b5 th\'abi.
\par }\pard\plain \s25\qj \fi426\li0\ri0\sb200\sa120\sl-284\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 S\'f9 SUY T\'b5N C\'f1A \'a7\'b6
NG KU KLUX Klan
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-284\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 \'a7\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 
Klan }{\f37\fs20\cgrid0\insrsid1378858 nh\'cat \'ae\'denh ph\'b6i b\'de ti\'aau di\'d6t v\'d7 nhi\'d2u l\'cf.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-284\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 1. Trong chi\'d5n tranh, ng\'ad\'eai da \'aeen \'ae\'b7 hi\'d3u r\'bbng h\'e4 l\'b5 m\'e9t l\'f9c l\'ad
\'eeng n\'d5u h\'e4 \'aeo\'b5n k\'d5t l\'b9i; cho n\'aan h\'e4 kh\'abng \'ae\'d3 cho ng\'ad\'eai kh\'b8c t\'f9 do \'ae\'b8nh \'ae\'cbp, ho\'c6c gi\'d5t h\'b9i \'ae\'e5ng b\'b5o c\'f1a h\'e4 n\'f7a. H\'e4 ch\'e8ng l\'b9i m\'e4i m\'adu toan h\'b5nh hung c
\'f1a \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan. }{\f37\fs20\cgrid0\insrsid1378858 Th\'b8ng 7-1919, \'eb Oasinht\'acn, h\'e4 \'ae\'b7 \'ae\'ad\'acng \'ae\'c7u v\'edi \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan }{
\f37\fs20\cgrid0\insrsid1378858 v\'b5 \'ae\'b8m \'ae\'abng cu\'e5ng lo\'b9n. Trong 4 ng\'b5y, cu\'e9c chi\'d5n \'ae\'cau s\'abi s\'f4c \'eb th\'f1 \'ae\'ab. Th\'b8ng 8, h\'e4 \'ae\'b7 \'ae\'b8nh nhau trong 5 ng\'b5y v\'edi \'ae\'b6ng }{
\i\f37\fs20\cgrid0\insrsid1378858 Klan }{\f37\fs20\cgrid0\insrsid1378858 v\'b5 \'ae\'b8m \'ae\'abng \'eb Sicag\'ab, 7 trung \'aeo\'b5n \'ae\'b7 \'ae\'ad\'eec huy \'ae\'e9ng \'ae\'d3 l\'cbp l\'b9i tr\'cbt t\'f9. Th\'b8ng 9, ch\'ddnh ph\'f1 \'ae\'b7 bu\'e9
c ph\'b6i g\'f6i qu\'a9n \'ae\'e9i li\'aan bang \'ae\'d5n Omaha \'ae\'d3 ch\'cam d\'f8t m\'e9t tr\'cbn \'ae\'b8nh nhau t\'ad\'acng t\'f9 nh\'ad th\'d5. T\'b9i c\'b8c x\'f8 kh\'b8c, ng\'ad\'eai da \'aeen c\'f2ng \'ae\'b7 t\'f9 v\'d6 kh\'abng k\'d0m ph\'c7
n c\'ad\'acng quy\'d5t.
\par 2. C\'f2ng nh\'ad \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan }{\f37\fs20\cgrid0\insrsid1378858 tr\'ad\'edc kia, v\'d7 nh\'f7ng h\'b5nh \'ae\'e9ng th\'b8i qu\'b8, n\'aan \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan }{
\f37\fs20\cgrid0\insrsid1378858 m\'edi \'ae\'b7 v\'cap ph\'b6i d\'ad lu\'cbn c\'f1a c\'abng ch\'f3ng \'ae\'d5n n\'e7i nh\'f7ng ng\'ad\'eai ban \'ae\'c7u t\'b8n th\'b5nh n\'e3 ho\'c6c \'aei theo n\'e3, nay c\'f2ng b\'bet \'ae\'c7u b\'e1 r\'aci n\'e3. Nh
\'f7ng chuy\'d6n x\'ab x\'b8t trong n\'e9i b\'e9, nh\'f7ng vi\'d6c qu\'b8 x\'cau xa \'ae\'e5i t\'d6 v\'b5 nh\'f7ng v\'f4 gian l\'cbn v\'d2 t\'b5i ch\'ddnh cu\'e8i c\'efng \'ae\'b7 l\'b5m cho nh\'f7ng ng\'ad\'eai b\'b5ng quan nh\'cat v\'b5 d\'d4 d\'b7i nh
\'cat c\'f2ng ph\'b6i \'aeau l\'dfng. Th\'ad\'eeng ngh\'de vi\'d6n \'ae\'b7 bu\'e9c ph\'b6i truy t\'e8 \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan. }{\f37\fs20\cgrid0\insrsid1378858 Ngay c\'b6 b\'b8o ch\'dd t\'ad s\'b6n nh\'ad t\'ea }{
\i\f37\fs20\cgrid0\insrsid1378858 New York World, }{\f37\fs20\cgrid0\insrsid1378858 t\'ea }{\i\f37\fs20\cgrid0\insrsid1378858 Chicago Defender, }{\f37\fs20\cgrid0\insrsid1378858 v.v. c\'f2ng c\'abng k\'ddch ch\'f3ng.
\par 3. "L\'e8i M\'fc 100 ph\'c7n tr\'a8m" v\'b5 th\'b8i \'ae\'e9 ch\'e8ng \'ae\'e8i c\'abng nh\'a9n c\'f1a ch\'f3ng \'ae\'b7 l\'b5m cho 20.000.000 gi\'b8o d\'a9n M\'fc, 3.000.000 ng\'ad\'eai Do Th\'b8i, 20.000.000 ngo\'b9i ki\'d2u, 12.000.000 ng\'ad\'eai da 
\'aeen, t\'cat c\'b6 nh\'f7ng ng\'ad\'eai M\'fc bi\'d5t \'aei\'d2u v\'b5 to\'b5n b\'e9 giai c\'cap c\'abng nh\'a9n M\'fc, t\'cbp h\'eep l\'b9i ph\'b6n \'ae\'e8i ch\'f3ng.
\par T\'b9i \'a7\'b9i h\'e9i Li\'aan hi\'d6p ng\'ad\'eai da \'aeen v\'f5a qua, ng\'ad\'eai ta \'ae\'b7 th\'abng qua b\'b6n ki\'d5n ngh\'de sau \'ae\'a9y:
\par "Ch\'f3ng t\'abi tuy\'aan b\'e8 r\'bbng \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Ku Klux Klan }{\f37\fs20\cgrid0\insrsid1378858 l\'b5 k\'ce th\'ef c\'f1a lo\'b5i ng\'ad\'eai; ch\'f3ng t\'abi tuy\'aan b\'e8 quy\'d5t \'ae\'denh \'ae\'cau tranh v\'edi 
\'ae\'b6ng \'ae\'e3 \'ae\'d5n c\'efng v\'b5 k\'d2 vai s\'b8t c\'b8nh v\'edi t\'cat c\'b6 nh\'f7ng ng\'ad\'eai lao \'ae\'e9ng n\'ad\'edc ngo\'b5i \'eb M\'fc c\'f2ng nh\'ad v\'edi c\'b6 nh\'f7ng ng\'ad\'eai b\'de \'ae\'b6ng \'ae\'e3 h\'b5nh h\'b9".
\par M\'c6t kh\'b8c, vi\'d6c di c\'ad c\'f1a ng\'ad\'eai da \'aeen mi\'d2n Nam n\'abng nghi\'d6p l\'aan mi\'d2n B\'bec c\'abng nghi\'d6p \'ae\'b7 bu\'e9c nh\'f7ng t\'aan ch\'f1 \'ae\'e5n \'aei\'d2n - b\'de nguy c\'ac ph\'b8 s\'b6n v\'d7 thi\'d5u nh\'a9n c\'ab
ng - ph\'b6i n\'edi tay trong quan h\'d6 \'ae\'e8i x\'f6 v\'edi ng\'ad\'eai lao \'ae\'e9ng da \'aeen, v\'b5 do \'ae\'e3, ng\'b5y c\'b5ng ph\'b6i lu\'abn lu\'abn l\'aan \'b8n nh\'f7ng ph\'ad\'acng ph\'b8p v\'b5 nh\'f7ng s\'f9 b\'b9o ng\'ad\'eec c\'f1
a tay sai c\'f1a ch\'f3ng l\'b5 \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Klan.}{\f37\fs20\cgrid0\insrsid1378858 
\par 4. Sau h\'d5t \'ae\'b6ng }{\i\f37\fs20\cgrid0\insrsid1378858 Ku Klux Klan }{\f37\fs20\cgrid0\insrsid1378858 mang t\'cat c\'b6 nh\'f7ng c\'b8i x\'cau c\'f1a \sect }\sectd 
