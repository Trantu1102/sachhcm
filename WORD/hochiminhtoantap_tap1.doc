\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 H\'bbng n\'a8m, ng\'ad\'eai An Nam ph\'b6i l\'b5m m\'e9t s
\'e8 ng\'b5y kh\'abng c\'abng cho Nh\'b5 n\'ad\'edc "b\'b6o h\'e9". Theo l\'d6, s\'e8 ng\'b5y \'cay \'ae\'denh t\'f5 10 \'ae\'d5n 30 ng\'b5y. Nh\'adng khi c\'e3 vi\'d6c nhi\'d2u, ch\'bcng h\'b9n \'ae\'bep m\'e9t con \'ae\'ad\'eang, ho\'c6c \'ae\'b5o m\'e9
t c\'b8i l\'b9ch, ng\'ad\'eai ta kh\'abng tu\'a9n theo gi\'edi h\'b9n quy \'ae\'denh \'ae\'e3. Khi kh\'abng c\'e3 vi\'d6c th\'d7 ng\'ad\'eai b\'b6n x\'f8 l\'b9i ph\'b6i chu\'e9c nh\'f7ng ng\'b5y t\'b9p d\'dech c\'f1a m\'d7nh, ngh\'dca l\'b5 ph\'b6i tr\'b6
 ti\'d2n cho Nh\'b5 n\'ad\'edc thay cho nh\'f7ng ng\'b5y kh\'abng ph\'b6i \'aei l\'b5m kh\'e6 sai kh\'abng c\'abng \'cay. Ngo\'b5i vi\'d6c t\'b9p d\'dech, c\'dfn c\'e3 vi\'d6c khu\'a9n v\'b8c. M\'e7i l\'c7n c\'e3 m\'e9t ng\'ad\'eai Ph\'b8p qua l\'b5ng m
\'d7nh l\'b5 ng\'ad\'eai An Nam ph\'b6i \'aei khi\'aang v\'e2ng, khi\'aang \'ae\'e5 \'ae\'b9c cho \'abng ta, v\'b5 khi\'aang c\'b6 v\'e2ng v\'b5 \'ae\'e5 \'ae\'b9c c\'f1a nh\'f7ng ng\'ad\'eai tu\'fa t\'efng c\'f1a \'abng ta n\'f7a. Nhi\'d2u khi, c\'b6 l
\'b5ng b\'de \'ae\'e9ng vi\'aan \'aei l\'b5m c\'b8i vi\'d6c kh\'abng c\'abng \'cay.
\par Nh\'adng th\'abi, t\'abi nh\'ad\'eang l\'eai cho ch\'ddnh ng\'ad\'eai Ph\'b8p n\'e3i:
\par }{\f37\fs20\expnd0\expndtw-2\insrsid1378858 C\'abng vi\'d6c t\'b9p d\'dech \'ae\'b7 v\'b5 v\'c9n c\'dfn l\'b5 c\'ac h\'e9i cho ng\'ad\'eai ta l\'b9m d\'f4ng v\'ab k\'d3. Th\'ad\'eang th\'d7 phu t\'b9p d\'dech ch\'d8 d\'efng \'ae\'d3 \'ae\'bep nh\'f7ng 
\'ae\'ad\'eang quanh c\'b8c to\'b5 s\'f8 \'ae\'d3 v\'b5i ng\'ad\'eai \'a2u d\'b9o c\'b6nh. Tuy nhi\'aan th\'d8nh tho\'b6ng c\'e3 vi\'aan c\'abng s\'f8, t\'e1 l\'dfng s\'e8t s\'beng, quy\'d5t \'ae\'denh l\'b5m m\'e9t c\'abng tr\'d7nh quan tr\'e4ng, nh\'ad 
\'ae\'bep m\'e9t con \'ae\'aa hay kh\'aci m\'e9t c\'b8i l\'b9ch cho d\'dfng n\'ad\'edc ch\'b6y theo h\'ad\'edng kh\'b8c. Trong tr\'ad\'eang h\'eep \'cay, vi\'aan c\'abng s\'f8 ch\'bcng c\'c7n ch\'f3 \'fd th\'b6o ra m\'e9t k\'d5 ho\'b9ch h\'eep l\'fd, ph
\'a9n chia c\'abng vi\'d6c l\'b5m sao kh\'e1i c\'b6n tr\'eb \'ae\'d5n c\'abng vi\'d6c \'ae\'e5ng \'b8ng; d\'a9n ch\'f3ng ph\'b6i \'ae\'e6 s\'f8c ra l\'b5m, v\'b5 \'b6nh h\'ad\'ebng th\'ad\'eang r\'cat tai h\'b9i cho t\'d7nh h\'d7nh trong t\'d8nh.
\par }{\f37\fs20\insrsid1378858 M\'edi \'ae\'ad\'eec tin vi\'aan B\'e9 tr\'ad\'ebng B\'e9 Thu\'e9c \'ae\'dea s\'bep sang th\'a8m \'a7\'abng D\'ad\'acng, ng\'ad\'eai ta \'ae\'b7 l\'cay ngay m\'e9t v\'b9n ng\'ad\'eai \'ae\'d3 ho\'b5n th\'b5nh g\'cap con \'ae\'ad
\'eang V.L. \'ae\'d3 m\'eai Ng\'b5i kh\'b8nh th\'b5nh.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 M\'efa h\'cc n\'a8m 19... trong l\'f3c n\'b9n \'ae\'e3i \'aeang l\'b5m cho mi\'d2n Trung K\'fa ph\'b6i ti\'aau \'aei\'d2
u kh\'e6 s\'eb, th\'d7 m\'e9t v\'b9n ng\'ad\'eai An Nam b\'de l\'fd tr\'ad\'ebng l\'b5ng h\'e4 b\'bet \'aei t\'cbp trung v\'d0t m\'e9t c\'b8i l\'b9ch. S\'e8 d\'a9n \'ae\'abng \'ae\'b6o \'cay, ng\'ad\'eai ta kh\'abng d\'efng h\'d5t m\'b5 v\'c9n c\'f8 ph
\'b6i l\'d7a xa \'ae\'e5ng ru\'e9ng c\'f1a m\'d7nh h\'b5ng th\'b8ng gi\'f7a l\'f3c h\'d5t s\'f8c c\'c7n thi\'d5t h\'e4 ph\'b6i c\'e3 m\'c6t \'eb nh\'b5. C\'c7n ch\'f3 \'fd r\'bbng ng\'ad\'eai ta ch\'ada h\'d2 t\'cbp h\'eep m\'e9t \'aeo\'b5n qu\'a9n \'ae
\'abng \'ae\'b6o nh\'ad v\'cby bao gi\'ea \'ae\'d3 ng\'a8n ch\'c6n m\'e9t thi\'aan tai. Trong th\'eai k\'fa k\'d3 tr\'aan, ng\'ad\'eai ta c\'e3 th\'d3 c\'f8u v\'edt \'ae\'ad\'eec nh\'f7ng ng\'ad\'eai ch\'d5t \'ae\'e3i kh\'e8n kh\'e6 \'eb Trung K\'fa, n
\'d5u ng\'ad\'eai ta t\'e6 ch\'f8c t\'f5 \'a7\'b5 N\'bdng tr\'eb \'aei m\'e9t d\'a9y chuy\'d2n v\'cbn t\'b6i \'ae\'d3 ti\'d5p t\'d5 cho c\'b8c v\'efng b\'de n\'b9n \'ae\'e3i ho\'b5nh h\'b5nh; m\'e9t v\'b9n ng\'ad\'eai v\'d0t l\'b9ch c\'e3 th\'d3 ph\'a9
n ph\'e8i trong c\'b8c t\'d8nh c\'f1a h\'e4 2.000 t\'can g\'b9o trong m\'e9t th\'b8ng.
\par C\'abng vi\'d6c \'ae\'bep \'ae\'ad\'eang \'eb \'a7\'b5 N\'bdng, \'eb Tr\'can Ninh v\'b5 \'eb L\'b5o \'ae\'b7 \'ae\'d3 l\'b9i bi\'d5t bao k\'fb ni\'d6m x\'e3t xa. Ng\'ad\'eai ta l\'cay phu l\'b5m \'ae\'ad\'eang trong \'ae\'b8m d\'a9n \'aei t\'b9p d\'de
ch. H\'e4 ph\'b6i \'aei b\'e9 h\'b5ng tr\'a8m kil\'abm\'d0t m\'edi \'ae\'d5n \'ae\'ad\'eec c\'abng tr\'ad\'eang, b\'de gi\'f7 l\'b9i nhi\'d2u ng\'b5y, s\'e8ng trong nh\'f7ng \'aei\'d2u ki\'d6n \'a8n \'eb 
\par }\pard \qj \li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 v\'b5 v\'d6 sinh th\'b6m h\'b9i. Kh\'abng c\'e3 t\'e6 ch\'f8c y t\'d5. D\'e4c \'ae\'ad\'eang, l\'f3c \'aei c\'f2ng nh\'ad
 khi v\'d2, kh\'abng c\'e3 l\'cay m\'e9t tr\'b9m cho h\'e4 ngh\'d8 ng\'aci, m\'e9t n\'aci cho h\'e4 tr\'f3 \'c8n. C\'acm \'a8n kh\'abng \'ae\'f1, ch\'d8 v\'edi m\'e9t t\'fd c\'b8 m\'bem, n\'ad\'edc u\'e8ng th\'d7 u\'e8ng ngay n\'ad\'edc \'ae\'e9c kinh kh
\'f1ng \'eb r\'f5ng n\'f3i. B\'d6nh t\'cbt, c\'f9c nh\'e4c h\'b5nh h\'b9 t\'b5n t\'d6 \'ae\'b7 g\'a9y n\'aan ch\'d5t ch\'e3c r\'efng r\'een.
\par }\pard \qc \li0\ri0\sb120\sa80\sl-274\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ng\'ad\'eai ta thay th\'d5 ch\'d5 \'ae\'e9 t\'b9p d\'dech b\'bbng ch\'d5 \'ae\'e9 tr\'adng t\'cbp, v\'b5 gi\'f7a hai ch
\'d5 \'ae\'e9 ch\'d8 c\'e3 m\'e9t \'aei\'d2u kh\'b8c nhau l\'b5 t\'b9p d\'dech c\'dfn c\'e3 s\'e8 ng\'b5y h\'b9n \'ae\'denh, m\'b5 tr\'adng t\'cbp th\'d7 v\'ab c\'efng. Ch\'d5 \'ae\'e9 tr\'adng t\'cbp \'ae\'b7 tho\'b6 m\'b7n m\'e4i nhu c\'c7u; n\'d5u nh
\'b5 \'aeoan c\'c7n chuy\'aan ch\'eb mu\'e8i, h\'e4 tr\'adng d\'f4ng thuy\'d2n b\'cc. C\'c7n x\'a9y m\'e9t c\'b8i kho \'ad ? H\'e4 b\'ccn tr\'adng t\'cbp th\'ee thuy\'d2n v\'b5 tr\'adng d\'f4ng lu\'abn c\'b6 v\'cbt li\'d6u x\'a9y d\'f9ng.
\par Ch\'d5 \'ae\'e9 tr\'adng t\'cbp tr\'eb th\'b5nh ch\'d5 \'ae\'e9 ph\'b8t v\'b7ng tr\'b8 h\'d7nh m\'e9t c\'b8ch v\'f4ng v\'d2. B\'cat ch\'cap vi\'d6c \'ae\'e5ng \'b8ng, b\'cat ch\'cap c\'b6 nh\'f7ng ng\'b5y h\'e9i h\'cc
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 hay nh\'f7ng ng\'b5y kh\'abng c\'e3 ngh\'dca v\'f4 g\'d7 c
\'b6, ng\'ad\'eai ta tr\'adng t\'cbp c\'b6 h\'b5ng x\'b7, \'ae\'ada \'ae\'d5n c\'abng tr\'ad\'eang, m\'b5 r\'e5i tr\'eb v\'d2 ch\'d8 l\'b5 ph\'c7n \'ddt. Kh\'abng n\'aan k\'d5t t\'e9i \'ae\'cat \'ae\'e5ng b\'bbng hay r\'f5ng nhi\'d6t \'ae\'edi n\'ad\'edc 
\'ae\'e9c, m\'b5 t\'e9i l\'b5 \'eb ch\'e7 thi\'d5u th\'e8n c\'b6 nh\'f7ng nhu c\'c7u \'ae\'acn gi\'b6n. Ng\'ad\'eai ta tr\'adng t\'cbp nh\'a9n c\'abng. Ng\'ad\'eai ta l\'b5m \'ae\'f1 th\'f8 c\'c7n thi\'d5t \'ae\'d3 r\'f3t nh\'f7ng ng\'ad\'eai lao \'ae\'e9
ng r\'eai kh\'e1i m\'b6nh \'ae\'cat c\'f1a m\'d7nh, \'ae\'ada h\'e4 \'aei xa h\'b5ng tr\'a8m ng\'b5n kil\'abm\'d0t, nh\'adng ch\'bcng bao gi\'ea t\'e6 ch\'f8c m\'e9t t\'fd g\'d7 \'ae\'d3 \'ae\'ada h\'e4 tr\'eb v\'d2 qu\'aa qu\'b8n.
\par }\pard\plain \qc \li0\ri0\sb120\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Kh\'abng m\'cay ai ch\'ada t\'f5ng nghe chuy\'d6n nh\'f7ng \'aeo\'b5n phu b\'de c\'ad\'ecng b\'f8c ph\'b6i \'ae
i Langbiang. Tr\'aan \'ae\'ad\'eang \'aei nh\'f7ng n\'aci r\'f5ng thi\'aang n\'ad\'edc \'ae\'e9c, \'ae\'d5n nh\'f7ng n\'aci th\'c7n ch\'d5t \'ae\'eei ch\'ea, \'a8n u\'e8ng kh\'e6 s\'eb, c\'e3 ng\'b5y kh\'abng \'ae\'ad\'eec l\'cay h\'e9t c\'acm v\'b5o b
\'f4ng, c\'b8c \'aeo\'b5n \'cay b\'e1 ch\'b9y t\'b8n lo\'b9n hay n\'e6i l\'aan ch\'e8ng l\'b9i, th\'d7 h\'e4 l\'b9i b\'de b\'e4n l\'ddnh \'b8p gi\'b6i \'ae\'b5n \'b8p gh\'aa g\'edm, v\'b5 x\'b8c h\'e4 r\'b6i kh\'bep n\'ceo \'ae\'ad\'eang.
\par M\'e9t vi\'aan quan cai tr\'de \'ae\'ad\'eec l\'d6nh c\'f1a ch\'ddnh ph\'f1 ph\'b6i b\'bet phu cho qu\'a9n \'ae\'e9i \'eb Trung Qu\'e8c. Vi\'aan quan \'cay li\'d2n cho t\'f3m c\'e6 h\'d5t m\'e4i ng\'ad\'eai b\'b6n x\'f8 \'aeang lao d\'dech ho\'c6c b\'e8
c h\'b5ng \'eb t\'b5u, ng\'ad\'eai ta tr\'e3i h\'e4 l\'b9i v\'b5 qu\'bcng h\'e4 xu\'e8ng t\'b5u \'ae\'eei s\'bdn \'eb b\'d5n m\'c6c cho h\'e4 k\'aau ca ph\'b6n \'ae\'e8i, m\'c6c cho v\'ee con h\'e4 kh\'e3c than th\'b6m thi\'d5t, u\'cat \'f8c ch\'bc
ng bao gi\'ea l\'b9i \'ae\'ad\'eec th\'cay m\'c6t ch\'e5ng, m\'c6t cha n\'f7a.
\par 
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \column 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 CH\'ddNH S\'b8CH NGU D\'a2N
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-284\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ng\'ad\'eai An Nam r\'cat hi\'d5u h\'e4c. Trong c\'b8c t
\'c7ng l\'edp x\'b7 h\'e9i, ng\'ad\'eai s\'dc phu chi\'d5m \'ae\'dea v\'de h\'b5ng \'ae\'c7u. C\'e3 con h\'e4c gi\'e1i l\'b5 m\'e9t vinh h\'b9nh cho cha m\'d1. Cho n\'aan, d\'ef c\'e3 ngh\'cco \'ae\'e3i \'ae\'d5n \'ae\'a9u, cha m\'d1 c\'f2ng c\'e8 t\'d7
m c\'b8ch cho con c\'b8i \'ae\'ad\'eec h\'e4c h\'b5nh. "N\'f6a b\'f4ng ch\'f7 b\'bbng m\'e9t h\'f2 v\'b5ng" l\'b5 m\'e9t c\'a9u t\'f4c ng\'f7 bi\'d3u hi\'d6n nhi\'d6t t\'d7nh ham mu\'e8n c\'e3 h\'e4c th\'f8c c\'f1a d\'a9n t\'e9c An Nam. }{
\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  l\'b5ng x\'b7 n\'b5o c\'f2ng c\'e3 tr\'ad\'eang c\'abng v\'b5 tr\'ad\'eang t\'ad. Ch\'f7 nho r\'cat kh\'e3 h\'e4c th\'d5 m\'b5 h\'c7u h\'d5t ng\'ad\'eai An Nam \'ae\'d2u bi\'d5t "k\'fd t\'aan b\'bb
ng ch\'f7 H\'b8n". N\'b9n m\'ef ch\'f7 h\'c7u nh\'ad kh\'abng c\'dfn.
\par Ng\'ad\'eai Ph\'b8p \'ae\'d5n \'ae\'b7 l\'b5m \'ae\'e6i thay t\'cat c\'b6. \'a7\'eai s\'e8ng c\'b5ng ng\'b5y c\'b5ng kh\'e3 kh\'a8n. Thu\'d5 m\'b8 n\'c6ng n\'d2, phu d\'dech th\'ad\'eang xuy\'aan. C\'b8c gia \'ae\'d7nh kh\'b8 gi\'b6 nay b\'de sa s\'f3t kh
\'abng c\'dfn c\'e3 th\'d3 nu\'abi th\'c7y \'ae\'e5 d\'b9y h\'e4c cho con c\'b8i m\'d7nh v\'b5 con c\'b8i nh\'f7ng ng\'ad\'eai l\'b8ng gi\'d2ng nh\'ad x\'ada n\'f7a. Nh\'f7ng k\'ce ngh\'cco \'ae\'e3i th\'d7 b\'de b\'c7n c\'efng, n\'aan h\'e4 ph\'b6i ch
\'e8ng \'ae\'e3i \'ae\'b7 r\'e5i m\'edi c\'e3 th\'d3 ngh\'dc \'ae\'d5n chuy\'d6n h\'e4c h\'b5nh.
\par C\'b5ng ngh\'cco kh\'e6 th\'d7 s\'e8 ng\'ad\'eai th\'cat h\'e4c c\'b5ng nhi\'d2u. M\'c6t kh\'b8c, th\'f9c d\'a9n Ph\'b8p l\'b9i c\'e8 t\'a9m hu\'fb b\'e1 H\'b8n h\'e4c m\'b5 ch\'f3ng th\'cay l\'b5 nguy hi\'d3m cho s\'f9 th\'e8ng tr\'de c\'f1a ch\'f3ng, v
\'d7 ch\'f3ng bi\'d5t r\'bbng H\'b8n h\'e4c c\'e3 th\'d3 \'ae\'ada v\'b5o An Nam nh\'f7ng t\'ad t\'ad\'ebng ti\'d5n b\'e9 ph\'ad\'acng T\'a9y th\'abng qua Trung Qu\'e8c v\'b5 Nh\'cbt B\'b6n. Ng\'ad\'eai ta c\'e3 th\'d3 t\'ad\'ebng r\'bbng b\'e1 H\'b8n h
\'e4c \'aei \'ae\'d3 \'ae\'c8y l\'efi \'b6nh h\'ad\'ebng n\'ad\'edc ngo\'b5i, ng\'ad\'eai Ph\'b8p s\'cf thay th\'d5 v\'b5o \'ae\'e3 b\'bbng n\'d2n gi\'b8o d\'f4c c\'f1a h\'e4. Kh\'abng ph\'b6i th\'d5 \'ae\'a9u. Th\'a9m \'fd c\'f1a h\'e4 ch\'d8 l\'b5 \'ae
\'c8y ng\'ad\'eai An Nam v\'b5o v\'dfng ngu t\'e8i. T\'abi xin n\'aau ra sau \'ae\'a9y m\'e9t v\'b5i b\'bbng ch\'f8ng c\'f1a ng\'ad\'eai Ph\'b8p.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f235\fs20\insrsid1378858\charrsid7421932 \'d0}{\f37\fs20\insrsid1378858 \'b9i t\'b8 B\'d0cna vi\'d5t: V\'d2 ph\'ad\'acng di\'d6n tinh th\'c7
n, ng\'ad\'eai Ph\'b8p kh\'abng t\'e6 ch\'f8c m\'e9t n\'d2n gi\'b8o d\'f4c m\'edi thay th\'d5 cho n\'d2n gi\'b8o d\'f4c An Nam m\'b5 h\'e4 \'ae\'b7 b\'e1 \'aei. H\'e4 ch\'d8 x\'a9y d\'f9ng \'ae\'ad\'eec m\'e9t \'ddt tr\'ad\'eang h\'e4c \'ae\'d3 \'ae\'b5
o t\'b9o ra nh\'f7ng con v\'d1t, nh\'f7ng ng\'ad\'eai vong b\'b6n thi\'d5u \'ae\'b9o \'ae\'f8c v\'b5 thi\'d5u c\'b6 ki\'d5n th\'f8c ph\'e6 th\'abng.
\par Trong m\'e9t b\'b6n b\'b8o c\'b8o v\'d2 t\'d7nh h\'d7nh \'a7\'abng D\'ad\'acng, t\'ad\'edng Pen\'accanh c\'f2ng vi\'d5t: Trong 50 n\'a8m chi\'d5m \'ae\'e3ng \'eb Nam K\'fa v\'b5 25 n\'a8m chi\'d5m \'ae\'e3ng \'eb B\'bec K\'fa, nh\'f7ng tr\'ad\'eang h\'e4
c Ph\'b8p kh\'abng \'ae\'b5o t\'b9o l\'cay \'ae\'ad\'eec m\'e9t ng\'ad\'eai An Nam th\'cbt s\'f9 c\'e3 h\'e4c th\'f8c.
\par \'a4ng M\'b8cx\'ac, v\'a8n s\'dc thu\'e9c \'ae\'dea, \'ae\'b7 vi\'d5t c\'a9u sau \'ae\'a9y l\'e9t t\'b6 \'ae\'ad\'eec \'ae\'f3ng t\'ad t\'ad\'ebng \'aeang th\'e8ng tr\'de trong \'ae\'c7u \'e3c c\'f1a c\'b8c nh\'b5 cai tr\'de c\'f1a ch\'f3ng ta: Ch\'f3
ng ta ch\'d8 c\'c7n d\'b9y ti\'d5ng Ph\'b8p cho ng\'ad\'eai An Nam, d\'b9y cho h\'e4 bi\'d5t \'ae\'e4c, bi\'d5t t\'ddnh to\'b8n ch\'f3t \'ddt th\'abi; bi\'d5t h\'acn n\'f7a ch\'d8 l\'b5 th\'f5a v\'ab \'ddch.
\par Nh\'adng ngay c\'b6 n\'d2n gi\'b8o d\'f4c s\'ac \'ae\'bcng \'cay c\'f2ng ch\'d8 \'ae\'ad\'eec ph\'e6 c\'cbp m\'e9t c\'b8ch qu\'b8 b\'f1n x\'d8n v\'b5 nh\'e1 gi\'e4t. Tr\'ad\'eang h\'e4c r\'e2 r\'b5ng l\'b5 c\'dfn thi\'d5u nhi\'d2u, gi\'b8o vi\'aan th\'d7
 ch\'ada \'ae\'f1 t\'ad c\'b8ch \'ae\'d3 gi\'b6ng d\'b9y. Cao Mi\'aan c\'e3 2.000.000 d\'a9n m\'b5 ch\'d8 c\'e3 60 tr\'ad\'eang h\'e4c. }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  Trung K\'fa ch\'d8 c\'e3 118 tr\'ad\'eang cho 6.000.000 d
\'a9n. Tr\'ad\'eang h\'e4c l\'cbp ra kh\'abng ph\'b6i \'ae\'d3 gi\'b8o d\'f4c cho thanh ni\'aan An Nam m\'e9t n\'d2n h\'e4c v\'can t\'e8t \'ae\'d1p v\'b5 ch\'a9n th\'f9c, m\'eb mang tr\'dd tu\'d6 v\'b5 ph\'b8t tri\'d3n t\'ad t\'ad\'ebng cho h\'e4, m\'b5
 tr\'b8i l\'b9i c\'b5ng l\'b5m cho h\'e4 \'ae\'c7n \'ae\'e9n th\'aam. Ngo\'b5i m\'f4c \'ae\'ddch gi\'b8o d\'f4c \'ae\'d3 \'ae\'b5o t\'b9o tu\'fa ph\'b8i, th\'abng ng\'abn v\'b5 vi\'aan ch\'f8c nh\'e1 \'ae\'f1 s\'e8 c\'c7n thi\'d5t ph\'f4c v\'f4 cho b\'e4
n x\'a9m l\'ad\'eec - ng\'ad\'eai ta \'ae\'b7 gieo r\'bec m\'e9t n\'d2n gi\'b8o d\'f4c \'ae\'e5i b\'b9i, x\'b6o tr\'b8 v\'b5 nguy hi\'d3m h\'acn c\'b6 s\'f9 d\'e8t n\'b8t n\'f7a, v\'d7 m\'e9t n\'d2n gi\'b8o d\'f4c nh\'ad v\'cby ch\'d8 l\'b5m h\'ad h\'e1
ng m\'cat t\'ddnh n\'d5t c\'f1a ng\'ad\'eai \'aei h\'e4c, ch\'d8 d\'b9y cho h\'e4 m\'e9t l\'dfng "trung th\'f9c" gi\'b6 d\'e8i, ch\'d8 d\'b9y cho h\'e4 bi\'d5t s\'efng b\'b8i nh\'f7ng k\'ce m\'b9nh h\'acn m\'d7nh, d\'b9y cho thanh ni\'aan y\'aau m\'e9t T
\'e6 qu\'e8c kh\'abng ph\'b6i l\'b5 T\'e6 qu\'e8c c\'f1a m\'d7nh v\'b5 \'aeang \'b8p b\'f8c m\'d7nh. N\'d2n gi\'b8o d\'f4c \'cay d\'b9y cho thanh thi\'d5u ni\'aan khinh r\'ce ngu\'e5n g\'e8c d\'dfng gi\'e8ng m\'d7nh. N\'e3 l\'b5m cho thanh thi\'d5u ni\'aa
n tr\'eb n\'aan ngu ng\'e8c. \'a7i\'d2u g\'d7 c\'e3 th\'d3 r\'ccn luy\'d6n \'ae\'ad\'eec cho h\'e4c sinh bi\'d5t suy ngh\'dc, bi\'d5t ph\'a9n t\'ddch th\'d7 ng\'ad\'eai ta kh\'abng d\'b9y \'eb nh\'b5 tr\'ad\'eang. V\'can \'ae\'d2 n\'b5o c\'e3 li\'aa
n quan \'ae\'d5n ch\'ddnh tr\'de, x\'b7 h\'e9i v\'b5 c\'e3 th\'d3 l\'b5m cho ng\'ad\'eai ta t\'d8nh ng\'e9 \'ae\'d2u b\'de b\'e3p m\'d0o v\'b5 xuy\'aan t\'b9c \'aei. C\'e3 h\'e4c l\'dech s\'f6 n\'ad\'edc Ph\'b8p \'aei n\'f7a, th\'d7 ng\'ad\'eai ta kh\'ab
ng h\'d2 \'ae\'b6 \'ae\'e9ng \'ae\'d5n ch\'ad\'acng n\'e3i v\'d2 c\'b8ch m\'b9ng. Ng\'ad\'eai ta c\'cam h\'e4c sinh \'ae\'e4c t\'b8c ph\'c8m c\'f1a Huyg\'ab, R\'f3tx\'ab v\'b5 M\'abngtexki\'ac. N\'e3i t\'e3m l\'b9i, tr\'ad\'eang h\'e4c th\'cbt l\'b5 t\'ad
\'acng x\'f8ng v\'edi ch\'d5 \'ae\'e9 \'ae\'b7 khai sinh ra n\'e3.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 C\'b8ch \'ae\'a9y v\'b5i n\'a8m, ng\'ad\'eai ta ban cho ch\'f3ng t\'abi m\'e9t tr\'ad\'eang \'ae\'b9i h\'e4c. M\'e9t tr
\'ad\'eang \'ae\'b9i h\'e4c th\'d5 n\'b5o? Theo nh\'f7ng b\'b5i di\'d4n v\'a8n ch\'ddnh th\'f8c v\'b5 nh\'f7ng l\'eai tuy\'aan truy\'d2n \'c7m \'fc xung quanh tr\'ad\'eang n\'b5y th\'d7 tr\'ad\'eang \'ae\'b9i h\'e4c c\'f1a ch\'f3ng t\'abi c\'e3 th\'d3
 so s\'b8nh \'ae\'ad\'eec v\'edi c\'b8c tr\'ad\'eang \'ae\'b9i h\'e4c to nh\'cat \'a2u ch\'a9u kia \'ae\'cay. Th\'f9c ra, th\'d7 h\'bbng n\'a8m tr\'ad\'eang \'ae\'b9i h\'e4c ch\'d8 s\'b6n xu\'cat \'ae\'ad\'eec hai ba \'abng c\'f6 nh\'a9n h\'b9ng t\'e5i. 
\'a4ng b\'e8 \'ae\'ec \'ae\'c7u cho c\'b8i tr\'ad\'eang "X\'e3ocbon Annamm\'ddt" \'cay, hi\'d6n gi\'ea l\'b5 th\'e8ng \'ae\'e8c Nam K\'fa, trong m\'e9t l\'f3c th\'b5nh th\'cbt hi\'d5m th\'cay x\'ada nay \'eb ng\'b5i, ng\'b5i \'ae\'b7 th\'f3 nh\'cbn r\'bb
ng ch\'ddnh ng\'b5i \'ae\'b7 "h\'bbng ch\'a8m lo \'ae\'d5n s\'f9 ti\'d5n b\'e9 c\'f1a c\'b6 d\'a9n t\'e9c An Nam; m\'eb tr\'ad\'eang y khoa v\'b5 tr\'ad\'eang \'ae\'b9i h\'e4c l\'b5 c\'e8t \'ae\'d3 sau n\'b5y (l\'eai th\'f3 nh\'cbn v\'b5o th\'b8ng 3 n\'a8
m 1924) ng\'ad\'eai An Nam c\'e3 th\'d3 thay th\'d5 ng\'ad\'eai Ph\'b8p trong c\'b8c }{\i\f37\fs20\insrsid1378858 ch\'f8c v\'f4 th\'f8 y\'d5u}{\f37\fs20\insrsid1378858  \'eb c\'b8c c\'abng s\'eb".
\par B\'aan c\'b9nh tr\'ad\'eang \'ae\'b9i h\'e4c \'ae\'b8ng qu\'fd \'cay, l\'cbp ra c\'e8t \'ae\'d3 lo\'cc n\'ad\'edc ngo\'b5i, \'ae\'d3 \'ae\'ada ra khoe khoang trong c\'b8c b\'b5i di\'d4n v\'a8n v\'b5 \'ae\'d3 l\'cay c\'ed ng\'a8n c\'cam ng\'ad\'ea
i An Nam xu\'cat d\'ad\'acng du h\'e4c, ch\'f3ng t\'abi c\'dfn c\'e3 m\'e9t tr\'ad\'eang y khoa, m\'e9t tr\'ad\'eang lu\'cbt, m\'e9t tr\'ad\'eang c\'abng ch\'ddnh, ba ho\'c6c b\'e8n tr\'ad\'eang chuy\'aan nghi\'d6p n\'f7a, cho c\'b6 20.000.000 d\'a9n.

\par Nh\'adng k\'d5t qu\'b6 thu \'ae\'ad\'eec \'eb c\'b8c tr\'ad\'eang \'cay th\'d7 nh\'ad th\'d5 n\'b5o? M\'e9t t\'ea b\'b8o Ph\'b8p xu\'cat b\'b6n \'eb \'a7\'abng D\'ad\'acng \'ae\'b7 tr\'b6 l\'eai c\'a9u h\'e1i \'ae\'e3 nh\'ad th\'d5 n\'b5y: S\'e8 thanh ni
\'aan An Nam c\'e3 tr\'d7nh \'ae\'e9 k\'fc thu\'cbt chuy\'aan nghi\'d6p cao c\'dfn r\'cat \'ddt, r\'cat \'ddt ng\'ad\'eai d\'a9n b\'b6o h\'e9 c\'e3 th\'d3 \'ae\'b6m \'ae\'ad\'acng \'ae\'ad\'eec x\'f8ng \'ae\'b8ng ch\'f8c v\'f4 c\'f1a m\'e9t k\'fc s\'ad c
\'abng ch\'ddnh, c\'f1a m\'e9t b\'b8c s\'dc y khoa hay c\'f1a m\'e9t thanh tra ho\'b6 xa, ch\'bcng h\'b9n.
\par Cho n\'aan b\'de ch\'ddnh s\'b8ch ngu d\'a9n tri\'d6t \'ae\'d3 ki\'d2m ch\'d5 nh\'ad v\'cby, ng\'ad\'eai An Nam mu\'e8n h\'e4c l\'aan ch\'d8 c\'dfn c\'e3 2 c\'b8ch: \'aei du h\'e4c \'eb n\'ad\'edc ngo\'b5i hay \'eb Ph\'b8p. Nh\'adng n\'d5u c\'e3 m\'e9t ng
\'ad\'eai An Nam n\'b5o c\'e3 \'fd \'ae\'denh \'aei du h\'e4c n\'ad\'edc ngo\'b5i th\'d7 s\'cf b\'de coi nh\'ad m\'e9t ng\'ad\'eai n\'e6i lo\'b9n, m\'e9t ng\'ad\'eai ch\'e8ng Ph\'b8p, c\'e3 t\'e9i l\'edn; ng\'ad\'eai ta h\'b7m h\'b9i ng\'ad\'eai \'ae\'e3
 v\'b5 c\'b6 gia \'ae\'d7nh h\'e4. Anbe Xar\'ab, nguy\'aan to\'b5n quy\'d2n \'a7\'abng D\'ad\'acng, nay l\'b5 B\'e9 tr\'ad\'ebng thu\'e9c \'ae\'dea \'ae\'b7 n\'e3i r\'e2 ch\'ddnh s\'b8ch bao v\'a9y tinh th\'c7n \'cay b\'bbng nh\'f7ng l\'eai l\'cf sau \'ae
\'a9y: "\'a7\'d3 cho l\'edp th\'ad\'eeng l\'adu tr\'dd th\'f8c \'ae\'ad\'eec \'ae\'b5o t\'b9o \'eb n\'ad\'edc ngo\'b5i tho\'b8t kh\'e1i v\'dfng ki\'d2m to\'b6 c\'f1a ch\'f3ng ta, ch\'deu \'b6nh h\'ad\'ebng v\'a8n ho\'b8 v\'b5 ch\'ddnh tr\'de c\'f1a n\'ad
\'edc kh\'b8c, th\'d7 th\'cbt l\'b5 m\'e9t \'aei\'d2u nguy hi\'d3m v\'ab c\'efng. Nh\'f7ng ng\'ad\'eai tr\'dd th\'f8c \'ae\'e3 tr\'eb v\'d2 n\'ad\'edc \'ae\'b7 \'ae\'ada h\'d5t t\'b5i n\'a8ng c\'f1a h\'e4 \'ae\'d3 tuy\'aan truy\'d2n v\'cbn \'ae\'e9ng ch
\'e8ng l\'b9i ch\'f3ng ta l\'b5 nh\'f7ng ng\'ad\'eai b\'b6o h\'e9 \'ae\'b7 ng\'a8n c\'cam kh\'abng cho h\'e4 h\'e4c t\'cbp".
\par C\'dfn sang du h\'e4c \'eb Ph\'b8p l\'b9i l\'b5 m\'e9t chuy\'d6n kh\'b8c h\'bcn. 1) Sinh ho\'b9t \'eb Ph\'b8p \'ae\'bet \'ae\'e1 h\'acn \'eb Trung Qu\'e8c v\'b5 \'eb Nh\'cbt B\'b6n, n\'aan du h\'e4c sinh ph\'b6i r\'cat gi\'b5u m\'edi c\'e3 \'ae\'f1 ti\'d2
n \'ae\'d5n h\'e4c \'eb m\'e9t tr\'ad\'eang ch\'ddnh qu\'e8c. 2) Ngo\'b5i ra, ng\'ad\'eai \'ae\'e3 ph\'b6i \'ae\'ad\'eec b\'b6o \'ae\'b6m v\'d2 tinh th\'c7n ngh\'dca l\'b5 cha m\'d1 anh ta ph\'b6i c\'e3 th\'b8i \'ae\'e9 ph\'f4c t\'efng Ch\'ddnh ph\'f1; ph
\'b6i c\'e3 b\'b6o \'ae\'b6m v\'d2 v\'cbt ch\'cat t\'f8c l\'b5 ph\'b6i \'ae\'f3t l\'e3t th\'cbt nhi\'d2u cho c\'b8c quan cai tr\'de. 3) Du h\'e4c sinh ph\'b6i l\'b5m \'ae\'f1 c\'b8c th\'d3 th\'f8c qu\'b8i g\'eb, v\'ab \'ddch v\'b5 nh\'f4c nh\'b7; nh\'f7
ng th\'d3 th\'f8c n\'b5y th\'ad\'eang l\'b5m cho ng\'ad\'eai xin \'aei h\'e4c ph\'b6i n\'b6n ch\'dd, v\'b6 l\'b9i Ch\'ddnh ph\'f1 c\'f2ng ch\'d8 mu\'e8n nh\'ad th\'d5 th\'abi. 4) Khi \'ae\'b7 sang Ph\'b8p, ng\'ad\'eai du h\'e4c sinh ph\'b6i ch\'deu s\'f9
 gi\'b8m s\'b8t, theo d\'e2i v\'b5 d\'df la c\'f1a Ch\'ddnh ph\'f1 Ph\'b8p.
\par Ch\'ddnh ph\'f1 Ph\'b8p c\'e8 \'ae\'ada du h\'e4c sinh An Nam v\'b5o h\'e4c \'eb nh\'f7ng tr\'ad\'eang ph\'b6n \'ae\'e9ng nh\'cat. Nh\'f7ng s\'b8ch v\'eb b\'b8o ch\'dd m\'b5 anh ta \'ae\'e4c, nh\'f7ng ho\'b9t \'ae\'e9ng, giao thi\'d6p h\'bbng ng\'b5y c
\'f1a anh \'ae\'d2u b\'de ki\'d3m so\'b8t, theo d\'e2i. Ng\'ad\'eai ta giao anh cho nh\'f7ng t\'aan ba que th\'f9c d\'a9n gi\'b5 \'ae\'b7 v\'d2 h\'adu tr\'abng nom. Ch\'ddnh ph\'f1 Ph\'b8p d\'f9ng l\'aan m\'e9t b\'f8c t\'ad\'eang ng\'a8n c\'b8ch h\'bc
n du h\'e4c sinh v\'edi nh\'f7ng lu\'e5ng t\'ad t\'ad\'ebng ch\'ddnh tr\'de v\'b5 x\'b7 h\'e9i \'eb ch\'ddnh qu\'e8c. \'a7\'d3 n\'bem ch\'c6t l\'cay anh ta, ng\'ad\'eai ta d\'efng ti\'d2n thu\'d5 c\'f1a ng\'ad\'eai An Nam t\'e6 ch\'f8c ra nh\'f7ng h\'e9
i qu\'b8n v\'b5 c\'a9u l\'b9c b\'e9 cho du h\'e4c sinh; \'eb \'ae\'cay mu\'e8n l\'b5m g\'d7 th\'d7 l\'b5m, tr\'f5 vi\'d6c h\'e4c t\'cbp. N\'d5u anh sinh vi\'aan t\'e1 v\'ce t\'f9 l\'cbp th\'d7 ng\'ad\'eai ta s\'cf b\'bet \'d0p cha m\'d1 ph\'b6i g\'e4
i anh ta v\'d2. N\'d5u anh ta kh\'abng nghe, th\'d7 ng\'ad\'eai ta c\'f8 vi\'d6c c\'bet l\'ad\'acng c\'f1a anh.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 H\'e4c xong v\'b5 n\'d5u \'ae\'b7 t\'e8t nghi\'d6p - d\'ef t\'e8t nghi\'d6p b\'b8c s\'dc y khoa, lu\'cbt s\'ad hay k\'fc
 s\'ad b\'b8ch khoa - ng\'ad\'eai An Nam mu\'e8n c\'e3 vi\'d6c l\'b5m \'eb trong n\'ad\'edc th\'d7 ph\'b6i nh\'cbp qu\'e8c t\'dech Ph\'b8p; m\'b5 mu\'e8n \'ae\'ad\'eec v\'b5o l\'b5ng T\'a9y th\'d7 ph\'b6i lu\'e5n l\'e4t xin x\'e1 th\'cbt l\'b5 nh\'f4c nh
\'b7 v\'b5 h\'ccn h\'b9.
\par Mu\'e8n m\'eb tr\'ad\'eang t\'ad th\'d7 ph\'b6i xin ph\'d0p Ch\'ddnh ph\'f1 tr\'ad\'edc. B\'cat c\'f8 l\'f3c n\'b5o Ch\'ddnh ph\'f1 c\'f2ng c\'e3 quy\'d2n ki\'d3m so\'b8t ho\'c6c b\'bet c\'b8c tr\'ad\'eang ph\'b6i \'ae\'e3ng c\'f6a.
\par Sau nh\'f7ng cu\'e9c bi\'d3u t\'d7nh n\'a8m 1907}{\f37\fs20\super\insrsid1378858 58}{\f37\fs20\insrsid1378858  m\'b5 t\'abi \'ae\'b7 c\'e3 d\'dep n\'e3i \'ae\'d5n, Ch\'ddnh ph\'f1 cho l\'ddnh t\'cbp v\'d2 ph\'b8 ph\'b8ch c\'b8c tr\'ad\'eang h\'e4c v\'b5 b
\'bet b\'ed gi\'b8o vi\'aan. C\'b8c \'abng gi\'b8o b\'de b\'bet, b\'de ng\'ad\'eec \'ae\'b7i h\'b5nh h\'b9, tay tr\'e3i gi\'cbt c\'b8nh khu\'fbu v\'b5 b\'de d\'c9n t\'f5ng x\'a9u l\'aan t\'d8nh l\'fe; \'ae\'c7u tr\'c7n, ch\'a9n kh\'abng, nh\'den \'ae\'e3
i, nh\'den kh\'b8t, h\'e4 b\'de \'ae\'b8nh \'ae\'cbp nh\'ad tr\'a9u ng\'f9a, r\'e5i b\'de k\'d5t \'b8n kh\'e6 sai. C\'dfn tr\'ad\'eang h\'e4c th\'d7 b\'e4n s\'dc quan Ph\'b8p d\'efng l\'b5m chu\'e5ng ng\'f9a.
\par M\'edi \'ae\'a9y, \'eb m\'e9t t\'d8nh Nam K\'fa ng\'ad\'eai ta thuy\'aan chuy\'d3n c\'b6 m\'e9t lo\'b9t gi\'b8o vi\'aan, l\'cay l\'fd do l\'b5 c\'b8c nh\'b5 gi\'b8o \'ae\'b7 quy\'d5t \'ae\'denh xin ra h\'e9i m\'b5 tr\'ad\'edc kia h\'e4 b\'de b\'bet bu\'e9
c ph\'b6i gia nh\'cbp. T\'aan c\'abng s\'f8 ch\'f1 t\'d8nh l\'b5m th\'f1 qu\'fc h\'e9i n\'b5y \'ae\'b7 b\'bet gi\'b8o vi\'aan ph\'b6i \'ae\'e3ng th\'aam 40 phr\'a8ng \'ae\'d3 b\'ef v\'b5o ti\'d2n qu\'fc b\'de h\'f4t. C\'b8c gi\'b8o vi\'aan b\'de thuy\'aa
n chuy\'d3n \'aei c\'f2ng v\'d7 m\'e9t l\'fd do kh\'b8c l\'b5 t\'aan ph\'e3 s\'f8 \'ae\'b7 ch\'f6i m\'beng, l\'b5m nh\'f4c h\'e4 v\'b5 do\'b9 \'ae\'b8nh v\'b5o m\'e2m h\'e4 (nguy\'aan v\'a8n).
\par \'a7\'d3 l\'b5m r\'e2 n\'d0t th\'aam c\'b8i ch\'d5 \'ae\'e9 t\'e8t \'ae\'d1p \'cay, t\'abi c\'c7n ph\'b6i n\'e3i th\'aam r\'bbng: Ch\'ddnh ph\'f1 \'ae\'b7 bi\'d5u b\'b5 qu\'b6 ph\'f4 c\'f1a m\'e9t vi\'aan c\'f9u th\'e8ng \'ae\'e8c m\'e9t m\'e3n ti\'d2n l
\'b5 1 tri\'d6u phr\'a8ng, v\'b5 tr\'ee c\'cap 800.000 phr\'a8ng cho 66 bu\'e6i k\'dech gi\'b6i tr\'dd cho kho\'b6ng 3 hay 4 ngh\'d7n ng\'ad\'eai \'a2u \'eb S\'b5i G\'dfn; nh\'adng Ch\'ddnh ph\'f1 l\'b9i thu h\'e5i kho\'b6n tr\'ee c\'cap ch\'d8 c\'e3
 2.000 \'ae\'e5ng cho m\'e9t t\'e6 ch\'f8c gi\'b8o d\'f4c b\'d7nh d\'a9n v\'d7 \'abng h\'e9i tr\'ad\'ebng c\'f1a t\'e6 ch\'f8c n\'b5y l\'b5 m\'e9t ng\'ad\'eai l\'b5ng T\'a9y c\'e3 ch\'a9n trong H\'e9i \'ae\'e5ng thu\'e9c \'ae\'dea, \'ae\'b7 vi\'d5t nh\'f7
ng b\'b5i b\'b8o ph\'b6n \'ae\'e8i vi\'d6c cho tr\'adng th\'c7u h\'b6i c\'b6ng S\'b5i G\'dfn.
\par 
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par 
\par 
\par 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8O CH\'dd
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-284\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 N\'e3i xong v\'can \'ae\'d2 gi\'b8o d\'f4c, th\'d7 t\'f9
 nhi\'aan ch\'f3ng t\'abi ngh\'dc ngay t\'edi c\'a9u h\'e1i: Th\'d5 c\'dfn b\'b8o ch\'dd? Nh\'f7ng \'aei\'d2u t\'abi s\'cf k\'d3 v\'d2 b\'b8o ch\'dd An Nam n\'e3 k\'fa d\'de qu\'b8 \'ae\'d5n n\'e7i kh\'e3 m\'b5 tin \'ae\'ad\'eec. Gi\'f7a th\'d5 k\'fb XX n
\'b5y, \'eb m\'e9t n\'ad\'edc c\'e3 \'ae\'d5n 20 tri\'d6u d\'a9n m\'b5 kh\'abng c\'e3 l\'cay m\'e9t t\'ea b\'b8o! C\'b8c b\'b9n c\'e3 th\'d3 t\'ad\'ebng t\'ad\'eeng \'ae\'ad\'eec nh\'ad th\'d5 kh\'abng? }{\i\f37\fs20\insrsid1378858 Kh\'abng c\'e3 l\'cay m
\'e9t t\'ea b\'b8o b\'bbng ti\'d5ng m\'d1 \'ae\'ce c\'f1a ch\'f3ng t\'abi}{\f37\fs20\insrsid1378858 . L\'fd do nh\'ad th\'d5 n\'b5y. Ch\'ddnh quy\'d2n Ph\'b8p quy\'d5t \'ae\'denh r\'bbng kh\'abng m\'e9t t\'ea b\'b8o b\'bbng ti\'d5ng An Nam n\'b5o \'ae\'ad
\'eec xu\'cat b\'b6n n\'d5u kh\'abng \'ae\'ad\'eec vi\'aan to\'b5n quy\'d2n cho ph\'d0p, r\'bbng h\'e4 ch\'d8 cho ph\'d0p v\'edi \'aei\'d2u ki\'d6n l\'b5 b\'b6n th\'b6o \'ae\'ada \'ae\'a8ng ph\'b6i tr\'d7nh vi\'aan to\'b5n quy\'d2n duy\'d6t tr\'ad\'edc 
\'ae\'b7, v\'b5 gi\'cay ph\'d0p \'cay h\'e4 thu h\'e5i l\'f3c n\'b5o c\'f2ng \'ae\'ad\'eec. Tinh th\'c7n b\'b6n s\'bec l\'d6nh v\'d2 b\'b8o ch\'dd l\'b5 nh\'ad th\'d5 \'ae\'cay. (Ch\'f3ng t\'abi b\'de cai tr\'de b\'bbng ch\'d5 \'ae\'e9 s\'bec l\'d6
nh do vi\'aan to\'b5n quy\'d2n ban b\'e8 ch\'f8 kh\'abng ph\'b6i b\'bbng nh\'f7ng \'ae\'b9o lu\'cbt \'ae\'b7 \'ae\'ad\'eec th\'b6o lu\'cbn v\'b5 bi\'d3u quy\'d5t \'eb ngh\'de vi\'d6n). Tr\'aan th\'f9c t\'d5 c\'dfn t\'d6 h\'acn n\'f7a. M\'b7i \'ae\'d5n b
\'a9y gi\'ea, ch\'ada c\'e3 ng\'ad\'eai An Nam n\'b5o \'ae\'ad\'eec ph\'d0p xu\'cat b\'b6n m\'e9t t\'ea b\'b8o c\'b6.
\par T\'abi g\'e4i b\'b8o l\'b5 m\'e9t t\'ea b\'b8o v\'d2 ch\'ddnh tr\'de, v\'d2 kinh t\'d5 hay v\'a8n h\'e4c nh\'ad ta th\'cay \'eb ch\'a9u \'a2u v\'b5 c\'b8c n\'ad\'edc ch\'a9u }{\f38\fs20\insrsid1378858 \'b8}{\f37\fs20\insrsid1378858  kh\'b8c, ch\'f8 kh\'ab
ng ph\'b6i m\'e9t t\'ea do ch\'ddnh quy\'d2n th\'b5nh l\'cbp v\'b5 giao cho b\'e4n tay ch\'a9n \'aei\'d2u khi\'d3n, ch\'d8 n\'e3i \'ae\'d5n chuy\'d6n n\'beng m\'ada, t\'b8n d\'ad\'acng nh\'f7ng k\'ce quy\'d2n th\'d5 \'ae\'ad\'acng th\'eai, k\'d3 chuy\'d6
n v\'ed v\'c8n, ca t\'f4ng c\'abng \'acn c\'f1a n\'d2n khai ho\'b8 v\'b5 ru ng\'f1 d\'a9n ch\'f3ng. B\'b8o \'ae\'c7u \'ae\'e9c ng\'ad\'eai ta nh\'ad th\'d5, th\'d7 \'eb \'a7\'abng D\'ad\'acng c\'f2ng c\'e3 ba hay b\'e8n t\'ea \'ae\'cay.
\par Ngay cho \'ae\'d5n c\'b6 nh\'f7ng t\'ea th\'abng tin thu\'c7n tu\'fd v\'d2 kinh t\'d5 v\'b5 th\'ad\'acng m\'b9i, ng\'ad\'eai k\'fd gi\'b6 b\'b6n x\'f8 c\'f2ng ch\'d8 xin \'ae\'ad\'eec ph\'d0p b\'bbng nh\'f7ng bi\'d6n ph\'b8p quanh co. Anh ta ph\'b6i thu
\'aa ti\'d2n m\'e9t ng\'ad\'eai Ph\'b8p c\'e3 \'ae\'dea v\'de v\'b5 \'ae\'ad\'eec k\'ddnh n\'d3. \'a4ng n\'b5y \'aei g\'c6p quan cai tr\'de v\'b5 xin ph\'d0p }{\i\f37\fs20\insrsid1378858 cho \'abng ta,}{\f37\fs20\insrsid1378858  l\'b5 ng\'ad\'eai Ph\'b8
p. V\'d7 \'abng ta v\'c9n s\'cf l\'b5 }{\i\f37\fs20\insrsid1378858 s\'b8ng l\'cbp vi\'aan}{\f37\fs20\insrsid1378858  c\'f1a t\'ea b\'b8o, m\'c6c d\'c7u \'abng ch\'bcng bi\'d5t m\'e9t ti\'d5ng An Nam n\'b5o g\'e4i l\'b5 c\'e3, \'abng ch\'bcng ph\'b6i b\'e1
 ti\'d2n t\'f3i ra l\'cay m\'e9t xu nh\'e1, ch\'bcng ph\'b6i \'ae\'f4ng t\'dd g\'d7 \'ae\'d5n c\'abng vi\'d6c c\'f1a t\'ea b\'b8o c\'b6 tr\'f5 vi\'d6c \'aei g\'c6p vi\'aan quan cai tr\'de. Ch\'d8 vi\'d6c cho m\'ad\'een t\'aan m\'d7nh, ng\'ad\'eai Ph\'b8
p kia nh\'cbn \'ae\'ad\'eec h\'bbng th\'b8ng m\'e9t s\'e8 ti\'d2n r\'cat h\'cbu m\'b5 ng\'ad\'eai k\'fd gi\'b6 b\'b6n x\'f8 ph\'b6i tr\'b6 cho \'abng l\'a9u d\'b5i, b\'b8o c\'dfn ra l\'b5 c\'dfn ph\'b6i tr\'b6.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\expnd0\expndtw-2\insrsid1378858 Tr\'ad\'edc khi \'ae\'ada \'aei nh\'b5 in, t\'cat c\'b6 c\'b8c b\'b5i b\'b8o ph\'b6i d\'dech ra ti\'d5
ng Ph\'b8p v\'b5 \'ae\'ada ki\'d3m duy\'d6t \'ae\'b7. C\'cam ng\'c6t nh\'f7ng t\'ea th\'abng tin \'cay kh\'abng \'ae\'ad\'eec \'ae\'b6 \'ae\'e9ng g\'d7 \'ae\'d5n nh\'f7ng v\'can \'ae\'d2 ch\'ddnh tr\'de hay t\'abn gi\'b8o, m\'b5 ch\'d8 \'ae\'ad\'eec \'ae
\'a8ng nh\'f7ng tin t\'f8c th\'abng th\'ad\'eang, nh\'f7ng v\'can \'ae\'d2 x\'d0t ra c\'e3 l\'eei cho Nh\'b5 n\'ad\'edc. Khi \'ae\'cat n\'ad\'edc b\'de m\'e9t thi\'aan tai n\'b5o, l\'f4t l\'e9i, b\'b7o t\'b8p, \'ae\'e3i k\'d0m, v.v., ph\'dfng ki\'d3m duy
\'d6t c\'cam b\'b8o kh\'abng \'ae\'ad\'eec cho d\'a9n ch\'f3ng bi\'d5t 
\par nh\'f7ng tin "kh\'abng vui" \'cay, c\'cam b\'b8o kh\'abng \'ae\'ad\'eec m\'eb l\'b9c quy\'aan gi\'f3p nh\'f7ng ng\'ad\'eai b\'de n\'b9n. B\'b8o kh\'abng c\'e3 quy\'d2n n\'e3i g\'d7, d\'ef ch\'d8 b\'e3ng gi\'e3, \'ae\'d5n vi\'d6c b\'c7u c\'f6 h\'e9i \'ae
\'e5ng thu\'e9c \'ae\'dea hay h\'e9i \'ae\'e5ng h\'b5ng t\'d8nh. C\'e3 m\'e9t t\'ea, d\'dech ra ti\'d5ng An Nam \'ae\'b9o lu\'cbt c\'cam nh\'f7ng h\'b5nh vi h\'e8i l\'e9 trong vi\'d6c tuy\'d3n c\'f6, \'ae\'b7 b\'de ki\'d3m duy\'d6t tr\'beng m\'cat n\'f6
a t\'ea b\'b8o m\'b5 c\'dfn b\'de khi\'d3n tr\'b8ch th\'aam n\'f7a. Nhi\'d2u khi ng\'ad\'eai ta c\'cam c\'b6 d\'dech \'ae\'a8ng nh\'f7ng b\'b5i \'ae\'b7 \'ae\'a8ng \'eb c\'b8c b\'b8o ti\'d5ng Ph\'b8p xu\'cat b\'b6n \'eb \'a7\'abng D\'ad\'acng.
\par C\'b8c b\'b9n ch\'ed t\'ad\'ebng r\'bbng m\'cay t\'ea b\'b8o th\'abng tin kh\'e8n kh\'e6 \'cay \'ae\'ad\'eec t\'f9 do ph\'a9n t\'ddch t\'cat c\'b6 nh\'f7ng c\'b8i thu\'e9c v\'d2 kinh t\'d5. Ch\'bcng h\'b9n, h\'e4 kh\'abng \'ae\'ad\'eec n\'e3i \'ae\'d5n 
\'ae\'eai s\'e8ng \'ae\'bet \'ae\'e1, \'ae\'d5n vi\'d6c m\'cat m\'efa, \'ae\'d5n vi\'d6c bu\'abn gian b\'b8n l\'cbu c\'f1a b\'e4n con bu\'abn ng\'ad\'eai \'a2u, \'ae\'d5n vi\'d6c xoay x\'eb ti\'d2n nong b\'cat l\'ad\'acng c\'f1a b\'e4n quan cai tr\'de, 
\'ae\'d5n nh\'f7ng v\'f4 \'ae\'c7u c\'ac \'ae\'aa ti\'d6n c\'f1a b\'e4n ch\'f1 \'ae\'e5n \'aei\'d2n v\'b5 ch\'f1 nh\'b5 m\'b8y ng\'ad\'eai da tr\'beng. V\'f5a r\'e5i, ng\'ad\'eai ta c\'cam b\'b8o ch\'dd kh\'abng \'ae\'ad\'eec \'ae\'b6 \'ae\'e9ng \'ae\'d5
n vi\'d6c Ch\'ddnh ph\'f1 nh\'ad\'eeng quy\'d2n kinh doanh h\'b6i c\'b6ng S\'b5i G\'dfn, n\'d5u kh\'abng ph\'b6i \'ae\'d3 t\'b8n d\'ad\'acng c\'abng \'ae\'f8c c\'f1a c\'abng ty \'ae\'e9c quy\'d2n v\'b5 l\'dfng v\'ab t\'ad c\'f1a Ch\'ddnh ph\'f1. C\'e3 m
\'e9t t\'ea c\'f2ng \'ae\'b7 "t\'b8n d\'ad\'acng", nh\'adng k\'d0m nhi\'d6t t\'d7nh, n\'aan ph\'dfng ki\'d3m duy\'d6t tr\'ad\'edc h\'d5t
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\expnd0\expndtw-2\insrsid1378858 \'ae\'b7 theo d\'e2i b\'dd m\'cbt, r\'e5i 
\'ae\'e3ng c\'f6a h\'bcn t\'ea b\'b8o \'cay.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Nh\'f7ng ng\'ad\'eai v\'b5o l\'b5ng T\'a9y, \'ae\'ad\'ee
c h\'ad\'ebng quy\'d2n c\'abng d\'a9n Ph\'b8p, c\'e3 th\'d3 xu\'cat b\'b6n b\'b8o, }{\i\f37\fs20\insrsid1378858 nh\'adng ch\'d8 b\'bbng ti\'d5ng Ph\'b8p m\'b5 th\'abi }{\f37\fs20\insrsid1378858 - \'eb Nam K\'fa c\'e3 5, 6 t\'ea b\'b8o v\'b5o lo\'b9i \'ca
y. }{\f38\fs20\insrsid1378858 \'eb }{\f37\fs20\insrsid1378858 c\'b8c v\'efng kh\'b8c, kh\'abng c\'e3 t\'ea b\'b8o n\'b5o, v\'d7 kh\'abng c\'e3 hay c\'e3 \'ddt ng\'ad\'eai v\'b5o l\'b5ng T\'a9y. Trong s\'e8 c\'b8c c\'ac quan ng\'abn lu\'cbn \'cay - th\'ad
\'eang l\'b5 b\'b8n nguy\'d6t san - c\'e3 hai hay ba t\'ea c\'e3 khuynh h\'ad\'edng }{\i\f37\fs20\insrsid1378858 qu\'e8c gia h\'eep ph\'b8p}{\f37\fs20\insrsid1378858 . Gh\'d0p hai t\'ddnh t\'f5 tr\'b8i ng\'ad\'eec nhau \'cay v\'edi nhau, c\'e3 th\'d3 k
\'fa d\'de \'ae\'cay v\'b5 c\'c7n gi\'b6i th\'ddch \'ae\'abi ch\'f3t. Nh\'f7ng t\'ea b\'b8o n\'b5y l\'b5 }{\f37\fs20\expnd0\expndtw-2\insrsid1378858 c\'f1a b\'e4n t\'ad s\'b6n b\'b6n x\'f8 m\'edi l\'aan, c\'e3 \'ae\'dea v\'de l\'b5 nh\'ea \'eb n\'d2n \'ae
\'ab h\'e9 Ph\'b8p. N\'d2n \'ae\'ab h\'e9 \'cay \'ae\'b7 sinh ra b\'e4n n\'b5y, nh\'adng l\'b9i kh\'abng \'ae\'d3 cho h\'e4 ph\'b8t tri\'d3n. V\'d7 v\'cby, t\'c7ng l\'edp t\'ad s\'b6n nh\'e1 b\'d0 \'ae\'e3 b\'de ng\'b9t th\'eb trong ph\'b9m vi ch\'cbt h
\'d1p v\'b5 ph\'f4 thu\'e9c m\'b5 quan th\'c7y ngo\'b9i qu\'e8c - cha \'ae\'ec \'ae\'c7u c\'f1a h\'e4- \'ae\'b7 d\'b5nh cho h\'e4. V\'b5 v\'d7 th\'d5, h\'e4 h\'ean m\'b8t nh\'adng c\'f2ng nh\'cc nh\'d1 th\'abi. B\'ebi th\'a9n ph\'cbn n\'f6a d\'aci n\'f6
a chu\'e9t c\'f1a h\'e4, ch\'bcng thu\'e9c ho\'b5n to\'b5n trong x\'b7 h\'e9i An Nam v\'d7 h\'e4 l\'b5 nh\'f7ng ng\'ad\'eai v\'b5o l\'b5ng T\'a9y, m\'b5 c\'f2ng ch\'bcng thu\'e9c trong t\'c7ng l\'edp "qu\'fd t\'e9c" T\'a9y v\'d7 h\'e4 xu\'cat th\'a9n ra l
\'b5 ng\'ad\'eai An Nam - n\'aan h\'e4 c\'b6m th\'cay l\'f3ng t\'f3ng trong m\'e4i vi\'d6c. \'a7\'e5ng th\'eai trong m\'e4i h\'b5nh \'ae\'e9ng v\'b5 t\'ad t\'ad\'ebng c\'f1a h\'e4, \'ae\'d2u th\'cay c\'b8i m\'a9u thu\'c9n x\'b7 h\'e9i v\'b5 t\'a9m l\'fd 
\'cay. B\'b8o c\'f1a h\'e4 ch\'d8 tr\'ddch nh\'f7ng v\'f4 h\'b5 l\'b9m, nh\'adng l\'b9i ph\'d8nh n\'denh nh\'f7ng k\'ce h\'b5 l\'b9m; h\'e4 than phi\'d2n v\'d2 nh\'f7ng \'ae\'b9o lu\'cbt \'ae\'cc n\'d0n \'b8p b\'f8c, nh\'adng v\'c9n c\'cby th\'d5 v\'b5o n
\'ad\'edc m\'d1; h\'e4 m\'f1i l\'dfng cho s\'e8 ph\'cbn kh\'e8n kh\'e6 c\'f1a ng\'ad\'eai An Nam, nh\'adng v\'c9n ca t\'f4ng c\'abng \'ae\'f8c m\'ac h\'e5 c\'f1a m\'e9t n\'d2n khai ho\'b8 t\'e8t \'ae\'d1p h\'acn. H\'e4 mu\'e8n ch\'f7a b\'d6nh, nh\'adng l
\'b9i kh\'abng d\'b8m t\'d7m v\'b5 t\'can c\'abng v\'b5o ngu\'e5n g\'e8c c\'f1a b\'d6nh.}{\f37\fs20\insrsid1378858 
\par }{\f38\fs20\insrsid1378858 \'b6}{\f37\fs20\insrsid1378858 nh h\'ad\'ebng c\'f1a h\'e4 b\'de c\'b6n tr\'eb m\'e4i \'ae\'ad\'eang:
\par a) V\'d7 ch\'ddnh s\'b8ch ngu d\'a9n nh\'ad c\'b8c b\'b9n \'ae\'b7 bi\'d5t, n\'aan \'ae\'e9c gi\'b6 ch\'d8 c\'e3 m\'e9t d\'f3m ng\'ad\'eai r\'cat h\'b9n ch\'d5. M\'e7i s\'e8 ph\'b8t h\'b5nh kh\'abng bao gi\'ea qu\'b8 m\'e9t hay hai ngh\'d7n b\'b6n, \'ca
y th\'d5 m\'b5 b\'b8n kh\'abng h\'d5t.
\par b) V\'d7 th\'b8i \'ae\'e9 l\'f5ng ch\'f5ng, v\'d7 kh\'abng c\'e3 ch\'ad\'acng tr\'d7nh c\'f4 th\'d3, kh\'abng c\'e3 k\'d5 ho\'b9ch r\'e2 r\'b5ng, kh\'abng c\'e3 khuynh h\'ad\'edng m\'b9nh d\'b9n, n\'aan m\'cay t\'ea b\'b8o \'cay kh\'abng thu h\'f3t \'ae
\'ad\'eec c\'b6m t\'d7nh c\'f1a d\'a9n ch\'f3ng. H\'e4 ng\'b6 nghi\'aang, hay \'ae\'f3ng h\'acn, l\'ac l\'f6ng gi\'f7a d\'a9n ch\'f3ng m\'b5 h\'e4 kh\'abng g\'c7n g\'f2i \'ae\'ad\'eec v\'b5 nh\'f7ng k\'ce th\'e8ng tr\'de kh\'abng \'ada h\'e4.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 c) Nh\'b5 n\'ad\'edc thu\'e9c \'ae\'dea c\'e8 t\'a9m ph\'b8 ph\'b8ch h\'e4. H\'e4 b\'de ph\'b8 b\'bbng nhi\'d2u c\'b8
ch. Sau \'ae\'a9y l\'b5 nh\'f7ng c\'b8ch th\'abng th\'ad\'eang nh\'cat:
\par 1. Nh\'b5 n\'ad\'edc b\'b8o cho c\'abng ch\'f8c v\'b5 nh\'a9n vi\'aan ng\'ad\'eai b\'b6n x\'f8 bi\'d5t r\'bbng c\'cap tr\'aan \'ae\'b7 coi nh\'f7ng t\'ea b\'b8o \'cay nh\'ad l\'b5m c\'b8ch m\'b9ng, r\'bbng nh\'f7ng ng\'ad\'eai n\'b5o \'ae\'e4c nh\'f7ng b
\'b8o \'ae\'e3 s\'cf b\'de ghi danh s\'b8ch ri\'aang, v\'b5 d\'dc nhi\'aan l\'b5 b\'b6n danh s\'b8ch \'cay s\'cf \'ae\'ddnh theo b\'b8o c\'b8o th\'a8ng hay gi\'b8ng ch\'f8c.
\par C\'e3 nhi\'d2u c\'abng ch\'f8c \'ae\'b7 b\'de b\'bet bu\'e9c ph\'b6i \'ae\'e6i \'aei ch\'e7 kh\'b8c hay b\'de b\'bet v\'d2 h\'adu ch\'d8 v\'d7 \'ae\'b7 vi ph\'b9m nh\'f7ng \'aei\'d2u r\'a8n \'aee \'cay.
\par 2. \'a7\'e8i v\'edi nh\'f7ng \'ae\'e9c gi\'b6 kh\'abng ph\'b6i l\'b5 c\'abng ch\'f8c (t\'abi n\'e3i kh\'abng ph\'b6i l\'b5 c\'abng ch\'f8c ch\'f8 kh\'abng n\'e3i t\'f9 do, v\'d7 \'eb \'ae\'cat n\'ad\'edc ch\'f3ng t\'abi kh\'abng ai \'ae\'ad\'eec t\'f9
 do c\'b6, tr\'f5 b\'e4n x\'e1 l\'b8 ba que ra) th\'d7 vi\'aan quan cai tr\'de cho g\'e4i h\'e4 \'ae\'d5n b\'b5n gi\'cay, \'a9n c\'c7n khuy\'aan b\'b6o h\'e4 \'aei\'d2u h\'acn l\'cf thi\'d6t. 
\par N\'d5u h\'e4 kh\'abng bi\'d5t nghe nh\'f7ng l\'eai khuy\'aan t\'f6 t\'d5 \'cay, th\'d7 h\'e4 b\'de c\'b6nh s\'b8t theo d\'e2i. V\'b5 c\'f8 m\'ad\'eai l\'c7n th\'d7 c\'e3 \'ae\'d5n ch\'ddn, b\'b8o ch\'dd v\'b5 th\'ad t\'f5 c\'f1a h\'e4 b\'de th\'cat l\'b9
c nh\'ad b\'de ph\'d0p th\'c7n. Ch\'ddnh ph\'f1 h\'b7y t\'b9m vui l\'dfng nh\'ad th\'d5 trong l\'f3c ch\'ea \'ae\'eei c\'ac h\'e9i \'ae\'d3 t\'e3m c\'e6 h\'e4 v\'d7 l\'cf n\'b5y hay l\'cf kh\'b8c.
\par 3. Ch\'ddnh ph\'f1 cho b\'e4n ch\'f1 nh\'b5 in l\'f9a ch\'e4n n\'aan l\'b5m vi\'d6c cho m\'e9t t\'ea b\'b8o "tin v\'det kh\'abng bi\'d5t \'aei\'d2u" \'ae\'ad\'eec \'ddt ti\'d2n, hay n\'aan nh\'cbn in cho Nh\'b5 n\'ad\'edc \'ae\'ad\'eec l\'eei l\'e9c v\'b5
 b\'b6o \'ae\'b6m h\'acn nhi\'d2u.
\par V\'d7 th\'d5, m\'e9t t\'ea b\'b8o \'eb S\'b5i G\'dfn \'ae\'b7 bu\'e9c ph\'b6i \'ae\'e6i ch\'f1 in nhi\'d2u l\'c7n trong m\'e9t th\'b8ng.
\par 4. Ch\'ddnh ph\'f1 vi ph\'b9m quy\'d2n t\'f9 do th\'ad t\'ddn, ngay c\'b6 th\'ad ri\'aang c\'f1a c\'b8c k\'fd gi\'b6. Nh\'f7ng ng\'ad\'eai n\'b5y b\'de "ghi" v\'b5o s\'e6 \'aeen, b\'de theo d\'e2i, d\'df la, do th\'b8m v\'b5 vu c\'b8o. Ch\'ddnh ph\'f1 d
\'efng c\'b6 \'b8p l\'f9c \'ae\'e8i v\'edi gia \'ae\'d7nh, b\'b5 con th\'a9n thu\'e9c v\'b5 b\'cc b\'b9n h\'e4 n\'f7a. Ch\'d8 nh\'ea \'ae\'dea v\'de c\'e3 l\'b5ng T\'a9y v\'b5 nh\'ea m\'b8nh kho\'d0 kh\'abn kh\'d0o k\'d5t th\'f3c m\'e4i b\'d7nh lu\'cbn b
\'bbng c\'b8ch n\'denh h\'e3t t\'a9ng b\'e8c h\'d5t m\'f8c n\'ad\'edc m\'d1 b\'b6o h\'e9, nh\'a9n t\'f5, thi\'aang li\'aang, v.v. m\'b5 h\'e4 tho\'b8t kh\'e1i \'aei t\'ef.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\expnd0\expndtw2\insrsid1378858 B\'b8o ch\'dd b\'b6n x\'f8 b\'bbng ti\'d5ng Ph\'b8p b\'de ph\'b8 ph\'b8ch nh\'ad v\'cby \'ae\'cay. Nh
\'f7ng h\'b5nh vi b\'cat h\'eep ph\'b8p c\'f1a l\'e8i tr\'de an \'ae\'aa h\'ccn \'cay c\'dfn \'ae\'ad\'eec t\'a8ng c\'ad\'eang v\'b5 b\'e6 sung th\'aam b\'bbng nh\'f7ng \'aei\'d2u l\'d6 ph\'b8p l\'fd nh\'ad th\'d5 n\'b5y: "M\'e4i vi\'d6c tr\'adng b\'b5
y hay g\'f6i \'aei n\'aci kh\'b8c nh\'f7ng b\'b5i h\'b8t, b\'f8c ho\'b9 hay tranh \'b6nh tr\'b8i \'ae\'b9o t\'abn k\'ddnh \'ae\'e8i v\'edi c\'b8c v\'de \'ae\'b9i di\'d6n c\'f1a Nh\'b5 n\'ad\'edc, s\'cf b\'de tr\'f5ng ph\'b9t bao nhi\'aau th\'b8ng t\'ef v
\'b5 ph\'b9t ti\'d2n bao nhi\'aau phr\'a8ng \'ae\'e3, v.v.".
\par }\pard \qj \fi397\li0\ri0\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ch\'ada h\'d5t \'ae\'a9u. N\'d2n v\'a8n minh c\'f1a th\'f9c d\'a9n \'ae\'b7 d\'efng ng\'e4n \'aeu\'e8c c\'e6 truy\'d2n th\'f1
 ti\'aau \'ae\'d5n ch\'f3t t\'f9 do cu\'e8i c\'efng c\'f1a ng\'ad\'eai b\'b6n x\'f8. \'a7\'b7 l\'b5m cho ng\'ad\'eai b\'b6n x\'f8 ph\'b6i \'ae\'c7n \'ae\'e9n v\'b5 c\'a9m, ch\'f3ng v\'c9n ch\'ada v\'f5a l\'dfng; ch\'f3ng c\'dfn mu\'e8n h\'e4 ph\'b6i \'aei
\'d5c n\'f7a kia. Ch\'f3ng b\'det tai h\'e4 kh\'abng cho h\'e4 nghe ti\'d5ng vang c\'f1a nh\'f7ng bi\'d5n c\'e8 b\'aan ngo\'b5i. Ch\'d8 \'ae\'acn gi\'b6n b\'bbng m\'e9t n\'d0t b\'f3t, ch\'f3ng \'ae\'d7nh ch\'d8 h\'bcn \'ae\'eai s\'e8ng tinh th\'c7n c\'f1
a c\'b6 m\'e9t d\'a9n t\'e9c. C\'f2ng s\'bec l\'d6nh v\'f5a k\'d3 tr\'aan \'ae\'denh r\'bbng: "S\'f9 l\'adu h\'b5nh b\'b8o v\'b5 t\'b9p ch\'dd }{\i\f37\fs20\insrsid1378858 b\'cat c\'f8 b\'bbng ti\'d5ng g\'d7, c\'e3 th\'d3 b\'de c\'cam do m\'e9t ngh\'de 
\'ae\'denh c\'f1a quan to\'b5n quy\'d2n"}{\f37\fs20\insrsid1378858 . C\'b8c b\'b9n c\'e3 tin ch\'bec r\'bbng quan to\'b5n quy\'d2n nh\'a9n t\'f5 ch\'bcng s\'ac su\'cat g\'d7 m\'b5 kh\'abng d\'efng v\'b5 l\'b9m d\'f4ng quy\'d2n h\'b5nh \'cay. B\'b8o ch\'dd
 b\'bbng ti\'d5ng Ph\'b8p, xu\'cat b\'b6n \'eb Pari, g\'f6i sang \'ae\'d2u b\'de t\'dech thu \'eb \'a7\'abng D\'ad\'acng. S\'eb b\'adu ch\'ddnh, s\'eb m\'cbt th\'b8m v\'b5 c\'b8c c\'ac quan h\'b5nh ch\'ddnh c\'efng nhau l\'b5m nhi\'d6m v\'f4 \'ae\'aa h
\'ccn \'cay. V\'b5 ng\'ad\'eai ta do\'b9 tr\'f5ng ph\'b9t nh\'f7ng ng\'ad\'eai c\'e3 t\'aan nh\'cbn nh\'f7ng t\'ea b\'b8o \'cay. Ng\'ad\'eai ta c\'cam ng\'c6t kh\'abng cho \'ae\'e4c b\'b8o Nh\'cbt v\'b5 Trung Qu\'e8c. Gi\'f7 m\'e9t t\'ea t\'b9p ch\'dd, m
\'e9t quy\'d3n s\'b8ch Trung Qu\'e8c n\'b5o \'ae\'e3 c\'e3 th\'d3 l\'b5 m\'e9t tr\'e4ng t\'e9i \'ae\'e8i v\'edi ng\'ad\'eai An Nam. T\'abi bi\'d5t nhi\'d2u nh\'b5 v\'a8n th\'a9n b\'de k\'d5t \'b8n kh\'e6 sai chung th\'a9n v\'d7 \'ae\'b7 \'ae\'e4c t\'b9
p ch\'dd }{\i\f37\fs20\insrsid1378858 Trung Qu\'e8c h\'e5n, }{\i\f38\fs20\insrsid1378858 \'c8}{\i\f37\fs20\insrsid1378858 m b\'a8ng}{\f37\fs20\insrsid1378858  v\'b5 nh\'f7ng b\'b5i c\'efng lo\'b9i \'cay c\'f1a c\'b8c nh\'b5 duy t\'a9n Trung Qu\'e8c. N\'a8
m 1920, c\'e3 nhi\'d2u ng\'ad\'eai An Nam \'eb B\'bec K\'fa b\'de k\'d5t \'b8n t\'f5 hai \'ae\'d5n n\'a8m n\'a8m t\'ef, ch\'d8 v\'d7 m\'e9t ng\'ad\'eai \'ae\'b7 l\'b5m th\'ac ca t\'f4ng t\'f9 do v\'b5 c\'b8c ng\'ad\'eai kh\'b8c \'ae\'b7 nghe ng\'a9m b\'b5
i th\'ac \'cay.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 THU\'d5 KHO\'b8
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ch\'ddnh s\'b8ch th\'f9c d\'a9n \'a8n c\'ad\'edp, ch\'bc
ng nh\'f7ng \'ae\'b7 t\'ad\'edc \'aeo\'b9t m\'cat ru\'e9ng \'ae\'cat, c\'f1a c\'b6i, \'ae\'b7 xo\'b8 b\'e1 h\'d5t m\'e4i quy\'d2n l\'eei, m\'e4i quy\'d2n t\'f9 do - k\'d3 c\'b6 quy\'d2n t\'f9 do th\'a9n th\'d3 c\'f1a ng\'ad\'eai d\'a9n b\'b6n x\'f8, m\'b5
 c\'dfn b\'bet h\'e4 ph\'b6i n\'e9p thu\'d5 v\'d2 nh\'f7ng m\'b6nh \'ae\'cat c\'bbn c\'e7i c\'dfn l\'b9i trong tay h\'e4, n\'e9p thu\'d5 v\'d2 ngh\'d2 nghi\'d6p sinh s\'e8ng c\'f1a h\'e4, n\'e9p c\'b6 thu\'d5 kh\'abng kh\'dd m\'b5 h\'e4 th\'eb n\'f7a.

\par \'a7\'e9t nhi\'aan ng\'ad\'eai ta t\'a8ng thu\'d5 th\'a9n t\'f5 m\'e9t h\'b5o l\'aan hai \'ae\'e5ng 
\par r\'ad\'eci. Nh\'f7ng ng\'ad\'eai ch\'ada \'ae\'d5n tu\'e6i n\'e9p s\'adu, ngh\'dca l\'b5 d\'ad\'edi 18 tu\'e6i, tr\'ad\'edc kia kh\'abng ph\'b6i \'ae\'e3ng g\'e3p g\'d7, th\'d7 nay ph\'b6i n\'e9p m\'e9t th\'f8 thu\'d5 n\'c6ng g\'cap m\'cay l\'c7n thu\'d5
 th\'a9n c\'f1a su\'cat \'aeinh tr\'ad\'edc kia.
\par Ng\'ad\'eai ta kh\'abng nh\'f7ng t\'a8ng thu\'d5 l\'aan g\'cap b\'e9i v\'b5 b\'bet nh\'f7ng ng\'ad\'eai ch\'ada h\'d2 ph\'b6i \'ae\'e3ng g\'e3p nay ph\'b6i \'ae\'e3ng g\'e3p, m\'b5 \'aei\'d2u tai h\'b9i nh\'cat \'ae\'e8i v\'edi d\'a9n \'aeinh l\'b5 thu
\'d5 su\'cat thay \'ae\'e6i lu\'abn v\'b5 ng\'ad\'eai d\'a9n b\'de b\'bet bu\'e9c ph\'b6i mang nhi\'d2u lo\'b9i th\'ce tu\'fa th\'a9n, th\'ce th\'abng h\'b5nh, do \'ae\'e3 m\'b5 ph\'b6i \'ae\'e3ng g\'e3p h\'d5t s\'f8c v\'ab l\'fd v\'b5 c\'e3 t\'ddnh ch
\'cat c\'ad\'ecng b\'f8c.
\par Ng\'ad\'eai An Nam b\'bet bu\'e9c l\'f3c n\'b5o c\'f2ng ph\'b6i mang th\'ce thu\'d5 th\'a9n trong ng\'ad\'eai, }{\i\f37\fs20\insrsid1378858 ai h\'e1i \'ae\'d5n}{\f37\fs20\insrsid1378858  \'ae\'d2u ph\'b6i xu\'cat tr\'d7nh. Th\'ce d\'d4 b\'de nh\'b5u n\'b8
t v\'b5 b\'c8n th\'d8u, nh\'adng ng\'ad\'eai n\'b5o qu\'aan ho\'c6c \'ae\'b8nh m\'cat th\'ce th\'d7 b\'de b\'bet v\'b5 b\'de t\'ef.
\par }\pard \qj \li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 N\'a8m 1919, ng\'ad\'eai ta \'ae\'b7 b\'e1 vi\'d6c ph\'a9n h\'b9ng \'ae\'e3ng thu\'d5 th\'a9n \'eb B\'bec K\'fa, ch\'d8 b\'bb
ng m\'e9t ngh\'de \'ae\'denh c\'f1a th\'e8ng s\'f8. M\'e4i ng\'ad\'eai d\'a9n t\'f5 18 \'ae\'d5n 60 tu\'e6i, \'ae\'d2u ph\'b6i nh\'cat lu\'cbt \'ae\'e3ng 5 \'ae\'e5ng thu\'d5 th\'a9n.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Theo m\'e9t ngh\'de \'ae\'denh kh\'b8c th\'d7 b\'cat c\'f8 ng\'ad\'eai An Nam n\'b5o kh\'abng mang th\'ce \'ae\'d2u c
\'e3 th\'d3 b\'de t\'ef v\'b5 bu\'e9c ph\'b6i \'ae\'e3ng thu\'d5 m\'e9t l\'c7n n\'f7a d\'ef tr\'ad\'edc kia ng\'ad\'eai \'ae\'e3 \'ae\'b7 n\'e9p r\'e5i.
\par \'a7\'d3 b\'ef v\'b5o ch\'e7 hao h\'f4t do \'ae\'e5ng b\'b9c b\'de s\'f4t gi\'b8, m\'e9t vi\'aan to\'b5n quy\'d2n \'ae\'b7 c\'e3 s\'b8ng ki\'d5n t\'a8ng g\'cap b\'e9i s\'e8 ng\'ad\'eai ph\'b6i ch\'deu thu\'d5 l\'aan \'ae\'d3 b\'bet c\'b8c x\'b7 ph\'b6i 
\'ae\'e3ng g\'e3p th\'aam.
\par }\pard \qc \li0\ri0\sb120\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ng\'ad\'eai An Nam ph\'b6i \'ae\'e3ng thu\'d5 n\'c6ng h\'acn ng\'ad\'eai}{\f38\fs20\insrsid1378858  \'ca}{
\f37\fs20\insrsid1378858 n \'a7\'e9, M\'b7 Lai, Nam D\'ad\'acng v\'b5 Nh\'cbt B\'b6n nhi\'d2u. Nh\'adng \'ae\'eai s\'e8ng kinh t\'d5 \'eb Nam D\'ad\'acng, }{\f38\fs20\insrsid1378858 \'ca}{\f37\fs20\insrsid1378858 n \'a7\'e9 v\'b5 Nh\'cbt B\'b6n l\'b9
i cao h\'acn \'eb \'a7\'abng D\'ad\'acng nhi\'d2u l\'bem, d\'a9n nh\'f7ng n\'ad\'edc n\'b5y c\'e3 th\'d3 \'ae\'e3ng g\'e3p d\'d4 d\'b5ng s\'e8 thu\'d5 qu\'b8 n\'c6ng \'ae\'e8i v\'edi ng\'ad\'eai An Nam.
\par }\pard \qc \li0\ri0\sb120\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Tr\'ad\'edc th\'eai Ph\'b8p thu\'e9c, b\'e9 thu\'d5 \'aei\'d2n th\'e6 ghi \'ae\'c7y \'ae\'f1 ru\'e9ng \'ae\'cat c\'ab
ng v\'b5 ru\'e9ng \'ae\'cat t\'ad c\'e3 ph\'a9n h\'b9ng theo lo\'b9i s\'b6n v\'cbt tr\'e5ng tr\'e4t. Thu\'d5 su\'cat ch\'d8 \'ae\'b8nh t\'f5 m\'e9t \'ae\'d5n n\'a8m h\'b5o m\'e9t m\'c9u \'ae\'e8i v\'edi ru\'e9ng c\'cay l\'f3a. \'a7\'e8i v\'edi c\'b8c lo
\'b9i ru\'e9ng \'ae\'cat kh\'b8c, thu\'d5 su\'cat \'ae\'b8nh t\'f5 hai h\'b5o \'ae\'d5n m\'e9t \'ae\'e5ng t\'ad. \'a7\'acn v\'de di\'d6n t\'ddch l\'b5 m\'c9u t\'f8c l\'b5 m\'e9t di\'d6n t\'ddch vu\'abng m\'e7i c\'b9nh \'ae\'e9 150 th\'ad\'edc. Chi\'d2u d
\'b5i c\'f1a m\'e9t th\'ad\'edc An Nam thay \'ae\'e6i tu\'fa t\'f5ng t\'d8nh t\'f5 42, 47 \'ae\'d5n 64 x\'a8ngtim\'d0t, do \'ae\'e3 di\'d6n t\'ddch m\'e9t m\'c9u tu\'fa n\'aci c\'e3 th\'d3 l\'b5 3.970, 4.900 ho\'c6c 6.200 m\'d0t vu\'abng.
\par \'a7\'d3 t\'a8ng th\'aam thu nh\'cbp cho Nh\'b5 n\'ad\'edc, ng\'ad\'eai ta d\'efng m\'e9t \'ae\'acn v\'de \'aeo \'ae\'b9c, d\'b5i 40 x\'a8ngtim\'d0t, ng\'ben h\'acn t\'cat c\'b6 c\'b8c \'ae\'acn v\'de th\'ad\'eang d\'efng, v\'d7 v\'cby di\'d6n t\'ddch m
\'e9t m\'c9u ch\'d8 c\'dfn 3.600 m\'d0t vu\'abng. B\'bbng c\'b8ch \'ae\'e3 thu\'d5 \'aei\'d2n th\'e6 \'ae\'b7 t\'a8ng l\'aan nhi\'d2u hay \'ddt kh\'b8c nhau tu\'fa t\'f5ng t\'d8nh: n\'aci th\'d7 t\'a8ng m\'e9t ph\'c7n m\'ad\'eai, n\'aci th\'d7 t\'a8ng m
\'e9t ph\'c7n ba, n\'aci b\'de thi\'d6t th\'dfi nh\'cat th\'d7 t\'a8ng \'ae\'d5n hai ph\'c7n ba.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 T\'f5 1890, thu\'d5 tr\'f9c thu t\'a8ng l\'aan g\'cap \'ae\'abi; t\'f5 1896 \'ae\'d5n 1898 t\'a8ng l\'aan m\'e9t n\'f6
a v\'b5 c\'f8 nh\'ad th\'d5 t\'a8ng l\'aan m\'b7i. C\'b8c x\'b7 th\'d7 c\'f8 nai l\'adng ra \'ae\'e3ng g\'e3p; c\'dfn bi\'d5t k\'aau ai b\'a9y gi\'ea? B\'e3p n\'c6n \'ae\'ad\'eec th\'d7 b\'e4n c\'abng s\'f8 l\'b9i c\'b5ng ra tay b\'e3p n\'c6n. B\'e4n Ph
\'b8p n\'b5y cho r\'bbng c\'b8c x\'b7 v\'c9n ngoan ngo\'b7n n\'e9p \'ae\'f1 thu\'d5 th\'d7 t\'f8c l\'b5 thu\'d5 m\'b8 ch\'ada \'ae\'d5n n\'e7i qu\'b8 n\'c6ng n\'d2!
\par }\pard \qc \li0\ri0\sb120\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 H\'bbng n\'a8m ng\'ad\'eai ta ph\'a9n b\'e6 cho m\'e7i l\'b5ng ph\'b6i n\'e9p thu\'d5 cho m\'e9t s\'e8 \'aeinh v\'b5 m
\'e9t s\'e8 ru\'e9ng \'ae\'cat c\'b8c h\'b9ng. C\'c7n c\'e3 th\'aam ti\'d2n \'ae\'d3 chi ti\'aau ch\'a8ng? Ng\'ad\'eai ta c\'f8 s\'f6a l\'b9i con s\'e8, m\'c6c d\'c7u \'aeang gi\'f7a n\'a8m, r\'e5i ng\'ad\'eai ta b\'bet c\'b8c l\'b5ng ph\'b6i \'ae\'e3ng 
\'ae\'f1 thu\'d5 cho s\'e8 \'aeinh, \'aei\'d2n cao h\'acn s\'e8 quy \'ae\'denh \'ae\'c7u n\'a8m. V\'d7 th\'d5 m\'b5 \'eb m\'e9t t\'d8nh B\'bec K\'fa, to\'b5n b\'e9 di\'d6n t\'ddch ch\'ada t\'edi 120.000 h\'d0cta m\'b5 b\'b6n th\'e8ng k\'aa l\'b9i ghi nh
\'f7ng 122.000 h\'d0cta ru\'e9ng v\'b5 c\'f8 nh\'ad th\'d5, ng\'ad\'eai An Nam v\'c9n ph\'b6i c\'f3i \'ae\'c7u \'ae\'e3ng thu\'d5 kh\'e8ng cho nh\'f7ng ru\'e9ng \'ae\'cat kh\'abng c\'e3 th\'f9c. C\'e3 k\'aau ca c\'f2ng ch\'bcng ai th\'ccm nghe!
\par Kh\'abng nh\'f7ng thu\'d5 \'ae\'b7 n\'c6ng n\'d2 m\'b5 l\'b9i c\'dfn thay \'ae\'e6i lu\'abn.
\par }\pard \qj \li0\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Vi\'d6c Ch\'ddnh ph\'f1 c\'e3 nh\'a9n nh\'ad\'eeng ph\'c7n n\'b5o trong vi\'d6c thu m\'e9t s\'e8 kho\'b6n thu\'d5 l\'adu th
\'abng h\'b5ng ho\'b8 \'ae\'b7 l\'b5m cho d\'a9n l\'b5ng b\'de phi\'d2n nhi\'d4u h\'acn v\'b5 \'ae\'b7 m\'eb \'ae\'ad\'eang cho t\'d6 nh\'f2ng l\'b9m. C\'e3 h\'abm ng\'ad\'eai ta tha kh\'abng \'ae\'b8nh thu\'d5 cho m\'e9t ng\'ad\'eai g\'b8nh m\'e9t g\'b8
nh cau, nh\'adng h\'abm sau ng\'ad\'eai ta l\'b9i b\'bet ng\'ad\'eai \'ae\'e3 \'ae\'e3ng thu\'d5 tuy g\'b8nh m\'e9t g\'b8nh nh\'d1 h\'acn. \'a7\'b8nh thu\'d5 nh\'ad v\'cby th\'d7 kh\'e3 m\'b5 c\'abng b\'bbng \'ae\'ad\'eec. Ng\'ad\'eai ta c\'cap m\'e9t gi
\'cay ph\'d0p l\'adu th\'abng cho 150 kil\'abgam thu\'e8c l\'b5o. S\'bep x\'d5p l\'b5m sao \'ae\'d3 kh\'e1i ph\'b6i \'ae\'b8nh thu\'d5 nhi\'d2u l\'c7n v\'b5o c\'efng m\'e9t s\'e8 thu\'e8c \'ae\'e3 khi s\'e8 h\'b5ng n\'b5y \'ae\'b7 chuy\'d3n sang tay m\'e9
t ch\'f1 kh\'b8c, hay khi 150 kil\'abgam thu\'e8c \'ae\'e3 \'ae\'b7 \'aeem chia cho ba, b\'e8n ng\'ad\'eai mua? Ch\'d8 c\'e3 tu\'fa \'eb c\'b8c \'abng nh\'b5 \'aeoan, mu\'e8n l\'b5m g\'d7 th\'d7 l\'b5m ch\'f8 kh\'abng c\'e3 lu\'cbt ph\'b8p n\'b5o c\'b6
. Cho n\'aan ng\'ad\'eai An Nam r\'cat s\'ee nh\'b5 \'aeoan, tho\'b8ng th\'cay nh\'a9n vi\'aan nh\'b5 \'aeoan l\'b5 h\'e4 \'ae\'b7 v\'f8t ngay gi\'f7a \'ae\'ad\'eang th\'f3ng mu\'e8i, th\'f3ng thu\'e8c l\'b8 hay th\'f3ng cau m\'b5 h\'e4 \'aeang g\'b8nh tr
\'aan vai; th\'b5 m\'cat c\'f1a c\'dfn h\'acn l\'b5 \'ae\'e3ng thu\'d5 qu\'b8 n\'c6ng. C\'e3 v\'efng, ng\'ad\'eai An Nam bu\'e9c ph\'b6i nh\'e6 thu\'e8c
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 l\'b5o, ch\'c6t cau \'aei, \'ae\'d3 tr\'b8nh kh\'e1i b\'de
 phi\'d2n nhi\'d4u v\'d7 c\'b8c th\'f8 thu\'d5 m\'edi.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 N\'a8m ngo\'b8i, mi\'d2n trung Trung K\'fa b\'de \'aei\'aa
u \'ae\'f8ng v\'d7 n\'b9n \'ae\'e3i. Kh\'abng c\'f8u gi\'f3p th\'d7 ch\'ed, Ch\'ddnh ph\'f1 c\'dfn t\'a8ng thu\'d5 l\'aan 30%.
\par Nhi\'d2u t\'d8nh \'eb Nam K\'fa b\'de n\'b9n l\'f4t ph\'b8 ho\'b9i. Ng\'ad\'eai ta c\'cam ng\'ad\'eai An Nam b\'b5n \'ae\'d5n vi\'d6c \'ae\'e3 v\'b5 c\'cam t\'e6 ch\'f8c l\'b9c quy\'aan gi\'f3p \'ae\'e5ng b\'b5o c\'f1a h\'e4 b\'de n\'b9n. H\'acn n\'f7
a, trong l\'f3c d\'a9n ch\'f3ng \'ae\'e3i kh\'e6 v\'d7 thi\'aan tai nh\'ad v\'cby ng\'ad\'eai ta v\'c9n b\'bet d\'a9n \'ae\'e3ng thu\'d5 nh\'ad th\'ad\'eang l\'d6. \'a7\'d3 thu cho \'ae\'ad\'eec thu\'d5, \'ae\'b7 x\'b6y ra bao nhi\'aau v\'f4 l\'b9m quy
\'d2n, bao nhi\'aau cu\'e9c truy b\'f8c th\'cbm t\'d6 \'ae\'e8i v\'edi d\'a9n b\'de n\'b9n.
\par Su\'e8t c\'b6 n\'a8m, \'eb th\'b5nh th\'de c\'f2ng nh\'ad \'eb n\'abng th\'abn, ng\'b5y n\'b5o ng\'ad\'eai ta c\'f2ng \'ae\'ad\'eec m\'f4c k\'ddch nh\'f7ng cu\'e9c b\'bet b\'ed, kh\'b8m x\'d0t g\'a9y n\'aan nh\'f7ng c\'b6nh \'aeau x\'e3t, th\'b6m th\'ad
\'acng trong vi\'d6c thu c\'b8c th\'f8 thu\'d5. C\'e3 l\'f3c thu thu\'d5 \'ae\'b7 th\'b5nh m\'e9t cu\'e9c s\'a8n b\'bet ng\'ad\'eai. Ng\'ad\'eai d\'a9n b\'b6n x\'f8 n\'b5o m\'b5 kh\'abng c\'e3 ti\'d2n n\'e9p kho b\'b9c, ch\'bcng ch\'deu cho ng\'ad\'ea
i ta c\'efm k\'d1p v\'b5 c\'f2ng ch\'bcng mu\'e8n l\'b5m vi\'d6c d\'ad\'edi l\'b5n roi v\'e4t, th\'d7 tr\'e8n bi\'d6t m\'e9t x\'e3 v\'b5 \'ae\'b5nh ch\'deu ch\'d5t \'ae\'e3i \'eb \'ae\'e3.
\par Nhi\'d2u ng\'ad\'eai ph\'b6i b\'b8n c\'b6 gia t\'b5i - b\'b8n c\'b6 con c\'b8i - \'ae\'d3 \'ae\'e3ng thu\'d5 cho Nh\'b5 n\'ad\'edc \'ae\'b7 \'b8p b\'f8c, b\'e3c l\'e9t h\'e4.
\par }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  Cao Mi\'aan, c\'e3 nhi\'d2u ph\'f4 n\'f7 kh\'e8n kh\'e6, ch\'a9n mang xi\'d2ng s\'bet, ph\'b6i \'aei qu\'d0t \'ae\'ad\'eang. H\'e4 ch\'d8 c\'e3 m\'e9t t\'e9i l\'b5 kh\'abng n\'e9p \'ae\'ad\'ee
c thu\'d5.
\par 
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \column 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 CU\'e9C KH\'b8NG CHI\'d5N
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-287\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 M\'c6c d\'c7u b\'e4n vua ch\'f3a \'ad\'acn h\'ccn, m\'c6
c d\'c7u \'ae\'dech \'aeang chi\'d5m \'adu th\'d5 v\'b5 m\'c6c d\'c7u ch\'d5 \'ae\'e9 qu\'a9n ch\'f1 \'ae\'b7 l\'b5m cho d\'a9n ch\'f3ng quen l\'b9nh nh\'b9t, b\'b5ng quan, d\'a9n ch\'f3ng c\'f2ng kh\'abng th\'d3 ch\'deu \'b8ch ngo\'b9i bang m\'b5 kh\'ab
ng b\'d2n b\'d8 ch\'e8ng l\'b9i. L\'f3c m\'edi th\'cay c\'b8c t\'b5u chi\'d5n l\'edn v\'b5 s\'f3ng \'e8ng tinh x\'b6o th\'d7 ng\'b9c nhi\'aan, nh\'adng khi c\'b6m gi\'b8c \'ae\'c7u ti\'aan \'cay \'ae\'b7 qua th\'d7 nh\'f7ng ng\'ad\'eai y\'aau n\'ad\'ed
c An Nam li\'d2n t\'e6 ch\'f8c \'ae\'cau tranh. Cu\'e9c x\'a9m chi\'d5m \'a7\'abng D\'ad\'acng b\'bet \'ae\'c7u t\'f5 n\'a8m 1858 m\'b7i \'ae\'d5n 1909 m\'edi k\'d5t th\'f3c. Ch\'ddnh trong th\'eai k\'fa n\'b5y, khi nh\'b5 \'b8i qu\'e8c \'a7\'d2 Th\'b8m 

\par ch\'d5t th\'d7 c\'abng cu\'e9c ch\'e8ng Ph\'b8p c\'e3 t\'e6 ch\'f8c v\'b5 c\'e3 v\'f2 trang ch\'cam d\'f8t. Ng\'ad\'eai anh h\'efng d\'a9n t\'e9c \'cay c\'efng v\'edi m\'e9t \'ddt ngh\'dca qu\'a9n ki\'aan quy\'d5t c\'f1a \'abng \'ae\'b7 chi\'d5m l\'dcnh c
\'b6 m\'e9t t\'d8nh nh\'e1 v\'b5 \'ae\'ad\'acng \'ae\'c7u v\'edi th\'f9c d\'a9n Ph\'b8p trong nhi\'d2u n\'a8m. Trong th\'eai k\'fa chi\'d5n tranh \'eb ch\'a9u \'a2u, nhi\'d2u cu\'e9c b\'b9o \'ae\'e9ng \'ae\'b7 n\'e6 ra nh\'adng l\'b9i b\'de d\'d1p t\'be
t ngay trong bi\'d3n m\'b8u. Trong s\'e8 c\'b8c cu\'e9c kh\'ebi ngh\'dca \'ae\'e3, c\'c7n ch\'f3 \'fd \'ae\'d5n cu\'e9c n\'e6i d\'cby c\'f1a binh l\'ddnh An Nam - binh l\'ddnh s\'bep \'ae\'ad\'eec \'aeem sang Ph\'b8p - do \'abng vua tr\'ce Duy T\'a9n t
\'e6 ch\'f8c. Sau khi \'a9m m\'adu b\'b9i l\'e9, vua Duy T\'a9n b\'de ph\'d5 v\'b5 \'ae\'b5y sang ch\'a9u Phi.
\par Trong cu\'e9c \'ae\'cau tranh tuy\'d6t v\'e4ng c\'f1a m\'e9t d\'a9n t\'e9c b\'de \'b8p b\'f8c c\'e3 nhi\'d2u h\'b5nh \'ae\'e9ng oanh li\'d6t v\'b5 nhi\'d2u s\'f9 hy sinh l\'edn, gi\'b8 k\'d3 \'ae\'ad\'eec \'eb \'ae\'a9y \'ae\'d3 c\'b8c b\'b9n bi\'d5t th
\'d7 hay l\'bem, nh\'adng kh\'abng th\'d3 n\'e3i h\'d5t \'ae\'ad\'eec trong ph\'b9m vi nh\'e1 h\'d1p c\'f1a bu\'e6i n\'e3i chuy\'d6n n\'b5y c\'f1a ch\'f3ng ta. V\'cby n\'aan t\'abi ch\'d8 c\'e3 th\'d3 nh\'bec l\'b9i \'ae\'a9y m\'e9t \'aeo\'b9n h\'e5i k
\'fd c\'f1a ph\'e3 \'ae\'ab \'ae\'e8c R\'aav\'a9ye nh\'ad sau:
\par }\pard \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 "N\'d5u ch\'f3ng ta \'ae\'b8nh gi\'b8 m\'e9t ng\'ad\'eai qua ph\'c8m ch\'cat \'ae\'b9o \'ae\'f8c ch\'f8 kh\'abng ph\'b6
i qua nh\'f7ng tri th\'f8c c\'f1a ng\'ad\'eai \'ae\'e3, th\'d7 ch\'f3ng ta s\'cf b\'edt ki\'aau c\'a8ng v\'d2 t\'ddnh ch\'cat cao \'ae\'bcng c\'f1a ch\'f3ng ta \'ae\'e8i v\'edi ng\'ad\'eai Vi\'d4n \'a7\'abng, nh\'f7ng ng\'ad\'eai bi\'d5t hy sinh m\'e9t c
\'b8ch c\'e3 \'fd ngh\'dca.
\par N\'a8m 1862, ch\'f3ng t\'abi \'ae\'ad\'eec ph\'b8i \'aei \'ae\'b5n \'b8p m\'e9t cu\'e9c kh\'ebi ngh\'dca. Vi\'aan t\'ad l\'d6nh V. sai m\'e9t trung u\'fd \'aeem qu\'a9n ch\'c6n \'ae\'ad\'eang r\'f3t lui c\'f1a ngh\'dca qu\'a9n sau khi h\'e4 b\'b9i tr\'cb
n.
\par M\'c6t tr\'eai v\'f5a l\'c6n th\'d7 vi\'aan trung u\'fd \'aeem l\'ddnh tr\'eb v\'d2, r\'cat m\'d6t m\'e1i, ng\'ad\'eai \'ae\'c9m b\'efn. Kh\'abng th\'cay t\'ef nh\'a9n, th\'cay n\'d0t m\'c6t ai c\'f2ng c\'e3 v\'ce b\'e8i r\'e8i, ch\'f3ng t\'abi bi\'d5
t ngay l\'b5 cu\'e9c chinh ph\'b9t n\'b5y kh\'abng k\'d5t qu\'b6. Nh\'f7ng ng\'ad\'eai An Nam d\'c9n \'ae\'ad\'eang, \'ae\'c7u c\'f3i xu\'e8ng, tay b\'de tr\'e3i, \'aeang \'aei gi\'f7a b\'e8n ng\'ad\'eai l\'ddnh mang s\'f3ng. Th\'a9n th\'d3 h\'e4, g\'c7
n nh\'ad tr\'c7n tru\'e5ng, mang \'ae\'c7y v\'d5t th\'ad\'acng. Vi\'aan trung u\'fd b\'ad\'edc t\'edi tr\'ad\'edc vi\'aan t\'ad l\'d6nh v\'b5 l\'f3ng t\'f3ng n\'e3i:
\par - Th\'ada quan t\'ad l\'d6nh, t\'f5 s\'edm nh\'f7ng ng\'ad\'eai \'ae\'ada \'ae\'ad\'eang \'ae\'b7 d\'c9n ch\'f3ng t\'abi kh\'bep n\'aci, l\'e9i b\'efn ng\'cbp \'ae\'d5n b\'f4ng, nh\'adng ch\'f3ng t\'abi kh\'abng t\'d7m th\'cay m\'e9t ng\'ad\'eai ch\'b9
y tr\'e8n n\'b5o c\'b6.
\par Vi\'aan t\'ad l\'d6nh cho g\'e4i hai ng\'ad\'eai An Nam \'ae\'d5n h\'e1i.
\par Hai ng\'ad\'eai n\'b5y l\'b5 hai anh em v\'d7 h\'e4 gi\'e8ng nhau l\'bem. Ch\'d8 c\'e3 ng\'ad\'eai anh tr\'b6 l\'eai nh\'f7ng c\'a9u h\'e1i c\'f1a vi\'aan t\'ad l\'d6nh:
\par - Ch\'f3ng m\'b5y bi\'d5t ch\'e7, ch\'f3ng m\'b5y \'ae\'b7 th\'f3 nh\'cbn r\'e5i kia m\'b5.
\par - C\'e3, ch\'f3ng t\'abi c\'e3 bi\'d5t ch\'e7.
\par - Tao \'ae\'b7 gi\'b6i th\'ddch cho ch\'f3ng m\'b5y r\'cat k\'fc vi\'d6c h\'ad\'edng d\'c9n l\'ddnh \'aei t\'d7m \'eb \'ae\'a9u v\'b5 b\'bbng c\'b8ch n\'b5o r\'e5i. Ch\'f3ng m\'b5y \'ae\'b7 khai hi\'d3u r\'e2 h\'d5t.
\par - Ch\'f3ng t\'abi hi\'d3u.
\par - Tao c\'e3 n\'e3i: "N\'d5u ch\'f3ng m\'b5y d\'c9n qu\'a9n l\'ddnh \'aei \'ae\'f3ng \'ae\'ad\'eang th\'d7 ch\'f3ng m\'b5y s\'cf tho\'b8t ch\'d5t; n\'d5u \'aeem h\'e4 \'aei l\'b9c th\'d7 ch\'f3ng m\'b5y s\'cf b\'de x\'f6 b\'ben", c\'e3 \'ae\'f3ng tao \'ae
\'b7 n\'e3i nh\'ad th\'d5 kh\'abng?
\par - \'a4ng ch\'d8 huy c\'e3 n\'e3i nh\'ad v\'cby.
\par - Ch\'f3ng m\'b5y \'ae\'b7 c\'e8 t\'a9m l\'b5m l\'b9c h\'ad\'edng c\'b6 \'ae\'e9i qu\'a9n trong \'ae\'e5ng l\'c7y.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Hai ch\'b5ng thanh ni\'aan \'ae\'f8ng im l\'c6ng.
\par - L\'f3c ra \'aei, tao \'ae\'b7 n\'e3i tr\'ad\'edc r\'bbng ch\'f3ng m\'b5y s\'cf b\'de b\'ben, n\'d5u ch\'f3ng m\'b5y kh\'abng \'ae\'ada \'ae\'f3ng \'ae\'ad\'eang... C\'e3 ph\'b6i nh\'ad th\'d5 kh\'abng? Tr\'b6 l\'eai \'aei.
\par - \'a4ng ch\'d8 huy c\'e3 b\'b6o nh\'ad v\'cby, ng\'ad\'eai anh c\'b6 tr\'b6 l\'eai.
\par - V\'cby ch\'f3ng m\'b5y bi\'d5t tr\'ad\'edc ch\'f3ng m\'b5y s\'cf b\'de x\'f6 b\'ben ch\'f8 ?
\par - Ch\'f3ng t\'abi \'aeang ch\'ea \'ae\'a9y.
\par Ng\'ad\'eai Nam K\'fa \'cay tr\'b6 l\'eai v\'edi m\'e9t th\'b8i \'ae\'e9 ch\'deu \'ae\'f9ng r\'cat th\'b6n nhi\'aan c\'f1a ng\'ad\'eai }{\f38\fs20\insrsid1378858 \'b8}{\f37\fs20\insrsid1378858  \'a7\'abng. Th\'cay tra v\'can \'ae\'b7 xong, hai ng\'ad\'ea
i An Nam ch\'b5o \'aei ra.
\par Vi\'aan t\'ad l\'d6nh g\'e4i m\'e9t t\'aan cai ng\'ad\'eai Th\'e6 Nh\'dc K\'fa v\'b5 b\'b6o: "L\'cay b\'e8n l\'ddnh v\'b5 \'aeem b\'ben hai t\'aan t\'ef n\'b5y sau tr\'b9i".
\par T\'aan cai Th\'e6 Nh\'dc K\'fa v\'c9y hai ng\'ad\'eai An Nam hai ng\'ad\'eai n\'b5y \'aei theo kh\'abng h\'d2 ng\'cbp ng\'f5ng v\'b5 c\'f2ng ch\'bcng k\'aau ca g\'d7. M\'e9t l\'b8t sau, ti\'d5ng s\'f3ng n\'e6.
\par Vi\'aan t\'ad l\'d6nh m\'c6t b\'f5ng \'ae\'e1, quay v\'d2 ph\'dda ch\'f3ng t\'abi n\'e3i: "Th\'cbt l\'b5 anh h\'efng... }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  Hy L\'b9p c\'e3 l\'cf ng\'ad\'eai ta ph\'b6i d\'f9ng t\'ad\'eeng h\'e4 \'ae
\'cay, c\'dfn t\'abi, t\'abi ph\'b6i b\'ben h\'e4".
\par \'a7\'d5n s\'b8ng, nh\'d7n ra ngo\'b5i ph\'b8o thuy\'d2n, ch\'f3ng t\'abi th\'cay b\'aan b\'ea m\'e9t t\'cam bi\'d3n l\'edn \'ae\'e3ng v\'b5o th\'a9n c\'a9y. Ng\'ad\'eai th\'abng ng\'abn d\'dech l\'b9i cho ch\'f3ng t\'abi nghe m\'e9t \'aeo\'b9n nh\'ad
 sau:
\par "C\'b8c \'abng \'ae\'b7 chi\'d5m m\'cat nhi\'d2u t\'d8nh c\'f1a ch\'f3ng t\'abi \'ae\'d3 l\'b5m gi\'b5u th\'aam cho \'ae\'d5 qu\'e8c c\'b8c \'abng, \'ae\'d3 cho thanh danh c\'b8c \'abng c\'b5ng th\'aam r\'b9ng r\'ec. C\'b8c \'abng c\'e3 \'ae\'dfi ch\'f3
ng t\'abi chu\'e9c l\'b9i \'ae\'cat \'aeai kh\'abng ? Ch\'f3ng t\'abi s\'bdn s\'b5ng tr\'b6, mi\'d4n l\'b5 c\'b8c \'abng \'ae\'f5ng \'ae\'b8nh nhau v\'edi ch\'f3ng t\'abi n\'f7a v\'b5 \'aeem qu\'a9n tr\'eb v\'d2 n\'ad\'edc.
\par "Nh\'adng n\'d5u c\'b8c \'abng t\'f5 ch\'e8i, ch\'f3ng t\'abi s\'cf kh\'abng ng\'f5ng chi\'d5n \'ae\'cau \'ae\'d3 tu\'a9n theo \'fd tr\'eai. Ch\'f3ng t\'abi c\'f2ng c\'e3 ch\'f3t e ng\'b9i tr\'ad\'edc th\'d5 l\'f9c c\'f1a c\'b8c \'abng, nh\'adng ch\'f3
ng t\'abi s\'ee tr\'eai h\'acn s\'f8c m\'b9nh c\'f1a c\'b8c \'abng. Ch\'f3ng t\'abi nguy\'d6n s\'cf chi\'d5n \'ae\'cau m\'b7i m\'b7i kh\'abng ngh\'d8. Khi kh\'abng c\'dfn g\'d7 n\'f7a, ch\'f3ng t\'abi s\'cf l\'cay c\'b5nh c\'a9y l\'b5m c\'ea, l\'b5m g\'cb
y \'ae\'d3 v\'f2 trang cho qu\'a9n \'ae\'e9i ch\'f3ng t\'abi. L\'f3c \'ae\'e3 c\'b8c \'abng l\'b5m th\'d5 n\'b5o m\'b5 c\'e3 th\'d3 s\'e8ng \'ae\'ad\'eec v\'edi ch\'f3ng t\'abi?".
\par }\pard \qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 \'a7\'a9y kh\'abng ph\'b6i l\'b5 nh\'f7ng l\'eai n\'e3i su\'abng: ch\'ada c\'e3 m\'e9t d\'a9n t\'e9c n\'b5o d\'b8m t\'e6
 ch\'f8c kh\'b8ng chi\'d5n trong m\'e9t t\'d7nh tr\'b9ng nguy nan nh\'ad th\'d5.
\par L\'f3c ph\'b8i qu\'e8c gia h\'cap h\'e8i, t\'abi b\'bet \'ae\'ad\'eec m\'e9t t\'ef nh\'a9n c\'e3 mang theo m\'e9t kh\'c8u s\'f3ng l\'f4c. T\'abi ti\'d5c kh\'abng gi\'f7 l\'b9i kh\'c8u s\'f3ng \'cay. S\'f3ng l\'b5m b\'bbng m\'e9t c\'b8i \'ab! Tay c\'c7m c
\'b8n \'ab d\'efng l\'b5m b\'b8ng s\'f3ng; c\'b8n \'ab c\'bet ng\'ben c\'dfn ch\'f5ng hai m\'ad\'aci x\'a8ngtim\'d0t l\'b5m n\'dfng s\'f3ng; tr\'aan n\'dfng c\'e3 \'ae\'f4c m\'e9t l\'e7 nh\'e1 \'ae\'d3 c\'bem ng\'dfi thu\'e8c n\'e6.
\par V\'edi nh\'f7ng kh\'dd c\'f4 nh\'ad v\'cby, v\'b5 sau nh\'f7ng tai bi\'d5n kh\'f1ng khi\'d5p, nh\'f7ng ng\'ad\'eai ch\'f1 tr\'d7 c\'dfn l\'b9i c\'f1a m\'e9t d\'a9n t\'e9c \'ae\'b7 b\'de d\'e5n \'ae\'d5n b\'ad\'edc \'ae\'ad\'eang c\'efng - v\'c9n chi\'d5n 
\'ae\'cau ch\'e8ng l\'b9i qu\'a9n \'ae\'e9i ph\'ad\'acng T\'a9y. \'a7\'abi khi h\'e4 gi\'d5t m\'e9t v\'b5i ng\'ad\'eai ch\'f3ng t\'abi b\'bbng c\'b9m b\'c9y, nh\'cat l\'b5 h\'e4 \'ae\'b7 l\'b5m cho ch\'f3ng t\'abi ch\'d5t v\'d7 b\'d6nh t\'cbt, v\'d7 ph
\'b6i \'aeu\'e6i theo h\'e4 tr\'aan nh\'f7ng c\'b8nh \'ae\'e5ng l\'c7y u\'d5 kh\'dd, d\'ad\'edi \'b8nh n\'beng gay g\'bet.
\par C\'e3 nhi\'d2u l\'c7n \'aeu\'e6i theo b\'bet nh\'f7ng ng\'ad\'eai y\'aau n\'ad\'edc \'ae\'e3 m\'b5 ch\'f3ng ta th\'ad\'eang g\'e4i l\'b5 k\'ce phi\'d5n lo\'b9n, t\'abi c\'b6m th\'cay v\'ab c\'efng th\'ad\'acng x\'e3t cho c\'b6 d\'a9n t\'e9c \'cay v\'b5 c
\'b6m ph\'f4c nh\'f7ng ng\'ad\'eai ch\'d8 huy c\'f1a h\'e4, nh\'f7ng ng\'ad\'eai v\'f7ng l\'dfng tin \'eb c\'abng l\'fd v\'b5 c\'e3 m\'e9t ngh\'de l\'f9c b\'cat khu\'cat.
\par Cu\'e9c \'ae\'b9i chi\'d5n k\'d5t th\'f3c, d\'a9n t\'e9c An Nam c\'f2ng nh\'ad c\'b8c d\'a9n t\'e9c kh\'b8c \'ae\'b7 b\'de }{\i\f37\fs20\insrsid1378858 m\'aa ho\'c6c}{\f37\fs20\insrsid1378858  theo nh\'f7ng l\'eai tuy\'aan b\'e8 r\'e9ng r\'b7i c\'f1a Uynx
\'acn v\'d2 quy\'d2n d\'a9n t\'e9c t\'f9 quy\'d5t. M\'e9t nh\'e3m ng\'ad\'eai An Nam trong \'ae\'e3 c\'e3 t\'abi, \'ae\'b7 g\'f6i cho ngh\'de vi\'d6n Ph\'b8p v\'b5 t\'cat c\'b6 nh\'f7ng \'aeo\'b5n \'ae\'b9i bi\'d3u \'eb H\'e9i ngh\'de V\'d0cx\'a9y m\'e9
t b\'b6n y\'aau s\'b8ch sau \'ae\'a9y:
\par }\pard\plain \s25\qc \li0\ri0\sb120\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Y\'a3U S\'b8CH C\'f1A NH\'a2N D\'a2N AN NAM
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 T\'f5 ng\'b5y \'a7\'e5ng minh th\'beng tr\'cbn, t\'cat c
\'b6 c\'b8c d\'a9n t\'e9c b\'de l\'d6 thu\'e9c \'ae\'d2u ch\'f8a chan hy v\'e4ng r\'bbng theo nh\'f7ng l\'eai cam k\'d5t ch\'ddnh th\'f8c v\'b5 tr\'denh tr\'e4ng m\'b5 c\'b8c c\'ad\'eang qu\'e8c \'a7\'e5ng minh \'ae\'b7 tuy\'aan b\'e8 v\'edi to\'b5n th
\'d5 gi\'edi, trong cu\'e9c \'ae\'cau tranh c\'f1a V\'a8n minh ch\'e8ng D\'b7 man, th\'d7 ti\'d2n \'ae\'e5 m\'e9t th\'eai \'ae\'b9i c\'abng l\'fd v\'b5 ch\'ddnh ngh\'dca nh\'cat \'ae\'denh l\'b5 ph\'b6i \'ae\'d5n v\'edi h\'e4.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Trong khi ch\'ea cho nguy\'aan t\'bec d\'a9n t\'e9c s\'cf t\'f5 l\'dcnh v\'f9c l\'fd t\'ad\'ebng chuy\'d3n v\'b5o l\'dc
nh v\'f9c hi\'d6n th\'f9c do ch\'e7 quy\'d2n t\'f9 quy\'d5t thi\'aang li\'aang c\'f1a c\'b8c d\'a9n t\'e9c \'ae\'ad\'eec th\'f5a nh\'cbn th\'cbt s\'f9, nh\'a9n d\'a9n n\'ad\'edc An Nam tr\'ad\'edc kia, nay l\'b5 x\'f8 \'a7\'abng - Ph\'b8p, xin tr\'d7nh b
\'b5y v\'edi c\'b8c qu\'fd Ch\'ddnh ph\'f1 trong \'a7\'e5ng minh n\'e3i chung v\'b5 v\'edi Ch\'ddnh ph\'f1 Ph\'b8p \'ae\'b8ng k\'ddnh n\'e3i ri\'aang, nh\'f7ng y\'aau s\'b8ch khi\'aam t\'e8n sau \'ae\'a9y:
\par 1. T\'e6ng \'a9n x\'b8 cho t\'cat c\'b6 nh\'f7ng ng\'ad\'eai b\'b6n x\'f8 b\'de \'b8n t\'ef ch\'ddnh tr\'de;
\par 2. C\'b6i c\'b8ch n\'d2n ph\'b8p l\'fd \'eb \'a7\'abng D\'ad\'acng b\'bbng c\'b8ch cho ng\'ad\'eai b\'b6n x\'f8 c\'f2ng \'ae\'ad\'eec quy\'d2n h\'ad\'ebng nh\'f7ng }{\i\f37\fs20\insrsid1378858 \'ae\'b6m b\'b6o v\'d2 m\'c6t ph\'b8p lu\'cbt}{
\f37\fs20\insrsid1378858  nh\'ad ng\'ad\'eai \'a2u ch\'a9u; }{\i\f37\fs20\insrsid1378858 xo\'b8 b\'e1 ho\'b5n to\'b5n}{\f37\fs20\insrsid1378858  c\'b8c t\'dfa \'b8n \'ae\'c6c bi\'d6t d\'efng l\'b5m c\'abng c\'f4 \'ae\'d3 kh\'f1ng b\'e8 v\'b5 \'b8p b\'f8c
 b\'e9 ph\'cbn trung th\'f9c nh\'cat trong nh\'a9n d\'a9n An Nam;
\par 3. T\'f9 do }{\i\f37\fs20\insrsid1378858 b\'b8o ch\'dd}{\f37\fs20\insrsid1378858  v\'b5 t\'f9 do }{\i\f37\fs20\insrsid1378858 ng\'abn lu\'cbn}{\f37\fs20\insrsid1378858 ;
\par 4. T\'f9 do }{\i\f37\fs20\insrsid1378858 l\'cbp h\'e9i}{\f37\fs20\insrsid1378858  v\'b5 t\'f9 do }{\i\f37\fs20\insrsid1378858 h\'e9i h\'e4p}{\f37\fs20\insrsid1378858 ;
\par 5. T\'f9 do }{\i\f37\fs20\insrsid1378858 c\'ad tr\'f3 \'eb n\'ad\'edc ngo\'b5i}{\f37\fs20\insrsid1378858  v\'b5 t\'f9 do xu\'cat d\'ad\'acng;
\par 6. T\'f9 do }{\i\f37\fs20\insrsid1378858 h\'e4c t\'cbp}{\f37\fs20\insrsid1378858 , th\'b5nh l\'cbp c\'b8c tr\'ad\'eang k\'fc thu\'cbt v\'b5 chuy\'aan nghi\'d6p \'eb t\'cat c\'b6 c\'b8c t\'d8nh cho ng\'ad\'eai b\'b6n x\'f8;
\par 7. Thay }{\i\f37\fs20\insrsid1378858 ch\'d5 \'ae\'e9 ra c\'b8c s\'bec l\'d6nh b\'bbng ch\'d5 \'ae\'e9 ra c\'b8c \'ae\'b9o lu\'cbt}{\f37\fs20\insrsid1378858 ;
\par 8. \'a7o\'b5n \'ae\'b9i bi\'d3u th\'ad\'eang tr\'f9c c\'f1a ng\'ad\'eai b\'b6n x\'f8, do ng\'ad\'eai b\'b6n x\'f8 b\'c7u ra, t\'b9i Ngh\'de vi\'d6n Ph\'b8p \'ae\'d3 gi\'f3p cho Ngh\'de vi\'d6n bi\'d5t \'ae\'ad\'eec nh\'f7ng nguy\'d6n v\'e4ng c\'f1a ng\'ad
\'eai b\'b6n x\'f8;
\par Cu\'e8i b\'b6n y\'aau s\'b8ch, ch\'f3ng t\'abi c\'e3 vi\'d5t th\'aam r\'cat nhi\'d2u c\'a9u ca t\'f4ng nh\'a9n d\'a9n v\'b5 nh\'a9n \'ae\'b9o.
\par Nh\'adng sau m\'e9t th\'eai gian nghi\'aan c\'f8u v\'b5 theo d\'e2i, ch\'f3ng t\'abi nh\'cbn th\'cay r\'bbng "ch\'f1 ngh\'dca Uynx\'acn"}{\f37\fs20\super\insrsid1378858 59}{\f37\fs20\insrsid1378858  ch\'d8 l\'b5 m\'e9t tr\'df b\'dep b\'eem l\'edn. }{
\i\f37\fs20\insrsid1378858 Ch\'d8 c\'e3 gi\'b6i ph\'e3ng giai c\'cap v\'ab s\'b6n th\'d7 m\'edi gi\'b6i ph\'e3ng \'ae\'ad\'eec d\'a9n t\'e9c}{\f37\fs20\insrsid1378858 ; c\'b6 hai cu\'e9c gi\'b6i ph\'e3ng n\'b5y ch\'d8 c\'e3 th\'d3 l\'b5 s\'f9 nghi\'d6p c
\'f1a ch\'f1 ngh\'dca c\'e9ng s\'b6n v\'b5 c\'f1a c\'b8ch m\'b9ng th\'d5 gi\'edi.
\par 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 GI\'b8O H\'e9I
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-296\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 N\'d5u c\'e3 d\'a9n t\'e9c n\'b5o ph\'b6i nh\'ed \'acn Ch
\'f3a v\'b5 c\'b8c gi\'b8o s\'dc, th\'d7 ch\'ddnh \'ae\'e3 l\'b5 d\'a9n t\'e9c An Nam! V\'d7 Ch\'f3a v\'b5 c\'b8c gi\'b8o s\'dc m\'b5 d\'a9n t\'e9c n\'b5y \'ae\'b7 sa v\'b5o t\'d7nh c\'b6nh n\'ab l\'d6 nh\'ad ng\'b5y nay. B\'ad\'edc \'ae\'c7u, khi gi\'f3
p Gia Long chi\'d5m l\'cay ng\'abi vua, Pinh\'ab \'ae\'ea B\'aahen \'ae\'b7 l\'b5m h\'d5t c\'b8ch d\'e4n \'ae\'ad\'eang cho th\'f9c d\'a9n c\'ad\'edp n\'ad\'edc. Cho n\'aan \'ae\'d3 \'ae\'e6i l\'cay m\'e9t \'ddt s\'f3ng \'e8ng, y \'ae\'b7 b\'be
t Gia Long nh\'ad\'eeng cho Ph\'b8p nh\'f7ng th\'ad\'acng c\'b6ng v\'b5 qu\'a9n c\'b6ng sau n\'b5y tr\'eb th\'b5nh nh\'f7ng c\'a8n c\'f8 x\'a9m l\'ad\'eec c\'f1a Ph\'b8p.
\par Ch\'ddnh nh\'f7ng t\'aan gi\'b8o s\'dc \'ae\'b7 v\'cf b\'b6n \'ae\'e5 An Nam cho \'ae\'e9i qu\'a9n x\'a9m l\'ad\'eec. Ch\'ddnh b\'e4n h\'e4 \'ae\'b7 \'ae\'ada tin cho gi\'b8n \'aei\'d6p, d\'c9n \'ae\'ad\'eang cho \'ae\'e9i qu\'a9n vi\'d4n chinh v\'b5 t
\'e8 gi\'b8c nh\'f7ng ng\'ad\'eai y\'aau n\'ad\'edc. Trong th\'eai chinh chi\'d5n \'eb B\'bec K\'fa, nhi\'d2u t\'aan gi\'b8m m\'f4c cha c\'e8 gi\'b6 danh \'aei l\'b5m vi\'d6c thi\'d6n, \'ae\'b7 len l\'e1i trong d\'a9n ch\'f3ng An Nam do th\'b8m phong tr
\'b5o, \'ae\'b8nh c\'bep k\'d5 ho\'b9ch ph\'dfng th\'f1 th\'b5nh ph\'e8 v\'b5 chuy\'d3n cho ng\'ad\'eai Ph\'b8p. Bi\'d5t r\'e2 nh\'f7ng v\'efng gi\'b5u c\'e3 nh\'adng l\'b9i ph\'b6n \'ae\'e8i truy\'d2n \'ae\'b9o, \'ae\'abi khi gi\'b8o h\'e9i c\'e8 \'fd 
\'ae\'ada cha c\'e8 v\'d2 ch\'deu b\'de \'f8c hi\'d5p \'ae\'d3 l\'cay c\'ed can thi\'d6p v\'b5 c\'ad\'edp b\'e3c nh\'a9n d\'a9n.
\par }{\f38\fs20\insrsid1378858 \'eb }{\f37\fs20\insrsid1378858 \'ae\'a9u c\'e3 cu\'e9c n\'e6i d\'cby, c\'e3 kh\'ebi ngh\'dca th\'d7 n\'aci \'ae\'e3 cha c\'e8 bi\'d5n th\'b5nh m\'cbt th\'b8m, nh\'b5 th\'ea Ch\'f3a bi\'d5n th\'b5nh n\'aci tra kh\'b6o. Trong nh
\'f7ng bu\'e6i x\'adng t\'e9i, b\'e4n cha c\'e8 ch\'cat v\'can ng\'ad\'eai d\'a9n qu\'aa, do\'b9 n\'b9t h\'e4 ho\'c6c h\'f8a h\'d1n kh\'abn kh\'d0o v\'edi h\'e4 \'ae\'d3 l\'cay tin t\'f8c v\'d2 phong tr\'b5o v\'b5 c\'b8c l\'b7nh t\'f4. L\'d4 x\'adng t\'e9
i xong, c\'b8c cha ch\'f3ng ta b\'ccn ch\'b9y \'aei t\'e8 c\'b8o v\'edi nh\'b5 ch\'f8c tr\'b8ch Ph\'b8p.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 V\'d2 m\'c6t kinh t\'d5 c\'f2ng nh\'ad v\'d2 m\'c6t tinh th\'c7n, gi\'b8o h\'e9i \'ae\'d2u t\'e1 ra r\'cat x\'f8ng \'ae
\'b8ng v\'edi Ch\'f3a. L\'cay danh ngh\'dca l\'b5m vi\'d6c thi\'d6n, ng\'ad\'eai ta t\'cbp trung tr\'ce m\'e5 c\'abi v\'d2 Nh\'b5 chung, th\'dd cho m\'e9t b\'b8t c\'acm r\'e5i b\'bet c\'b8c em l\'b5m vi\'d6c nh\'ad t\'ef kh\'e6 sai. C\'e3 nh\'f7ng cha c
\'e8 \'ae\'b7 b\'b8n nh\'f7ng em g\'b8i m\'e5 c\'abi do h\'e4 tr\'abng nom, cho nh\'f7ng t\'aan th\'ddch \'ae\'efi non \'ae\'d3 l\'cay ti\'d2n ti\'aau. C\'e3 cha c\'e8 tuy\'d3n m\'e9 nh\'f7ng ng\'ad\'eai th\'cat nghi\'d6p, \'aeem \'aei khai hoang v\'b5 h
\'f8a chia l\'eei cho h\'e4; nh\'adng khi ru\'e9ng \'ae\'cat \'ae\'b7 c\'e3 thu ho\'b9ch th\'d7 b\'e4n cha c\'e8 l\'b9i th\'bcng tay \'aeu\'e6i h\'e4 \'aei.
\par \'a7\'d3 b\'e3c l\'e9t ng\'ad\'eai b\'b6n x\'f8, gi\'b8o h\'e9i \'ae\'b7 d\'efng nhi\'d2u m\'b8nh kh\'e3e m\'b5 nh\'f7ng th\'f1 \'aeo\'b9n ch\'ddnh nh\'ad sau:
\par Trong c\'b8c cu\'e9c xung \'ae\'e9t An - Ph\'b8p, ng\'ad\'eai An Nam \'aei l\'b8nh n\'b9n ph\'b6i t\'b6n c\'ad sang c\'b8c t\'d8nh l\'a9n c\'cbn. Khi h\'e4 tr\'eb v\'d2 l\'b5ng th\'d7 \'ae\'cat \'aeai c\'f1a h\'e4 \'ae\'b7 b\'de chi\'d5m \'aeo\'b9t. Nh
\'a9n c\'ac h\'e9i lo\'b9n l\'b9c, v\'beng ch\'f1, Nh\'b5 chung \'ae\'b7 c\'ad\'edp c\'b6 v\'a8n t\'f9 l\'c9n ru\'e9ng \'ae\'cat c\'f1a h\'e4.
\par Nh\'f7ng n\'a8m m\'cat m\'efa, Nh\'b5 chung cho n\'abng d\'a9n vay ti\'d2n nh\'adng b\'bet h\'e4 ph\'b6i \'ae\'ada ru\'e9ng \'ae\'cat b\'b6o \'ae\'b6m. V\'d7 l\'cay l\'b7i c\'bet c\'e6 n\'aan \'ae\'d5n k\'fa h\'b9n ng\'ad\'eai n\'abng d\'a9n kh\'abng tr
\'b6 \'ae\'ad\'eec n\'ee, th\'d5 l\'b5 t\'cat c\'b6 ru\'e9ng n\'ad\'acng \'ae\'d2u r\'aci v\'b5o tay Nh\'b5 chung.
\par Nh\'f7ng t\'aan quan cai tr\'de, th\'e8ng \'ae\'e8c, to\'b5n quy\'d2n c\'f2ng \'ddt li\'aam khi\'d5t l\'bem. Ch\'d8 c\'c7n n\'bem \'ae\'ad\'eec \'ddt gi\'cay t\'ea b\'dd m\'cbt v\'d2 \'ae\'eai t\'ad v\'b5 c\'e3 th\'d3 ch\'b9m \'ae\'d5n thanh danh c\'f1a h
\'e4, th\'d7 Nh\'b5 chung b\'ccn d\'efng \'ae\'d3 l\'b5m ti\'d2n v\'b5 \'ae\'dfi h\'e1i t\'cat c\'b6 nh\'f7ng \'aei\'d2u h\'e4 mu\'e8n. V\'d7 v\'cby m\'b5 m\'e9t vi\'aan to\'b5n quy\'d2n \'ae\'b7 ph\'b6i nh\'ad\'eeng l\'b9i cho Nh\'b5 chung \'ae\'d5
n 7.000 h\'d0cta \'ae\'cat m\'b5u m\'ec c\'f1a d\'a9n b\'b6n x\'f8. D\'a9n m\'cat quy\'d2n s\'eb h\'f7u, b\'de \'aeu\'e6i \'aei v\'b5 bu\'e9c ph\'b6i \'aei \'a8n xin.
\par Nh\'b5 chung c\'dfn m\'eb nh\'f7ng c\'abng ty c\'e3 nh\'f7ng s\'e8 v\'e8n kh\'e6ng l\'e5 \'ae\'d3 khai th\'b8c sinh l\'eei nh\'f7ng \'ae\'e5n \'aei\'d2n do Ch\'ddnh ph\'f1 thu\'e9c \'ae\'dea cho kh\'abng h\'e4 v\'b5 do "con chi\'aan" c\'b5y c\'cay kh\'ab
ng c\'abng cho h\'e4. Nh\'f7ng \'ae\'e5n \'aei\'d2n c\'f1a to\'b5 th\'b8nh c\'e3 l\'f3c d\'efng t\'edi s\'b8u b\'b6y ngh\'d7n n\'ab l\'d6 b\'b6n x\'f8. Ri\'aang \'eb \'a7\'abng D\'ad\'acng, gi\'b8o h\'e9i \'ae\'b7 chi\'d5m m\'cat 1 ph\'c7n 5 ru\'e9ng \'ae
\'cat, v\'b5 \'eb Cao Mi\'aan \'ae\'d5n 1 ph\'c7n 3.
\par 
\par 
\par 
\par 
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f235\fs20\insrsid1378858\charrsid8599747 \'d0}{\f37\fs20\insrsid1378858 \'b9i t\'b8 B\'d0cna vi\'d5t: "Nh\'f7ng \'aei\'d2u m\'b5 ng\'ad\'eai th
\'f9c d\'a9n ph\'b6i d\'f9a v\'b5o Nh\'b5 n\'ad\'edc m\'edi l\'b5m \'ae\'ad\'eec th\'d7 ng\'ad\'eai gi\'b8o s\'dc v\'c9n l\'b5m \'ae\'ad\'eec c\'b6, b\'cat ch\'cap Nh\'b5 n\'ad\'edc. B\'aan c\'b9nh l\'b7nh \'ae\'dea c\'f1a ng\'ad\'eai ch\'f1 \'ae\'e5n 
\'aei\'d2n, xu\'cat hi\'d6n l\'b7nh \'ae\'dea c\'f1a Nh\'b5 chung. R\'e5i \'ae\'a9y kh\'abng c\'dfn r\'ceo \'ae\'cat n\'b5o cho ng\'ad\'eai An Nam c\'ad tr\'f3, tr\'e5ng tr\'e4t v\'b5 sinh s\'e8ng n\'f7a, n\'d5u h\'e4 kh\'abng cam ch\'deu s\'e8ng ki\'d5
p n\'abng n\'ab".
\par 
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \column 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'a4NG L\'fd
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 N\'e3i v\'d2 n\'d2n c\'abng l\'fd Ph\'b8p \'eb Angi\'aa
ri, m\'e9t ngh\'de s\'dc Ph\'b8p \'ae\'b7 vi\'d5t m\'e9t c\'b8ch ch\'a9m bi\'d5m r\'bbng: "Ph\'b8p lu\'cbt, c\'abng l\'fd v\'edi ng\'ad\'eai b\'b6n x\'f8 \'ad? Th\'abi \'aei! Ch\'d8 c\'e3 ba toong, s\'f3ng l\'f4c, s\'f3ng tr\'ad\'eang, \'ae\'e3 m\'edi l
\'b5 nh\'f7ng th\'f8 x\'f8ng \'ae\'b8ng v\'edi l\'f2 s\'a9u b\'e4 \'cay!".
\par M\'e9t ng\'ad\'eai Ph\'b8p kh\'b8c, c\'f2ng k\'aau l\'aan nh\'ad th\'d5 n\'b5y: "}{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  \'a7\'abng D\'ad\'acng c\'f2ng \'ae\'f3ng nh\'ad v\'cby \'ae\'cay, \'eb \'ae\'a9y "c\'abng l\'fd" n\'bbm tr
ong tay nh\'f7ng t\'aan quan l\'b9i thi\'d5u tr\'b8ch nhi\'d6m, ho\'c6c khi ch\'f3ng ta ph\'b6i th\'f9c 
\par h\'b5nh c\'abng l\'fd, th\'d7 b\'bbng s\'f3ng!". M\'e9t ng\'ad\'eai Ph\'b8p kh\'b8c vi\'d5t: "N\'d5u vi\'aan ch\'f1 s\'f9 vi\'d6n ki\'d3m s\'b8t x\'d0t k\'fc theo \'ae\'f3ng tinh th\'c7n ph\'b8p l\'fd th\'d7 trong s\'e8 hai ngh\'d7n \'ae\'d5n hai ngh\'d7
n r\'ad\'ebi bi\'aan b\'b6n l\'cbp h\'bbng n\'a8m \'eb B\'bec K\'fa, kh\'abng c\'e3 bi\'aan b\'b6n n\'b5o l\'b5 c\'e3 gi\'b8 tr\'de \'ae\'e8i v\'edi Pari c\'b6".
\par }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  \'a7\'abng D\'ad\'acng c\'e3 hai th\'f8 c\'abng l\'fd. M\'e9t th\'f8 cho ng\'ad\'eai Ph\'b8p, m\'e9t th\'f8 cho ng\'ad\'eai b\'b6n x\'f8. Ng\'ad\'eai Ph\'b8p th\'d7 \'ae\'ad\'eec x\'f6 nh\'ad \'eb
 Ph\'b8p. Ng\'ad\'eai An Nam th\'d7 kh\'abng c\'e3 h\'e9i \'ae\'e5ng b\'e5i th\'c8m, c\'f2ng kh\'abng c\'e3 lu\'cbt s\'ad ng\'ad\'eai An Nam. Th\'ad\'eang ng\'ad\'eai ta x\'f6 \'b8n v\'b5 tuy\'aan \'b8n theo gi\'cay t\'ea, v\'beng m\'c6t ng\'ad\'eai b\'de
 c\'b8o. N\'d5u c\'e3 v\'f4 ki\'d6n c\'b8o gi\'f7a ng\'ad\'eai An Nam v\'edi ng\'ad\'eai Ph\'b8p th\'d7 l\'f3c n\'b5o ng\'ad\'eai Ph\'b8p c\'f2ng c\'e3 l\'fd c\'b6, m\'c6c d\'ef t\'aan n\'b5y \'a8n c\'ad\'edp hay gi\'d5t ng\'ad\'eai. Sau \'ae\'a9y l\'b5 v
\'b5i v\'dd d\'f4:
\par Quan cai tr\'de B\'ab\'aeoanh - b\'de m\'e9t vi\'aan ch\'f8c Ph\'b8p t\'e8 c\'b8o l\'b5m gi\'b6 m\'b9o gi\'cay t\'ea - \'ae\'ad\'eec phong ch\'f8c quy\'d2n to\'b5n quy\'d2n v\'b5 \'ae\'ad\'eec th\'ad\'ebng b\'bec \'ae\'c8u b\'e9i tinh.
\par }\pard \qj \li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Quan cai tr\'de \'a7\'b8cl\'ac - b\'de t\'e8 c\'b8o \'a8n h\'e8i l\'e9; v\'d7 s\'f9 nh\'f2ng l\'b9m t\'b5n
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 b\'b9o c\'f1a \'abng ta m\'b5 x\'b6y ra cu\'e9c kh\'ebi ngh
\'dca \'eb m\'e9t t\'d8nh l\'b5m cho nhi\'d2u ng\'ad\'eai Ph\'b8p v\'b5 An Nam ch\'d5t - l\'b9i \'ae\'ad\'eec c\'f6 l\'b5m u\'fb vi\'aan h\'e9i \'ae\'e5ng th\'b5nh ph\'e8.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Quan cai tr\'de Bu\'aein\'ab - can t\'e9i tham \'ab, th
\'f4t ti\'d2n c\'abng qu\'fc v\'b5 nh\'f2ng l\'b9m - l\'b9i \'ae\'ad\'eec tha b\'e6ng.
\par K\'fc s\'ad T\'aaa - gi\'b8m \'ae\'e8c m\'e9t h\'b7ng l\'edn, b\'de t\'e8 c\'b8o tham \'ab - c\'f2ng \'ae\'ad\'eec v\'ab s\'f9.
\par M\'e9t t\'aan quan cai tr\'de \'eb Qu\'b6ng Ch\'a9u Loan b\'de t\'e8 c\'b8o l\'b5 \'ae\'b7 d\'efng nh\'f4c h\'d7nh gi\'d5t ch\'d5t h\'acn hai m\'ad\'aci ng\'ad\'eai b\'b6n x\'f8, l\'b9i \'ae\'ad\'eec tha b\'e6ng.
\par M\'e9t t\'aan qu\'b6n ng\'f4c C\'abn L\'abn, b\'de t\'e8 c\'b8o l\'b5 \'ae\'b7 gi\'d5t m\'e9t c\'b8ch th\'b6n nhi\'aan m\'e9t l\'f3c h\'acn 40 ph\'b9m nh\'a9n, \'ae\'ad\'eec tr\'beng \'b8n v\'b5 khen th\'ad\'ebng.
\par \'a4ng Pu\'e8cxinh\'abng th\'cay m\'e9t ng\'ad\'eai An Nam d\'b8m nh\'d7n v\'b5o nh\'b5 m\'e9t ng\'ad\'eai \'a2u v\'b5i gi\'a9y, \'ae\'b7 h\'efng h\'e6 nh\'b6y ra \'ae\'b8nh ng\'ad\'eai An Nam \'cay v\'b5 k\'d5t li\'d4u \'ae\'eai anh b\'bbng m\'e9t ph\'b8
t s\'f3ng l\'f4c b\'ben v\'b5o \'ae\'c7u.
\par M\'e9t nh\'a9n vi\'aan ho\'b6 xa d\'efng roi m\'a9y \'ae\'b8nh m\'e9t ng\'ad\'eai l\'fd tr\'ad\'ebng B\'bec K\'fa.
\par \'a4ng B\'d5ch \'ae\'cam v\'ec s\'e4 ng\'ad\'eai l\'b8i xe cho \'abng ta.
\par \'a4ng th\'c7u kho\'b8n Br\'d0t \'ae\'b7 tr\'e3i tay m\'e9t ng\'ad\'eai An Nam cho ch\'e3 c\'ben r\'e5i d\'efng ch\'a9n \'ae\'b8 ng\'ad\'eai \'cay \'ae\'d5n ch\'d5t.
\par \'a4ng \'a7\'d0pphi, ch\'f1 s\'f9 thu\'d5 quan, \'ae\'b8 m\'e9t c\'b8i gh\'aa g\'edm v\'b5o m\'b9ng m\'ec ng\'ad\'eai \'ae\'b5y t\'ed l\'b5m anh n\'b5y ch\'d5t t\'ad\'aci.
\par \'a4ng H\'a8ngri, th\'ee m\'b8y \'eb H\'b6i Ph\'dfng, nghe c\'e3 ti\'d5ng \'e5n \'b5o \'eb ngo\'b5i ph\'e8; c\'f6a nh\'b5 \'abng v\'f5a m\'eb th\'d7 m\'e9t ng\'ad\'eai \'ae\'b5n b\'b5 An Nam ch\'b9y x\'e9c v\'b5o, \'ae\'bbng sau l\'b5 m\'e9t ng\'ad\'eai 
\'ae\'b5n \'abng \'aeang \'aeu\'e6i theo. H\'a8ngri v\'ed l\'cay kh\'c8u s\'f3ng v\'b5 b\'ben m\'e9t ph\'b8t. Ng\'ad\'eai \'ae\'b5n \'abng ng\'b7 v\'cbt xu\'e8ng ch\'d5t ngay; \'ae\'e3 l\'b5 m\'e9t ng\'ad\'eai \'a2u. H\'e1i \'ae\'d5n th\'d7 H\'a8ngri tr
\'b6 l\'eai: "T\'abi t\'ad\'ebng n\'e3 l\'b5 ng\'ad\'eai b\'b6n x\'f8".
\par M\'e9t ng\'ad\'eai Ph\'b8p \'aeem ng\'f9a c\'f1a h\'ben bu\'e9c v\'b5o m\'e9t c\'b8i chu\'e5ng trong \'ae\'e3 c\'e3 nh\'e8t con ng\'f9a c\'b8i c\'f1a m\'e9t ng\'ad\'eai d\'a9n b\'b6n x\'f8. Con ng\'f9a \'ae\'f9c l\'e5ng l\'aan, l\'b5m cho ng\'ad\'eai Ph
\'b8p t\'f8c \'aei\'aan l\'aan. H\'ben li\'d2n \'ae\'b8nh ng\'ad\'eai b\'b6n x\'f8 h\'e9c m\'b8u m\'e5m, m\'b8u m\'f2i. R\'e5i h\'ben c\'dfn tr\'e3i ng\'ad\'eai \'cay l\'b9i \'aeem treo l\'aan c\'c7u thang.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 M\'e9t gi\'b8o s\'dc (v\'a9ng, m\'e9t m\'abn \'ae\'e5 nh\'a9n t\'f5 c\'f1a Ch\'f3a) nghi cho m\'e9t h\'e4c sinh tr\'ad
\'eang d\'dfng ng\'ad\'eai b\'b6n x\'f8 l\'cay c\'bep c\'f1a m\'d7nh m\'e9t ngh\'d7n \'ae\'e5ng, b\'ccn tr\'e3i anh l\'b9i, treo l\'aan x\'b5 nh\'b5 m\'b5 \'ae\'b8nh. Ng\'ad\'eai h\'e4c sinh \'ae\'b8ng th\'ad\'acng \'cay ch\'d5t ng\'cat \'aei. H\'e4 h\'b9
 anh xu\'e8ng. Khi anh h\'e5i t\'d8nh ng\'ad\'eai ta l\'b9i treo anh l\'aan tra kh\'b6o. Anh \'cay \'ae\'b7 ch\'d5t.
\par V\'a9n v\'a9n, v.v..
\par B\'b6n k\'aa n\'b5y c\'dfn c\'e3 th\'d3 k\'d0o d\'b5i kh\'abng c\'efng.
\par T\'cat c\'b6 nh\'f7ng t\'aan gi\'d5t ng\'ad\'eai \'cay \'ae\'d2u \'ae\'ad\'eec tr\'beng \'b8n. V\'d7 uy t\'ddn c\'f1a ng\'ad\'eai Ph\'b8p n\'aan ph\'b6i nh\'ad th\'d5 \'ae\'cay!
\par Ph\'b6i nh\'cat thi\'d5t k\'d5t \'b8n nh\'f7ng ng\'ad\'eai d\'a9n b\'b6n x\'f8 v\'ab t\'e9i c\'f2ng nh\'ad tha b\'e6ng nh\'f7ng ng\'ad\'eai Ph\'b8p c\'e3 t\'e9i. Khi m\'e9t ng\'ad\'eai An Nam b\'de bu\'e9c t\'e9i l\'b5 ch\'e8ng Ph\'b8p th\'d7 ng\'ad\'eai 
\'cay b\'de \'aeem x\'f6 tr\'ad\'edc m\'e9t to\'b5 \'b8n g\'e4i l\'b5 to\'b5 \'b8n \'ae\'c6c bi\'d6t. To\'b5 \'b8n g\'e5m m\'cay t\'aan quan binh v\'b5 quan cai tr\'de \'ae\'d2u l\'b5 ng\'ad\'eai Ph\'b8p c\'b6. To\'b5 \'b8n x\'f6 k\'ddn v\'b5 c\'e3 th\'d3
 tuy\'aan \'b8n t\'f6 h\'d7nh. Kh\'abng \'ae\'ad\'eec ch\'e8ng \'b8n.
\par N\'a8m 1908, m\'e9t \'a9m m\'adu \'eb B\'bec K\'fa b\'de kh\'b8m ph\'b8. Trong s\'e8 ng\'ad\'eai b\'de k\'d5t \'b8n, c\'e3 c\'b6 \'ae\'b5n b\'b5, tr\'ce con v\'b5 c\'b6 m\'e9t thanh ni\'aan m\'b5 ai c\'f2ng bi\'d5t l\'b5 ng\'ed ng\'c8n.
\par \'a7\'abi khi h\'e4 tuy\'aan \'b8n v\'beng m\'c6t ng\'ad\'eai b\'de c\'b8o, nh\'f7ng \'b8n kh\'e6 sai c\'e3 khi c\'b6 nh\'f7ng \'b8n t\'f6 h\'d7nh n\'f7a; b\'de c\'b8o kh\'abng h\'d2 \'ae\'ad\'eec b\'b5o ch\'f7a.
\par Nh\'f7ng ng\'ad\'eai b\'b6n x\'f8 b\'de bu\'e9c t\'e9i v\'d2 ch\'ddnh tr\'de n\'c6ng hay nh\'d1, n\'e3i chung \'ae\'d2u b\'de b\'bet, k\'d5t \'b8n v\'b5 \'aeem \'aei \'ae\'b5y - chung th\'a9n hay 10 n\'a8m tu\'fa \'ae\'cay. Kh\'abng c\'c7n \'aei\'d2
u tra x\'d0t x\'f6 g\'d7 c\'b6.
\par Sau \'ae\'a9y l\'b5 m\'e9t b\'b6n tr\'ddch l\'f4c \'b8n \'ae\'d3 gi\'f3p c\'b8c b\'b9n h\'d7nh dung \'ae\'ad\'eec th\'d5 n\'b5o l\'b5 c\'abng l\'fd \'ae\'e8i v\'edi nh\'f7ng ng\'ad\'eai d\'a9n b\'b6n x\'f8.
\par }{\i\f37\fs20\insrsid1378858 Tr\'ddch l\'f4c \'b8n:
\par }{\f37\fs20\insrsid1378858 X\'d0t r\'bbng: Nh\'f7ng t\'aan A, B, C, D v\'b5 F \'ae\'d2u l\'b5 nh\'f7ng nh\'b5 v\'a8n th\'a9n An Nam n\'e6i ti\'d5ng, h\'e4 bi\'d5t ai l\'b5 k\'ce phi\'d5n lo\'b9n ch\'e8ng Ph\'b8p nh\'adng h\'e4 l\'b9i cho r\'bbng kh\'ab
ng c\'c7n ph\'b6i theo d\'e2i ng\'ad\'eai \'cay (kh\'abng th\'cay n\'e3i t\'aan k\'ce phi\'d5n lo\'b9n, c\'f2ng kh\'abng n\'e3i ph\'b6i theo d\'e2i ng\'ad\'eai \'ae\'e3 \'ae\'d5n \'ae\'a9u?).
\par }\pard \qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 X\'d0t r\'bbng: Khi \'ae\'b7 th\'cay ng\'ad\'eai \'ae\'e3 v\'d2 nh\'b5, C b\'ccn \'aei m\'eai B v\'b5 A v\'d2 h\'e4p b
\'b5n (b\'b5n vi\'d6c g\'d7?).
\par X\'d0t r\'bbng: C v\'b5 B v\'b5 D c\'dfn t\'e6 ch\'f8c c\'b6 nh\'f7ng h\'e9i bu\'abn, nh\'f7ng h\'e9i di\'d4n thuy\'d5t v\'b5 h\'e9i m\'c6c \'a2u ph\'f4c, c\'bet t\'e3c ng\'ben (kh\'f1ng khi\'d5p ch\'ada!).
\par X\'d0t r\'bbng: T\'cat c\'b6 nh\'f7ng vi\'d6c \'ae\'e3, h\'e4 \'ae\'b7 c\'efng l\'b5m v\'edi nhau m\'e9t l\'c7n.
\par X\'d0t r\'bbng: Trong nh\'f7ng b\'b5i th\'ac c\'f1a h\'e4, c\'e3 m\'e9t c\'a9u c\'e3 th\'d3 d\'dech l\'b5: "Ch\'deu c\'b6nh \'ab nh\'f4c, ch\'deu th\'a9n c\'b8 ch\'cbu chim l\'e5ng". (Sai. C\'a9u th\'ac tr\'b5o ph\'f3ng ch\'d5 gi\'d4u nh\'f7ng cu\'e9
c thi c\'f6 ph\'b6i d\'dech nh\'ad sau: N\'d5u c\'b8c \'abng c\'dfn \'aeeo \'aeu\'e6i m\'b7i nh\'f7ng cu\'e9c thi c\'f6 l\'e7i th\'eai \'cay, th\'d7 trong kho\'b6ng tr\'a8m n\'a8m n\'f7a c\'b8c \'abng s\'cf \'ae\'ad\'eec nghe ng\'ad\'eai ta ch\'f6i v\'b5
o m\'c6t. Khi n\'b5o th\'d7 c\'b8c \'abng s\'cf tho\'b8t kh\'e1i c\'b6nh c\'b8 ch\'cbu chim l\'e5ng \'cay?).
\par X\'d0t r\'bbng: D \'ae\'b7 cho ph\'d0p h\'e4c tr\'df c\'f1a anh ta h\'e9i h\'e4p (!) v\'b5 nh\'f7ng h\'e4c tr\'df \'cay \'ae\'b7 \'ae\'e4c c\'a9u ph\'ad\'acng ng\'abn: "Ng\'ad\'eai trong m\'e9t n\'ad\'edc ph\'b6i th\'ad\'acng nhau c\'efng" (t\'e9i n\'c6
ng ch\'ada!).
\par L\'b9i x\'d0t r\'bbng: Trong c\'b8c bu\'e6i di\'d4n thuy\'d5t h\'e4 \'ae\'b7 n\'e3i \'ae\'d5n v\'can \'ae\'d2 m\'eb mang tr\'dd tu\'d6, h\'e4 \'ae\'b7 b\'b5n \'ae\'d5n nh\'f7ng nhu c\'c7u \'ae\'eai s\'e8ng v\'a8n minh, \'ae\'d5n vi\'d6c gi\'b6m b\'edt nh
\'f7ng h\'e9i h\'cc \'ae\'d7nh \'ae\'b8m v\'ab \'ddch, \'ae\'d5n l\'eei \'ddch h\'e4c h\'b5nh, h\'e4 l\'b9i c\'dfn kh\'aau g\'eei cho ng\'ad\'eai nghe \'fd th\'f8c v\'d2 ch\'f1 quy\'d2n c\'f1a nh\'a9n d\'a9n v\'b5 tr\'d7nh b\'b5y \'aei\'d2u \'ae\'e3 nh
\'ad l\'b5 m\'e9t nguy\'aan l\'fd c\'ac b\'b6n (c\'f1a c\'b8i g\'d7?) v\'b5 g\'a9y cho m\'e4i ng\'ad\'eai \'fd ngh\'dc khinh b\'d8 (khinh b\'d8 ai?).
\par X\'d0t r\'bbng: N\'d5u kh\'abng tr\'f5ng ph\'b9t nghi\'aam kh\'bec nh\'f7ng ho\'b9t \'ae\'e9ng \'cay theo \'ae\'f3ng ph\'b8p lu\'cbt, th\'d7 nh\'a9n d\'a9n kh\'abng kh\'e1i b\'de l\'abi cu\'e8n theo nh\'f7ng g\'ad\'acng x\'cau nh\'ad v\'cby.
\par Chi\'d5u ch\'d8, x\'f6 t\'aan A, B v\'b5 C }{\i\f37\fs20\insrsid1378858 t\'f6 h\'d7nh \'b8n treo c\'e6}{\f37\fs20\insrsid1378858 , x\'f6 \'ae\'b8nh D v\'b5 F 100 tr\'ad\'eeng (ch\'d8 c\'e3 th\'d5 th\'abi \'b5!) v\'b5 \'ae\'b5y ch\'f3ng bi\'d6t x\'f8 \'ae
i xa 1.500 kil\'abm\'d0t kh\'e1i n\'ad\'edc An Nam (ch\'f3ng ta c\'c7n ch\'f3 \'fd l\'b5 nh\'f7ng b\'de c\'b8o kh\'abng \'ae\'ad\'eec ph\'d0p t\'f9 b\'b5o ch\'f7a v\'b5 h\'e4 ho\'b5n to\'b5n kh\'abng h\'d2 bi\'d5t g\'d7 c\'b6 v\'d2 nh\'f7ng l\'eai bu\'e9
c t\'e9i l\'c9n b\'b6n \'b8n).
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Nh\'ad v\'cby ch\'d8 v\'d7 h\'e4 l\'b5 nh\'f7ng nh\'b5 v\'a8n th\'a9n danh ti\'d5ng, h\'e4 \'ae\'b7 l\'cbp h\'e9i v\'b5
 di\'d4n thuy\'d5t, h\'e4 \'ae\'b7 \'a8n m\'c6c \'a2u ph\'f4c v\'b5 c\'bet t\'e3c ng\'ben, h\'e4 \'ae\'b7 c\'abng k\'ddch nh\'f7ng vi\'d6c ph\'ef phi\'d5m, h\'ab h\'b5o \'ae\'e5ng b\'b5o c\'f1a h\'e4 th\'ad\'acng y\'aau nhau, v\'b5 h\'e4 \'ae\'b7 n\'e3i 
\'ae\'d5n d\'a9n quy\'d2n m\'b5 nh\'f7ng ng\'ad\'eai An Nam \'cay \'ae\'b7 b\'de x\'f6 t\'f6 h\'d7nh v\'b5 b\'de \'ae\'b5y \'aei bi\'d6t x\'f8.
\par C\'abng l\'fd n\'ad\'edc Ph\'b8p \'eb \'a7\'abng D\'ad\'acng l\'b5 nh\'ad th\'d5 \'ae\'cay!
\par 
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
