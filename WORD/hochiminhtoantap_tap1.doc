N
\par }\pard\plain \qj \fi397\li0\ri0\sa240\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs20\cgrid0\insrsid1378858 KiNH NGHI\'d6M \'eb CH\'a2U PHI X\'ddCH \'a7\'b9
O THU\'e9C PH\'b8P
\par }\pard \qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Ch\'d5 \'ae\'e9 th\'f9c d\'a9n Ph\'b8p \'ae\'b7 "thu \'ae\'ad\'eec"... nhi\'d2u th\'cat b\'b9i. Kh\'abng ph\'b6
i ch\'d8 c\'e3 ch\'f3ng t\'abi m\'edi nh\'cbn th\'cay nh\'ad th\'d5. Nh\'a9n m\'e9t cu\'e9c th\'cat b\'b9i \'ae\'c6c bi\'d6t th\'b6m h\'b9i, t\'ea }{\i\f37\fs20\cgrid0\insrsid1378858 Le Temps, }{\f37\fs20\cgrid0\insrsid1378858 ng\'b5y 24 th\'b8ng 9 \'ae
\'b7 vi\'d5t: 
\par "Th\'cbt v\'cby, ai c\'f2ng bi\'d5t r\'bbng t\'d7nh h\'d7nh ch\'a9u Phi x\'ddch \'ae\'b9o c\'f1a ch\'f3ng ta kh\'abng ph\'b6i l\'b5 \'ae\'f3ng nh\'ad ch\'f3ng ta \'ae\'b7 hy v\'e4ng ch\'f3t n\'b5o c\'b6, khi m\'b5... l\'b8 c\'ea c\'f1a n\'ad\'edc Ph\'b8
p ph\'cap ph\'edi tr\'aan nh\'f7ng v\'efng r\'e9ng bao la m\'b5 ch\'f3ng ta \'ae\'b7 chi\'d5m \'aeo\'b9t \'ae\'ad\'eec ch\'f8 kh\'abng ph\'b6i l\'b5 thu ph\'f4c \'ae\'ad\'eec cho n\'ad\'edc C\'e9ng ho\'b5. Kh\'abng ph\'e3ng \'ae\'b9i v\'b5 c\'f2ng kh\'ab
ng c\'ad\'eang \'aei\'d6u g\'d7 c\'b6, ta c\'e3 th\'d3 n\'e3i r\'bbng... ch\'a9u Phi x\'ddch \'ae\'b9o hi\'d6n nay \'aeang \'eb v\'b5o t\'d7nh tr\'b9ng th\'cbt s\'f9 l\'b5 t\'f4t l\'efi. Vi\'d6c khai th\'b8c mi\'d2n \'ae\'e3 th\'cbt l\'b5 th\'ab s\'ac, c
\'abng c\'f4 \'eb \'ae\'e3 h\'d7nh nh\'ad kh\'abng c\'e3 g\'d7 c\'b6. Hi\'d6n nay ng\'a9n s\'b8ch thi\'d5u h\'f4t c\'f1a mi\'d2n \'ae\'e3 ch\'d8 th\'a8ng b\'bbng \'ae\'ad\'eec l\'b5 nh\'ea ch\'ddnh ph\'f1 tr\'ee c\'cap. Cu\'e8i c\'efng - \'aei\'d2u nghi
\'aam tr\'e4ng h\'acn - l\'b5 }{\i\f37\fs20\cgrid0\insrsid1378858 d\'a9n c\'ad mi\'d2n \'ae\'e3 m\'dfn m\'e1i \'aei}{\f37\fs20\cgrid0\insrsid1378858  }{\i\f37\fs20\cgrid0\insrsid1378858 v\'b5 ch\'d5t d\'c7n, }{\f37\fs20\cgrid0\insrsid1378858 y\'d5u t\'e8
 d\'a9n s\'e8 m\'b5 s\'f9 duy tr\'d7, s\'f9 c\'b6i thi\'d6n v\'b5 t\'a8ng l\'aan l\'b5 c\'ac s\'eb cho m\'e4i s\'f9 nghi\'d6p, }{\i\f37\fs20\cgrid0\insrsid1378858 \'aeang \'aei \'ae\'d5n ch\'e7 ti\'aau di\'d6t". }{\f37\fs20\cgrid0\insrsid1378858 (Do ch
\'f3ng t\'abi g\'b9ch d\'ad\'edi).
\par V\'b5 sau \'ae\'e3, t\'ea b\'b8o c\'dfn vi\'d5t:
\par "H\'acn n\'f7a, ch\'f3ng ta c\'dfn ph\'b9m nhi\'d2u sai l\'c7m; n\'e3i d\'b5i d\'dfng v\'d2 nh\'f7ng sai l\'c7m n\'b5y c\'f2ng v\'ab \'ddch, b\'a9y gi\'ea kh\'abng ph\'b6i l\'f3c ng\'e5i h\'e8i ti\'d5c m\'e9t c\'b8ch v\'ab b\'e6 v\'d2 qu\'b8 kh\'f8, ph
\'b6i chu\'c8n b\'de cho m\'e9t t\'ad\'acng lai t\'e8t \'ae\'d1p h\'acn. H\'b5nh \'ae\'e9ng c\'f1a ch\'f3ng ta \'eb ch\'a9u Phi x\'ddch \'ae\'b9o \'ae\'b7 b\'de t\'aa li\'d6t hay ch\'d6ch h\'ad\'edng ngay t\'f5 \'ae\'c7u, v\'d7 nh\'f7ng sai l\'c7m v\'d2
 nguy\'aan t\'bec... \'ae\'d5n nay c\'f2ng v\'c9n c\'dfn t\'b8c h\'b9i m\'e9t c\'b8ch gh\'aa g\'edm; ngo\'b5i ra, ho\'b9t \'ae\'e9ng c\'f1a ch\'f3ng ta c\'dfn mang h\'cbu qu\'b6 tai h\'b9i c\'f1a nh\'f7ng sai l\'c7m v\'d2 ph\'ad\'acng ph\'b8p c\'c7n ph
\'b6i g\'cap r\'f3t s\'f6a ch\'f7a".
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Nh\'f7ng sai l\'c7m v\'b5 khuy\'d5t \'aei\'d3m m\'b5 t\'ea }{\i\f37\fs20\cgrid0\insrsid1378858 Le Temps }{
\f37\fs20\cgrid0\insrsid1378858 than phi\'d2n v\'d2 nh\'f7ng h\'cbu qu\'b6 tai h\'b9i m\'b5 kh\'abng n\'aau ra nh\'f7ng s\'f9 vi\'d6c, l\'b5 nh\'f7ng sai l\'c7m v\'b5 nh\'f7ng khuy\'d5t \'aei\'d3m n\'b5o? \'a7\'e3 l\'b5 vi\'d6c t\'ad\'edc \'aeo\'b9t nh
\'f7ng ng\'ad\'eai b\'b6n x\'f8, \'ae\'e3 l\'b5 vi\'d6c b\'bet phu khu\'a9n v\'b8c, l\'b5 ch\'d5 \'ae\'e9 lao d\'dech, \'ae\'e3 l\'b5 thu\'d5 kho\'b8 n\'c6ng n\'d2, l\'b5 vi\'d6c tuy\'d3n m\'e9 c\'abng ch\'f8c v\'b5 binh l\'ddnh, l\'b5 vi\'d6c b\'be
t con tin, l\'b5 nh\'f7ng s\'f9 t\'b5n \'b8c \'ae\'e8i v\'edi nh\'a9n d\'a9n, \'ae\'e3 l\'b5 t\'cat c\'b6 c\'b8i ch\'d5 \'ae\'e9 c\'ad\'edp b\'e3c, gi\'d5t ch\'e3c \'ae\'b8ng gh\'aa t\'ebm \'ae\'b7 l\'b5m cho thu\'e9c \'ae\'dea n\'b5y \'aei \'ae\'d5n t
\'d7nh tr\'b9ng th\'aa th\'b6m hi\'d6n nay.
\par C\'b8ch \'ae\'a9y h\'acn 20 n\'a8m, \'abng \'a4guyxt\'ac S\'acvali\'aa, sau khi m\'ab t\'b6 s\'f9 d\'b7 man c\'f1a ch\'d5 \'ae\'e9 th\'f9c d\'a9n, ti\'aan \'aeo\'b8n nh\'ad sau:
\par }{\i\f37\fs20\cgrid0\insrsid1378858 "N\'d5u ng\'ad\'eai ta c\'f8 ti\'d5p t\'f4c l\'b5m nh\'ad th\'d5 m\'b7i, n\'d5u ng\'ad\'eai ta kh\'abng ng\'f5ng vi\'d6c \'ae\'e8t ph\'b8 c\'b8c l\'b5ng m\'b9c th\'d7 ch\'bcng bao l\'a9u... hai b\'ea s\'abng C\'abngg
\'ab c\'f2ng nh\'ad nh\'f7ng v\'efng Ubanghi v\'b5 Xanga s\'cf ho\'b5n to\'b5n kh\'abng c\'dfn}{\f37\fs20\cgrid0\insrsid1378858  }{\i\f37\fs20\cgrid0\insrsid1378858 m\'e9t b\'e3ng ng\'ad\'eai... N\'d5u ch\'ddnh s\'b8ch \'cay c\'f8 ti\'d5p t\'f4c nh\'ad th
\'d5 m\'b7i th\'d7 sau \'ae\'a9y n\'f6a th\'d5 k\'fb, t\'cat nh\'f7ng gi\'e8ng ng\'ad\'eai c\'c7n c\'ef \'ae\'e3 s\'cf ti\'aau di\'d6t h\'d5t }{\f37\fs20\cgrid0\insrsid1378858 ... }{\i\f37\fs20\cgrid0\insrsid1378858 (Morel)".}{
\f37\fs20\cgrid0\insrsid1378858 
\par Nh\'f7ng cu\'e9c tranh c\'b7i trong ngh\'de vi\'d6n n\'a8m 1906 \'ae\'b7 \'ae\'d3 l\'e9 ra r\'bbng m\'e9t t\'ea th\'abng tri c\'f1a m\'e9t c\'abng ty khai kh\'c8n \'ae\'e5n \'aei\'d2n \'ae\'b7 vi\'d5t: "Kh\'abng \'ae\'ad\'eec qu\'aan r\'bbng c\'b8c nh\'a9
n vi\'aan c\'f1a ch\'f3ng ta ph\'b6i \'ae\'e3ng vai tr\'df nh\'ad l\'b5 nh\'f7ng t\'aan k\'ce c\'ad\'edp". V\'b5 m\'e9t vi\'aan to\'b5n quy\'d2n \'ae\'b7 vi\'d5t cho c\'b8c c\'abng ch\'f8c d\'ad\'edi quy\'d2n y nh\'ad sau: "T\'abi kh\'abng gi\'cau c\'b8c 
\'abng r\'bbng, khi \'ae\'d2 ngh\'de th\'a8ng th\'ad\'ebng, t\'abi \'ae\'c6c bi\'d6t c\'a8n c\'f8 v\'b5o s\'e8 thu\'d5 thu \'ae\'ad\'eec c\'f1a ng\'ad\'eai b\'b6n x\'f8, \'aei\'d2u m\'b5 c\'b8c \'abng ph\'b6i lu\'abn lu\'abn ch\'f3 \'fd".
\par Nh\'f7ng d\'dfng sau \'ae\'a9y tr\'ddch trong m\'e9t quy\'d3n s\'e6 ch\'f8ng t\'e1 r\'bbng nh\'f7ng l\'d6nh \'ae\'e3 \'ae\'b7 \'ae\'ad\'eec ch\'cap h\'b5nh t\'f5ng ly t\'f5ng t\'fd:
\par }{\i\f37\fs20\cgrid0\insrsid1378858 "H\'b5nh qu\'a9n c\'b5n}{\f37\fs20\cgrid0\insrsid1378858  }{\i\f37\fs20\cgrid0\insrsid1378858 qu\'d0t l\'b5ng C\'abl\'abv\'ab}{\f37\fs20\cgrid0\insrsid1378858 .
\par }{\i\f37\fs20\cgrid0\insrsid1378858 C\'b5n qu\'d0t d\'a9n Ph\'a8ng v\'efng th\'ad\'eeng Cun\'ab: \'ae\'e8t l\'b5ng, ph\'b8 v\'ad\'ean tr\'b9i.}{\f37\fs20\cgrid0\insrsid1378858 
\par }\pard \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\i\f37\fs20\cgrid0\insrsid1378858 \sect }\sectd 
