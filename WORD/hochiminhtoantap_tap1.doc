\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-300\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~Trong khi ch\'ea \'ae\'eei \'aei khai ho\'b8 nh\'f7ng ng
\'ad\'eai \'a7\'abng D\'ad\'acng t\'b9i \'a7\'abng D\'ad\'acng, ng\'b5i th\'b8i th\'f3 M\'d0clanh mu\'e8n h\'b7y khai ho\'b8 nh\'f7ng ng\'ad\'eai \'a7\'abng D\'ad\'acng \'ae\'b7 ch\'d5t, c\'b8c ng\'ad\'eai bi\'d5t \'ae\'cay, nh\'f7ng ng\'ad\'eai ch\'d5
t cho T\'e6 qu\'e8c, cho c\'abng l\'fd, }{\i\f37\fs20\insrsid1378858 v\'b5 v\'a9n v\'a9n,}{\f37\fs20\insrsid1378858  \'eb Ph\'b8p.
\par C\'ad\'eai \'eb ngh\'dca trang l\'b5 m\'e9t c\'b8i th\'f3 c\'f1a nh\'f7ng b\'cbc v\'dc nh\'a9n}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0
\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) }{\f38\insrsid1378858 \'b8}{\insrsid1378858 m ch\'d8 Th\'f1 t\'ad\'edng Ph\'b8p Po\'a8ngcar\'aa. Khi \'ae\'d5
n th\'a8m m\'e9t ngh\'dca trang l\'ddnh Ph\'b8p, Po\'a8ngcar\'aa nh\'a8n r\'a8ng c\'ad\'eai. \'a7\'b6ng C\'e9ng s\'b6n Ph\'b8p l\'cay b\'f8c \'b6nh \'ae\'e3 in ra h\'b5ng tri\'d6u t\'cam d\'ad\'edi \'ae\'d2 ch\'f7: "Po\'a8ngcar\'aa n\'e3 c\'ad\'eai" v\'b5
 b\'b8n kh\'bep n\'ad\'edc Ph\'b8p. B\'f8c \'b6nh g\'a9y ra m\'e9t phong tr\'b5o s\'abi n\'e6i ch\'e8ng Po\'a8ngcar\'aa. Cu\'e8i c\'efng ch\'ddnh ph\'f1 c\'f1a \'abng ta b\'de \'ae\'e6.}})}{\f37\fs20\insrsid1378858 , nh\'adng \'eb \'ae\'cay m\'b5 c\'ad
\'eai m\'e9t m\'d7nh th\'d7 c\'e3 th\'d3 l\'b5 v\'ab duy\'aan. V\'d7 v\'cby, b\'f7a n\'e4, quan l\'edn M\'b8cxian M\'d0clanh ra l\'d6nh cho \'aeo\'b5n thanh ni\'aan Annam\'ddt \'ae\'ad\'eec tr\'ee c\'cap theo ng\'b5i \'ae\'d5n V\'ad\'ean Ng\'ad\'eai Ch
\'d5t \'eb N\'abgi\'a8ng tr\'aan s\'abng M\'b8cn\'ac v\'d7 \'eb \'ae\'e3 s\'cf \'ae\'ad\'eec \'ae\'e4c m\'e9t b\'b5i di\'d4n v\'a8n do ng\'b5i ch\'f8ng gi\'b8m. B\'b5i di\'d4n v\'a8n tr\'ad\'edc khi \'ae\'e4c cho c\'abng ch\'f3ng, ph\'b6i tr\'d7nh l\'aa
n quan l\'edn \'ae\'d3 ng\'b5i duy\'d6t. Ng\'ad\'eai ta \'ae\'b7 tr\'d7nh v\'b5 b\'b5i di\'d4n v\'a8n b\'de coi l\'b5 qu\'b8 ng\'e7 ng\'ad\'eec, quan l\'edn ra l\'d6nh c\'f8 vi\'d6c b\'e1 \'aei \'ae\'d3 thay th\'d5 b\'bbng m\'e9t b\'b5i kh\'b8c m\'b5
 quan l\'edn cho d\'b5n \'fd.
\par C\'e8 nhi\'aan, b\'b5i di\'d4n v\'a8n x\'b5o n\'cau trong c\'b8c th\'f8 n\'ad\'edc c\'e8t c\'f1a quan l\'edn nh\'ad v\'cby, th\'d7 h\'ad\'acng v\'de c\'f1a l\'dfng trung th\'b5nh v\'b5 l\'dfng \'b8i m\'e9 b\'cat di\'d6t \'ae\'e8i v\'edi n\'ad\'edc Ph\'b8
p ph\'b6i x\'abng l\'aan \'ae\'d5n ng\'b9t m\'f2i...
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 N\'d5u ng\'ad\'eai ch\'d5t n\'e3i \'ae\'ad\'eec, nh\'ad b\'e4n \'ae\'e5ng c\'e8t b\'b6o th\'d5, th\'d7 nh\'f7ng h\'e5
n ma An Nam \'eb N\'abgi\'a8ng s\'cf l\'aan ti\'d5ng: "C...\'b6m \'acn \'abng to\'b5n quy\'d2n! Nh\'adng xin l\'b5m \'acn... c\'f3t \'aei cho!"}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0
\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) }{\i\insrsid1378858 M...erci \'b5 toi, ... F... nous la paix!}{\insrsid1378858  Trong ti\'d5ng Ph\'b8p ch\'f7
 M vi\'d5t t\'bet, ng\'ad\'eai ta th\'ad\'eang hi\'d3u l\'b5 Merde, l\'b5 m\'e9t ti\'d5ng ch\'f6i r\'f1a r\'cat t\'f4c, c\'f2ng c\'e3 ngh\'dca l\'b5 ph\'a9n - Ch\'f7 F. l\'b5 Foutre c\'e3 ngh\'dca l\'b5 c\'f3t, x\'d0o \'aei, \'ae\'d3 y\'aan (}{
\i\insrsid1378858 Foutre le camp, Foutre la paix...}{\insrsid1378858 ). \'a7\'a9y l\'b5 l\'e8i ch\'aci ch\'f7 c\'f1a t\'b8c gi\'b6.}})}{\f37\fs20\insrsid1378858 .
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~N.
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 Le Paria,}{\insrsid1378858  s\'e8 15,

