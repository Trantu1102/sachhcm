\par 
\par 
\par 
\par 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \line \line \line \line TH\'a6 NG\'e1 G\'f6I \'a4
NG ANBE XAR\'a4,\line B\'e9 TR\'a6\'ebNG B\'e9 THU\'e9C \'a7\'deA
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i\f37\fs20\insrsid1378858 \~Th\'ada ng\'b5i,
\par }\pard \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ch\'f3ng t\'abi ho\'b5n to\'b5n hi\'d3u r\'e2 r\'bbng, \'ae\'e8i v\'edi d\'a9n b\'b6n x\'f8 \'eb thu\'e9c \'ae\'dea n
\'e3i chung v\'b5 \'ae\'e8i v\'edi d\'a9n An Nam n\'e3i ri\'aang, l\'dfng th\'ad\'acng y\'aau c\'f1a Ng\'b5i th\'cbt l\'b5 bao la r\'e9ng r\'b7i.
\par D\'ad\'edi quy\'d2n cai tr\'de c\'f1a Ng\'b5i, d\'a9n An Nam \'ae\'b7 \'ae\'ad\'eec h\'ad\'ebng ph\'e5n vinh th\'cbt s\'f9 v\'b5 h\'b9nh ph\'f3c th\'cbt s\'f9, h\'b9nh ph\'f3c \'ae\'ad\'eec th\'cay nhan nh\'b6n kh\'bep trong n\'ad\'edc, nh\'f7ng ty r\'ad
\'eeu v\'b5 ty thu\'e8c phi\'d6n, nh\'f7ng th\'f8 \'ae\'e3 song song v\'edi nh\'f7ng s\'f9 b\'ben gi\'d5t h\'b5ng lo\'b9t, nh\'b5 t\'ef, n\'d2n d\'a9n ch\'f1 v\'b5 t\'cat c\'b6 b\'e9 m\'b8y tinh vi c\'f1a n\'d2n v\'a8n minh hi\'d6n \'ae\'b9i, \'ae\'b7 l
\'b5m cho ng\'ad\'eai An Nam ti\'d5n b\'e9 nh\'cat ch\'a9u }{\f38\fs20\insrsid1378858 \'b8}{\f37\fs20\insrsid1378858  v\'b5 sung s\'ad\'edng nh\'cat tr\'c7n \'ae\'eai.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 H\'b5nh \'ae\'e9ng nh\'a9n \'b8i \'cay \'ae\'f1 \'ae\'d3 ch
\'f3ng t\'abi kh\'abng c\'c7n nh\'bec l\'b9i t\'cat c\'b6 nh\'f7ng h\'b5nh \'ae\'e9ng kh\'b8c nh\'ad: b\'bet l\'ddnh v\'b5 b\'bet mua c\'abng tr\'b8i, \'ae\'b5n \'b8p \'ae\'c9m m\'b8u, tru\'cat ng\'abi v\'b5 \'ae\'c7y bi\'d6t x\'f8 m\'e9t \'abng vua, x
\'a9m ph\'b9m v\'b5 l\'b5m \'ab u\'d5 nh\'f7ng n\'aci linh thi\'aang, v.v..
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Th\'cbt \'ae\'f3ng nh\'ad c\'a9u th\'ac ch\'f7 H\'b8n \'ae
\'b7 t\'b6: }{\i\f37\fs20\insrsid1378858 Gi\'e3 \'a9u y\'d5m th\'e6i chi\'d2u qu\'b9t ph\'c8y, m\'ada ngh\'dca nh\'a9n \'ae\'e3n v\'d5t xe l\'a8n}{\f37\fs20\super\insrsid1378858 26}{\f37\fs20\insrsid1378858 . \'a7\'ad\'eec n\'bem quy\'d2n t\'e8
i cao cai qu\'b6n c\'b8c thu\'e9c \'ae\'dea, danh v\'e4ng c\'f1a Ng\'b5i c\'b5ng cao bao nhi\'aau th\'d7 s\'f9 quan t\'a9m \'ae\'c6c bi\'d6t c\'f1a Ng\'b5i \'ae\'e8i v\'edi nh\'f7ng ng\'ad\'eai \'a7\'abng D\'ad\'acng c\'b5ng t\'a8ng l\'aan b\'cay nhi\'aa
u. Ng\'b5i \'ae\'b7 cho thi\'d5t l\'cbp ngay \'eb Pari m\'e9t c\'ac quan \'ae\'c6c tr\'b8ch \'ae\'d3 theo d\'e2i nh\'f7ng ng\'ad\'eai b\'b6n x\'f8 c\'ad tr\'f3 tr\'aan \'ae\'cat Ph\'b8p, \'ae\'c6c bi\'d6t l\'b5 theo d\'e2i nh\'f7ng ng\'ad\'eai \'a7\'ab
ng D\'ad\'acng, nh\'ad m\'e9t t\'ea b\'b8o thu\'e9c \'ae\'dea \'ae\'b7 n\'e3i r\'e2.
\par }\pard \qj \fi397\li0\ri0\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Nh\'adng ch\'d8 "theo d\'e2i" kh\'abng th\'abi th\'d7 th\'cay h\'d7nh nh\'ad ch\'ada x\'f8ng v\'edi t\'cam l\'dfng th\'ad\'ac
ng y\'aau c\'f1a Ng\'b5i nh\'ad b\'cbc cha m\'d1, n\'aan Ng\'b5i c\'dfn mu\'e8n gia \'acn h\'acn n\'f7a. V\'d7 v\'cby m\'b5 g\'c7n \'ae\'a9y, Ng\'b5i \'ae\'b7 ban cho m\'e7i ng\'ad\'eai An Nam - ng\'ad\'eai An Nam y\'aau qu\'fd, nh\'ad ng\'b5i th\'ad\'ea
ng n\'e3i - nhi\'d2u ng\'ad\'eai "h\'c7u c\'cbn" \'ae\'c6c bi\'d6t. Tuy nh\'f7ng ng\'ad\'eai n\'b5y c\'dfn \'cau tr\'dc trong ngh\'d6 thu\'cbt c\'f1a S\'d0cl\'e8c H\'abm}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain 
\s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) Nh\'a9n v\'cbt n\'e6i ti\'d5ng trong ti\'d3u thuy\'d5t trinh th\'b8
m Anh, ch\'d8 th\'b8m t\'f6 l\'b5nh ngh\'d2.}})}{\f37\fs20\insrsid1378858 , nh\'adng h\'e4 c\'f2ng \'ae\'b7 t\'e1 ra r\'cat t\'cbn t\'f4y v\'b5 r\'cat \'ae\'b8ng y\'aau. Ch\'f3ng t\'abi ch\'d8 c\'dfn bi\'d5t khen ng\'eei h\'e4 v\'b5 ca t\'f4ng ng\'ad\'ea
i c\'c7m \'ae\'c7u h\'e4 l\'b5 Ng\'b5i.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ch\'f3ng t\'abi th\'b5nh th\'cbt l\'cay l\'b5m c\'b6m \'ae\'e9ng \'ae\'ad\'eec Ng\'b5i d\'b5nh cho vinh d\'f9 \'ae\'e3
, v\'b5 ch\'f3ng t\'abi c\'e3 l\'cf s\'cf ti\'d5p nh\'cbn vinh d\'f9 \'ae\'e3 v\'edi t\'cam l\'dfng bi\'d5t \'acn s\'a9u s\'bec nh\'cat, n\'d5u vinh d\'f9 \'cay \'ae\'e8i v\'edi ch\'f3ng t\'abi x\'d0t ra kh\'abng ph\'b6i l\'b5 c\'e3 h\'aci th\'f5a, v\'b5
 kh\'abng g\'a9y ra nh\'f7ng s\'f9 ghen t\'de v\'b5 suy b\'d7.
\par }\pard \qj \fi397\li0\ri0\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Trong l\'f3c Ngh\'de vi\'d6n \'aeang t\'d7m c\'b8ch ti\'d5t ki\'d6m chi ti\'aau, h\'b9n ch\'d5 s\'e8 nh\'a9n vi\'aan c\'b8c c
\'ac quan h\'b5nh ch\'ddnh; trong l\'f3c ng\'a9n s\'b8ch b\'de th\'a9m h\'f4t nhi\'d2u, n\'abng nghi\'d6p v\'b5 c\'abng nghi\'d6p thi\'d5u nh\'a9n c\'abng; trong l\'f3c ph\'b6i h\'b9n ch\'d5 ti\'d2n l\'ad\'acng c\'f1a ng\'ad\'eai lao \'ae\'e9ng v\'b5
 trong l\'f3c vi\'d6c ph\'f4c h\'e5i d\'a9n s\'e8 \'ae\'dfi h\'e1i ph\'b6i s\'f6 d\'f4ng m\'e4i n\'a8ng l\'f9c v\'b5o vi\'d6c s\'b6n xu\'cat, - trong l\'f3c nh\'ad th\'d5, ch\'f3ng t\'abi l\'b9i c\'f8 ti\'d5p nh\'cbn nh\'f7ng \'ae\'c6c \'a9n ri\'aa
ng cho c\'b8 nh\'a9n m\'d7nh, g\'a9y ra l\'b7ng ph\'dd s\'f8c l\'f9c c\'f1a nh\'f7ng ng\'ad\'eai c\'abng d\'a9n b\'de \'ae\'b5y v\'b5o c\'b6nh v\'ab c\'abng r\'e5i ngh\'d2 nh\'ad nh\'f7ng ng\'ad\'eai "h\'c7u c\'cbn" n\'e3i tr\'aan, v\'b5 g\'a9y ra s\'f9
 ti\'aau ph\'dd ti\'d2n b\'b9c m\'b5 giai c\'cap v\'ab s\'b6n \'ae\'b7 \'ae\'e6 m\'e5 h\'abi s\'abi n\'ad\'edc m\'bet m\'edi ki\'d5m ra \'ae\'ad\'eec, - th\'d7 qu\'b6 l\'b5 kh\'abng y\'aau n\'ad\'edc t\'fd n\'b5o.
\par }\pard \qj \fi397\li0\ri0\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 V\'d7 v\'cby, tuy r\'bbng v\'c9n l\'b5 k\'ce \'ae\'e9i \'acn Ng\'b5i, ch\'f3ng t\'abi c\'f2ng tr\'a9n tr\'e4ng xin Ng\'b5i mi
\'d4n cho c\'b8i \'ae\'c6c \'a9n \'cay, \'ae\'e8i v\'edi ch\'f3ng t\'abi th\'d7 n\'e3 qu\'fd ho\'b8 th\'cbt, nh\'adng \'ae\'e8i v\'edi n\'ad\'edc nh\'b5 th\'d7 l\'b9i l\'b5 qu\'b8 l\'b7ng ph\'dd.
\par N\'d5u Ng\'b5i nh\'cat thi\'d5t c\'c7n bi\'d5t h\'bbng ng\'b5y ch\'f3ng t\'abi l\'b5m g\'d7 th\'d7 r\'cat d\'d4 th\'abi: c\'f8 m\'e7i bu\'e6i s\'b8ng ch\'f3ng t\'abi s\'cf ph\'b8t h\'b5nh m\'e9t b\'b6n tin v\'d2 s\'f9 \'aei l\'b9i c\'f1a ch\'f3ng t\'abi v
\'b5 Ng\'b5i ch\'d8 vi\'d6c \'ae\'e4c l\'b5 bi\'d5t.
\par }\pard \qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 V\'b6 l\'b9i, th\'eai kho\'b8 bi\'d3u c\'f1a ch\'f3ng t\'abi r\'cat gi\'b6n \'ae\'acn v\'b5 h\'c7u nh\'ad c\'e8 \'ae\'denh.

\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 S\'b8ng: T\'f5 8 \'ae\'d5n 12 gi\'ea \'eb x\'ad\'ebng m\'b8y.
\par Chi\'d2u: }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  ph\'dfng b\'b8o ch\'dd (d\'dc nhi\'aan l\'b5 b\'b8o c\'f1a ph\'b8i t\'b6), ho\'c6c \'eb th\'ad vi\'d6n.
\par T\'e8i: }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  nh\'b5 ri\'aang, ho\'c6c d\'f9 nh\'f7ng bu\'e6i n\'e3i chuy\'d6n b\'e6 \'ddch.
\par Ch\'f1 nh\'cbt v\'b5 ng\'b5y l\'d4: Th\'a8m nh\'b5 b\'b6o t\'b5ng hay nh\'f7ng n\'aci b\'e6 \'ddch kh\'b8c.
\par Ch\'d8 c\'e3 th\'d5 th\'abi!
\par Hy v\'e4ng r\'bbng c\'b8ch n\'b5y v\'f5a ti\'d6n, v\'f5a h\'eep l\'fd c\'e3 th\'d3 l\'b5m Ng\'b5i h\'b5i l\'dfng \'ae\'ad\'eec, ch\'f3ng t\'abi xin k\'ddnh g\'f6i Ng\'b5i, v.v..
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 nguy\'d4n \'b8i qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 L'Humanit\'d0,}{\insrsid1378858 
\par ng\'b5y 25-7-1922.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~
\par \column 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 KHAI HO\'b8 GI\'d5T NG\'a6\'eaI
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~C\'f2ng tr\'aan m\'f4c di\'d4n \'ae\'b5n n\'b5y, g\'c7n 
\'ae\'a9y ch\'f3ng t\'abi \'ae\'b7 n\'aau l\'aan m\'e9t lo\'b9t nh\'f7ng v\'f4 gi\'d5t ng\'ad\'eai m\'b5 th\'f1 ph\'b9m l\'b5 nh\'f7ng k\'ce \'aei "khai h\'e3a" c\'f1a ch\'f3ng ta, nh\'adng v\'c9n kh\'abng b\'de tr\'f5ng ph\'b9t. Than \'abi! quy\'d3n s
\'e6 \'aeo\'b9n tr\'ad\'eang \'cay c\'f8 m\'e7i ng\'b5y m\'e9t d\'b5i th\'aam, th\'cbt l\'b5 \'aeau x\'e3t.
\par L\'b9i m\'edi \'ae\'a9y th\'abi, m\'e9t ng\'ad\'eai An Nam, tr\'b9c 50 tu\'e6i, l\'b5m c\'abng cho s\'eb xe l\'f6a Nam K\'fa \'ae\'b7 25 n\'a8m nay, b\'de m\'e9t vi\'aan ch\'f8c ng\'ad\'eai da tr\'beng gi\'d5t. S\'f9 vi\'d6c nh\'ad sau:
\par Anh L\'aa V\'a8n T\'b5i \'aei\'d2u khi\'d3n b\'e8n ng\'ad\'eai An Nam kh\'b8c l\'b5m vi\'d6c d\'ad\'edi quy\'d2n m\'d7nh. Ph\'cbn s\'f9 c\'f1a h\'e4 l\'b5 \'ae\'e3ng c\'c7u m\'e7i khi c\'e3 xe l\'f6a \'aei qua v\'b5 m\'eb c\'c7u cho t\'c7u b\'cc qua l\'b9
i. Theo l\'d6nh \'ae\'b7 quy \'ae\'denh th\'d7 ph\'b6i \'ae\'e3ng c\'c7u 10 ph\'f3t tr\'ad\'edc khi xe l\'f6a \'aei qua.
\par Ng\'b5y 2 th\'b8ng 4, h\'e5i 16 gi\'ea 30, m\'e9t ng\'ad\'eai trong b\'e4n h\'e4 m\'edi \'ae\'e3ng c\'c7u v\'b5 h\'b9 t\'ddn hi\'d6u xu\'e8ng, v\'f5a l\'f3c }{\i\f37\fs20\insrsid1378858 m\'e9t chi\'d5c thuy\'d2n m\'b8y c\'abng \'aei \'ae\'d5n, tr\'aa
n thuy\'d2n ch\'eb m\'e9t vi\'aan ch\'f8c x\'ad\'ebng \'ae\'e3ng t\'b5u c\'f1a h\'b6i qu\'a9n \'aei s\'a8n v\'d2.}{\f37\fs20\insrsid1378858  Chi\'d5c thuy\'d2n m\'b8y k\'d0o c\'dfi l\'aan. Nh\'a9n vi\'aan ng\'ad\'eai b\'b6n x\'f8 li\'d2n ra \'ae\'f8ng gi
\'f7a c\'c7u, ph\'cat c\'ea \'ae\'e1 b\'b8o cho nh\'f7ng ng\'ad\'eai tr\'aan thuy\'d2n m\'b8y bi\'d5t r\'bbng xe l\'f6a s\'bep ch\'b9y qua v\'b5 do \'ae\'e3 c\'c7u \'ae\'b7 \'ae\'e3ng r\'e5i. V\'b5 sau \'ae\'a9y l\'b5 c\'a9u chuy\'d6n \'ae\'b7 x\'b6y ra
: Chi\'d5c thuy\'d2n m\'b8y gh\'d0 s\'b8t v\'b5o tr\'f4 c\'c7u. Ng\'ad\'eai vi\'aan ch\'f8c Ph\'b8p li\'d2n nh\'b6y l\'aan b\'ea v\'b5 h\'c7m h\'c7m ti\'d5n v\'d2 ph\'dda ng\'ad\'eai An Nam. Anh n\'b5y kh\'abn ngoan, ch\'b9y tr\'e8n v\'d2 ph\'dda nh\'b5 
\'abng T\'b5i l\'b5 "x\'d5p" c\'f1a m\'d7nh. Ng\'ad\'eai vi\'aan ch\'f8c kia \'aeu\'e6i theo, l\'cay \'ae\'b8 n\'d0m anh ta. Nghe c\'e3 ti\'d5ng \'e5n \'b5o, T\'b5i li\'d2n ch\'b9y ra \'ae\'e3n v\'de \'ae\'b9i di\'d6n c\'f1a n\'d2n v\'a8n minh, vi\'aan n
\'b5y m\'beng ngay: "\'a7\'e5 s\'f3c v\'cbt, t\'b9i sao m\'b5y
\par }\pard \qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 kh\'abng m\'eb ra ?". V\'e8n kh\'abng bi\'d5t ti\'d5ng Ph\'b8p, T\'b5i ch\'d8 c\'dfn bi\'d5t tr\'b6 l\'eai b\'bbng c\'b8ch tr
\'e1 v\'b5o c\'b8i t\'ddn hi\'d6u \'ae\'e1. C\'f6 ch\'d8 \'ae\'acn gi\'b6n \'cay l\'b5m cho \'abng c\'e9ng t\'b8c vi\'aan c\'f1a Ng\'b5i L\'abng n\'e6i xung l\'aan. Kh\'abng ph\'a9n ph\'b6i tr\'b8i g\'d7, \'abng ta nh\'b6y x\'e6 v\'b5o T\'b5i v\'b5 }{
\i\f37\fs20\insrsid1378858 sau khi \'ae\'b7 "khi\'d2n" cho m\'e9t tr\'cbn, c\'dfn \'ae\'c8y anh v\'b5o m\'e9t \'ae\'e8ng than h\'e5ng \'eb g\'c7n \'ae\'e3}{\f37\fs20\insrsid1378858 .
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ng\'ad\'eai An Nam g\'b8c c\'c7u \'cay b\'de b\'e1ng m\'e9t c\'b8ch r\'efng r\'een, \'ae\'ad\'eec ch\'eb \'ae\'d5n nh
\'b5 th\'ad\'acng, v\'b5 sau s\'b8u h\'abm c\'f9c k\'fa \'aeau \'ae\'edn anh \'ae\'b7 ch\'d5t t\'b9i nh\'b5 th\'ad\'acng.
\par Ng\'ad\'eai vi\'aan ch\'f8c kia v\'c9n \'ae\'ad\'eec v\'ab s\'f9 kh\'abng c\'e3 g\'d7 ph\'b6i lo l\'beng c\'b6. Trong l\'f3c \'eb M\'b8cx\'a9y, ng\'ad\'eai ta tri\'d3n l\'b7m c\'b6nh ph\'e5n th\'denh gi\'b6 t\'b9o}{\f37\fs20\super\insrsid1378858 27}{
\f37\fs20\insrsid1378858  c\'f1a x\'f8 \'a7\'abng D\'ad\'acng th\'d7 \'eb An Nam \'aeang c\'e3 nh\'f7ng ng\'ad\'eai b\'de ch\'d5t \'ae\'e3i. }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  b\'aan n\'b5y, ng\'ad\'eai ta ca t\'f4ng l\'df
ng trung th\'b5nh, c\'dfn \'eb b\'aan kia, ng\'ad\'eai ta \'aeang gi\'d5t ng\'ad\'eai! Nh\'ad v\'cby ngh\'dca l\'b5 th\'d5 n\'b5o h\'eci \'a7\'cang ch\'dd t\'abn Kh\'b6i \'a7\'denh v\'b5 C\'f4 l\'edn Xar\'ab ?
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~NGUY\'d4N A.Q.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par T.B.- Trong khi t\'ddnh m\'d6nh c\'f1a m\'e9t ng\'ad\'eai An Nam b\'de xem nh\'ad th\'a9n con ch\'e3, kh\'abng \'ae\'b8ng gi\'b8 m\'e9t \'ae\'e5ng trinh, th\'d7 Ng\'b5i T\'e6ng thanh tra R\'aana, b\'de s\'ad\'edt c\'e3 m\'e9t ch\'f3t da \'eb c\'b8nh tay m
\'b5 \'ae\'ad\'eec l\'dcnh 120.000 phr\'a8ng ti\'d2n b\'e5i th\'ad\'eang. \'a4i, b\'d7nh \'ae\'bcng! B\'d7nh \'ae\'bcng qu\'fd ho\'b8 thay!
\par 
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 Le Paria}{\insrsid1378858 , s\'e8 5,

\par ng\'b5y 1-8-1922.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \column 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 PH\'f4 N\'f7 AN NAM V\'b5 S\'f9 \'a7\'a4 H\'e9\line C
\'f1A PH\'b8P
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~Ch\'d5 \'ae\'e9 th\'f9c d\'a9n, t\'f9 b\'b6n th\'a9n n
\'e3, \'ae\'b7 l\'b5 m\'e9t h\'b5nh \'ae\'e9ng b\'b9o l\'f9c c\'f1a k\'ce m\'b9nh \'ae\'e8i v\'edi k\'ce y\'d5u r\'e5i. B\'b9o l\'f9c \'ae\'e3, \'aeem ra \'ae\'e8i x\'f6 v\'edi tr\'ce em v\'b5 ph\'f4 n\'f7, l\'b9i c\'b5ng b\'d8 \'e6i h\'acn n\'f7a.
\par Th\'cbt l\'b5 m\'e9t s\'f9 m\'d8a mai \'aeau \'ae\'edn khi ta th\'cay r\'bbng v\'a8n minh d\'ad\'edi nhi\'d2u h\'d7nh th\'f8c kh\'b8c nhau, nh\'ad t\'f9 do, c\'abng l\'fd, v.v. - \'ae\'ad\'eec t\'ad\'eeng tr\'adng b\'bbng h\'d7nh \'b6nh m\'e9t ng\'ad\'ea
i \'ae\'b5n b\'b5 d\'deu hi\'d2n v\'b5 \'ae\'ad\'eec m\'e9t
\par  h\'b9ng ng\'ad\'eai n\'e6i ti\'d5ng l\'b5 h\'b5o hoa phong nh\'b7 ra s\'f8c \'aei\'d3m t\'ab - l\'b9i \'ae\'e8i x\'f6 m\'e9t c\'b8ch h\'d5t s\'f8c b\'d8 \'e6i v\'edi ng\'ad\'eai \'ae\'b5n b\'b5 b\'bbng x\'ad\'acng b\'bbng th\'det v\'b5 x\'f3c ph\'b9m m
\'e9t c\'b8ch v\'ab li\'aam s\'d8 t\'edi phong ho\'b8, trinh ti\'d5t v\'b5 \'ae\'eai s\'e8ng c\'f1a h\'e4.
\par Th\'e3i d\'a9m b\'b9o \'eb thu\'e9c \'ae\'dea l\'b5 m\'e9t hi\'d6n t\'ad\'eeng ph\'e6 bi\'d5n v\'b5 t\'b5n \'b8c kh\'abng th\'d3 n\'b5o t\'ad\'ebng t\'ad\'eeng \'ae\'ad\'eec. }{\f38\fs20\insrsid1378858 \'eb }{\f37\fs20\insrsid1378858 \'ae\'a9y ch\'f3ng t
\'abi ch\'d8 t\'b9m n\'aau ra m\'e9t v\'b5i s\'f9 vi\'d6c m\'b5 nh\'f7ng ng\'ad\'eai v\'ab t\'ad \'ae\'b7 ch\'f8ng ki\'d5n v\'b5 k\'d3 l\'b9i nh\'f7ng \'aei\'d2u tai nghe m\'bet th\'cay, \'ae\'d3 ch\'de em ph\'f4 n\'f7 ph\'ad\'acng T\'a9y hi\'d3u r\'e2 gi
\'b8 tr\'de c\'f1a c\'b8i g\'e4i l\'b5 "s\'f8 m\'b9ng khai ho\'b8" m\'b5 b\'e4n t\'ad b\'b6n \'ae\'b7 gi\'b5nh l\'cay \'ae\'e9c quy\'d2n thi h\'b5nh, \'ae\'e5ng th\'eai hi\'d3u r\'e2 n\'e7i \'aeau kh\'e6 c\'f1a ch\'de em ph\'f4 n\'f7 \'eb thu\'e9c \'ae
\'dea.
\par }\pard \qj \li0\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 M\'e9t ng\'ad\'eai \'eb thu\'e9c \'ae\'dea k\'d3 l\'b9i r\'bbng: "Khi b\'e4n l\'ddnh k\'d0o \'ae\'d5n, d\'a9n ch\'f3ng ch\'b9
y tr\'e8n c\'b6, ch\'d8 c\'dfn l\'b9i hai c\'f4 gi\'b5 v\'b5 hai ph\'f4 n\'f7, m\'e9t thi\'d5u n\'f7 c\'dfn t\'a9n v\'b5 m\'e9t ph\'f4 n\'f7 \'aeang cho \'ae\'f8a con m\'edi \'ae\'ce b\'f3, tay d\'bet m\'e9t em g\'b8i nh\'e1 l\'aan t\'b8m. B\'e4n l\'ddnh 
\'ae\'dfi ti\'d2n, r\'ad\'eeu m\'b9nh v\'b5 thu\'e8c phi\'d6n.
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 Kh\'abng ai hi\'d3u ch\'f3ng n\'e3i g\'d7, th\'d5 l\'b5 ch
\'f3ng n\'e6i gi\'cbn l\'cay b\'b8ng s\'f3ng n\'d6n m\'e9t c\'f4 gi\'b5 ng\'cat \'aei, r\'e5i c\'dfn m\'e9t c\'f4 th\'d7 trong m\'cay gi\'ea li\'d2n, hai t\'aan trong b\'e4n l\'ddnh, khi k\'d0o \'ae\'d5n \'ae\'b7 say b\'dd t\'d8, \'aeem thi\'aau trong m
\'e9t \'ae\'e8ng c\'f1i c\'b5nh kh\'ab l\'b5m tr\'df vui v\'edi nhau. Trong khi \'ae\'e3, th\'d7 nh\'f7ng t\'aan kh\'b8c hi\'d5p hai ph\'f4 n\'f7 v\'b5 em g\'b8i nh\'e1, ch\'b8n r\'e5i, ch\'f3ng gi\'d5t ch\'d5t em b\'d0. L\'f3c \'ae\'e3, ng\'ad\'eai m\'d1
 b\'e5ng \'ae\'f8a con kia tr\'e8n \'ae\'ad\'eec, r\'e5i t\'f5 trong m\'e9t c\'b8i b\'f4i c\'a9y c\'b8ch \'ae\'cay \'ae\'e9 100 m\'d0t, tr\'abng th\'cay ng\'ad\'eai ch\'de em m\'d7nh \'aeang b\'de h\'b5nh h\'b9. Duy\'aan c\'ed l\'b5m sao, ch\'de ch\'bc
ng bi\'d5t, ch\'de ch\'d8 th\'cay ng\'ad\'eai thi\'d5u n\'f7 b\'de \'ae\'c6t ng\'f6a tr\'aan m\'c6t \'ae\'cat, tay ch\'a9n b\'de tr\'e3i ch\'c6t, mi\'d6ng b\'de b\'det l\'b9i, c\'dfn m\'e9t t\'aan l\'ddnh th\'d7 l\'cay l\'ad\'eci l\'aa c\'f8 t\'f5 t\'f5
, t\'f5ng nh\'b8t m\'e9t, ch\'e4c v\'b5o b\'f4ng ch\'de, r\'e5i l\'b9i ch\'c7m ch\'cbm r\'f3t ra. Sau \'ae\'e3, ch\'f3ng ch\'c6t ng\'e3n tay ng\'ad\'eai thi\'d5u n\'f7 \'ae\'b7 ch\'d5t \'ae\'d3 c\'ad\'edp l\'cay chi\'d5c nh\'c9n v\'b5 ch\'c6t c\'e6 \'ae
\'d3 c\'ad\'edp l\'cay chi\'d5c v\'dfng.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 "Tr\'aan m\'b6nh \'ae\'cat b\'bbng ph\'bcng tr\'ad\'ed
c kia l\'b5 ru\'e9ng mu\'e8i, ba c\'b8i x\'b8c ch\'d5t n\'bbm \'ae\'e3: em b\'d0 b\'de l\'e9t tru\'e5ng, thi\'d5u n\'f7 b\'de m\'e6 b\'f4ng, c\'b8nh tay tr\'b8i c\'f8ng \'ae\'ea gi\'ac l\'aan tr\'eai v\'ab t\'d7nh, b\'b5n tay n\'bem ch\'c6t. C\'dfn x\'b8
c \'abng c\'f4 gi\'b5 th\'d7 gh\'aa g\'edm l\'b5m sao, c\'f2ng tr\'c7n tru\'e5ng nh\'ad th\'d5, nh\'adng v\'d7 b\'de thi\'aau ch\'b8y n\'aan kh\'abng nh\'cbn ra h\'d7nh th\'ef \'ae\'ad\'eec n\'f7a, m\'ec ch\'b6y l\'aanh l\'b8ng \'ae\'b7 \'ae\'e4ng l\'b9
i v\'b5 da b\'f4ng th\'d7 b\'de ph\'e5ng l\'aan, ch\'ddn v\'b5ng, \'e3ng \'b8nh nh\'ad da con l\'een quay v\'cby".
\par }{\i\f37\fs20\insrsid1378858 (C\'dfn ti\'d5p)}{\cs17\i\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) C\'b8c s\'e8 b\'b8o }{\i\insrsid1378858 Le Paria}{\insrsid1378858  sau kh\'abng th\'cay \'ae\'a8ng ti\'d5p.}})}{\f37\fs20\insrsid1378858 
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nguy\'d4n \'b8i qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 Le Paria, }{\insrsid1378858 s\'e8 5,

\par ng\'b5y 1-8-1922.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \column 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \line \line "S\'eb TH\'ddCH \'a7\'c6C BI\'d6T"
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i\f37\fs20\insrsid1378858 \~T\'f5 khi \'ae\'d5n Pari, Kh\'b6i \'a7\'denh, Ho\'b5
ng \'ae\'d5 n\'ad\'edc An Nam \'ae\'b7 th\'b5nh m\'f4c ti\'aau bao v\'a9y theo nh\'ad th\'ad\'eang l\'d6 c\'f1a m\'e9t s\'e8 b\'b5 bu\'abn son b\'b8n ph\'can. H\'e4 \'ae\'b7 d\'a9ng l\'aan Ng\'b5i Ng\'f9 nhi\'d2u b\'f8c th\'ad n\'e5ng n\'b5n t\'d7nh t\'f8
 v\'b5 nhi\'d2u t\'cam \'b6nh kh\'aau g\'eei. Nh\'adng Kh\'b6i \'a7\'denh v\'e8n l\'b5 b\'cbc hi\'d2n tri\'d5t,
\par Ng\'b5i Ng\'f9 b\'ccn truy\'d2n \'aeem t\'cat c\'b6 th\'ad v\'b5 \'b6nh \'cay v\'f8t v\'b5o s\'e4t r\'b8c, v\'b5 ai h\'e1i, Ng\'b5i Ng\'f9 c\'f2ng \'ae\'d2u t\'f5 ch\'e8i kh\'abng tr\'b6 l\'eai g\'d7 h\'d5t.
\par \'a4ng Anbe Xar\'ab \'ae\'b7 tr\'b6 l\'eai m\'e9t m\'fc nh\'a9n h\'e1i v\'d2 vi\'d6c \'ae\'e3 nh\'ad sau:
\par - }{\i\f38\fs20\insrsid1378858 \'ca}{\i\f37\fs20\insrsid1378858 y, Ho\'b5ng th\'ad\'eeng Ng\'b5i c\'e3 nh\'f7ng s\'eb th\'ddch r\'cat \'ae\'c6c bi\'d6t.
\par B\'b5 n\'b5y r\'cat \'ae\'e7i ng\'b9c nhi\'aan v\'b5 mu\'e8n h\'e1i c\'c6n k\'cf th\'aam, nh\'adng \'abng B\'e9 tr\'ad\'ebng B\'e9 Thu\'e9c \'ae\'dea \'ae\'b7 \'ae\'b8nh tr\'e8ng l\'b6ng:
\par - Ho\'b5ng th\'ad\'eeng Ng\'b5i ch\'d8 th\'ddch \'ae\'e4c s\'b8ch th\'abi.
\par B\'b5 ta l\'b9i h\'e1i:
\par - Th\'d5 hi\'d6n gi\'ea Ho\'b5ng th\'ad\'eeng \'aeang \'ae\'e4c g\'d7?
\par \'a4ng Anbe Xar\'ab tr\'b6 l\'eai:
\par - Plat\'abng.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 
\par }\pard \qc \fi397\li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs18\insrsid1378858 (Nghe L\'e1m)}{\i\f37\fs20\insrsid1378858 
\par }\pard \qj \li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 B\'b6o r\'bbng Ho\'b5ng \'ae\'d5 Kh\'b6i \'a7\'denh l\'b5 b\'cbc hi\'d2n tri\'d5t, \'aei\'d2u \'ae\'e3 ta kh\'abng nghi ng\'ea
 g\'d7 c\'b6. Nh\'adng hi\'d2n tri\'d5t th\'d7 c\'f2ng kh\'abng ph\'b6i l\'b5 kh\'abng c\'c7n l\'d4 \'ae\'e9, v\'b5 ch\'f3ng t\'abi m\'b9n ph\'d0p k\'ddnh t\'a9u Ho\'b5ng th\'ad\'eeng r\'bbng c\'f6 ch\'d8 c\'f1a Ng\'b5i d\'ef uy nghi \'ae\'d5n \'ae\'a9
u ch\'a8ng n\'f7a nh\'adng v\'c9n ho\'b5n to\'b5n thi\'d5u l\'dech s\'f9. Ri\'aang ch\'d8 ngh\'dc r\'bbng nh\'f7ng b\'b5 l\'dech s\'f9 kia, v\'d7 ham chu\'e9ng nh\'f7ng c\'b8i c\'f1a vua ch\'f3a m\'b5 b\'de khinh mi\'d6t m\'e9t c\'b8ch ph\'f2 ph\'b5ng nh
\'ad th\'d5 \'bet kh\'abng kh\'e1i s\'cf tr\'f3t t\'cat c\'b6 m\'e8i c\'a8m th\'ef gh\'aa g\'edm c\'f1a c\'b8c b\'b5 v\'b5o nh\'f7ng }{\i\f37\fs20\insrsid1378858 \'ae\'d2 t\'b5i}{\f37\fs20\insrsid1378858  v\'d2 Ho\'b5ng th\'ad\'eeng, l\'b5 ng\'ad\'ea
i ta c\'f2ng \'ae\'f1 run l\'aan r\'e5i. Quan l\'edn B\'e9 tr\'ad\'ebng v\'e8n c\'e3 t\'b5i \'a8n n\'e3i. \'a4ng l\'b9i r\'cat am hi\'d3u ch\'f7 ngh\'dca c\'f1a n\'ad\'edc \'abng. V\'cby m\'b5 c\'a9u \'abng tr\'b6 l\'eai m\'fc nh\'a9n l\'b9i r\'cat m\'cb
p m\'ea. \'a4ng d\'efng ch\'f7 "s\'eb th\'ddch \'ae\'c6c bi\'d6t", th\'cbt ra l\'b5 mu\'e8n n\'e3i g\'d7 nh\'d8? C\'e3 ph\'b6i ng\'c9u nhi\'aan m\'b5, m\'c6c d\'c7u v\'f5a m\'edi ch\'a9n \'ad\'edt ch\'a9n r\'b8o t\'edi c\'b8i th\'b5nh ph\'e8 \'b8nh s\'b8
ng n\'b5y, \'a7\'f8c Ho\'b5ng th\'ad\'eeng r\'cat \'ad th\'abng th\'b8i v\'b5 \'ae\'c7y t\'a9m h\'e5n ngh\'d6 s\'dc \'ae\'b7 l\'b5m quen \'ae\'ad\'eec ngay v\'edi m\'e9t ngh\'d6 s\'dc n\'e6i ti\'d5ng v\'b5 m\'e9t thi s\'dc l\'f5ng danh r\'e5i ch\'a8ng? 
\'a7\'c6t c\'a9u h\'e1i nh\'ad th\'d5, ch\'ddnh l\'b5 \'ae\'b7 tr\'b6 l\'eai r\'e5i \'ae\'e3. Sau khi m\'fc nh\'a9n mu\'e8n h\'e1i c\'c6n k\'cf th\'aam, v\'b5 sau khi quan l\'edn B\'e9 tr\'ad\'ebng \'ae\'b8nh tr\'e8ng l\'b6ng, th\'d7 c\'b8i c\'a9u n\'e3
i m\'cbp m\'ea r\'cat h\'efng bi\'d6n kia v\'c9n c\'dfn ti\'d5p t\'f4c th\'aam r\'bbng: tuy trong ch\'f7 }{\i\f37\fs20\insrsid1378858 Th\'d0\'d0t\'ccte}{\cs17\i\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain 
\s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) }{\i\insrsid1378858 Th\'d0\'d0t\'ccte}{\insrsid1378858 , t\'aan m\'e9
t b\'b5i \'ae\'e8i tho\'b9i c\'f1a Plat\'abng b\'b5n v\'d2 tri th\'f8c v\'b5 c\'ac s\'eb c\'f1a tri\'d5t h\'e4c, vi\'d5t v\'b5o kho\'b6ng n\'a8m 369 tr\'ad\'edc c\'abng nguy\'aan. T\'b8c gi\'b6 vi\'d5t c\'a9u n\'b5y \'ae\'d3 n\'e3i \'fd r\'bbng ch\'f7 }{
\i\insrsid1378858 Plat\'abng}{\insrsid1378858  \'eb c\'a9u sau c\'f2ng c\'dfn d\'efng d\'eb v\'c7n.
\par 2) }{\i\insrsid1378858 Platonique}{\insrsid1378858  ngh\'dca \'aeen l\'b5 theo h\'e4c thuy\'d5t Plat\'abng: thu\'c7n tu\'fd l\'fd t\'ad\'ebng. Ngh\'dca b\'e3ng l\'b5 v\'ab hi\'d6u l\'f9c. }{\f38\insrsid1378858 \'eb }{\insrsid1378858 \'ae\'a9y, mu\'e8n 
\'b8m ch\'d8 b\'d6nh li\'d6t d\'ad\'acng c\'f1a Kh\'b6i \'a7\'denh.}})}{\f37\fs20\insrsid1378858  c\'e3 ch\'f7 }{\i\f37\fs20\insrsid1378858 Th\'d0}{\f37\fs20\insrsid1378858  (nh\'ad V\'ddchto Huyg\'ab t\'f5ng n\'e3i), ch\'f3ng ta v\'c9n kh\'abng tin r\'bb
ng Ho\'b5ng th\'ad\'eeng l\'b9i h\'b9 c\'e8 \'ae\'d5n nh\'f7ng t\'b8c ph\'c8m c\'f1a ng\'ad\'eai th\'c7y h\'e4c c\'f1a Arixt\'e8t, v\'d7 Ho\'b5ng th\'ad\'eeng v\'c9n lu\'abn lu\'abn ph\'b6i c\'e3 ng\'ad\'eai th\'abng ng\'abn m\'edi hi\'d3u \'ae\'ad\'ee
c ti\'d5ng Ph\'b8p (v\'b5 c\'b6 ti\'d5ng Hy L\'b9p n\'f7a) kia m\'b5. Cho n\'aan khi \'abng B\'e9 tr\'ad\'ebng n\'e3i r\'bbng Ho\'b5ng th\'ad\'eeng hi\'d6n \'aeang \'ae\'e4c Plat\'abng l\'b5 \'abng ch\'ada n\'e3i h\'d5t c\'b8i ch\'f7 m\'b5 \'abng \'ae\'de
nh n\'e3i: Ch\'bec l\'b5 \'abng \'ae\'denh n\'e3i ch\'f7 Plat\'ab...n\'ddch}{\f37\fs20\super\insrsid1378858 2)}{\f37\fs20\insrsid1378858  \'ae\'cay m\'b5.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\i\f37\fs20\insrsid1378858 Amicus Plato, sed magis amica veritass}{\cs17\i\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain 
\s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) Ngh\'dca l\'b5 }{\i\insrsid1378858 T\'abi r\'cat qu\'fd Plat\'abng nh
\'adng \'ae\'e8i v\'edi t\'abi, s\'f9 th\'cbt c\'dfn qu\'fd h\'acn nhi\'d2u}{\insrsid1378858 . \'a7\'a9y l\'b5 m\'e9t c\'a9u ch\'a9m ng\'abn r\'f3t trong t\'b8c ph\'c8m c\'f1a Am\'abniuyt, nhan \'ae\'d2 l\'b5 }{\i\insrsid1378858 Cu\'e9c \'ae\'eai c\'f1
a Arixt\'e8t.}})}{\f37\fs20\insrsid1378858 
