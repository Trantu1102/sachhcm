\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 51.000 NG\'a6\'eaI AN NAM B\'de \'a7\'d5 QU\'e8C PH\'b8
P\line \'a7\'e9NG VI\'a3N \'a7I L\'b5M BIA \'a7\'ec \'a7\'b9N
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 V\'d7 danh d\'f9 c\'f1a ch\'f1 ngh\'dca \'ae\'d5 qu\'e8
c Ph\'b8p, x\'f8 \'a7\'abng D\'ad\'acng thu\'e9c \'ae\'dea \'ae\'b7 b\'de thi\'d6t h\'b9i n\'c6ng n\'d2. 51.000 ng\'ad\'eai An Nam (ng\'ad\'eai \'a7\'abng D\'ad\'acng) \'ae\'b7 b\'de \'ae\'e9ng vi\'aan v\'b5 \'ae\'c8y ra m\'c6t tr\'cbn c\'f1a n\'ad\'ed
c Ph\'b8p. 49.000 ng\'ad\'eai b\'de \'ae\'ada \'ae\'d5n c\'b8c nh\'b5 m\'b8y \'ae\'d3 s\'b6n xu\'cat thi\'d5t b\'de qu\'a9n s\'f9.
\par Ng\'ad\'eai Ph\'b8p trong nh\'f7ng b\'b8o c\'b8o ch\'ddnh th\'f8c v\'c9n th\'ad\'eang vi\'d5t v\'d2 "tuy\'d3n m\'e9 l\'ddnh t\'d7nh nguy\'d6n"; s\'f9 th\'f9c nh\'f7ng ng\'ad\'eai An Nam \'ae\'b7 b\'de h\'e4 b\'bet v\'b5 \'ae\'c8y v\'b5o chi\'d5n tranh l
\'b5m bia \'ae\'ec \'ae\'b9n.
\par Ng\'ad\'eai Ph\'b8p kh\'abng ch\'d8 \'ae\'c8y ng\'ad\'eai An Nam ra tr\'cbn. H\'e4 c\'dfn t\'ad\'edc \'aeo\'b9t h\'d5t th\'b6y nh\'f7ng g\'d7 c\'e3 th\'d3 t\'ad\'edc \'aeo\'b9t \'ae\'ad\'eec d\'ad\'edi h\'d7nh th\'f8c thu\'d5.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'a7\'d3 \'ae\'e6i l\'cay nh\'f7ng th\'f8 \'ae\'e3, n\'ad
\'edc Ph\'b8p \'ae\'d5 qu\'e8c \'ae\'b7 nhi\'d2u l\'c7n h\'f8a s\'cf \'aeem l\'b9i t\'f9 do v\'b5 quy\'d2n t\'f9 quy\'d5t cho c\'b8c d\'a9n t\'e9c b\'de \'b8p b\'f8c. Nh\'adng nguy c\'ac chi\'d5n tranh v\'f5a m\'edi qua kh\'e1i, th\'d7 nh\'f7ng ch\'f1 nh
\'b5 b\'a8ng ng\'ad\'eai Ph\'b8p l\'b9i b\'bet \'ae\'c7u n\'c6n th\'aam c\'b5ng nhi\'d2u th\'f8 thu\'d5. C\'dfn c\'b8c v\'de t\'ad\'edng th\'d7 c\'e8 ph\'f4c v\'f4 trong qu\'a9n \'ae\'e9i \'ae\'d5n 4 n\'a8m.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Chi\'d5n d\'dech ch\'e8ng chi\'d5n tranh do Qu\'e8c t\'d5
 C\'e9ng s\'b6n ph\'b8t \'ae\'e9ng, \'aeang vang d\'e9i kh\'bep c\'b8c thu\'e9c \'ae\'dea.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb240\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nguy\'d4n \'b8i Qu\'e8c
\par }\trowd \lastrow \ts11\trgaph108\trleft-108\trftsWidth1\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3 \clvertalt\clbrdrt\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3510\clshdrawnil \cellx3402\clvertalt\clbrdrt
\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3119\clshdrawnil \cellx6521\pard\plain \s26\ql \li0\ri175\sl-260\slmult0\nowidctlpar\intbl\aspalpha\aspnum\faauto\adjustright\rin175\lin0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Vi\'d5t n\'a8m 1924. T\'b5i li\'d6u ti\'d5ng Nga,
\par }\pard \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\intbl\aspalpha\aspnum\faauto\adjustright\rin567\lin0 {\insrsid1378858 l\'adu t\'b9i C\'f4c l\'adu tr\'f7 V\'a8n ph\'dfng\line Trung \'ad\'acng \'a7\'b6ng.\cell }\pard \s26\qc \li0\ri175\sl-260\slmult0
\nowidctlpar\intbl\aspalpha\aspnum\faauto\adjustright\rin175\lin0 {\i\insrsid1378858 \'a7\'b9i bi\'d3u \'a7\'abng D\'ad\'acng d\'f9 \'a7\'b9i h\'e9i
\par l\'c7n th\'f8 V Qu\'e8c t\'d5 C\'e9ng s\'b6n.
\par }\pard \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\intbl\aspalpha\aspnum\faauto\adjustright\rin567\lin0 {\insrsid1378858 \cell }\pard\plain \ql \li0\ri0\widctlpar\intbl\aspalpha\aspnum\faauto\adjustright\rin0\lin0 
\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \trowd \lastrow \ts11\trgaph108\trleft-108\trftsWidth1\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3 \clvertalt\clbrdrt\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr
\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3510\clshdrawnil \cellx3402\clvertalt\clbrdrt\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3119\clshdrawnil \cellx6521\row }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0
\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 L\'a3NIN V\'b5 C\'b8C D\'a2N T\'e9C PH\'a6\'a5NG \'a7
\'a4NG
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 N\'d5u giai c\'cap v\'ab s\'b6n ph\'ad\'acng T\'a9y coi L
\'aanin l\'b5 m\'e9t th\'f1 l\'dcnh, m\'e9t l\'b7nh t\'f4, m\'e9t ng\'ad\'eai th\'c7y th\'d7 c\'b8c d\'a9n t\'e9c ph\'ad\'acng \'a7\'abng l\'b9i coi L\'aanin l\'b5 m\'e9t ng\'ad\'eai con v\'dc \'ae\'b9i h\'acn n\'f7a, cao qu\'fd h\'acn n\'f7a, n\'d5u t
\'abi c\'e3 th\'d3 n\'e3i nh\'ad v\'cby.
\par Kh\'abng ph\'b6i ch\'d8 thi\'aan t\'b5i c\'f1a Ng\'ad\'eai, m\'b5 ch\'ddnh l\'b5 t\'ddnh coi khinh s\'f9 xa hoa, tinh th\'c7n y\'aau lao \'ae\'e9ng, \'ae\'eai t\'ad trong s\'b8ng, n\'d5p s\'e8ng gi\'b6n d\'de, t\'e3m l\'b9i l\'b5 \'ae\'b9o \'ae\'f8c v\'dc
 \'ae\'b9i v\'b5 cao \'ae\'d1p c\'f1a ng\'ad\'eai th\'c7y, \'ae\'b7 \'b6nh h\'ad\'ebng l\'edn lao t\'edi c\'b8c d\'a9n t\'e9c ch\'a9u }{\f38\fs20\insrsid1378858 \'b8}{\f37\fs20\insrsid1378858  v\'b5 \'ae\'b7 khi\'d5n cho tr\'b8i tim c\'f1a h\'e4 h\'ad\'ed
ng v\'d2 Ng\'ad\'eai, kh\'abng g\'d7 ng\'a8n c\'b6n n\'e6i.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Quen b\'de \'ae\'e8i x\'f6 nh\'ad nh\'f7ng k\'ce l\'b9c h
\'cbu, th\'cap h\'ccn, c\'b8c d\'a9n t\'e9c ph\'ad\'acng \'a7\'abng \'ae\'b7 coi L\'aanin l\'b5 hi\'d6n th\'a9n c\'f1a t\'d7nh anh em b\'e8n b\'d3. Kh\'abng nh\'f7ng h\'e4 bi\'d5t \'acn Ng\'ad\'eai m\'b5 c\'dfn tha thi\'d5t y\'aau m\'d5n Ng\'ad\'eai. H
\'e4 t\'abn k\'ddnh Ng\'ad\'eai t\'ad\'acng t\'f9 nh\'ad t\'abn k\'ddnh cha m\'d1. C\'e3 th\'cay c\'b8c sinh vi\'aan Tr\'ad\'eang \'ae\'b9i h\'e4c c\'b8c d\'a9n t\'e9c ph\'ad\'acng \'a7\'abng kh\'e3c s\'adng c\'b6 m\'bet, c\'e3 th\'cay c\'b8c ch\'b5ng
 trai tr\'ce \'ae\'e3 n\'f8c n\'eb khi bi\'d5t tin L\'aanin t\'f5 tr\'c7n th\'d7 m\'edi hi\'d3u th\'cau \'ae\'ad\'eec t\'d7nh y\'aau c\'f1a h\'e4 \'ae\'e8i v\'edi Ng\'ad\'eai.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 L\'aanin t\'f5 tr\'c7n, \'ae\'e3 l\'b5 c\'b8
i tang chung cho to\'b5n th\'d5 gi\'edi. Qu\'e8c d\'a9n \'ae\'b6ng}{\f37\fs20\super\insrsid1378858 50}{\f37\fs20\insrsid1378858  (\'ae\'b6ng nh\'a9n d\'a9n, hi\'d6n n\'bem ch\'ddnh quy\'d2n \'eb Hoa Nam) \'aeang h\'e4p \'ae\'b9i h\'e9i th\'d7 \'ae\'ad\'ee
c tin L\'aanin m\'cat. To\'b5n th\'d3 \'ae\'b9i h\'e9i \'ae\'f8ng ngay d\'cby v\'b5 bu\'e6i h\'e4p \'ae\'ad\'eec b\'d5 m\'b9c \'ae\'d3 t\'e1 \'fd \'ae\'d3 tang L\'aanin. Theo \'ae\'d2 ngh\'de c\'f1a b\'b8c s\'dc T\'abn D\'cbt Ti\'aan, Ch\'ddnh ph\'f1 Qu
\'b6ng Ch\'a9u \'ae\'b7 quy\'d5t \'ae\'denh ng\'f5ng c\'b8c cu\'e9c bi\'d3u di\'d4n ngh\'d6 thu\'cbt trong ba ng\'b5y. T\'cat c\'b6 c\'b8c c\'abng s\'eb \'ae\'d2u treo c\'ea r\'f1, c\'b8c \'aeo\'b5n th\'d3 v\'a8n ho\'b8, ch\'ddnh tr\'de, kinh t\'d5 \'eb c
\'b8c \'ae\'dea ph\'ad\'acng v\'b5 \'eb B\'bec Kinh, ch\'f1 y\'d5u l\'b5 c\'b8c h\'e9i sinh vi\'aan v\'b5 c\'b8c t\'e6 ch\'f8c c\'abng nh\'a9n, \'ae\'d2u t\'e6 ch\'f8c m\'e9t c\'b8ch tr\'e4ng th\'d3 l\'d4 truy \'aei\'d6u nh\'b5 c\'b8ch m\'b9ng v\'dc \'ae
\'b9i. C\'f2ng trong d\'dep n\'b5y, c\'b8c \'aeo\'b5n th\'d3 \'cay \'ae\'d2u nh\'cat tr\'dd bi\'d3u quy\'d5t \'ae\'dfi ph\'b6i th\'f5a nh\'cbn ngay l\'cbp t\'f8c ch\'ddnh quy\'d2n x\'abvi\'d5t. Sinh vi\'aan \'ae\'b7 quy\'d5t \'ae\'denh d\'f9ng m\'e9t b
\'f8c t\'ad\'eeng L\'aanin trong c\'abng vi\'aan l\'edn nh\'cat \'eb B\'bec Kinh.
\par Ngh\'de vi\'d6n Trung Qu\'e8c \'ae\'b7 g\'f6i \'aei\'d6n chia bu\'e5n.
\par Ph\'f4 n\'f7 c\'f2ng kh\'e3c th\'ad\'acng L\'aanin. }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  Trung Qu\'e8c, c\'f2ng nh\'ad \'eb t\'cat c\'b6 c\'b8c n\'ad\'edc ph\'ad\'acng \'a7\'abng, ph\'f4 n\'f7 r\'cat \'ddt bi\'d5t nh\'f7ng s\'f9 vi
\'d6c x\'b6y ra tr\'aan th\'d5 gi\'edi, h\'e4 th\'ea \'ac v\'edi nh\'f7ng s\'f9 vi\'d6c \'cay. Nh\'adng h\'e4 \'ae\'b7 \'ae\'d3 tang L\'aanin. Nh\'ad v\'cby l\'b5 nh\'f7ng bi\'d3u hi\'d6n c\'f1a ph\'f4 n\'f7 Trung Qu\'e8c trong ho\'b5n c\'b6nh \'aeau \'ae
\'edn n\'b5y c\'e3 m\'e9t \'fd ngh\'dca l\'dech s\'f6. M\'e9t m\'c6t, \'aei\'d2u \'ae\'e3 ch\'f8ng t\'e1 r\'bbng ph\'f4 n\'f7 ph\'ad\'acng \'a7\'abng \'ae\'b7 th\'f8c t\'d8nh; m\'c6t kh\'b8c, ch\'f8ng t\'e1 r\'bbng ng\'ad\'eai th\'c7y v\'dc \'ae\'b9i \'ae
\'b7 \'ae\'ad\'eec t\'cat c\'b6 m\'e4i ng\'ad\'eai, nam c\'f2ng nh\'ad n\'f7, nh\'f7ng ng\'ad\'eai b\'d7nh th\'ad\'eang nh\'cat c\'f2ng nh\'ad nh\'f7ng ng\'ad\'eai ti\'aan ti\'d5n 
\par nh\'cat, \'ae\'d2u hi\'d3u v\'b5 y\'aau m\'d5n. V\'d7 th\'d5, t\'abi xin d\'dech ra \'ae\'a9y b\'b5i k\'aau g\'e4i c\'f1a m\'e9t n\'f7 sinh vi\'aan, \'ae\'a8ng trong m\'e9t t\'ea b\'b8o ph\'f4 n\'f7 \'eb Th\'ad\'eeng H\'b6i:
\par "H\'eci c\'b8c ch\'de em!
\par }\pard \qj \fi397\li0\ri0\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 T\'f5 khi c\'e3 ch\'f1 ngh\'dca t\'ad b\'b6n, to\'b5n b\'e9 c\'ac th\'d3 x\'b7 h\'e9i \'ae\'d2u b\'de \'b6nh h\'ad\'eb
ng tai h\'b9i c\'f1a n\'e3. C\'b8c v\'cbt ph\'c8m do t\'cat c\'b6 m\'e4i ng\'ad\'eai s\'b6n xu\'cat ra, \'ae\'b8ng l\'cf ph\'b6i thu\'e9c v\'d2 t\'cat c\'b6 m\'e4i ng\'ad\'eai th\'d7 l\'b9i thu\'e9c \'ae\'c6c quy\'d2n c\'f1a m\'e9t v\'b5i ng\'ad\'eai! }{
\f38\fs20\insrsid1378858 \'b8}{\f37\fs20\insrsid1378858 ch \'b8p b\'f8c kinh t\'d5 \'ae\'b7 n\'ab d\'dech con ng\'ad\'eai, c\'f2ng \'b8ch \'b8p b\'f8c \'cay \'ae\'b7 bi\'d5n ph\'f4 n\'f7 th\'b5nh nh\'f7ng \'ae\'e5 v\'cbt tu\'fa thu\'e9c quy\'d2n s\'f6 d
\'f4ng c\'f1a nam gi\'edi!
\par T\'f5 bao th\'d5 k\'fb nay, bao nhi\'aau tri\'d6u con ng\'ad\'eai \'ae\'b7 b\'de xi\'d2ng x\'ddch nh\'ad th\'d5? Bao nhi\'aau tri\'d6u \'ae\'b5n b\'b5 \'ae\'b7 b\'de hy sinh?
\par }{\f37\fs20\expnd0\expndtw-4\insrsid1378858\charrsid13248793 Trong l\'f3c cu\'e9c chi\'d5n tranh th\'d5 gi\'edi \'aeang di\'d4n ra \'b8c li\'d6t, trong l\'f3c h\'b5ng tri\'d6u con ng\'ad\'eai kh\'abng l\'b5m h\'b9i \'ae\'d5n ai, \'aeang mu\'e8n s\'e8
ng, nh\'adng l\'b9i b\'de \'ae\'ada v\'b5o ch\'e7 ch\'d5t, L\'aanin \'ae\'b7 \'ae\'b9p b\'bbng gian kh\'e6 v\'b5 kh\'e3 kh\'a8n, \'ae\'b7}{\f37\fs20\insrsid1378858\charrsid13248793 
\par }\pard\plain \s15\qj \li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd0\expndtw-4\insrsid1378858 th\'f8c t\'d8nh giai c\'cap v\'ab s\'b6n Nga n
\'e6i d\'cby, \'ae\'b7 t\'e6 ch\'f8c c\'b8c x\'abvi\'d5t.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 L\'aanin kh\'abng nh\'f7ng ch\'d8 gi\'b6i ph\'e3ng nam gi
\'edi v\'b5 n\'f7 gi\'edi tr\'aan \'ae\'cat n\'ad\'edc Ti\'aan sinh, m\'b5 c\'dfn ch\'d8 \'ae\'ad\'eang cho t\'cat c\'b6 nh\'f7ng ng\'ad\'eai ngh\'cco kh\'e6 tr\'aan th\'d5 gi\'edi. V\'b5 b\'cat ch\'cap b\'e4n b\'b9ch v\'d6 t\'can c\'abng \'eb b\'aa
n trong, b\'e4n t\'ad b\'b6n bao v\'a9y b\'aan ngo\'b5i, \'fd ch\'dd ki\'aan c\'ad\'eang c\'f1a L\'aanin \'ae\'b7 c\'f8u \'ae\'e5ng b\'b5o c\'f1a Ti\'aan sinh ra kh\'e1i c\'b6nh \'aeau kh\'e6 v\'b5 l\'c7m than, v\'b5 \'ae\'b7 n\'aau cao ng\'e4n c\'ea c
\'f1a Qu\'e8c t\'d5 cho t\'cat c\'b6 nh\'f7ng ng\'ad\'eai b\'de \'b8p b\'f8c.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'a7i\'d2u \'ae\'e3 h\'b8 ch\'bcng \'ae\'b8ng \'ae\'d3 ch\'f3
ng ta k\'ddnh c\'c8n m\'c6c ni\'d6m tr\'ad\'edc anh linh v\'dc \'ae\'b9i c\'f1a Ti\'aan sinh hay sao?
\par }\pard\plain \qj \fi397\li0\ri0\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ng\'b5y 21 th\'b8ng 1 h\'b8 ch\'bcng \'ae\'b8ng m\'b7i m\'b7i l
\'b5 m\'e9t ng\'b5y tang cho t\'cat c\'b6 nh\'f7ng nam n\'f7 \'aeang ch\'deu kh\'e6 c\'f9c hay sao?
\par }\pard \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 N\'ad\'edc Nga \'aeang ti\'d5n \'ae\'d5n ch\'e7 ph\'e5n vinh. Nh\'adng mu\'e8n c\'e3 \'ae\'ad\'eec m\'e9t n\'d2n ho\'b5
 b\'d7nh th\'cbt s\'f9, th\'d7 c\'dfn ph\'b6i ti\'d5n l\'aan h\'acn n\'f7a v\'b5 c\'dfn ph\'b6i l\'b5m nhi\'d2u vi\'d6c h\'acn n\'f7a. Lo\'b5i ng\'ad\'eai \'aeang th\'f8c t\'d8nh; nh\'adng mu\'e8n t\'f9 gi\'b6i ph\'e3ng ho\'b5n to\'b5n, th\'d7 c\'dfn ph
\'b6i \'ae\'cau tranh. Th\'d5 m\'b5 gi\'ea \'ae\'a9y, ng\'ad\'eai th\'c7y \'ae\'e9t ng\'e9t t\'f5 gi\'b7 ch\'f3ng ta, ch\'ada \'ae\'ad\'eec tr\'abng th\'cay k\'d5t qu\'b6 cu\'e8i c\'efng c\'f1a s\'f9 nghi\'d6p c\'f1a m\'d7nh.
\par Nh\'f7ng ng\'ad\'eai c\'e3 t\'a9m huy\'d5t l\'b5m sao m\'b5 c\'e3 th\'d3 c\'c7m \'ae\'ad\'eec n\'ad\'edc m\'bet? Nh\'f7ng ng\'ad\'eai b\'de \'b8p b\'f8c, nam v\'b5 n\'f7, h\'b8 l\'b9i kh\'abng n\'aan nh\'cbn l\'cay nhi\'d6m v\'f4 m\'b5 L\'aanin \'ae\'b7 
\'ae\'d3 l\'b9i v\'b5 ti\'d5n l\'aan hay sao? Ti\'d5n l\'aan!
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'b8c ch\'de em th\'a9n m\'d5n!
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ch\'f3ng ta h\'b7y t\'e6 ch\'f8c truy \'aei\'d6u m\'e9t c
\'b8ch tr\'e4ng th\'d3 Ng\'ad\'eai \'ae\'b7 su\'e8t \'ae\'eai \'ae\'cau tranh ch\'e8ng c\'b6nh c\'efng kh\'e6 v\'b5 \'b8ch \'b8p b\'f8c c\'f1a c\'b8c d\'a9n t\'e9c, Ng\'ad\'eai \'ae\'b7 \'ae\'cau tranh cho th\'d5 gi\'edi \'ae\'d5n h\'aci th\'eb cu\'e8i c
\'efng!".
\par \'a7}{\f37\fs20\expnd0\expndtw-4\insrsid1378858 \'d3 k\'d5t th\'f3c, ch\'f3ng ta h\'b7y ch\'f3 \'fd r\'bbng \'ae\'d3 ch\'d8 L\'aanin, th\'d7 khi n\'e3i hay vi\'d5t, ng\'ad\'eai Trung Qu\'e8c \'ae\'d2u ch\'d8 d\'efng t\'f5 "Ti\'aan sinh", m\'e9t t\'f5
 vinh d\'f9 \'ae\'e5ng ngh\'dca v\'edi "T\'f6" (Kh\'e6ng T\'f6, M\'b9nh T\'f6) v\'b5 c\'e3 ngh\'dca l\'b5: th\'c7y.}{\f37\fs20\insrsid1378858 
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb240\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 NGUY\'d4N \'b8I QU\'e8C
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 Le Paria,}{\insrsid1378858  s\'e8 27,

\par th\'b8ng 7-1924.
