\'e9C \'a7\'deA
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~Trong th\'eai chi\'d5n tranh vinh quang, \'ae\'d3 c\'e3 
\'ae\'ad\'eec nh\'f7ng "t\'d7nh nguy\'d6n qu\'a9n", ng\'ad\'eai ta \'ae\'b7 h\'f8a tr\'eai h\'f8a bi\'d3n v\'edi d\'a9n b\'b6n x\'f8. Chi\'d5n tranh h\'d5t, nh\'f7ng l\'eai h\'f8a trang tr\'e4ng \'cay c\'f2ng \'ae\'ad\'eec trang tr\'e4ng qu\'aan \'aei.

\par Trong k\'fa c\'abng tr\'b8i tr\'ad\'edc l\'c7n cu\'e8i - c\'abng tr\'b8i m\'b5 d\'a9n b\'b6n x\'f8 h\'ad\'ebng \'f8ng "m\'e9t c\'b8ch t\'f9 nguy\'d6n v\'edi m\'e9t t\'cam l\'dfng s\'e8t s\'beng v\'b5 ph\'can kh\'ebi" \'ae\'d5n n\'e7i ph\'b6i \'ae\'e3ng k
\'d0t l\'b9i tr\'ad\'edc th\'eai h\'b9n v\'d7 \'ae\'b7 \'ae\'ad\'eec g\'cap hai l\'c7n r\'ad\'eci s\'e8 ti\'d2n d\'f9 \'ae\'denh. \'a7\'e8i v\'edi l\'c7n c\'abng tr\'b8i n\'b5y, ngo\'b5i nh\'f7ng bi\'d6n ph\'b8p th\'f3c \'d0p, ng\'ad\'eai ta c\'dfn h\'f8
a v\'edi nh\'f7ng ng\'ad\'eai mua, ph\'c8m h\'b5m, ho\'b5n ti\'d2n d\'d4 d\'b5ng, v\'b5 h\'b5ng l\'ab c\'b8i kh\'b8c n\'f7a.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'a9y gi\'ea, khi l\'dfng trung th\'b5nh \'ae\'b7 \'ae\'ad
\'eec ch\'f8ng t\'e1, nh\'f7ng ng\'ad\'eai mua c\'abng tr\'b8i tr\'eb th\'b5nh ng\'ad\'eai d\'b9i d\'e9t. Kh\'abng nh\'f7ng c\'b8c c\'ac quan t\'b5i ch\'ddnh kh\'abng nh\'cbn mua l\'b9i tr\'b8i phi\'d5u m\'b5 c\'dfn t\'f5 ch\'e8i c\'b6 vi\'d6c c\'c7m c
\'e8 tr\'b8i phi\'d5u. Th\'d5 \'ae\'e3, nh\'f7ng vi\'d6c t\'e8t tr\'eb th\'b5nh x\'cau! C\'dfn v\'d2 nh\'f7ng ph\'c8m h\'b5m v\'b5 s\'bec phong cao qu\'fd kh\'b8c th\'d7 xin ki\'d5u!
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\expnd0\expndtw-4\insrsid1378858 C\'dfn n\'f7a, mu\'e8n l\'dcnh \'ae\'ad
\'eec nh\'f7ng tr\'b8i phi\'d5u \'ae\'b7 }{\i\f37\fs20\expnd0\expndtw-4\insrsid1378858 ho\'b5n to\'b5n qu\'b8 h\'b9n tr\'b6}{\f37\fs20\expnd0\expndtw-4\insrsid1378858 , ng\'ad\'eai ch\'f1 phi\'d5u c\'dfn b\'bet bu\'e9c ph\'b6i xu\'cat tr\'d7nh th\'ce thu
\'d5 th\'a9n.
\par }{\f37\fs20\insrsid1378858 Ch\'f3ng ta c\'e3 n\'aan ph\'b5n n\'b5n cho 72.177 k\'ce "kh\'e8n kh\'e6"}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0
\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) T\'b8c gi\'b6 ch\'aci ch\'f7 }{\i\insrsid1378858 pauvre}{\insrsid1378858  c\'e3 ngh\'dca l\'b5 ngh\'cco, n\'d5
u \'ae\'c6t sau danh t\'f5, nh\'adng c\'e3 ngh\'dca l\'b5 \'ae\'b8ng th\'ad\'acng n\'d5u \'ae\'c6t tr\'ad\'edc danh t\'f5. T\'b8c gi\'b6 \'ae\'c6t ch\'f7 }{\i\insrsid1378858 "pauvre"}{\insrsid1378858  trong ngo\'c6c k\'d0p \'ae\'d3 ch\'aci c\'b6 hai ngh
\'dca.}})}{\f37\fs20\insrsid1378858  l\'b5 \'ae\'e5ng b\'b5o c\'f1a ch\'f3ng ta \'ae\'b7 mua c\'abng tr\'b8i hay kh\'abng ? Tr\'ad\'edc khi tr\'b6 l\'eai c\'a9u h\'e1i n\'b5y, ch\'f3ng ta h\'b7y t\'f9 h\'e1i xem vi\'d6c n\'b5y, n\'d5u ph\'b6i l\'b5 m\'e9
t vi\'d6c c\'e3 \'ddch th\'cbt, m\'b5 kh\'abng c\'abng b\'e8 l\'b5 c\'f1a nh\'b5 n\'ad\'edc, kh\'abng tuy\'aan truy\'d2n, ch\'bcng qu\'b6ng c\'b8o, th\'d7 li\'d6u c\'e3 bao nhi\'aau \'ae\'e5ng b\'b5o h\'b5o hi\'d6p n\'b5y c\'f1a ch\'f3ng ta ch\'deu nh\'b6
 ra m\'e9t xu?
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 S\'f9 th\'abng minh t\'ddnh to\'b8n c\'f1a \'ae\'b8m "d\'b7 d\'a9n" c\'f2ng ch\'bcng l\'d0p g\'d7 so v\'edi t\'b5i lo
\'cc b\'dep h\'f8a h\'d1n c\'f1a gi\'edi "n\'bem quy\'d2n".
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 N.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par T.B. Ph\'f1 To\'b5n quy\'d2n \'a7\'abng D\'ad\'acng s\'bep \'ae\'ad\'eec ph\'d0p ph\'b8t h\'b5nh \'ae\'eet hai c\'abng tr\'b8i 90.000.000 phr\'a8ng. Kh\'d0o \'ae\'cay, anh em \'aci!
\par 
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 Le Paria}{\insrsid1378858 , s\'e8 11,

\par ng\'b5y 1-2-1923.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par 
