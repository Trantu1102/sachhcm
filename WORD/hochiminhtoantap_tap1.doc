\par 
\par 
\par 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa380\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 H\'b7Y Y\'a3U M\'d5N N\'a6\'edC PH\'b8P,\line NG\'a6
\'eaI B\'b6O H\'e9 C\'b8C ANH
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i\f37\fs20\insrsid1378858 H\'b7y y\'aau m\'d5n n\'ad\'edc Ph\'b8p, ng\'ad\'eai b
\'b6o h\'e9 c\'b8c anh.
\par }{\f37\fs20\insrsid1378858 \'a7\'e3 l\'b5 b\'b5i t\'cbp vi\'d5t m\'b5 ng\'ad\'eai ta d\'b9y ch\'f3ng t\'abi vi\'d5t ki\'d3u ch\'f7 r\'abng}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0
\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) Ronde.
\par 2) B\'a9tarde.}})}{\f37\fs20\insrsid1378858 , ki\'d3u n\'f6a gi\'e8ng ch\'f7 r\'abng v\'b5 n\'f6a gi\'e8ng ch\'f7 Anh}{\f37\fs20\super\insrsid1378858 2)}{\f37\fs20\insrsid1378858 , ki\'d3u ch\'f7 g\'abt\'ddch t\'f5 l\'edp ABC cho \'ae\'d5n b\'cbc ti\'d3
u h\'e4c trong nh\'f7ng tr\'ad\'eang h\'e4c hi\'d5m c\'e3 \'eb \'a7\'abng D\'ad\'acng. Nh\'f7ng tr\'ad\'eang h\'e4c hi\'d5m c\'e3 n\'b5y \'ae\'d5n m\'f8c ph\'b6i h\'acn m\'e9t tr\'a8m qu\'b8n r\'ad\'eeu v\'b5 thu\'e8c phi\'d6n m\'edi c\'e3 m\'e9t tr\'ad
\'eang h\'e4c. C\'b8c nh\'b5 khai ho\'b8 c\'f1a ch\'f3ng ta ki\'d5m \'ae\'ad\'eec tr\'aan 21.000.000 \'ae\'e5ng b\'b9c \'a7\'abng D\'ad\'acng, t\'f8c l\'b5 h\'acn 139.000.000 phr\'a8ng b\'bbng c\'b8ch b\'b8n c\'b8c ch\'cat \'ae\'e9c n\'b5y. C\'b8c anh c
\'e3 bi\'d5t h\'e4 chi cho gi\'b8o d\'f4c trong m\'e9t n\'a8m l\'b5 bao nhi\'aau kh\'abng? 172.000 \'ae\'e5ng b\'b9c \'a7\'abng D\'ad\'acng!
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 D\'dfng ch\'f7 }{\i\insrsid1378858 H\'b7y y\'aau m\'d5n n
\'ad\'edc Ph\'b8p, ng\'ad\'eai b\'b6o h\'e9 c\'b8c anh }{\insrsid1378858 \'ae\'ad\'eec vi\'d5t b\'bbng ch\'f7 to m\'b5u tr\'beng tr\'aan n\'d2n \'aeen c\'f1a m\'e9t t\'cam c\'b8c t\'abng ch\'b9y d\'b5i d\'bbng d\'c6c, treo trong t\'cat c\'b6 c\'b8c l\'ed
p h\'e4c, c\'f8 \'b8m \'b6nh ch\'f3ng t\'abi m\'e9t c\'b8ch \'aam \'b8i. Sung s\'ad\'edng thay cho nh\'f7ng c\'b8i \'ae\'c7u An Nam nh\'e1 b\'d0 \'ae\'ad\'eec chi\'aam ng\'ad\'ecng nh\'f7ng d\'dfng ch\'f7 y\'aau n\'ad\'edc n\'b5y, \'ae\'ad\'acng nhi\'aa
n l\'b5 y\'aau n\'ad\'edc v\'edi nh\'f7ng k\'ce \'aei nh\'e5i s\'e4 v\'b5 b\'bet bu\'e9c ph\'b6n qu\'e8c \'ae\'e8i v\'edi nh\'f7ng ng\'ad\'eai b\'de nh\'e5i s\'e4.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 T\'abi nh\'ed t\'edi nh\'f7ng ng\'ad\'eai anh em h\'e4 t
\'abi mu\'e8n v\'b5o m\'e9t trong nh\'f7ng thi\'aan \'ae\'ad\'eang tr\'ad\'eang h\'e4c, \'ae\'b7 ph\'b6i ch\'b9y ch\'e4t \'ae\'f1 ki\'d3u, g\'f6i h\'d5t \'ae\'acn n\'b5y \'ae\'d5n \'ae\'acn kh\'b8c cho quan kh\'a9m s\'f8, quan c\'abng s\'f8, cho quan gi
\'b8m \'ae\'e8c tr\'ad\'eang qu\'e8c h\'e4c v\'b5 cho th\'b5y gi\'b8o ch\'ddnh c\'f1a tr\'ad\'eang ti\'d3u h\'e4c. \'a7\'ad\'acng nhi\'aan l\'b5 anh ch\'bcng nh\'cbn \'ae\'ad\'eec m\'e9t s\'f9 ph\'f3c \'ae\'b8p n\'b5o. M\'e9t h\'abm, anh \'ae\'b8nh b\'b9
o \'ae\'d5n m\'f8c \'ae\'ddch th\'a9n mang \'ae\'acn vi\'d5t cho th\'c7y gi\'b8o ch\'ddnh, m\'e9t ng\'ad\'eai Ph\'b8p, \'eb tr\'ad\'eang m\'b5 t\'abi \'ae\'b7 \'ae\'ad\'eec \'ae\'c6c \'a9n h\'e4c tr\'ad\'edc \'ae\'e3 \'ddt l\'a9u. Quan \'ae\'e8c c\'f1a ch
\'f3ng ta th\'cay anh c\'b6 gan nh\'ad th\'d5, li\'d2n qu\'b8t l\'aan: "Ai cho ph\'d0p m\'b5y t\'edi \'ae\'a9y?" r\'e5i x\'d0 v\'f4n l\'b8 \'ae\'acn tr\'ad\'edc nh\'f7ng c\'c6p m\'bet ng\'ac ng\'b8c c\'f1a c\'b6 l\'edp h\'e4c.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 \'a7i\'d2u \'ae\'e3 n\'e3i cho anh bi\'d5t c\'b8i ng\'ad\'eai cai tr\'de ch\'f3ng ta truy\'d2n b\'b8 n\'d2n gi\'b8o d
\'f4c v\'ab th\'c7n v\'b5 nguy\'aan l\'fd c\'e9ng ho\'b5 trong c\'b8c thu\'e9c \'ae\'dea nh\'ad th\'d5 n\'b5o.
\par Ch\'f3ng ta \'ae\'b7 t\'f5ng bi\'d5t nh\'f7ng ng\'ad\'eai m\'b5 n\'ad\'edc Ph\'b8p g\'f6i sang \'a7\'abng D\'ad\'acng \'ae\'d3 d\'b9y cho ng\'ad\'eai An Nam y\'aau m\'d5n n\'ad\'edc Ph\'b8p, y\'aau m\'d5n [sic] n\'ad\'edc Ph\'b8p nh\'ad nh\'f7ng \'ae\'f8
a tr\'ce y\'aau m\'d5n m\'d1 n\'e3, b\'ebi v\'d7, n\'ad\'edc Ph\'b8p l\'b5 t\'e6 qu\'e8c th\'f8 hai c\'f1a to\'b5n c\'c7u, l\'b5 "n\'ad\'edc M\'d1" c\'f1a ng\'ad\'eai An Nam, c\'e3 ph\'b6i th\'d5 kh\'abng?
\par Nh\'cbt k\'fd h\'b5nh qu\'a9n c\'f1a m\'e9t t\'aan th\'f9c d\'a9n k\'d3 l\'b9i v\'edi ch\'f3ng ta: "Sau khi chi\'d5m \'ae\'ad\'eec ch\'ee M\'edi, v\'b5o bu\'e6i chi\'d2u, m\'e9t s\'dc quan c\'f1a ti\'d3u
\par  \'aeo\'b5n l\'ddnh Phi tr\'abng th\'cay m\'e9t ng\'ad\'eai ch\'a9u }{\f38\fs20\insrsid1378858 \'b8}{\f37\fs20\insrsid1378858  b\'de b\'bet l\'b5m t\'ef, c\'dfn s\'e8ng, kh\'abng c\'e3 th\'ad\'acng t\'ddch g\'d7. Bu\'e6i s\'b8ng ng\'b5y h\'abm sau, ng\'ad
\'eai s\'dc quan nh\'d7n th\'cay ng\'ad\'eai \'cay ch\'d5t, b\'de \'ae\'e8t ch\'b8y, \'ae\'b7 ch\'ddn, m\'ec ch\'b6y ra, da b\'f4ng tr\'ad\'acng ph\'e5ng l\'aan, s\'d0m v\'b5ng. B\'e4n l\'ddnh \'ae\'b7 th\'f8c su\'e8t \'ae\'aam \'ae\'d3 quay ch\'dd
n con ng\'ad\'eai \'ae\'b7 b\'de t\'ad\'edc m\'cat v\'f2 kh\'dd, trong khi nh\'f7ng t\'aan kh\'b8c h\'b5nh h\'b9 m\'e9t ph\'f4 n\'f7.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 "M\'e9t t\'aan l\'ddnh mu\'e8n b\'bet m\'e9t ph\'f4 n\'f7
 An Nam ph\'b6i hi\'d5n th\'a9n cho ch\'e3 c\'f1a n\'e3. Ng\'ad\'eai ph\'f4 n\'f7 \'cay kh\'abng ch\'deu, li\'d2n b\'de \'ae\'a9m ch\'d5t b\'bbng m\'e9t nh\'b8t l\'ad\'eci l\'aa v\'b5o b\'f4ng".
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \'a4i! n\'ad\'edc Ph\'b8p, n\'d5u ng\'ad\'eai bi\'d5t ch
\'f3ng t\'abi \'ae\'ad\'eec che ch\'eb nh\'ad th\'d5 n\'b5o, ng\'ad\'eai s\'cf ki\'aau h\'b7nh l\'b5 nh\'f7ng k\'ce b\'b6o h\'e9 ch\'f3ng t\'abi.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~NGUY\'d4N A.Q.
\par }\pard\plain \ql \li0\ri0\sa80\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 B\'b8o }{\i\f37\fs18\insrsid1378858 Le Libertaire,}{
\f37\fs18\insrsid1378858 \line ng\'b5y 7 - 14-10-1921.}{\f37\fs20\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \line \line \line \line R\'f1I RO
\par }\pard\plain \s25\qc \li0\ri0\sb120\sa480\sl-340\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs22\insrsid1378858 C\'b6NH SINH HO\'b9T\line C\'f1A TH\'ee THUY\'d2
N AN NAM}{\insrsid1378858 
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-288\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~N\'e3ng b\'f8c! M\'e9t c\'b8i n\'e3ng b\'f8c m\'b5 ch
\'d8 ch\'f3ng t\'abi, nh\'f7ng ng\'ad\'eai Nam K\'fa v\'b5 nh\'f7ng ng\'ad\'eai h\'a9n h\'b9nh \'ae\'ad\'eec \'abng Ut\'acr\'a9y b\'b6o h\'e9, m\'edi \'ae\'ad\'eec \'ae\'c6c \'a9n h\'ad\'ebng th\'f4. M\'c6t tr\'eai n\'beng \'ae\'e6 h\'e9t. C\'b8c b\'b9n c
\'e3 bi\'d5t m\'c6t tr\'eai \'ae\'e6 h\'e9t l\'b5 g\'d7 kh\'abng? Trong ph\'ad\'acng ng\'f7 c\'f1a ch\'f3ng t\'abi, \'aei\'d2u \'ae\'e3 c\'e3 ngh\'dca l\'b5 t\'b8c \'ae\'e9ng c\'f1a n\'e3ng b\'f8c d\'f7 d\'e9i \'ae\'d5n m\'f8c m\'b5 lu\'abn lu\'abn b\'b9
n th\'cay tr\'ad\'edc m\'bet c\'e3 m\'e9t c\'b8i g\'d7 r\'aci nh\'ad m\'ada nh\'adng \'ae\'b8ng l\'cf l\'b5 n\'ad\'edc th\'d7 l\'b5 nh\'f7ng h\'b9t l\'f6a.
\par C\'b8c v\'b8ch t\'ad\'eang c\'f1a nh\'b5 th\'ea S\'b5i G\'dfn n\'e3ng b\'e1ng l\'aan nh\'ad nh\'f7ng m\'b6ng t\'ad\'eang c\'f1a \'ae\'dea ng\'f4c. C\'e9t thi\'aan l\'abi \'b8nh l\'aan nh\'ad m\'e9t l\'ad\'eci l\'aa v\'cay m\'b8u v\'b5 s\'bdn s\'b5ng xuy
\'aan th\'f1ng da tr\'eai b\'de n\'cau ch\'ddn theo ngh\'dca \'aeen c\'f1a t\'f5.
\par T\'f5 s\'b8ng \'ae\'d5n gi\'ea ch\'bcng c\'e3 m\'e9t ng\'ad\'eai kh\'b8ch n\'b5o! T\'abi \'ae\'b7 \'ae\'e3i v\'b5 t\'abi u\'e8n m\'d7nh kh\'e3 kh\'a8n trong khung h\'d7nh ch\'f7 nh\'cbt h\'eep th\'b5nh c\'b8i \'b8ch cho con v\'cbt - h\'d7nh ng\'ad\'eai l
\'b5 ng\'ad\'eai k\'d0o xe tay. Hai g\'e4ng c\'f1a chi\'d5c xe \'ae\'cc n\'c6ng l\'aan c\'b8nh tay t\'abi v\'b5 b\'b8nh xe th\'d7 k\'aau r\'aan r\'d8 nh\'ad th\'d3 ch\'f3ng kh\'b8t n\'ad\'edc.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-288\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'abi v\'b5 chi\'d5c xe c\'f1a t\'abi ti\'d5p t\'f4c k\'d0
o nhau v\'d2 h\'ad\'edng Dinh Th\'e8ng \'ae\'e8c. Nh\'f7ng l\'b8 b\'b5ng r\'e9ng b\'b6n v\'b5 l\'b8 cau l\'b5m th\'b5nh nh\'f7ng t\'cam g\'ad\'acng ph\'b6n chi\'d5u t\'cbp trung to\'b5n b\'e9 s\'f8c m\'b9nh c\'f1a m\'c6t tr\'eai \'ae\'d5n ng\'ad\'eai \'ae
i \'ae\'ad\'eang. Ng\'ad\'eai ta c\'f8 t\'ad\'ebng to\'b5n b\'e9 v\'f2 tr\'f4 \'ae\'b7 bi\'d5n th\'b5nh m\'e9t l\'df ho\'b6 t\'b8ng.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Hai hay ba ng\'ad\'eai da tr\'beng c\'e3 m\'c6t tr\'aan qu
\'b6ng tr\'ad\'eang; h\'e4 l\'b5 nh\'f7ng ng\'ad\'eai da tr\'beng duy nh\'cat c\'e3 c\'b6m t\'d7nh v\'edi ng\'ad\'eai b\'b6n x\'f8, b\'ebi v\'d7 h\'e4 l\'b5 ng\'ad\'eai b\'bbng \'ae\'e5ng; nh\'adng l\'b9i l\'b5 nh\'f7ng kh\'b8ch h\'b5ng t\'e5i v\'d7 h\'e4
 ch\'bcng bao gi\'ea \'aei xe k\'d0o!
\par T\'abi th\'cay m\'e9t b\'e3ng ng\'ad\'eai \'aei ra kh\'e1i dinh. T\'abi t\'f9 nh\'f1: "M\'e9t ng\'ad\'eai ra kh\'e1i nh\'b5 h\'e9p n\'b5y ch\'bec ph\'b6i l\'b5 m\'e9t ng\'ad\'eai l\'dech s\'f9, m\'b5 m\'e9t ng\'ad\'eai l\'dech s\'f9 th\'d7 kh\'abng \'ae
i b\'e9 d\'ad\'edi tr\'eai n\'beng th\'d5 n\'b5y; \'abng ta s\'cf \'aei xe; v\'b5 \'abng ta s\'cf l\'b5 kh\'b8ch h\'b5ng c\'f1a t\'abi. Khi t\'abi th\'cay \'b8o \'aeen c\'f1a \'abng ta, t\'abi c\'b5ng l\'b9c quan v\'d7 t\'abi cho \'ae\'e3 l\'b5 m\'e9t th
\'c7y th\'abng}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {
\insrsid1378858 1) Hai ch\'f7  "th\'c7y th\'abng" trong nguy\'aan b\'b6n vi\'d5t b\'bbng ti\'d5ng Vi\'d6t.}})}{\f37\fs20\insrsid1378858  (M\'e9t ng\'ad\'eai th\'abng ng\'abn An Nam). T\'abi ch\'b9y \'ae\'d5n \'ae\'e3n \'abng ta. \'a7\'e3 l\'b5 m\'e9t cha 
\'ae\'b9o, m\'e9t cha \'ae\'b9o \'ae\'b8ng k\'ddnh.
\par T\'abi c\'f3i ng\'ad\'eai xu\'e8ng ch\'a9n \'abng ta \'ae\'d3 \'abng ta c\'e3 th\'d3 l\'aan xe d\'d4 d\'b5ng h\'acn, \'ae\'e3 l\'b5 c\'b8ch thanh l\'dech \'ae\'d3 \'ae\'e3n kh\'b8ch. \'a7\'b8ng l\'cf \'ae\'c6t ch\'a9n l\'aan b\'d6 xe, con ng\'ad\'eai th
\'b8nh thi\'d6n l\'b9i mu\'e8n \'ae\'c6t ch\'a9n l\'aan m\'abng t\'abi. T\'abi hi\'d3u ngay c\'f6 ch\'d8 \'cay, v\'d7 t\'abi \'ae\'b7 quen v\'edi nh\'f7ng ng\'ad\'eai hi\'d2n nh\'ad th\'d5 r\'e5i; v\'b5 t\'abi b\'e1 ch\'b9y v\'edi chi\'d5c xe k\'d0o c\'f1
a t\'abi; t\'abi v\'e8n \'ae\'b7 quen v\'edi nh\'f7ng tr\'df nh\'b5o l\'e9n n\'b5y r\'e5i, ngh\'d2 nghi\'d6p bu\'e9c t\'abi nh\'ad th\'d5. Trong khi ch\'b9y ra xa, t\'abi c\'dfn nghe v\'de con c\'f1a Ch\'f3a tr\'eai l\'c8m b\'c8m c\'a9u kinh ng\'c9u h\'f8
ng: "Kh\'e8n ki\'d5p! v\'de t\'abng \'ae\'e5 n\'e3i - ng\'ad\'eai ta kh\'abng th\'d3 b\'ad\'edc \'aei m\'e9t b\'ad\'edc m\'b5 kh\'abng b\'de b\'e4n xe k\'d0o t\'e5i t\'b5n n\'b5y qu\'cay r\'c7y!"
\par S\'f9 c\'e8 n\'b5y l\'b5m t\'abi qu\'aan c\'b6 m\'d6t m\'e1i, c\'b6 \'ae\'e3i kh\'b8t, v\'d7 sau khi \'ae\'b9t \'ae\'ad\'eec kho\'b6ng c\'b8ch kh\'b8 xa gi\'f7a "cha t\'abi" v\'b5 t\'abi, t\'abi \'ae\'efa c\'eet, ngh\'dc \'ae\'d5n Ch\'f3a, \'ae\'d5n h\'d7
nh \'b6nh con ng\'ad\'eai, t\'f8c l\'b5 \'ae\'d5n ng\'ad\'eai n\'e4 v\'b5 t\'abn gi\'b8o c\'f1a anh ta. Khi t\'abi quay \'ae\'c7u l\'b9i th\'d7 th\'cay g\'cby t\'abng \'ae\'e5 v\'c9n c\'dfn ti\'d5p t\'f4c d\'f8 d\'f8 v\'d2 ph\'dda t\'abi nh\'ad m\'e9
t que r\'b6y n\'ad\'edc ph\'d0p.
\par T\'abi \'aei, hay \'ae\'f3ng h\'acn, ch\'f3ng t\'abi, chi\'d5c xe v\'b5 t\'abi, \'aei v\'d2 b\'d5n \'ae\'df. 
\par T\'f5 trong c\'b8i qu\'b8n b\'d0 t\'d1o c\'f1a b\'b5 Th\'de Hai}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) Hai ch\'f7 "Th\'de Hai" trong nguy\'aan b\'b6n vi\'d5t b\'bbng ti\'d5ng Vi\'d6t.
\par 2) }{\i\insrsid1378858 Trois nauds \'b5 l'heure.}{\insrsid1378858 
\par 3) Th\'cbt ra, \'ae\'a9y l\'b5 v\'a8n ph\'c8m s\'b8ng t\'b8c c\'f1a Nguy\'d4n }{\f38\insrsid1378858 \'b8}{\insrsid1378858 i Qu\'e8c.}})}{\f37\fs20\insrsid1378858  to\'b8t l\'aan m\'e9t kh\'abng kh\'dd h\'b9nh ph\'f3c v\'b5 sung t\'f3c. G\'b9o tr\'beng nh
\'ad ng\'b5, n\'ad\'edc m\'bem to\'b6 ra m\'e9t h\'ad\'acng th\'acm ng\'b5o ng\'b9t l\'b5m kho\'b8i m\'f2i. N\'ad\'edc ch\'cc s\'abi s\'efng s\'f4c tr\'aan b\'d5p. Th\'cbt l\'b5 h\'cap d\'c9n. T\'abi d\'f5ng l\'b9i, quy\'d5t \'ae\'denh mua m\'e9t b\'b8t c
\'acm ngon, bi\'d5t r\'bbng b\'b5 Th\'de Hai t\'e8t b\'f4ng kh\'abng n\'ec t\'f5 ch\'e8i b\'b8n ch\'deu cho m\'e9t ng\'ad\'eai th\'ee l\'ad\'acng thi\'d6n.
\par V\'f5a m\'edi ng\'e5i l\'aan chi\'d5u, t\'abi th\'cay m\'e9t ng\'ad\'eai l\'ddnh thu\'fb \'aei ngo\'bbn ngo\'cco tr\'aan b\'d5n t\'b5u c\'f1a h\'b7ng S\'b8cgi\'ac R\'aauyni. Bu\'abng \'ae\'f2a xu\'e8ng, t\'abi nh\'b6y ra xe v\'b5 b\'bbng hai b\'ad\'edc ch
\'a9n, t\'abi \'ae\'b7 \'ae\'f8ng tr\'ad\'edc v\'de kh\'b8ch h\'b5ng th\'f8 hai c\'f1a t\'abi s\'b8ng nay. \'a7\'e3 l\'b5 m\'e9t ng\'ad\'eai t\'e8t b\'f4ng, anh ta ch\'bcng h\'d2 m\'c6c c\'b6 gi\'b8 c\'b6. Anh ta n\'d0m cho t\'abi \'ae\'dea ch\'d8 n\'aci 
\'ae\'d5n r\'e5i l\'aan xe v\'b5 ng\'e5i ch\'d4m ch\'d6 b\'aan m\'b9n ph\'b6i, c\'dfn g\'e3i \'ae\'e5 \'ae\'b9c th\'d7 \'ae\'d3 b\'aan tay tr\'b8i. T\'abi ch\'b9y nh\'f7ng ba h\'b6i l\'fd/gi\'ea}{\f37\fs20\super\insrsid1378858 2)}{
\f37\fs20\insrsid1378858 , v\'d7 kh\'abng mu\'e8n Th\'de Hai ph\'b6i ng\'e3ng ch\'ea.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd0\expndtw-4\insrsid1378858 \'a7\'d5n c\'b6ng, t\'aan thu\'fb th\'f1 l
\'b7o luy\'d6n l\'aan b\'ea v\'b5 b\'e1 \'aei, t\'d8nh b\'ac, ch\'bcng h\'d2 c\'e3 \'fd \'ae\'denh tr\'b6 th\'ef lao cho t\'abi. T\'abi y\'aau s\'b8ch. H\'ben ch\'bcng th\'ccm quay l\'b9i. T\'abi ch\'b9y theo h\'ben v\'b5 h\'d0t l\'aan: "Tr\'b6 ti\'d2n, 
\'abng \'aci, tr\'b6 ti\'d2n!"
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 H\'ben chuy\'d3n g\'e3i \'ae\'e5 qua b\'aan tr\'b8
i, tay ph\'b6i th\'df v\'b5o t\'f3i v\'b5 r\'f3t ra m\'e9t... kh\'c8u s\'f3ng l\'f4c. V\'f2 kh\'dd c\'f1a v\'a8n minh h\'efng h\'e5n th\'d0t l\'aan: Pan! Pan! "L\'b9i m\'e9t c\'f3 n\'f7a x\'abi h\'e1ng b\'e1ng kh\'abng!", t\'abi t\'f9 nh\'f1.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'abi tr\'eb l\'b9i qu\'b8n \'a8n, ch\'cc v\'c9n c\'dfn 
\'aeang b\'e8c kh\'e3i.
\par }\pard\plain \s24\ql \li3969\ri283\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin283\lin3969\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 CULIXE\line }{\i\f37\insrsid1378858 Nguy\'d4n }{
