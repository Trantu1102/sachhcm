\par 
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \column 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 TH\'a6 G\'f6I TRUNG \'a6\'a5NG\line \'a7\'b6NG C\'e9
NG S\'b6N PH\'b8P
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i\f37\fs20\insrsid1378858 C\'b8c \'ae\'e5ng ch\'dd,
\par }{\f37\fs20\insrsid1378858 Nh\'f7ng ngh\'de quy\'d5t c\'f1a \'a7\'b9i h\'e9i l\'c7n th\'f8 II c\'f1a Qu\'e8c t\'d5}{\f37\fs20\super\insrsid1378858 35}{\f37\fs20\insrsid1378858  v\'d2 v\'can \'ae\'d2 thu\'e9c \'ae\'dea \'ae\'b7 mang l\'b9i hai t\'b8c d\'f4
ng \'ae\'e5ng th\'eai nh\'adng l\'b9i ho\'b5n to\'b5n tr\'b8i ng\'ad\'eec nhau. M\'e9t m\'c6t, ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c \'aei \'b8p b\'f8c - ng\'f5a tr\'ad\'edc nh\'f7ng k\'d5t qu\'b6 c\'e3 th\'d3 x\'b6y ra c\'f1a ch\'ddnh s\'b8ch \'ae\'e3 n\'d5
u n\'e3 \'ae\'ad\'eec thi h\'b5nh nghi\'aam t\'f3c - \'ae\'b7 \'ae\'d2 ph\'dfng v\'b5 t\'a8ng g\'cap b\'e9i nh\'f7ng ho\'b9t \'ae\'e9ng tuy\'aan truy\'d2n, ngu d\'a9n v\'b5 \'ae\'b5n \'b8p. M\'c6t kh\'b8c, nh\'a9n d\'a9n b\'de \'b8p 
\par b\'f8c \'eb c\'b8c thu\'e9c \'ae\'dea, \'ae\'ad\'eec ti\'d5ng vang c\'f1a c\'b8ch m\'b9ng th\'f8c t\'d8nh, \'ae\'b7 h\'ad\'edng theo b\'b6n n\'a8ng c\'f1a h\'e4 v\'d2 Qu\'e8c t\'d5 c\'f1a ch\'f3ng ta, m\'e9t ch\'ddnh \'ae\'b6ng duy nh\'cat m\'b5 h\'e4
 hy v\'e4ng l\'b5 s\'cf quan t\'a9m \'ae\'d5n h\'e4 m\'e9t c\'b8ch th\'a9n thi\'d5t, m\'b5 h\'e4 ho\'b5n to\'b5n mong m\'e1i l\'b5 s\'cf mang l\'b9i cho h\'e4 s\'f9 gi\'b6i ph\'e3ng. Nh\'ad v\'cby, ch\'f3ng ta s\'cf c\'e3 th\'d3 kh\'abng nh\'f7ng \'ae\'b8
nh \'ae\'e6 uy th\'d5 c\'f1a ch\'f1 ngh\'dca th\'f9c d\'a9n b\'e3c l\'e9t v\'b5 lay chuy\'d3n v\'de tr\'dd c\'f1a ch\'f3ng, m\'b5 c\'dfn c\'e3 th\'d3 bi\'d5n m\'e8i c\'b6m t\'d7nh thu\'c7n tu\'fd t\'d7nh c\'b6m v\'b5 th\'f4 \'ae\'e9ng c\'f1a c\'b8c d\'a9
n t\'e9c thu\'e9c \'ae\'dea \'ae\'e8i v\'edi ch\'f3ng ta th\'b5nh m\'e8i c\'b6m t\'d7nh h\'b5nh \'ae\'e9n}{\f37\fs20\expnd0\expndtw-2\insrsid1378858 g, n\'d5u nh\'f7ng ngh\'de quy\'d5t c\'f1a Qu\'e8c t\'d5 \'ae\'ad\'eec ch\'cap h\'b5nh. Kh\'e8n n\'e7
i cho \'ae\'d5n nay, nh\'f7ng ngh\'de quy\'d5t \'cay ch\'d8 \'ae\'ad\'eec d\'efng \'ae\'d3 t\'ab \'aei\'d3m m\'c6t gi\'cay! Ph\'a9n b\'e9 Ph\'b8p, ph\'a9n b\'e9 Anh v\'b5 nh\'f7ng ph\'a9n b\'e9 c\'b8c n\'ad\'edc th\'f9c d\'a9n kh\'b8c \'ae\'b7 l\'b5m g
\'d7 cho c\'b8c thu\'e9c \'ae\'dea c\'f1a ch\'f1 ngh\'dca t\'ad b\'b6n n\'ad\'edc h\'e4? Nh\'f7ng ph\'a9n b\'e9 \'cay \'ae\'b7 c\'e3 m\'e9t ch\'ddnh s\'b8ch thu\'e9c \'ae\'dea v\'b5 m\'e9t c\'ad\'acng l\'dcnh r\'e2 r\'d6t v\'d2 thu\'e9c \'ae\'dea, ch\'dd
nh x\'b8c v\'b5 li\'aan t\'f4c ch\'ada? Nh\'f7ng chi\'d5n s\'dc c\'f1a c\'b8c ph\'a9n b\'e9 \'cay c\'e3 hi\'d3u thu\'e9c \'ae\'dea l\'b5 g\'d7 v\'b5 t\'c7m quan tr\'e4ng c\'f1a thu\'e9c
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\expnd0\expndtw-2\insrsid1378858 \'ae\'dea l\'b5 nh\'ad th\'d5 n\'b5o kh\'ab
ng? Ng\'ad\'eai ta c\'e3 th\'d3 tr\'b6 l\'eai l\'b5 kh\'abng.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \'a7\'e8i v\'edi c\'b8c thu\'e9c \'ae\'dea Ph\'b8p,
\par a) m\'e9t ban nghi\'aan c\'f8u thu\'e9c \'ae\'dea \'ae\'b7 \'ae\'ad\'eec th\'b5nh l\'cbp;
\par b) m\'e9t m\'f4c vi\'d5t v\'d2 thu\'e9c \'ae\'dea \'ae\'b7 \'ae\'ad\'eec m\'eb ra tr\'aan b\'b8o }{\i\f37\fs20\insrsid1378858 L'Humanit\'d0;}{\f37\fs20\insrsid1378858 
\par c) nh\'f7ng l\'eai tuy\'aan b\'e8 \'f1ng h\'e9 d\'a9n ch\'f3ng thu\'e9c \'ae\'dea \'ae\'b7 \'ae\'ad\'eec ph\'b8t bi\'d3u trong c\'b8c \'ae\'b9i h\'e9i to\'b5n qu\'e8c;
\par d) hai cu\'e9c h\'b5nh tr\'d7nh tuy\'aan truy\'d2n \'ae\'b7 \'ae\'ad\'eec c\'b8c \'ae\'b9i bi\'d3u c\'f1a \'a7\'b6ng ti\'d5n h\'b5nh.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Sau khi \'ae\'ad\'eec th\'b5nh l\'cbp \'ddt l\'a9u v\'b5
 khi \'ae\'b7 gi\'b5nh \'ae\'ad\'eec kh\'abng ph\'b6i l\'b5 kh\'abng ch\'cbt v\'cbt nh\'f7ng c\'e9t b\'b8o tr\'aan t\'ea }{\i\insrsid1378858 L'Humanit\'d0}{\insrsid1378858 , Ban nghi\'aan c\'f8u thu\'e9c \'ae\'dea \'ae\'b7 ho\'b9t \'ae\'e9ng kh\'b8 t\'e8
t. Nh\'f7ng t\'b5i li\'d6u v\'b5 tin t\'f8c c\'e3 gi\'b8 tr\'de \'ae\'b7 b\'bet \'ae\'c7u \'ae\'ad\'eec g\'f6i t\'f5 c\'b8c thu\'e9c \'ae\'dea \'ae\'d5n Ban. Chi\'d5n d\'dech m\'b5 Ban ti\'d5n h\'b5nh tr\'aan b\'b8o \'a7\'b6ng nh\'bbm ch\'e8ng nh\'f7ng nh
\'f2ng l\'b9m v\'b5 t\'e9i \'b8c c\'f1a b\'cc l\'f2 th\'f9c d\'a9n, \'ae\'b7 nhanh ch\'e3ng thu h\'f3t s\'f9 quan t\'a9m m\'b9nh m\'cf c\'f1a d\'a9n ch\'f3ng c\'b8c thu\'e9c \'ae\'dea v\'b5 mang l\'b9i n\'e7i lo l\'beng cho ch\'f1 ngh\'dca \'ae\'d5 qu\'e8
c th\'f9c d\'a9n v\'b5 b\'b8o ch\'dd c\'f1a n\'e3. Nh\'adng di\'d4n \'ae\'b5n \'cay \'ae\'e9t nhi\'aan \'ae\'b7 b\'de b\'b8o }{\i\insrsid1378858 L'Humanit\'d0}{\insrsid1378858  b\'e1 \'aei. B\'de t\'ad\'edc m\'cat ph\'ad\'acng ti\'d6n c\'abng t\'b8c v\'b5
 ho\'b9t \'ae\'e9ng, Ban l\'a9m v\'b5o t\'d7nh tr\'b9ng ho\'b5n to\'b5n b\'de t\'aa li\'d6t. \'a7i\'d2u \'ae\'e3 \'ae\'b7 l\'b5m cho gi\'edi b\'b8o ch\'dd to l\'edn c\'f1a giai c\'cap t\'ad s\'b6n r\'cat h\'b5i l\'dfng, nh\'f7ng b\'b8o ch\'dd n\'b5y \'ae
\'b7 d\'b5nh r\'cat \'ae\'d2u \'ae\'c6n h\'b5ng bao nhi\'aau trang cho c\'abng t\'b8c tuy\'aan truy\'d2n th\'f9c d\'a9n v\'b5 lu\'abn lu\'abn s\'ee b\'de c\'b6i ch\'ddnh v\'b5 l\'cbt m\'c6t n\'b9.
\par \'a7i\'d2u \'ae\'e3 \'ae\'b7 \'ae\'c6c bi\'d6t g\'a9y nh\'f7ng \'can t\'ad\'eeng r\'cat n\'c6ng n\'d2 cho d\'a9n b\'b6n x\'f8. M\'c6c d\'c7u l\'b5 h\'b7o huy\'d2n, nh\'f7ng l\'eai tuy\'aan b\'e8 trong c\'b8c \'ae\'b9i h\'e9i to\'b5n qu\'e8c \'f1ng h\'e9 d
\'a9n ch\'f3ng c\'b8c thu\'e9c \'ae\'dea c\'f2ng \'ae\'b7 g\'e3p ph\'c7n c\'f1ng c\'e8 m\'e8i c\'b6m t\'d7nh m\'b5 h\'e4 \'ae\'b7 c\'e3 \'ae\'e8i v\'edi \'a7\'b6ng. Tuy nhi\'aan th\'cbt l\'b5 kh\'abng th\'ddch \'ae\'b8ng n\'d5u c\'f8 l\'bep \'aei l\'bep l
\'b9i m\'b7i m\'e9t \'aei\'d2u m\'b5 kh\'abng l\'b5m g\'d7 c\'b6. V\'b5 nh\'f7ng ng\'ad\'eai b\'de \'b8p b\'f8c kh\'e8n kh\'e6 th\'cay ch\'f3ng ta ch\'d8 lu\'abn lu\'abn h\'f8a h\'d1n nh\'adng c\'f2ng lu\'abn lu\'abn kh\'abng h\'b5nh \'ae\'e9ng g\'d7 th
\'d7 b\'bet \'ae\'c7u t\'f9 h\'e1i r\'bbng kh\'abng bi\'d5t th\'f9c ra ch\'f3ng ta l\'b5 nh\'f7ng ng\'ad\'eai \'ae\'f8ng \'ae\'ben hay l\'b5 nh\'f7ng k\'ce l\'f5a ph\'d8nh. Cu\'e9c h\'b5nh tr\'d7nh c\'f1a c\'b8c \'ae\'e5ng ch\'dd Vay\'a8ng Cutuyari\'aa v
\'b5 \'a1ng\'aer\'aa B\'d0ct\'abng qua Angi\'aari v\'b5 Tuynidi, ti\'d5n h\'b5nh h\'c7u nh\'ad c\'efng m\'e9t l\'f3c v\'edi c\'b8c cu\'e9c d\'b9o ch\'aci \'ae\'d5 v\'ad\'acng c\'f1a b\'e4n \'ae\'b9i bi\'d3u t\'ad s\'b6n, \'ae\'b7 \'ae\'ad\'eec d\'a9n ch
\'f3ng ch\'a9u Phi r\'cat hoan ngh\'aanh. N\'d5u nh\'f7ng cu\'e9c h\'b5nh tr\'d7nh c\'efng m\'e9t t\'ddnh ch\'cat nh\'ad th\'d5 \'ae\'ad\'eec ti\'d5p t\'f4c trong t\'cat c\'b6 c\'b8c thu\'e9c \'ae\'dea th\'d7 ch\'bec ch\'ben l\'b5 k\'d5t qu\'b6 s\'cf \'ae
\'b8ng m\'f5ng.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Nh\'adng, \'ae\'b8ng l\'cf ph\'b6i t\'a8ng c\'ad\'eang tuy
\'aan truy\'d2n th\'d7 ch\'f3ng ta l\'b9i \'ae\'b7 b\'e1 d\'eb c\'b8i vi\'d6c \'ae\'b7 \'ae\'ad\'eec b\'bet \'ae\'c7u, v\'b5 b\'e1 m\'cat nh\'f7ng c\'ac h\'e9i t\'e8t. B\'ebi th\'d5, ch\'f3ng ta \'ae\'b7 l\'b5m r\'cat \'ddt trong khi x\'b6y ra cu\'e9c b
\'b7i c\'abng \'ae\'c9m m\'b8u \'eb M\'b8ctin\'ddch, c\'b6nh ch\'d5t \'ae\'e3i \'eb B\'bec Phi v\'b5 cu\'e9c n\'e6i d\'cby \'eb \'a7ah\'abm\'a9y.
\par }\pard \qj \fi397\li0\ri0\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Trong tr\'ad\'eang h\'eep sau ch\'e3t n\'b5y, ch\'f3ng ta \'ae\'b7 c\'e3 m\'e9t b\'e9 m\'c6t thi\'d3u n\'b7o. Nhi\'d2u ng\'b5
y sau t\'cat c\'b6 c\'b8c b\'b8o t\'ad s\'b6n v\'b5 m\'ad\'eai ng\'b5y sau b\'b8}{\f37\fs20\expnd0\expndtw-2\insrsid1378858 o }{\i\f37\fs20\expnd0\expndtw-2\insrsid1378858 L'Oeuvre,}{\f37\fs20\expnd0\expndtw-2\insrsid1378858  b\'b8o \'a7\'b6ng m\'edi \'ae
\'a8ng tin v\'d2 cu\'e9c n\'e6i d\'cby. Trong l\'f3c ch\'ddnh ph\'f1 thu\'e9c \'ae\'dea \'ae\'b7 thi\'d5t qu\'a9n lu\'cbt, t\'cbp trung qu\'a9n \'ae\'e9i, huy \'ae\'e9ng chi\'d5n h\'b9m, huy \'ae\'e9ng c\'b8c b\'e9 m\'b8y \'ae\'b5n \'b8p, b\'bet b\'ed v
\'b5 k\'d5t \'b8n c\'b8c nh\'b5 ho\'b9t \'ae\'e9ng t\'f5 5 \'ae\'d5n 10 n\'a8m t\'ef; trong l\'f3c c\'b8c b\'b8o ch\'dd vi\'d5t thu\'aa \'ae\'b7 ti\'d5n h\'b5nh m\'e9t c\'b8ch c\'e3 h\'d6 th\'e8ng m\'e9t chi\'d5n d\'dech l\'f5a d\'e8i v\'b5 b\'adng b\'dd
t d\'ad lu\'cbn th\'d7 ch\'f3ng ta ch\'d8 vi\'d5t c\'e3 hai hay ba b\'b5i b\'b8o ng\'ben, r\'e5i th\'abi. Kh\'abng 
\par }\pard \qj \li0\ri0\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\expnd0\expndtw-2\insrsid1378858 ph\'b6i l\'b5 kh\'abng m\'d8a mai v\'b5 kh\'abng \'ae\'b8ng bu\'e5n khi trong b\'e3ng t\'e8i c\'f1a nh\'f7ng ng
\'f4c t\'ef c\'e3 t\'ddnh ch\'cat khai ho\'b8, nh\'f7ng ng\'ad\'eai anh em \'a7ah\'abm\'a9y \'aeau kh\'e6 c\'f1a t\'abi \'ae\'e4c \'aei\'d2u th\'f8 8, trong s\'e8 21 \'aei\'d2u ki\'d6n, n\'e3i r\'bbng: "}{\i\f37\fs20\expnd0\expndtw-2\insrsid1378858 M\'e7
i \'ae\'b6ng cam \'aeoan ti\'d5n h\'b5nh m\'e9t c\'abng t\'b8c c\'e6 \'ae\'e9ng c\'e3 h\'d6 th\'e8ng trong qu\'a9n \'ae\'e9i n\'ad\'edc m\'d7nh nh\'bbm ch\'e8ng m\'e4i \'b8ch \'b8p b\'f8c d\'a9n ch\'f3ng thu\'e9c \'ae\'dea; v\'b5 m\'e7i \'ae\'b6ng ph\'b6
i \'f1ng h\'e9, kh\'abng nh\'f7ng b\'bbng l\'eai n\'e3i m\'b5 c\'b6 b\'bbng h\'b5nh \'ae\'e9ng, phong tr\'b5o gi\'b6i ph\'e3ng c\'f1a c\'b8c thu\'e9c \'ae\'dea}{\f37\fs20\expnd0\expndtw-2\insrsid1378858 ".}{\f37\fs20\insrsid1378858 
\par }\pard \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Nh\'adng th\'cbt l\'b5 v\'ab \'ddch n\'d5u bu\'e9c t\'e9i qu\'b8 kh\'f8 v\'b5 ti\'d5c r\'ce th\'d7 gi\'ea \'ae\'b7 m\'ca
t. T\'e8t nh\'cat l\'b5 bi\'d5t s\'f6 d\'f4ng t\'e8t th\'d7 gi\'ea trong t\'ad\'acng lai. V\'cby ch\'f3ng t\'abi y\'aau c\'c7u \'a7\'b6ng:
\par 1) ch\'ddnh th\'f8c th\'f5a nh\'cbn Li\'aan \'aeo\'b5n M\'b8ctin\'ddch (nh\'e3m Gi\'a8ng Gi\'abr\'d0t);
\par 2) m\'eb l\'b9i m\'f4c vi\'d5t v\'d2 thu\'e9c \'ae\'dea trong b\'b8o }{\i\f37\fs20\insrsid1378858 L'Humanit\'d0}{\f37\fs20\insrsid1378858 ;
\par }{\insrsid1378858 3) }{\insrsid1378858\charrsid4605537 y\'aau c\'c7u Ban nghi\'aan c\'f8u thu\'e9c \'ae\'dea cung c\'cap t\'b5i li\'d6u cho ph\'a9n b\'e9 thu\'e9c \'ae\'dea v\'b5 c\'f8 hai ho\'c6c ba th\'b8ng m\'e9t, b\'b8o c\'b8o c\'abng }{
\f37\insrsid1378858\charrsid3436628 t\'b8c c\'f1a m\'d7nh v\'edi ph\'a9n b\'e9;}{\insrsid1378858 
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 4) \'eb nh\'f7ng n\'aci \'ae\'b7 th\'b5nh l\'cbp ph\'a9n b\'e9 thu\'e9c \'ae\'dea th\'d7 khuy\'d5n kh\'ddch c\'b8c ph
\'a9n b\'e9 n\'b5y t\'a8ng c\'ad\'eang c\'abng t\'b8c tuy\'aan truy\'d2n v\'b5 tuy\'d3n th\'aam ng\'ad\'eai b\'b6n x\'f8;
\par 5) tr\'aan t\'cat c\'b6 b\'b8o ch\'dd c\'f1a \'a7\'b6ng, m\'eb m\'e9t m\'f4c vi\'d5t v\'d2 thu\'e9c \'ae\'dea \'ae\'d3 l\'b5m cho \'ae\'e9c gi\'b6 l\'b5m quen v\'edi c\'b8c v\'can \'ae\'d2 thu\'e9c \'ae\'dea;
\par 6) n\'e3i \'ae\'d5n c\'b8c thu\'e9c \'ae\'dea trong h\'d5t th\'b6y c\'b8c \'ae\'b9i h\'e9i, m\'ddt tinh ho\'c6c h\'e9i ngh\'de c\'f1a \'a7\'b6ng;
\par 7) c\'f6 c\'b8c ngh\'de s\'dc \'aei th\'a8m c\'b8c thu\'e9c \'ae\'dea, m\'e7i khi n\'d2n t\'b5i ch\'ddnh c\'f1a \'a7\'b6ng cho ph\'d0p;
\par 8) t\'e6 ch\'f8c nh\'f7ng nghi\'d6p \'aeo\'b5n ho\'c6c th\'b5nh l\'cbp c\'b8c nh\'e3m t\'ad\'acng t\'f9 \'eb c\'b8c thu\'e9c \'ae\'dea.
\par }\pard\plain \s24\qc \li3119\ri283\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin283\lin3119\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i\f37\fs20\insrsid1378858 M\'b8txc\'acva, th\'b8ng 7 n\'a8m 1923
}{\fs20\insrsid1378858 \line }{\insrsid1378858 \line }{\fs20\insrsid1378858 Nguy\'d4n \'b8i Qu\'e8c}{\f37\fs20\insrsid1378858 
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'b5i li\'d6u vi\'d5t tay, ti\'d5ng Ph\'b8p,
\par l\'adu t\'b9i C\'f4c l\'adu tr\'f7
\par V\'a8n ph\'dfng Trung \'ad\'acng \'a7\'b6ng.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \column 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'d6 \'a7\'e9C \'a7O\'b8N \'eb \'a7\'a4NG D\'a6\'a5
NG - \line NG\'a6\'eaI \'a7\'a6\'eeC B\'b6O H\'e9 V\'b5 NG\'a6\'eaI \'a7I B\'b6O H\'e9
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-288\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'a4ng C\'c8m \'a7\'b5 L\'b9t (Trung K\'fa) c\'e3 m\'e9t c
\'b8ch hi\'d3u vai tr\'df khai ho\'b8 c\'f1a m\'d7nh \'ae\'d5n l\'b5 hay. M\'e9t h\'abm, ng\'ad\'eai c\'e9ng t\'b8c r\'cat x\'f8ng c\'f1a \'abng Xar\'ab n\'b5y c\'c7n \'ae\'d5n v\'b8n g\'e7. \'a4ng ta sai ng\'ad\'eai \'ae\'d5n ki\'d5m v\'b8n \'eb nh\'b5 m
\'e9t ng\'ad\'eai b\'b6n x\'f8 l\'b5m ngh\'d2 bu\'abn b\'b8n. Nh\'b5 bu\'abn n\'b5y \'ae\'dfi ph\'b6i tr\'b6 ti\'d2n r\'e5i m\'edi \'ae\'ad\'eec mang h\'b5ng \'aei. Nghe l\'eai y\'aau c\'c7u n\'b5y, \'abng C\'c8m n\'e6i gi\'cbn, ph\'b8i ngay l\'f9c l\'ad
\'eeng v\'f2 trang \'ae\'d5n v\'edi nghi\'aam l\'d6nh l\'b5 d\'ef "s\'e8ng 
\par hay ch\'d5t" c\'f2ng ph\'b6i b\'bet cho \'ae\'ad\'eec t\'aan An Nam \'ae\'e3 v\'d2 s\'eb.
\par }\pard\plain \s27\qj \fi397\li0\ri0\sa80\sl-288\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \'a7\'d3 tr\'b8nh c\'acn gi\'cbn c\'f1a v\'de \'ae
\'b9i di\'d6n cho n\'ad\'edc b\'b6o h\'e9, nh\'b5 bu\'abn kh\'abng k\'d3 g\'d7 \'aeang \'e8m c\'f2ng \'ae\'b5nh ph\'b6i b\'e1 c\'b6 nh\'b5 c\'f6a qu\'aa h\'ad\'acng l\'b8nh sang t\'d8nh kh\'b8c.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-288\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 M\'e9t th\'c7y thu\'e8c ng\'ad\'eai \'a2u ch\'f8ng ki\'d5
n t\'can tr\'df k\'d3 tr\'aan \'ae\'b7 can thi\'d6p \'ae\'d3 b\'aanh v\'f9c nh\'b5 bu\'abn b\'b6n x\'f8. V\'f4 can thi\'d6p "ch\'ad\'edng tai gai m\'bet" n\'b5y l\'b5m cho vi\'aan th\'c7y thu\'e8c b\'de \'ae\'e6i \'aei, b\'de \'ae\'b5y l\'aan Kon Tum, m
\'e9t n\'aci n\'ad\'edc \'ae\'e9c m\'b5 ng\'ad\'eai \'a2u r\'cat s\'ee. Ch\'ddnh \'ae\'cay l\'b5 n\'aci m\'b5 vi\'aan th\'c7y thu\'e8c \'ae\'e3 \'aeang \'ae\'d2n c\'b8i t\'e9i th\'a9n ng\'ad\'eai b\'b6n x\'f8 c\'f1a \'abng. Trong khi \'cay th\'d7 b\'e4n 
\'a7\'b8cl\'ac, B\'ab\'aeoanh v\'c9n ung dung ph\'cc ph\'ecn trong vinh d\'f9 v\'b5 kho\'b8i l\'b9c. K\'ce m\'bec c\'b8i t\'e9i x\'f3c ph\'b9m uy t\'ddn k\'d3 tr\'aan l\'b5 b\'b8c s\'dc H\'abngxtarich. Ch\'f3ng t\'abi xin t\'e1 t\'cam c\'b6m t\'d7nh c\'f1
a ch\'f3ng t\'abi \'ae\'e8i v\'edi \'abng \'cay.
\par C\'dfn nh\'b5 bu\'abn An Nam th\'d7 sau ra sao ? Anh ta b\'de ghi t\'aan v\'b5o s\'e6 nh\'f7ng ng\'ad\'eai b\'de t\'d7nh nghi, li\'d6t v\'b5o h\'b9ng "ch\'e8ng T\'a9y", v\'b5o s\'e8 nh\'f7ng
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-288\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 k\'ce c\'c7n theo d\'e2i. M\'e9t b\'c7y m\'cbt th\'b8m Ph\'b8
p v\'b5 An Nam b\'b8m ri\'d5t theo g\'e3t anh ta. Nhi\'d6m v\'f4 c\'f1a b\'e4n n\'b5y l\'b5 ghi t\'f5ng gi\'ea t\'f5ng ph\'f3t m\'e4i h\'b5nh \'ae\'e9ng c\'f6 ch\'d8 c\'f1a anh ta, v\'b5 t\'ab \'aeen t\'cat c\'b6 m\'e4i \'fd \'ae\'denh c\'f1a anh.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'abng cu\'e9c theo d\'e2i n\'b5y \'ae\'ad\'eec ti\'d5n h
\'b5nh m\'e9t c\'b8ch kh\'b8 l\'e9 li\'d4u \'ae\'d3 l\'b5m cho b\'b9n b\'cc quen thu\'e9c c\'f1a ng\'ad\'eai An Nam n\'b5y ph\'b6i ch\'efn l\'b9i kh\'abng d\'b8m lai v\'b7ng nh\'b5 anh n\'f7a, \'ae\'d5n n\'e7i \'ae\'eai s\'e8ng c\'f1a anh tr\'eb n\'aan h
\'d5t s\'f8c kh\'e3 kh\'a8n. B\'cat c\'f8 th\'d5 n\'b5o c\'f2ng kh\'abng m\'e9t ng\'ad\'eai b\'b6n x\'f8 n\'b5o d\'b8m \'ae\'d5n nh\'b5 anh. Ho\'b5n to\'b5n b\'de c\'ab l\'cbp v\'edi \'ae\'e5ng b\'b5o c\'f1a m\'d7nh, nh\'b5 bu\'abn n\'b5y ch\'d8 c\'dfn c
\'e3 hai con \'ae\'ad\'eang: ho\'c6c \'aei \'a8n c\'ad\'edp, ho\'c6c \'aei \'a8n m\'b5y. Nh\'adng c\'b8i ngh\'d2 th\'f8 hai n\'b5y c\'e3 th\'d3 l\'b9i l\'b5m cho anh c\'b5ng \'ae\'b8ng kh\'b6 nghi h\'acn v\'d7 ki\'d5p s\'e8ng lang thang.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 nGUY\'d4N \'b8I QU\'e8C
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 Le Paria}{\insrsid1378858  , s\'e8 16,

\par th\'b8ng 7-1923.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }{\b\f37\fs20\insrsid1378858 \column 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'b8CH \'b8P B\'f8C KH\'a4NG T\'f5\line M\'e9T CH\'f1
NG T\'e9C N\'b5O
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 V\'abr\'e8pxki, ph\'b8i vi\'aan c\'f1a n\'ad\'edc Nga c
\'abng n\'abng \'ae\'b7 b\'de b\'e4n ph\'b8t x\'ddt \'b8m s\'b8t \'eb Thu\'fe S\'dc. Kh\'abng m\'e9t ph\'b8i vi\'aan n\'b5o c\'f1a c\'b8c c\'ad\'eang qu\'e8c r\'cat v\'a8n minh v\'b5 r\'cat s\'efng \'ae\'b9o Thi\'aan ch\'f3a \'aeang h\'e4p \'eb L\'abdann
\'ac h\'b9 c\'e8 \'aei \'ae\'ada \'ae\'b8m. Ch\'d8 c\'e3 ph\'b8i \'aeo\'b5n Th\'e6 Nh\'dc K\'fa do Ixm\'d5t Pasa d\'c9n \'ae\'c7u \'ae\'b7 \'ae\'d5n nghi\'aang m\'d7nh tr\'ad\'edc thi h\'b5i ng\'ad\'eai b\'de s\'b8t h\'b9i.
\par }{\f37\fs20\expnd0\expndtw-2\insrsid1378858 Ben Ra\'aeia, m\'e9t c\'abng nh\'a9n, qu\'aa \'eb Tuynidi \'ae\'b7 }{\i\f37\fs20\expnd0\expndtw-2\insrsid1378858 b\'de c\'b6nh s\'b8t gi\'d5t}{\f37\fs20\expnd0\expndtw-2\insrsid1378858  \'eb Pari ng\'b5y 1 th
\'b8ng 5. C\'b8c t\'e6 ch\'f8c c\'abng nh\'a9n \'eb Pari \'ae\'b7 t\'e6 ch\'f8c m\'e9t 
\par \'ae\'b8m tang l\'edn. H\'b5ng m\'cay ngh\'d7n c\'abng nh\'a9n \'ae\'b7 ngh\'d8 vi\'d6c ng\'b5y h\'abm \'ae\'e3 \'ae\'d3 \'aei \'ae\'ada ng\'ad\'eai \'ae\'e5ng ch\'dd b\'b6n x\'f8 c\'f1a m\'d7nh t\'edi n\'aci an ngh\'d8 cu\'e8i c\'efng.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'cat c\'b6 nh\'f7ng li\'d6t s\'dc c\'f1a giai c\'cap c
\'abng nh\'a9n, ng\'ad\'eai \'eb L\'abdann\'ac c\'f2ng nh\'ad \'eb Pari, nh\'f7ng ng\'ad\'eai Havr\'ac c\'f2ng nh\'ad nh\'f7ng ng\'ad\'eai \'eb M\'b8ctin\'ddch, \'ae\'d2u l\'b5 nh\'f7ng n\'b9n nh\'a9n c\'f1a m\'e9t k\'ce gi\'d5t ng\'ad\'eai: ch\'f1 ngh
\'dca t\'ad b\'b6n qu\'e8c t\'d5. V\'b5 h\'ad\'acng h\'e5n c\'f1a nh\'f7ng ng\'ad\'eai b\'de hy sinh n\'b5y lu\'abn t\'d7m th\'cay ngu\'e5n an \'f1i cao c\'b6 nh\'cat \'eb l\'dfng tin v\'b5o s\'f9 nghi\'d6p gi\'b6i ph\'e3ng nh\'f7ng anh em c\'f1a h\'e4 b
\'de \'b8p b\'f8c - kh\'abng ph\'a9n bi\'d6t ch\'f1ng t\'e9c hay x\'f8 s\'eb.
\par }\pard\plain \qj \fi397\li0\ri0\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Sau nh\'f7ng b\'b5i h\'e4c \'aeau \'ae\'edn n\'b5y, nh\'f7ng ng
\'ad\'eai b\'de \'b8p b\'f8c \'eb t\'cat c\'b6 c\'b8c n\'ad\'edc h\'bcn ph\'b6i hi\'d3u \'ae\'a9u l\'b5 nh\'f7ng ng\'ad\'eai anh em th\'cbt s\'f9 v\'b5 \'ae\'a9u l\'b5 k\'ce th\'ef c\'f1a h\'e4.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~NGUY\'d4N \'b8I QU\'e8C
\par }\pard\plain \ql \fi397\li0\ri0\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 Le Paria}{\insrsid1378858 , s\'e8 17,\line }{
\f37\fs20\insrsid1378858\charrsid4605537 th\'b8ng 8-1923.}{\f37\fs20\expnd0\expndtw-2\insrsid1378858 
\par }\pard \qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\expnd0\expndtw-2\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'a7\'e9I QU\'a2N CH\'e8NG C\'b8CH M\'b9NG
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-296\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ch\'f3ng ta \'ae\'d2u bi\'d5t r\'bbng s\'f9 tranh gi\'b5
nh thu\'e9c \'ae\'dea l\'b5 m\'e9t trong nh\'f7ng nguy\'aan nh\'a9n ch\'ddnh c\'f1a chi\'d5n tranh \'ae\'d5 qu\'e8c ch\'f1 ngh\'dca n\'a8m 1914-1918.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-296\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'a7i\'d2u m\'b5 t\'cat c\'b6 nh\'f7ng ng\'ad\'eai Ph\'b8p 
\'ae\'d2u kh\'abng th\'d3 kh\'abng bi\'d5t \'ae\'d5n l\'b5 vi\'d6c \'ae\'ada nh\'f7ng \'ae\'e9i qu\'a9n vi\'d4n chinh sang c\'b8c thu\'e9c \'ae\'dea \'ae\'b7 l\'b5m cho d\'a9n s\'e8 gi\'b6m s\'f3t m\'e9t c\'b8ch tr\'c7m tr\'e4ng m\'b5 hi\'d6n nay \'ae\'ca
t n\'ad\'edc h\'e4 \'aeang ph\'b6i ch\'deu \'ae\'f9ng. N\'d5u \'ae\'e4c c\'b8c b\'b6n th\'e8ng k\'aa nh\'f7ng s\'f9 t\'e6n th\'cat qu\'a9n s\'f9 v\'d2 ng\'ad\'eai ch\'d5t v\'b5 b\'de th\'ad\'acng \'eb c\'b8c thu\'e9c \'ae\'dea, th\'d7 ng\'ad\'eai ta s\'cf
 ph\'b6i kinh kh\'f1ng v\'d2 s\'f9 hao h\'f4t m\'b5 nh\'f7ng s\'f9 t\'e6n th\'cat \'ae\'e3 \'ae\'b7 g\'a9y ra cho m\'e9t d\'a9n s\'e8 \'aeang m\'e7i ng\'b5y m\'e9t gi\'b6m s\'f3t nh\'ad d\'a9n s\'e8 n\'ad\'edc Ph\'b8p. T\'f5 th\'b8ng 1 \'ae\'d5n th\'b8
ng 6-1923, ri\'aang \'eb Mar\'e8c c\'f2ng \'ae\'b7 c\'e3 840 binh l\'ddnh b\'de gi\'d5t hay b\'de th\'ad\'acng \'ae\'d3 mang l\'b9i quang vinh cho th\'e8ng ch\'d5 Li\'abt\'a9y!
\par \'a7i\'d2u m\'b5 giai c\'cap c\'abng nh\'a9n Ph\'b8p kh\'abng th\'d3 kh\'abng bi\'d5t \'ae\'d5n l\'b5 ch\'f1 ngh\'dca t\'ad b\'b6n d\'f9a v\'b5o thu\'e9c \'ae\'dea \'ae\'d3 ch\'e8ng l\'b9i t\'cat c\'b6 m\'e4i phong tr\'b5o gi\'b6i ph\'e3ng m\'b5 giai c
\'cap c\'abng nh\'a9n Ph\'b8p \'ae\'denh m\'adu \'ae\'e5. Kh\'abng ho\'b5n to\'b5n tin t\'ad\'ebng nh\'f7ng binh l\'ddnh ng\'ad\'eai da tr\'beng n\'f7a v\'d7 h\'e4 \'ddt nhi\'d2u c\'f2ng \'ae\'b7 ti\'aam nhi\'d4m t\'ad t\'ad\'ebng v\'d2 giai c\'cap, b\'e4
n qu\'a9n phi\'d6t Ph\'b8p l\'cay nh\'f7ng ng\'ad\'eai b\'b6n x\'f8 \'eb ch\'a9u Phi v\'b5 ch\'a9u }{\f38\insrsid1378858 \'b8}{\insrsid1378858  \'ae\'d3 thay th\'d5 h\'e4. Trong s\'e8 150 trung \'aeo\'b5n c\'f1a qu\'a9n \'ae\'e9i Ph\'b8p, c\'e3 10 trung 
\'aeo\'b5n ng\'ad\'eai da tr\'beng \'eb c\'b8c thu\'e9c \'ae\'dea, ngh\'dca l\'b5 nh\'f7ng ng\'ad\'eai n\'f6a b\'b6n x\'f8; 30 trung \'aeo\'b5n ng\'ad\'eai ch\'a9u Phi v\'b5 39 trung \'aeo\'b5n ng\'ad\'eai b\'b6n x\'f8 c\'b8c thu\'e9c \'ae\'dea kh\'b8
c. Nh\'ad v\'cby, m\'e9t n\'f6a s\'e8 qu\'a9n \'ae\'e9i Ph\'b8p l\'b5 tuy\'d3n m\'e9 \'eb c\'b8c thu\'e9c \'ae\'dea.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 M\'b5 ng\'ad\'eai An Nam ph\'b6i t\'dfng qu\'a9n 4 n\'a8
m, ng\'ad\'eai Angi\'aari 3 n\'a8m; th\'d5 l\'b5 theo s\'f9 t\'ddnh to\'b8n c\'f1a b\'e4n qu\'a9n phi\'d6t Ph\'b8p th\'d7 gi\'b8 tr\'de 2 ng\'ad\'eai l\'ddnh b\'b6n x\'f8 g\'c7n b\'bbng 5 ng\'ad\'eai l\'ddnh Ph\'b8p.
\par H\'acn n\'f7a, v\'d7 kh\'abng hi\'d3u ti\'d5ng n\'e3i v\'b5 ch\'ddnh tr\'de trong n\'ad\'edc, kh\'abng c\'e3 m\'e9t m\'e8i quan h\'d6 n\'b5o r\'b5ng bu\'e9c h\'e4 v\'edi d\'a9n c\'ad ch\'ddnh qu\'e8c, t\'ad\'ebng r\'bbng t\'cat c\'b6 nh\'f7ng ng\'ad\'ea
i da tr\'beng \'ae\'d2u c\'efng gi\'e8ng v\'edi nh\'f7ng ng\'ad\'eai b\'e3c l\'e9t h\'e4, v\'b5 cu\'e8i c\'efng, do nh\'f7ng ng\'ad\'eai da tr\'beng c\'cap tr\'aan c\'f1a h\'e4 th\'f3c \'ae\'c8y, n\'aan ng\'ad\'eai l\'ddnh b\'b6n x\'f8 c\'e3 th\'d3
 ngoan ngo\'b7n v\'b5 m\'ef qu\'b8ng b\'ad\'edc v\'b5o ch\'e7 m\'b5 ng\'ad\'eai l\'ddnh Ph\'b8p, gi\'b8c ng\'e9 h\'acn, c\'e3 th\'d3 t\'f5 ch\'e8i kh\'abng ch\'deu b\'ad\'edc. Nguy hi\'d3m l\'b5 \'eb ch\'e7 \'ae\'e3.
\par Ng\'ad\'eai ta t\'f9 h\'e1i v\'d7 l\'fd do g\'d7 m\'b5 31 trung \'aeo\'b5n trong s\'e8 nh\'f7ng trung \'aeo\'b5n ng\'ad\'eai b\'b6n x\'f8 s\'cf \'ae\'e3ng l\'b9i tr\'aan l\'b7nh th\'e6 Ph\'b8p. H\'e4 s\'cf \'ae\'ad\'eec d\'efng \'ae\'d3 l\'b5m g\'d7? Ph
\'b6i ch\'a8ng ng\'ad\'eai ta s\'cf d\'efng nh\'f7ng ng\'ad\'eai b\'b6n x\'f8 \'ae\'e3 \'ae\'d3 khai ho\'b8 cho ng\'ad\'eai Ph\'b8p? Nh\'ad v\'cby l\'b5 \'fd \'ae\'denh c\'f1a ch\'f1 ngh\'dca t\'ad b\'b6n Ph\'b8p \'ae\'b7 r\'e2 r\'b5ng. C\'abng nh\'a9n Ph
\'b8p c\'e3 nhi\'d6m v\'f4 ph\'b6i h\'b5nh \'ae\'e9ng. H\'e4 ph\'b6i k\'d5t t\'d7nh anh em v\'edi binh l\'ddnh b\'b6n x\'f8. H\'e4 ph\'b6i l\'b5m cho binh l\'ddnh b\'b6n x\'f8 hi\'d3u r\'bbng c\'b6 c\'abng nh\'a9n \'eb ch\'ddnh qu\'e8c l\'c9n binh l\'dd
nh \'eb thu\'e9c \'ae\'dea, \'ae\'d2u c\'efng b\'de chung m\'e9t b\'e4n ch\'f1 \'b8p b\'f8c v\'b5 b\'e3c l\'e9t, do \'ae\'e3, h\'e4 \'ae\'d2u l\'b5 anh em c\'efng m\'e9t giai c\'cap v\'b5 khi t\'edi l\'f3c ph\'b6i chi\'d5n \'ae\'cau, th\'d7 c\'b6 hai b
\'aan \'ae\'d2u ph\'b6i c\'efng \'ae\'b8nh b\'e4n ch\'f1 chung c\'f1a m\'d7nh, ch\'f8 anh em kh\'abng n\'aan \'ae\'b8nh l\'c9n nhau.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~NGUY\'d4N \'b8I QU\'e8C
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~B\'b8o }{\i\insrsid1378858 La Vie Ouvri\'ccre,}{\insrsid1378858 

\par \~ng\'b5y 7-9-1923.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par 
\par 
\par }\pard\plain \s23\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8O C\'b8O G\'f6I QU\'e8C T\'d5 C\'e9NG S\'b6N}{
\cs17\super\insrsid1378858 1{\footnote \pard\plain \s30\ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f42\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) }{\f37\insrsid1378858\charrsid3436628 \'a7\'c7
u b\'b5i do BBT \'ae\'c6t. Tr\'aan \'ae\'c7u t\'b5i li\'d6u ghi 21/IX/23. }{\i\f37\insrsid1378858\charrsid3436628 M\'cbt}{\i\insrsid1378858 .}})}{\insrsid1378858 
\par }\pard\plain \s25\qc \li0\ri0\sa120\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'a7\'a4NG D\'a6\'a5NG, T\'e3M T\'beT
\par }\pard\plain \s4\qj \fi397\li0\ri0\sb120\sa80\sl-268\slmult0\keepn\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel3\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Ch\'ddnh tr\'de
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Kh\'abng c\'e3 ch\'ddnh \'ae\'b6ng: \'a7\'cat n\'ad\'edc b
\'de cai tr\'de theo c\'b8ch nh\'ad sau:
\par Nam K\'fa v\'b5 B\'bec K\'fa b\'de cai tr\'de tr\'f9c ti\'d5p b\'ebi c\'b8c nh\'b5 c\'c7m quy\'d2n Ph\'b8p v\'edi nh\'f7ng thu\'e9c h\'b9 ng\'ad\'eai b\'b6n x\'f8.
\par Trung K\'fa v\'b5 Campuchia c\'e3 ch\'ddnh ph\'f1 b\'b6n x\'f8 c\'f1a m\'d7nh m\'b5 th\'f9c t\'d5 ch\'d8 l\'b5 th\'f9c h\'b5nh c\'b8c m\'d6nh l\'d6nh c\'f1a c\'b8c nh\'b5 cai tr\'de Ph\'b8p.
\par }\pard\plain \s1\qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\i\f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i0\fs20\insrsid1378858 Kinh t\'d5
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 X\'dd nghi\'d6p, \'ae\'e5n \'aei\'d2n, h\'c7m m\'e1
, giao th\'abng v\'cbn t\'b6i v\'b5 th\'ad\'acng nghi\'d6p l\'edn, t\'cat c\'b6 \'ae\'d2u \'eb trong tay ng\'ad\'eai Ph\'b8p. Th\'ad\'acng nghi\'d6p h\'b9ng v\'f5a c\'e3 th\'d3 n\'e3i l\'b5 ng\'ad\'eai Trung Qu\'e8c n\'bem \'ae\'e9c quy\'d2n. Ng\'ad\'ea
i b\'b6n x\'f8 ch\'d8 c\'e3 th\'ad\'acng nghi\'d6p \'ae\'dea ph\'ad\'acng nh\'e1.
\par }\pard\plain \s1\qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\i\f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i0\fs20\insrsid1378858 X\'b7 h\'e9i
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 D\'a9n c\'ad h\'eep th\'b5nh x\'b7, nh\'f7ng x\'b7 h\'ee
p th\'b5nh t\'e6ng, nh\'f7ng t\'e6ng th\'b5nh huy\'d6n, nh\'f7ng huy\'d6n th\'b5nh t\'d8nh.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 D\'a9n c\'ad b\'c7u l\'cay l\'fd tr\'ad\'ebng, nh\'f7ng l
\'fd tr\'ad\'ebng b\'c7u l\'cay ch\'b8nh t\'e6ng. Cu\'e9c b\'c7u c\'f6 c\'f1a nh\'a9n d\'a9n d\'f5ng l\'b9i \'eb \'ae\'cay.
\par Nh\'f7ng huy\'d6n v\'b5 nh\'f7ng t\'d8nh th\'d7 c\'b8c quan cai tr\'de do ch\'ddnh ph\'f1 ch\'d8 \'ae\'denh.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-258\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\i\f37\fs20\insrsid1378858 Tri\'d2u \'ae\'d7nh v\'b5 quan ch\'f8c}{\f37\fs20\insrsid1378858  l\'d6 thu\'e9c tuy\'d6t \'ae\'e8i v\'b5o ch\'dd
nh quy\'d2n Ph\'b8p. H\'e4 b\'de ch\'f1 Ph\'b8p c\'f1a h\'e4 khinh b\'d8 v\'b5 nh\'a9n d\'a9n An Nam gh\'d0t.
\par }{\i\f37\fs20\insrsid1378858 Thi\'d3u s\'e8 c\'b8c nh\'b5 nho hay l\'b5 c\'b8c nh\'b5 tr\'dd th\'f8c}{\f37\fs20\insrsid1378858  l\'b5 c\'b8c nh\'b5 c\'b8ch m\'b9ng d\'a9n t\'e9c ch\'f1 ngh\'dca. Ch\'ddnh h\'e4 \'ae\'b7 kh\'ddch \'ae\'e9ng m\'e4i cu\'e9c n
\'e6i d\'cby trong qu\'b8 kh\'f8.
\par }{\i\f37\fs20\insrsid1378858 C\'abng nh\'a9n}{\f37\fs20\insrsid1378858  c\'e3 th\'d3 l\'b5 2% trong d\'a9n s\'e8, kh\'abng \'ae\'ad\'eec h\'e4c h\'b5nh, kh\'abng \'ae\'ad\'eec t\'e6 ch\'f8c. Do v\'cby h\'e4 kh\'abng c\'e3 m\'e9t l\'f9c l\'ad\'eeng ch\'dd
nh tr\'de n\'b5o.
\par }{\i\f37\fs20\insrsid1378858 Ti\'d3u t\'ad s\'b6n}{\f37\fs20\insrsid1378858  kh\'abng nhi\'d2u, l\'b5 m\'e9t ph\'c7n t\'f6 b\'cap b\'aanh. N\'e3 ch\'deu s\'f9 chi ph\'e8i b\'ebi nhi\'d2u th\'f8 tri\'d5t l\'fd, nh\'ad l\'b5 n\'e3 h\'ad\'edng v\'b5
o phong tr\'b5o d\'a9n t\'e9c r\'cat v\'e9i v\'b7. N\'e3 nh\'f3t nh\'b8t.
\par }{\i\f37\fs20\insrsid1378858 Qu\'c7n ch\'f3ng n\'abng d\'a9n}{\f37\fs20\insrsid1378858  b\'de b\'e3c l\'e9t nh\'cat v\'b5 c\'efng kh\'e6 nh\'cat, r\'cat y\'aau n\'ad\'edc.
\par Tuy\'aan truy\'d2n t\'e8t trong n\'abng d\'a9n v\'b5 t\'e6 ch\'f8c t\'e8t trong c\'abng nh\'a9n n\'d5u ch\'f3ng ta l\'b5m t\'edi \'ae\'ad\'eec \'aei\'d2u \'ae\'e3 th\'d7 t\'ad\'acng lai thu\'e9c v\'d2 ch\'f3ng ta.
\par }\pard\plain \s25\qc \li0\ri0\sb160\sa120\sl-258\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 cH\'a6\'a5NG TR\'d7NH HO\'b9T \'a7\'e9NG
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-258\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 1/ Xu\'cat b\'b6n m\'e9t t\'ea b\'b8o nh\'e1 ti\'d5ng Vi
\'d6t.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-258\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 2/ T\'cbp h\'eep nh\'f7ng ph\'c7n t\'f6 d\'a9n t\'e9c c\'b8
ch m\'b9ng.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-258\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 3/ C\'e8 g\'beng \'ae\'ada nh\'f7ng thanh ni\'aan ng\'ad
\'eai b\'b6n x\'f8 \'aei M\'b8txc\'acva.
\par 4/ X\'a9y d\'f9ng d\'a9y li\'aan l\'b9c M\'b8txc\'acva - \'a7\'abng D\'ad\'acng - Pari.
\par }\pard\plain \s25\qc \li0\ri0\sb160\sa120\sl-258\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 H\'eeP T\'b8C
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-258\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~a/ \'a7i\'d2u g\'d7 m\'b5 }{\i\f37\fs20\insrsid1378858 
\'a7\'b6ng}{\f37\fs20\insrsid1378858  c\'e3 th\'d3 l\'b5m th\'d7 \'ae\'b7 li\'d6t k\'aa trong th\'ad g\'f6i cho n\'e3 do Ban ph\'ad\'acng \'a7\'abng chuy\'d3n.
\par b/ }{\i\f37\fs20\insrsid1378858 T\'e6ng c\'abng h\'e9i th\'e8ng nh\'cat}{\f37\fs20\insrsid1378858  \'ae\'b7 h\'f8a l\'b5m h\'d5t s\'f8c m\'d7nh \'ae\'d3 2 ho\'c6c 3 \'ae\'e5ng ch\'dd ng\'ad\'eai Ph\'b8p c\'e3 th\'d3 sang \'a7\'abng D\'ad\'acng \'ae\'d3 t
\'e6 ch\'f8c c\'abng nh\'a9n.
\par }{\f37\fs20\expnd0\expndtw-2\insrsid1378858 c/ }{\i\f37\fs20\expnd0\expndtw-4\insrsid1378858 Thanh ni\'aan c\'e9ng s\'b6n Ph\'b8p}{\f37\fs20\expnd0\expndtw-4\insrsid1378858  ph\'b6i l\'eei d\'f4ng ch\'f1 ngh\'dca qu\'a9n phi\'d6t \'ae\'d3 \'ae\'ada nh\'f7
ng th\'b5nh vi\'aan ch\'bec ch\'ben nh\'cat \'ae\'a8ng l\'ddnh v\'b5o \'ae\'e9i qu\'a9n thu\'e9c \'ae\'dea \'ae\'d3 d\'bet d\'c9n s\'f9 tuy\'aan truy\'d2n trong nh\'f7}{\f37\fs20\expnd0\expndtw-2\insrsid1378858 ng ng\'ad\'eai}{\f37\fs20\insrsid1378858  b
\'b6n x\'f8.
\par }\pard \qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 2/ S\'f9 gi\'f3p \'ae\'ec c\'f1a }{\i\f37\fs20\insrsid1378858 Thanh ni\'aan c\'e9ng s\'b6n Trung Qu\'e8c}{
\f37\fs20\insrsid1378858  l\'b5 tuy\'d6t \'ae\'e8i c\'c7n thi\'d5t cho s\'f9 ho\'b9t \'ae\'e9ng \'eb \'a7\'abng D\'ad\'acng.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 M\'e9t cu\'e9c th\'b6o lu\'cbn gi\'f7a nh\'f7ng \'ae\'b9i bi\'d3u c\'f1a \'a7\'b6ng, c\'f1a T\'e6ng c\'abng h\'e9i th
\'e8ng nh\'cat, c\'f1a Thanh ni\'aan v\'b5 c\'f1a Ban ph\'ad\'acng \'a7\'abng c\'e3 th\'d3 l\'e3 ra nhi\'d2u \'b8nh s\'b8ng kh\'b8c.
\par \~
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'b5i li\'d6u vi\'d5t tay, ti\'d5ng Ph\'b8p,
\par b\'b6n ch\'f4p l\'adu t\'b9i Vi\'d6n H\'e5 Ch\'dd Minh.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }{\b\f37\fs20\insrsid1378858 \column 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 KH\'a4NG PH\'b6I CH\'f1 NGH\'dcA\line QU\'a2N PHI\'d6T 
\'a7\'a2U, NH\'a6NG...
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-256\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~\'a4ng Cl\'aam\'a8ngx\'ab \'ae\'b7 ch\'f8ng minh r\'ca
t r\'b5nh r\'e4t cho th\'d5 gi\'edi n\'e3i chung, v\'b5 cho ng\'ad\'eai M\'fc n\'e3i ri\'aang r\'bbng n\'ad\'edc Ph\'b8p kh\'abng ph\'b6i l\'b5 m\'e9t n\'ad\'edc qu\'a9n phi\'d6t, c\'f2ng kh\'abng ph\'b6i l\'b5 m\'e9t n\'ad\'edc \'ae\'d5 qu\'e8c ch\'f1
 ngh\'dca, ho\'b5n to\'b5n ch\'bcng ph\'b6i th\'d5 \'ae\'a9u nh\'d0!
\par Th\'d5 nh\'adng \'abng }{\f38\fs20\insrsid1378858 \'b8}{\f37\fs20\insrsid1378858 csimb\'ab l\'b9i v\'f5a m\'edi l\'b5m cho ti\'aau m\'cat \'ae\'abi ch\'f3t c\'b8i v\'ce m\'fc mi\'d2u c\'f1a nh\'f7ng l\'eai n\'e3i c\'f1a "\'a4ng C\'e4p", khi \'abng }{
\f38\fs20\insrsid1378858 \'b8}{\f37\fs20\insrsid1378858 csimb\'ab vi\'d5t trong b\'b6n b\'b8o c\'b8o v\'f5a r\'e5i c\'f1a \'abng ta v\'d2 ng\'a9n s\'b8ch thu\'e9c \'ae\'dea r\'bbng:
\par N\'a8m 1914, qu\'a9n \'ae\'e9i chi\'d5m \'ae\'e3ng g\'e5m c\'e3 1.852 s\'dc quan, 17.290 h\'b9 s\'dc quan v\'b5 l\'ddnh ng\'ad\'eai \'a2u, 42.099 ng\'ad\'eai b\'b6n x\'f8; l\'b9i ph\'b6i th\'aam v\'b5o s\'e8 \'ae\'e3 1.979 ng\'ad\'eai trong c\'b8c \'ae
\'e9i c\'b6nh v\'d6 b\'b6n x\'f8 c\'f1a \'a7ah\'abm\'a9y, Ghin\'aa v\'b5 B\'ea Bi\'d3n Ng\'b5, hi\'d6n nay nh\'f7ng \'ae\'e9i l\'ddnh n\'b5y \'ae\'b7 \'ae\'ad\'eec thay th\'d5 b\'bbng nh\'f7ng \'ae\'e9i qu\'a9n ch\'ddnh quy. T\'e6ng c\'e9ng qu\'a9n s\'e8
 l\'b5 63.220 ng\'ad\'eai.
\par T\'f5 sau chi\'d5n tranh, ng\'ad\'eai ta \'ae\'b7 ph\'b6i thi\'d5t l\'cbp t\'b9i c\'b8c khu v\'f9c u\'fb tr\'de, T\'abg\'ab v\'b5 Cam\'acrun, nh\'f7ng tr\'b9i l\'ddnh m\'b5 qu\'a9n s\'e8 l\'aan t\'edi 1.712 ng\'ad\'eai.
\par Ngo\'b5i ra, c\'dfn ph\'b6i th\'b5nh l\'cbp, nh\'cat l\'b5 t\'b9i T\'a9y Phi thu\'e9c Ph\'b8p, nh\'f7ng \'ae\'acn v\'de \'ae\'c6c bi\'d6t \'ae\'d3 tuy\'d3n m\'e9, \'ae\'a8ng k\'fd nh\'cbp ng\'f2 v\'b5 hu\'can luy\'d6n s\'e8 binh l\'ddnh ng\'ad\'eai b\'b6
n x\'f8 ph\'f4c v\'f4 \'eb Ph\'b8p ho\'c6c \'eb n\'ad\'edc ngo\'b5i. C\'b8c \'ae\'acn v\'de \'ae\'e3 \'ae\'b7 thu h\'f3t 2.237 ng\'ad\'eai, trong \'ae\'e3 c\'e3 271 s\'dc quan v\'b5 h\'b9 s\'dc quan ng\'ad\'eai \'a2u.
\par }{\insrsid1378858 Sau }{\f37\fs20\insrsid1378858\charrsid4605537 h\'d5t, con s\'e8 nh\'f7ng ng\'ad\'eai b\'b6n x\'f8 ph\'f4c v\'f4 \'eb Ph\'b8p ho\'c6c}{\f37\insrsid1378858\charrsid4605537  \'eb}{\f37\fs20\insrsid1378858 
\par }\pard\plain \s15\qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 n\'ad\'edc ngo\'b5i, v\'b5 do c\'b8c thu\'e9c \'ae\'dea tr\'f9
c thu\'e9c B\'e9 Thu\'e9c \'ae\'dea cung c\'cap, l\'b5 45.000 ng\'ad\'eai.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 N\'d5u ch\'f3ng ta n\'e3i th\'aam r\'bbng, ch\'d8 ri\'aa
ng \'eb \'a7\'abng D\'ad\'acng, chi ph\'dd v\'d2 qu\'a9n s\'f9 n\'a8m 1921, c\'f2ng \'ae\'b7 h\'acn 35.600.000 phr\'a8ng, trong khi \'ae\'e3 ng\'a9n s\'b8ch gi\'b8o d\'f4c c\'e3 kh\'abng \'ae\'c7y 350 ngh\'d7n \'ae\'e5ng b\'b9c v\'b5 ng\'a9n s\'b8ch v\'d2
 y t\'d5 kh\'abng \'ae\'c7y 65 ngh\'d7n \'ae\'e5ng b\'b9c th\'d7 s\'cf th\'cay ngay t\'cat c\'b6 s\'f9 t\'e8t \'ae\'d1p c\'f1a ch\'d5 \'ae\'e9 th\'f9c d\'a9n c\'f1a c\'b8i n\'ad\'edc C\'e9ng ho\'b5 Ph\'b8p r\'cat nh\'a9n t\'f5 v\'b5 \'ae\'b7 t\'b5i gi\'b6
m qu\'a9n b\'de n\'b5y.
