\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858  NH\'f7NG NG\'a6\'eaI L\'b5M C\'a4NG T\'e6 CH\'f8C L
\'b9I, CH\'e8NG B\'e3C L\'e9T C\'f1A CH\'f1 NGH\'dcA T\'a6 B\'b6N
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~M\'c6c d\'c7u n\'d2n c\'abng nghi\'d6p l\'edn v\'b5 c
\'ac kh\'dd l\'edn ch\'ada \'ae\'ad\'eec ph\'b8t tri\'d3n ho\'b5n to\'b5n \'eb Trung Qu\'e8c, nh\'f7ng t\'cbp t\'f4c gia tr\'ad\'ebng ch\'ada m\'cat h\'bcn, c\'abng nh\'a9n Trung Qu\'e8c b\'de hai t\'c7ng \'b8p b\'f8c c\'f1a t\'ad b\'b6n n\'ad\'edc ngo
\'b5i v\'b5 c\'f1a b\'e4n qu\'a9n phi\'d6t b\'b6n x\'f8, \'ae\'b7 b\'bet \'ae\'c7u ho\'b9t \'ae\'e9ng m\'b9nh. C\'e3 kho\'b6ng m\'e9t tri\'d6u ng\'ad\'eai lao \'ae\'e9ng \'ae\'b7 ch\'deu \'b6nh h\'ad\'ebng (tr\'f9c ti\'d5p ho\'c6c gi\'b8n ti\'d5p) c\'f1
a s\'f9 tuy\'aan truy\'d2n nghi\'d6p \'aeo\'b5n v\'b5 c\'b8ch m\'b9ng.
\par }{\i\f37\fs20\insrsid1378858 Li\'aan hi\'d6p h\'b6i vi\'aan c\'abng h\'e9i H\'e5ng C\'abng}{\f37\fs20\insrsid1378858  c\'e3 30.000 h\'e9i vi\'aan. H\'e4 \'ae\'b7 ph\'b8t \'ae\'e9ng m\'e9t cu\'e9c \'ae\'d7nh c\'abng b\'e8n th\'b8ng (t\'f5 th\'b8ng 12-1921 
\'ae\'d5n th\'b8ng 3-1922). \'a7\'d3 t\'e1 t\'d7nh \'aeo\'b5n k\'d5t, qu\'c7n ch\'f3ng ngo\'b5i c\'abng h\'e9i \'ae\'b7 tuy\'aan b\'e8 t\'e6ng \'ae\'d7nh c\'abng. Nh\'f7ng ng\'ad\'eai th\'ee gi\'c6t v\'b5 nh\'f7ng ng\'ad\'eai ph\'f4c v\'f4 c\'f2ng h\'ad
\'ebng \'f8ng phong tr\'b5o. K\'d5t qu\'b6 l\'b5 c\'abng nh\'a9n \'ae\'ad\'eec t\'a8ng l\'ad\'acng t\'f5 20 \'ae\'d5n 40%.
\par }{\i\f37\fs20\insrsid1378858 Li\'aan hi\'d6p h\'b6i vi\'aan c\'abng h\'e9i Th\'ad\'eeng H\'b6i}{\f37\fs20\insrsid1378858  c\'e3 15.000 h\'e9i vi\'aan. M\'e9t cu\'e9c \'ae\'d7nh c\'abng ba tu\'c7n \'ae\'b7 \'ae\'ad\'eec tuy\'aan b\'e8 th\'b8ng 7-1922. K
\'d5t qu\'b6 l\'b5 c\'abng nh\'a9n \'ae\'ad\'eec t\'a8ng l\'ad\'acng 20%.
\par C\'abng nghi\'d6p b\'abng s\'eei s\'f6 d\'f4ng 72.300 c\'abng nh\'a9n, ph\'c7n l\'edn l\'b5 ph\'f4 n\'f7 v\'b5 tr\'ce em d\'ad\'edi t\'b8m tu\'e6i. Ng\'b5y l\'b5m vi\'d6c 12 gi\'ea. Nhi\'d2u cu\'e9c kh\'ebi ngh\'dca \'ae\'b7 n\'e6 ra \'ae\'dfi c\'b6i thi
\'d6n \'aei\'d2u ki\'d6n l\'b5m vi\'d6c.
\par 93 x\'dd nghi\'d6p d\'d6t t\'ac l\'edn s\'f6 d\'f4ng 130.000 ph\'f4 n\'f7 v\'b5 thi\'d5u ni\'aan n\'f7 t\'f5 8 \'ae\'d5n 14 tu\'e6i. H\'e4 l\'b5m vi\'d6c 11 gi\'ea m\'e7i ng\'b5y. Do h\'aci n\'e3ng c\'f1a n\'ad\'edc s\'abi th\'ad\'eang xuy\'aan to\'b6
 ra v\'b5 m\'efi khai c\'f1a k\'d0n t\'bbm, n\'aan \'aei\'d2u ki\'d6n l\'b5m vi\'d6c c\'f1a nh\'f7ng n\'f7 c\'abng nh\'a9n \'ae\'e3 v\'ab c\'efng kh\'e3 kh\'a8n. Th\'b8ng 6-1922, m\'e9t n\'f7 c\'abng nh\'a9n \'ae\'b7 ch\'d5t v\'d7 tai n\'b9n lao \'ae\'e9
ng do ch\'f7a ch\'b8y k\'d0m. M\'e9t cu\'e9c \'ae\'d7nh c\'abng t\'f9 ph\'b8t b\'efng n\'e6 \'ae\'d3 ph\'b6n \'ae\'e8i. Cu\'e9c \'ae\'d7nh c\'abng \'ae\'e3 \'ae\'ad\'eec c\'b8c x\'dd nghi\'d6p d\'d6t \'eb Th\'ad\'eeng H\'b6i h\'ad\'ebng \'f8ng. K\'d5t qu
\'b6 l\'b5 gi\'ea l\'b5m vi\'d6c h\'bbng ng\'b5y gi\'b6m xu\'e8ng hai gi\'ea.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 M\'e9t cu\'e9c \'ae\'d7nh c\'abng c\'f1a th\'ee d\'d6t Nam Kinh \'ae\'b7 ng\'a8n c\'b6n \'ae\'ad\'eec \'ae\'e9c quy\'d2
n t\'ac s\'eei c\'f1a th\'b5nh ph\'e8 s\'eei v\'b5o tay m\'e9t t\'cbp \'aeo\'b5n kinh doanh Nh\'cbt.
\par Cu\'e8i n\'a8m 1921, nh\'f7ng ng\'ad\'eai l\'b5m thu\'aa cho ch\'f1 xe k\'d0o n\'ad\'edc ngo\'b5i, bao g\'e5m 3.000 ng\'ad\'eai tham gia nghi\'d6p \'aeo\'b5n, \'ae\'b7 \'ae\'d7nh c\'abng. V\'d7 vi\'d6c gi\'b6m l\'ad\'acng \'ae\'ad\'eec th\'f9c hi\'d6
n do s\'b8ng ki\'d5n c\'f1a c\'b8c ch\'f1 ng\'ad\'eai Ph\'b8p (900 xe k\'d0o), n\'aan nh\'f7ng ng\'ad\'eai \'ae\'d7nh c\'abng \'ae\'e3i r\'b8ch \'ae\'b7 t\'e6 ch\'f8c m\'e9t \'aeo\'b5n "\'a8n xin" tu\'c7n h\'b5nh trong t\'ab gi\'edi Ph\'b8p. C\'b6nh s\'b8
t Ph\'b8p gi\'b6i t\'b8n cu\'e9c bi\'d3u t\'d7nh v\'b5 b\'bet giam nh\'f7ng ng\'ad\'eai l\'b7nh \'ae\'b9o. C\'c7n nh\'ed r\'bbng: b\'e4n ch\'f1 Ph\'b8p c\'e3 to\'b5 \'b8n v\'b5 nh\'b5 giam ri\'aang \'ae\'d3 x\'d0t x\'f6 v\'b5 giam gi\'f7 nh\'f7ng ng\'ad
\'eai culi xe kh\'abng th\'d3 tr\'b6 n\'e6i ti\'d2n thu\'d5. Nh\'f7ng ng\'ad\'eai b\'de b\'bet giam b\'de \'ae\'e8i x\'f6 t\'b5n t\'d6 v\'b5 nhi\'d2u ng\'ad\'eai \'ae\'b7 ch\'d5t.
\par Nh\'f7ng n\'a8m g\'c7n \'ae\'a9y, c\'e3 kho\'b6ng 200 culi xe b\'de b\'e4n ch\'f1 gi\'d5t h\'b9i.
\par Trong s\'e8 20 t\'ea b\'b8o xu\'cat b\'b6n \'eb H\'b8n Kh\'c8u, c\'abng nh\'a9n c\'e3 hai t\'ea b\'b8o h\'bbng ng\'b5y v\'b5 m\'e9t t\'ea b\'b8o h\'bbng tu\'c7n. M\'c6c d\'c7u b\'e4n t\'ad b\'b6n n\'ad\'edc ngo\'b5i v\'b5 t\'ad b\'b6n b\'b6n x\'f8 c\'e8 h
\'d5t s\'f8c d\'cbp t\'bet ho\'c6c ng\'a8n c\'b6n m\'e4i phong tr\'b5o gi\'b6i ph\'e3ng, nh\'adng nh\'f7ng ng\'ad\'eai c\'abng nh\'a9n Trung Qu\'e8c \'ae\'ad\'eec s\'f9 gi\'f3p \'ae\'ec m\'b9nh m\'cf c\'f1a nh\'f7ng ng\'ad\'eai tr\'dd th\'f8c t\'cbn t\'f4
y, \'ae\'b7 t\'e6 ch\'f8c l\'b9i m\'e9t c\'b8ch nhanh ch\'e3ng v\'b5 h\'b5nh \'ae\'e9ng t\'e8t \'ae\'d1p.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 nguy\'d4n \'b8i qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 La Vie Ouvri\'ccre,}{\insrsid1378858 

\par ng\'b5y 16-3-1923.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }{\b\f37\fs20\insrsid1378858 
\par 
\par 
\par }\pard\plain \s20\qc \li0\ri0\sb1680\sa480\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 CU\'e9C B\'b9O \'a7\'e9NG \'eb \'a7AH\'a4M\'a2y}{
\super\insrsid1378858 33}{\insrsid1378858 
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-320\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~Nh\'f7ng n\'ab l\'d6 c\'f1a G\'acbekhandin, h\'acn 30 n
\'a8m tr\'ad\'edc \'ae\'a9y, \'ae\'b7 tho\'b8t kh\'e1i \'b8ch n\'ab l\'d6 c\'f1a \'a7\'e8tx\'ac v\'b5 L\'acben, l\'b5 nh\'f7ng anh h\'efng c\'f1a nh\'f7ng chi\'d5n c\'abng vang d\'e9i m\'e9t th\'eai, - b\'a9y gi\'ea l\'b9i \'ae\'ad\'eec l\'b5m quen v\'ed
i n\'ad\'edc Ph\'b8p "v\'a8n minh". C\'c7n ph\'b6i n\'e3i th\'bcng ra r\'bbng, v\'d7 l\'fd do \'ae\'e3 m\'b5 nh\'f7ng v\'de quan cai tr\'de th\'f9c d\'a9n c\'f1a ch\'f3ng ta \'ae\'b7 n\'a9ng ng\'ad\'eai \'a7ah\'abm\'a9y l\'aan c\'b8i danh hi\'d6u l\'b5 c
\'abng d\'a9n n\'ad\'edc Ph\'b8p.
\par \'a7\'a9y l\'b5 m\'e9t s\'e8 chi ti\'d5t v\'d2 nh\'f7ng s\'f9 ki\'d6n, trong \'ae\'e3, c\'b8c nh\'b5 t\'ad b\'b6n th\'f9c d\'a9n \'ae\'e8i x\'f6 v\'edi nh\'f7ng ng\'ad\'eai b\'b7i c\'abng \'eb Po\'e3ct\'ab - N\'abv\'ab gi\'e8ng nh\'ad h\'e4 \'aeang \'ae
\'e8i x\'f6 v\'edi c\'abng nh\'a9n \'eb Havr\'ac v\'b5 Xar\'acbuy Ken.
\par }\pard \s15\qj \fi397\li0\ri0\sa80\sl-300\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 Ng\'b5y 12 th\'b8ng 2, - ng\'b5y h\'abm sau khi \'abng H\'a8ngri Misen, \'ae\'b9i bi\'d3u c\'f1a H\'e9i \'ae\'e5ng thu\'e9c 
\'ae\'dea t\'e8i cao \'aei kh\'e1i, - m\'e9t l\'b5n s\'e3ng k\'ddch \'ae\'e9ng \'ae\'e9t nhi\'aan bao tr\'efm to\'b5n d\'a9n th\'b5nh ph\'e8 Po\'e3ct\'ab - N\'abv\'ab; b\'bet \'ae\'c7u nh\'f7ng cu\'e9c bi\'d3u t\'d7nh k\'ccm theo nh\'f7ng cu\'e9c b\'b7i c
\'abng c\'f1a c\'abng nh\'a9n b\'b6n x\'f8 l\'b5m vi\'d6c trong c\'b8c c\'abng tr\'ad\'eang x\'a9y d\'f9ng c\'f1a th\'b5nh ph\'e8.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-320\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ng\'b5y 18 th\'b8ng 2, nh\'f7ng ng\'ad\'eai bi\'d3u t\'d7
nh t\'e6 ch\'f8c m\'e9t cu\'e9c h\'e4p to\'b5n th\'d3. C\'b6nh s\'b8t \'ae\'b7 gi\'b6i t\'b8n h\'e4 v\'b5 b\'bet \'aei 10 c\'abng nh\'a9n.
\par Cu\'e9c chi\'d5n \'ae\'cau b\'bet \'ae\'c7u. Nh\'f7ng nh\'e3m c\'abng nh\'a9n b\'b7i c\'abng, c\'e3 nhi\'d2u ng\'ad\'eai d\'a9n b\'b6n x\'f8 tham gia, \'ae\'b7 chi\'d5m c\'b8c b\'e8t g\'b8c \'eb xung quanh Po\'e3ct\'ab - N\'abv\'ab v\'b5 \'aeu\'e6i h\'d5
t c\'b6nh s\'b8t kh\'e1i c\'b8c b\'e8t g\'b8c \'cay. Sau \'ae\'e3, \'ae\'b7 x\'b6y ra cu\'e9c \'ae\'f4ng \'ae\'e9 \'ae\'c7u ti\'aan gi\'f7a nh\'f7ng ng\'ad\'eai b\'b9o \'ae\'e9ng v\'edi l\'ddnh b\'e9 binh do vi\'aan quan cai tr\'de - \'abng Satxecl\'ab, c
\'cap t\'e8c ph\'b8i \'ae\'d5n. Qu\'a9n \'ae\'e9i n\'e6 s\'f3ng. Nh\'adng nh\'f7ng ng\'ad\'eai \'ae\'d7nh c\'abng c\'f2ng \'ae\'b7 \'ae\'ad\'eec v\'f2 trang. H\'e4 \'ae\'b7 b\'ben tr\'b6. Tr\'aan m\'c6t \'ae\'cat c\'dfn l\'b9i n\'a8m ng\'ad\'eai ch\'d5
t: m\'e9t vi\'aan cai v\'b5 b\'e8n ng\'ad\'eai d\'a9n b\'b6n x\'f8.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-332\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 S\'f9 k\'ddch \'ae\'e9ng t\'a8ng l\'aan. Theo l\'d6nh c\'f1a \'abng M\'d0clanh, to\'b5n quy\'d2n T\'a9y Phi, t\'d7nh tr
\'b9ng gi\'edi nghi\'aam \'ae\'ad\'eec ban b\'e8 trong t\'cat c\'b6 c\'b8c khu \'eb Po\'e3ct\'ab - N\'abv\'ab. Ba trung \'aeo\'b5n l\'ddnh b\'e9 binh c\'e3 s\'f3ng m\'b8y v\'b5 }{\i\f37\fs20\insrsid1378858 ph\'b8o d\'b7 chi\'d5n}{\f37\fs20\insrsid1378858 
 \'ae\'ad\'eec \'ae\'ada xu\'e8ng t\'b5u v\'cbn t\'b6i "}{\f38\fs20\insrsid1378858 TS\'b8T}{\f37\fs20\insrsid1378858 " \'eb \'a7aca. Ngo\'b5i ra, chi\'d5c t\'b5u tu\'c7n ti\'d4u "C\'b8txi\'abp\'aa" \'ae\'ad\'eec \'ae\'ada ngay l\'cbp t\'f8c \'ae\'d5n Po
\'e3ct\'ab - N\'abv\'ab. C\'efng m\'e9t l\'f3c v\'edi vi\'d6c \'aei\'d2u \'ae\'e9ng l\'f9c l\'ad\'eeng qu\'a9n \'ae\'e9i, ng\'ad\'eai ta ti\'d5n h\'b5nh c\'b8c cu\'e9c b\'bet b\'ed.
\par "M\'ad\'eai ng\'ad\'eai th\'f1 x\'ad\'edng", trong \'ae\'e3 c\'e3 Uybeliu v\'b5 \'a3chi\'aan T\'aat\'aa, b\'de 
\par }\pard \qj \li0\ri0\sa80\sl-332\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 b\'e1 t\'ef. Nh\'f7ng cu\'e9c \'ae\'b5n \'b8p t\'b5n nh\'c9n di\'d4n ra kh\'bep n\'aci.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-332\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Ng\'ad\'eai ta \'ae\'b7 bu\'e9c c\'abng nh\'a9n Po\'e3ct
\'ab - N\'abv\'ab tr\'eb l\'b9i l\'b5m vi\'d6c b\'bbng l\'ad\'eci l\'aa v\'b5 d\'efi cui. Nh\'adng l\'b5n s\'e3ng k\'ddch \'ae\'e9ng v\'c9n lan r\'e9ng \'eb n\'abng th\'abn. C\'b8c b\'b8o thu\'e9c \'ae\'dea, \'ae\'c6c bi\'d6t l\'b5 t\'ea }{
\i\insrsid1378858 D\'d0p\'aache Coloniale}{\insrsid1378858  \'ae\'dfi thi h\'b5nh ngay nh\'f7ng h\'d7nh ph\'b9t t\'b5n kh\'e8c v\'b5 chuy\'d3n v\'cbn m\'d6nh c\'f1a \'a7ah\'abm\'a9y sang cho nh\'f7ng b\'b5n tay c\'f8ng r\'ben h\'acn.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-332\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ch\'f3ng ta ph\'b6i r\'f3t ra nh\'f7ng k\'d5t lu\'cbn nghi
\'aam t\'f3c t\'f5 nh\'f7ng s\'f9 ki\'d6n n\'b5y, c\'f4 th\'d3 l\'b5: trong c\'b8c thu\'e9c \'ae\'dea, c\'abng nh\'a9n \'ae\'b7 b\'bet \'ae\'c7u hi\'d3u th\'d5 n\'b5o l\'b5 \'ae\'cau tranh giai c\'cap. C\'c7n ph\'b6i l\'b5m th\'d5 n\'b5o \'ae\'d3 cho c
\'abng nh\'a9n da \'aeen v\'b5 da v\'b5ng c\'f2ng hi\'d3u r\'bbng: K\'ce th\'ef duy nh\'cat c\'f1a h\'e4 n\'bbm ngay trong b\'b6n th\'a9n c\'b8i ch\'d5 \'ae\'e9 n\'b5y, ch\'d5 \'ae\'e9 \'aeang d\'c9n \'ae\'d5n m\'e9t ch\'d5 \'ae\'e9 n\'ab l\'d6 tinh vi h
\'acn, n\'c6ng n\'d2 h\'acn, v\'b5 v\'ab nh\'a9n \'ae\'b9o h\'acn ch\'d5 \'ae\'e9 tr\'ad\'edc \'ae\'a9y. V\'b5 ch\'d8 v\'edi s\'f9 gi\'f3p \'ae\'ec c\'f1a nh\'f7ng ng\'ad\'eai anh em b\'de \'b8p b\'f8c
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-332\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 c\'f1a m\'d7nh \'eb c\'b8c n\'ad\'edc ch\'a9u \'a2u, h\'e4 m
\'edi s\'cf c\'e3 th\'d3 t\'f9 gi\'b6i ph\'e3ng \'ae\'ad\'eec m\'d7nh.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 nguy\'d4n \'b8i qu\'e8c
