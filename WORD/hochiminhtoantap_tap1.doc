\par \~
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \column 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'e9I \'b8C C\'f1A CH\'f1 NGH\'dcA TH\'f9C D\'a2N

\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-288\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~"D\'ad\'edi s\'f9 b\'b6o tr\'ee c\'f1a n\'ad\'edc Ph\'b8
p, x\'f8 \'a7\'abng D\'ad\'acng \'aeang theo \'aeu\'e6i m\'e9t c\'b8ch ho\'b5 b\'d7nh v\'cbn m\'d6nh c\'f1a m\'d7nh, v\'b5 th\'ada c\'b8c ng\'b5i, c\'b8c ng\'b5i \'ae\'b7 th\'cay b\'bbng ch\'f8ng t\'e8t \'ae\'d1p nh\'cat r\'bbng x\'f8 \'ae\'e3 \'aeang h
\'b9nh ph\'f3c". \'a7\'cay, \'abng Ut\'acr\'a9y, ngh\'de s\'dc x\'f8 Nam K\'fa (?) \'ae\'b7 n\'e3i nh\'ad v\'cby v\'edi c\'b8c \'ae\'e5ng s\'f9 \'eb Ngh\'de vi\'d6n Ph\'b8p.
\par Trong t\'cbp san th\'b8ng t\'b8m, H\'e9i Nh\'a9n quy\'d2n v\'b5 D\'a9n quy\'d2n v\'f5a ch\'f8ng minh cho ch\'f3ng ta bi\'d5t \'a7\'abng D\'ad\'acng h\'b9nh ph\'f3c nh\'ad th\'d5 n\'b5o v\'b5 n\'ad\'edc Ph\'b8p \'ae\'ad\'eec \'ae\'b9i di\'d6n t\'e8t \'ae
\'d1p nh\'ad th\'d5 n\'b5o.
\par Ch\'f3ng t\'abi xin t\'e3m t\'bet b\'bbng m\'cay d\'dfng sau \'ae\'a9y:
\par Nh\'ad \'eb t\'cat c\'b6 c\'b8c t\'d8nh, m\'e9t t\'d8nh B\'bec K\'fa c\'f2ng c\'e3 m\'e9t v\'de c\'abng s\'f8 Ph\'b8p. Nh\'ad t\'cat c\'b6 c\'b8c v\'de c\'abng s\'f8 Ph\'b8p \'eb B\'bec K\'fa, v\'de c\'abng s\'f8 \'eb t\'d8nh m\'b5 ch\'f3ng t\'abi n\'e3
i t\'edi, \'ae\'ad\'eec trao cho m\'e9t quy\'d2n h\'b5nh v\'ab h\'b9n. \'a4ng ta l\'b5 ch\'f1 t\'d8nh, \'ae\'e8c l\'fd, ch\'b8nh \'b8n, m\'e2 to\'b5, ch\'f1 th\'c7u. \'a4ng ki\'aam nhi\'d6m t\'cat c\'b6 m\'e4i quy\'d2n h\'b5nh: t\'ad ph\'b8p, thu\'d5 v
\'f4, sinh m\'d6nh v\'b5 t\'b5i s\'b6n c\'f1a ng\'ad\'eai b\'b6n x\'f8, vi\'d6c b\'c7u c\'f6 nh\'f7ng ng\'ad\'eai c\'c7m quy\'d2n b\'b6n x\'f8, quy\'d2n l\'eei c\'f1a c\'abng ch\'f8c, v\'a9n v\'a9n v\'b5 v\'a9n v\'a9n.
\par }\pard \qj \fi397\li0\ri0\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 V\'de quan ch\'f8c cao c\'cap \'ae\'e3 \'ae\'b7 d\'efi m\'b5i t\'cat c\'b6 khoa h\'e4c ch\'ddnh tr\'de v\'b5 h\'b5nh ch\'dd
nh \'eb khu ph\'e8 la tinh m\'b5 \'abng ta v\'e8n l\'b5m ngh\'d2... b\'b8n ch\'b8o. B\'de n\'ee nh\'ad ch\'f3a ch\'e6m v\'b5 kh\'abng c\'dfn m\'e9t xu d\'ddnh t\'f3i, \'abng ta may m\'ben \'ae\'ad\'eec m\'e9t ch\'ddnh kh\'b8ch c\'e3 th\'d5 l\'f9c "\'ae
\'d2 b\'b9t" cho l\'b5m c\'abng s\'f8 ph\'f4 
\par }\pard \qj \li0\ri0\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 tr\'b8ch m\'e9t t\'d8nh c\'e3 h\'b5ng ngh\'d7n ng\'ad\'eai.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858\charrsid5980464 Ngo\'b5i vi\'d6c \'abng ta bi\'d5t b\'bet gi\'f7, t\'e8ng giam v\'b5 k\'d5t \'b8n m\'e9t c\'b8ch}{
\f37\fs20\insrsid1378858 
\par }\pard\plain \s15\qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'ae\'e9c \'aeo\'b8n nh\'f7ng ng\'ad\'eai An Nam \'ae\'d3 th\'f3
c thu\'d5 h\'e4, \'abng ta c\'dfn bi\'d5t th\'f5a h\'ad\'ebng c\'f1a n\'d2n C\'e9ng ho\'b5 v\'b5 t\'ab \'aei\'d3m tri\'d2u \'ae\'b9i c\'f1a m\'d7nh b\'bbng nh\'f7ng chi\'d5n t\'ddch m\'b5 sau \'ae\'a9y l\'b5 v\'b5i v\'dd d\'f4:
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Nh\'f7ng ng\'ad\'eai t\'d7nh nguy\'d6n b\'b6n x\'f8
 - theo h\'e4 n\'e3i - \'ae\'ad\'eec d\'c9n t\'edi \'ae\'d3 sung v\'b5o l\'ddnh kh\'e8 xanh v\'b5 \'ae\'ad\'eec kh\'b8m s\'f8c kho\'ce \'ae\'d3 tuy\'d3n m\'e9. \'a7\'cay l\'b5 nh\'f7ng ng\'ad\'eai d\'a9n m\'ef ch\'f7, s\'ee s\'d6t m\'b5 quan c\'abng s\'f8
 m\'beng ch\'f6i v\'b5 n\'bem tay \'ae\'cam, l\'cay g\'cby v\'f4t v\'d7 h\'e4 tr\'b6 l\'eai h\'aci ch\'cbm ch\'b9p.
\par \'a4ng \'ae\'b7 hung b\'b9o n\'bem tay \'ae\'cam ba ng\'ad\'eai l\'ddnh b\'b6n x\'f8 v\'d7 h\'e4 \'ae\'b7 l\'b5m s\'e6ng m\'e9t ng\'ad\'eai t\'ef, \'abng t\'f3m t\'e3c k\'d0o l\'aa h\'e4 d\'ad\'edi \'ae\'cat, \'ae\'cbp \'ae\'c7u h\'e4 v\'b5o t\'ad\'ea
ng to\'b5 s\'f8.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Khi h\'e1i cung t\'ef, quan c\'abng s\'f8 l\'cay ki\'d5m ch\'ddch v\'b5o \'ae\'efi h\'e4. C\'e3 ng\'ad\'eai \'ae\'b7 ng
\'cat khi \'ae\'ada tr\'eb l\'b9i nh\'b5 giam.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nh\'f7ng ng\'ad\'eai t\'ef kh\'e8n kh\'e6 \'a8n kh\'abng 
\'ae\'f1 no, \'b8o qu\'c7n r\'b8ch r\'ad\'edi, d\'cby t\'f5 s\'b8ng s\'edm cho \'ae\'d5n t\'e8i m\'det, g\'abng \'aeeo c\'e6, xi\'d2ng to x\'ddch ch\'a9n, ng\'ad\'eai n\'e4 x\'ddch v\'b5o ng\'ad\'eai kia, ph\'b6i k\'d0o b\'b8nh xe lu, chi\'d5c b\'b8
nh xe lu to t\'ad\'edng m\'b5 h\'e4 ph\'b6i l\'a8n tr\'aan m\'c6t \'ae\'ad\'eang r\'b6i \'ae\'b8 d\'b5y. B\'de ki\'d6t s\'f8c, h\'e4 kh\'e3 nh\'e4c l\'aa b\'ad\'edc d\'ad\'edi m\'c6t tr\'eai n\'e3ng b\'e1ng. Quan c\'abng s\'f8 \'ae\'d5n, c\'c7m m\'e9t chi
\'d5c g\'cby l\'edn theo th\'e3i quen, v\'b5 v\'edi th\'e3i t\'b5n b\'b9o kh\'abng th\'d3 t\'ad\'ebng t\'ad\'eeng, y v\'ab c\'ed l\'c7n l\'ad\'eet vung g\'cby \'ae\'b8nh nh\'f7ng ng\'ad\'eai kh\'e8n kh\'e6 \'ae\'e3, m\'beng ch\'f6i h\'e4 l\'ad\'eai bi\'d5
ng.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 M\'e9t h\'abm, nh\'b5 khai ho\'b8 c\'f1a ch\'f3ng ta, v
\'f5a khi\'d3n tr\'b8ch m\'e9t nh\'a9n vi\'aan ng\'ad\'eai \'a2u, v\'b5 kh\'abng bi\'d5t tr\'f3t t\'f8c gi\'cbn v\'b5o \'ae\'a9u, y v\'ed m\'e9t c\'b8i th\'ad\'edc s\'bet tr\'aan b\'b5n gi\'cay v\'b5 \'ae\'b8nh g\'b7y hai ng\'e3n tay c\'f1a m\'e9t ng\'ad
\'eai th\'ad k\'fd b\'b6n x\'f8 kh\'abng c\'e3 li\'aan quan g\'d7 \'ae\'d5n vi\'d6c n\'b5y.
\par M\'e9t h\'abm kh\'b8c, y l\'cay roi v\'f4t v\'b5o m\'c6t m\'e9t vi\'aan cai b\'b6n x\'f8 tr\'ad\'edc m\'c6t binh l\'ddnh c\'f1a anh ta.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 M\'e9t l\'c7n kh\'b8c, y ch\'abn ng\'cbp \'ae\'d5n c\'e6 nh
\'f7ng ng\'ad\'eai l\'ddnh tr\'b8i \'fd y v\'b5 ch\'d8 cho \'ae\'b5o l\'aan khi h\'e4 \'ae\'b7 g\'c7n ch\'d5t.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Khi y \'ae\'d5n nh\'f7ng con \'ae\'ad\'eang m\'b5 y b\'be
t nh\'f7ng ng\'ad\'eai b\'b6n x\'f8 ph\'b6i l\'b5m v\'edi ng\'b5y c\'abng m\'e9t hay hai xu, sau khi \'ae\'b7 b\'bet h\'e4 ph\'b6i chu\'e9c ng\'b5y lao d\'dech v\'edi gi\'b8 m\'ad\'eai l\'a8m xu m\'e9t ng\'b5y, th\'d7 ng\'ad\'eai ta \'ae\'d5m th\'cay h
\'b5ng t\'b8 ng\'ad\'eai g\'b7y ch\'a9n v\'d7 b\'de \'ae\'b8nh b\'bbng x\'ceng v\'b5 c\'b8n cu\'e8c.
\par M\'e9t l\'c7n, t\'b9i m\'e9t c\'abng tr\'ad\'eang, y v\'ed l\'cay s\'f3ng c\'f1a m\'e9t ng\'ad\'eai gi\'b8m th\'de \'ae\'d3 \'ae\'b8nh m\'e9t ng\'ad\'eai t\'ef. Ng\'ad\'eai t\'ef n\'b5y t\'d7m c\'b8ch l\'c8n tr\'b8nh \'ae\'ad\'eec, quan c\'abng s\'f8
 quay l\'b9i ng\'ad\'eai g\'b8c v\'b5 d\'efng kh\'c8u s\'f3ng \'ae\'e3 \'ae\'b8nh lu\'abn. Ng\'ad\'eai v\'ee x\'f8ng \'ae\'b8ng c\'f1a quan, b\'b5 c\'abng s\'f8, c\'f2ng can thi\'d6p v\'b5o, b\'b5 s\'bdn s\'b5ng \'ae\'b8nh nh\'f7ng ng\'ad\'eai t\'ef v\'b5
 nh\'a9n d\'dep \'ae\'e3 ph\'b9t nh\'f7ng ng\'ad\'eai l\'ddnh.
\par Ng\'ad\'eai ta \'ae\'b7 th\'cay quan c\'abng s\'f8 d\'efng g\'cby \'ae\'b8nh l\'dfi m\'bet m\'e9t vi\'aan cai.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Th\'ada c\'b8c ng\'b5i, c\'b8c ng\'b5i \'ae\'ad\'eec th\'ca
y d\'ad\'edi s\'f9 b\'b6o h\'e9 c\'f1a n\'ad\'edc Ph\'b8p nh\'a9n t\'f5, x\'f8 \'a7\'abng D\'ad\'acng h\'b9nh ph\'f3c bi\'d5t nh\'ad\'eang n\'b5o? V\'b5 \'ae\'cay ch\'d8 m\'edi l\'b5 m\'e9t h\'b5ng m\'c9u c\'f1a c\'b8i kho v\'a8n minh th\'ad\'eeng \'ae
\'bcng.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 NGUY\'d4N \'b8I QU\'e8C
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 La Vie Ouvri\'ccre,}{\insrsid1378858 
\line s\'e8 126, ng\'b5y 30-9-1921.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par 
\par 
