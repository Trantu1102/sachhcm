\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-294\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~Tuy \'ae\'b7 \'eb thu\'e9c \'ae\'dea l\'a9u n\'a8m, b
\'b9n X\'abra c\'f1a t\'abi l\'b5 m\'e9t ng\'ad\'eai d\'d4 th\'ad\'acng. Anh l\'b9i r\'cat l\'b5 h\'e3m h\'d8nh, \'aei\'d2u r\'cat hi\'d5m th\'cay trong gi\'edi anh. Anh c\'e3 th\'e3i quen k\'fa qu\'c6c l\'b5 khi n\'e3i, g\'c6p v\'c7n n\'b5o b\'bet \'ae
\'c7u b\'bbng \'a9m c\'ea l\'b5 c\'f8 l\'c6p \'aei l\'c6p l\'b9i hai l\'c7n li\'d2n, khi\'d5n c\'b8ch n\'e3i c\'f1a anh s\'cf tr\'eb n\'aan ng\'e4t ng\'b5o v\'b5 th\'f3 v\'de kh\'b8c th\'ad\'eang.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-294\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 H\'abm n\'e4 anh \'ae\'d5n th\'a8m t\'abi. Ch\'d8 nh\'d7n 
\'ae\'abi m\'bet anh n\'cap sau \'ae\'abi m\'f4c k\'d8nh to t\'ad\'edng, t\'abi \'aeo\'b8n ngay anh s\'bep tu\'abn ra m\'e9t \'aei\'d2u ba hoa g\'d7 \'ae\'e3 m\'b5 anh th\'ad\'eang n\'e3i. Qu\'b6 kh\'abng sai.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-294\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 - N\'b5y \'abng c\'f4 m\'d7nh, n\'b5y! Anh b\'bet tay t
\'abi, n\'e3i. M\'e9t Vi\'d6n h\'b5n... h\'b5n l\'a9m khoa h\'e4c thu\'e9c... thu\'e9c \'ae\'dea}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s30\ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f42\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd0\expndtw2\insrsid1378858 1) }{\i\f37\expnd0\expndtw2\insrsid1378858\charrsid7345493 Acad\'d0mie des Sciences Coloniales. }{\f37\expnd0\expndtw2\insrsid1378858\charrsid7345493 C\'e3 nh\'f7
ng v\'c7n ca, co, b\'bet \'ae\'c7u b\'bbng \'a9m c\'ea, theo t\'cbt c\'f1a nh\'a9n v\'cbt X\'abra, th\'d7 t\'b8c gi\'b6 cho y n\'e3i l\'bep ca-ca, c\'ac-c\'ac... kh\'abng nh\'f7ng nghe ngang tai (v\'b5 th\'f3 v\'de theo c\'b8ch n\'e3i m\'d8a mai c\'f1a t
\'b8c gi\'b6), m\'b5 c\'dfn g\'eei ra nh\'f7ng \'fd ni\'d6m th\'ab t\'f4c bu\'e5n c\'ad\'eai (caca c\'e3 ngh\'dca l\'b5 ph\'a9n, coco c\'e3 ngh\'dca l\'b5 t\'aan qu\'cay). T\'b8c gi\'b6 h\'ad c\'cau chi ti\'d5t \'ae\'e3 \'ae\'d3 mua vui, d\'ad\'edi c\'e3
 tr\'eb l\'b9i v\'b5i l\'c7n n\'f7a, nh\'ad khi n\'e3i \'ae\'d5n candidat, \'f8ng c\'f6 vi\'aan (can can c\'e3 ngh\'dca l\'b5 chuy\'d6n ba l\'b8p), nh\'adng t\'b8c gi\'b6 b\'e1 qua nhi\'d2u tr\'ad\'eang h\'eep kh\'b8c m\'b5 v\'c9n c\'e3 \'a9m c\'ea l\'be
p l\'b9i hai l\'c7n kh\'abng c\'e3 ngh\'dca bu\'e5n c\'ad\'eai nh\'ad \'eb nh\'f7ng tr\'ad\'eang h\'eep v\'f5a n\'e3i.}})}{\f37\fs20\super\insrsid1378858  }{\f37\fs20\insrsid1378858 \'ae\'b7 \'ae\'ad\'eec th\'b5nh l\'cbp, c\'cbu bi\'d5t ch\'f8?
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 - Bi\'d5t, }{\f38\fs20\insrsid1378858 \'f5!}{\f37\fs20\insrsid1378858  Th\'d7 sao?
\par }\pard \qj \fi397\li0\ri0\sa80\sl-254\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 - }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  \'ae\'cay c\'e3 m\'e9t Ban \'ae\'dea l\'fd, m\'e9t Ban m
\'fc ngh\'d6, m\'e9t Ban gi\'b8o d\'f4c, t\'f8c l\'b5 c\'e3 bao nhi\'aau ng\'ad\'eai c\'c7n g\'b8n v\'b5o th\'d7 c\'e3 b\'cay nhi\'aau ban. Nh\'adng ng\'ad\'eec l\'b9i, th\'d5 v\'c9n c\'dfn thi\'d5u m\'e9t ban, ban quan tr\'e4ng nh\'cat \'ae\'d3 cho m\'e9
t vi\'d6n lo\'b9i c\'e3 t\'c7m c\'ec n\'e6i b\'cbt l\'aan.
\par - L\'b5 ban g\'d7 v\'cby?
\par - T\'ed \'ae\'b7 n\'e3i \'ae\'cay: l\'b5 Ban \'ae\'b9o l\'fd... thu\'e9c... thu\'e9c \'ae\'dea.
\par - \'a7\'d3 mex\'f5}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {
\insrsid1378858 1) }{\i\insrsid1378858 Mossieu, }{\insrsid1378858 t\'f8c}{\i\insrsid1378858  Monsieur}{\insrsid1378858 , nh\'b9i c\'b8ch ph\'b8t \'a9m c\'f1a ng\'ad\'eai ch\'a9u Phi thu\'e9c Ph\'b8p.}})}{\f37\fs20\insrsid1378858  X\'abra l\'b5m tr\'ad\'eb
ng ban ch\'f8 g\'d7?
\par - Kh\'abng! \'a7\'ddt t\'ed \'ae\'a9u c\'e3 c\'b8i th\'ed h\'b5n... h\'b5n l\'a9m, nh\'adng t\'ed c\'e3 m\'e9t danh s\'b8ch nh\'f7ng ng\'ad\'eai l\'ad\'acng thi\'d6n, li\'aam khi\'d5t, y\'aau n\'ad\'edc, x\'f8ng \'ae\'b8ng \'ae\'ad\'eec \'ae\'d2 ngh\'de 
\'ae\'ada v\'b5o h\'b5ng b\'cat tri\'d6t (hay b\'cat t\'f6 nh\'ad ng\'ad\'eai ta g\'e4i theo c\'b8ch th\'abng t\'f4c). \'a7\'a9y l\'b5 h\'e4, t\'aan, ngh\'d2 nghi\'d6p c\'f1a nh\'f7ng v\'de \'f8ng... \'f8ng c\'f6 vi\'aan c\'f1a t\'ed!
\par C\'b8c \'abng:
\par \'a1ng\'aer\'aa B\'d0ct\'abl\'ab, th\'ad\'eeng ngh\'de s\'dc qu\'cbn Xen, Gi\'b8m \'ae\'e8c tuy\'d5n \'ae\'ad\'eang s\'bet t\'f5 C\'abngg\'ab Th\'ad\'eeng \'ae\'d5n v\'efng H\'e5 L\'edn ch\'a9u Phi.
\par Sanh\'ab L\'aa\'abng, th\'ad\'eeng ngh\'de s\'dc qu\'cbn Cr\'acd\'ac, Gi\'b8m \'ae\'e8c c\'abng ty v\'cbn t\'b6i Mar\'e8c.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-254\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Saxt\'acn\'aa Ghi\'abm, th\'ad\'eeng ngh\'de s\'dc qu\'cb
n Gir\'abng\'ae\'ac, Gi\'b8m \'ae\'e8c H\'e9i h\'eep nh\'cat Liegi\'ac \'ae\'aa Ham\'a8ng\'aea - Ti\'d3u Kabili.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-254\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 C\'abk\'aa (Gi\'a8ng), th\'ad\'eeng ngh\'de s\'dc qu\'cb
n R\'abn, Gi\'b8m \'ae\'e8c t\'e6 h\'eep k\'fc ngh\'d6 v\'b5 th\'ad\'acng m\'b9i B\'bec Phi.
\par C\'abxne (H\'a8ngri), th\'ad\'eeng ngh\'de s\'dc qu\'cbn Anh\'aer\'ac, Gi\'b8m \'ae\'e8c C\'abng ty Phi ch\'a9u v\'d2 th\'ad\'acng m\'b9i, k\'fc thu\'cbt v\'b5 canh n\'abng.
\par M\'b8cxan (Phr\'a8ngxoa), th\'ad\'eeng ngh\'de s\'dc qu\'cbn C\'a8ngta, Gi\'b8m \'ae\'e8c H\'e9i bu\'abn b\'b8n T\'a9y Phi.
\par Gi\'aara (Anbe), th\'ad\'eeng ngh\'de s\'dc qu\'cbn Ac\'aeen, Gi\'b8m \'ae\'e8c C\'abng ty k\'d2n T\'a9n Cal\'aa\'ae\'abni.
\par Gr\'ab\'aei\'aei\'aa, th\'ad\'eeng ngh\'de s\'dc qu\'cbn M\'acd\'ac, Gi\'b8m \'ae\'e8c C\'abng ty v\'cbn t\'b6i \'eb Mar\'e8c.
\par }\pard \qj \li0\ri0\sa80\sl-250\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 H\'c7u t\'ad\'edc \'a7\'ac M\'abngteguy, th\'ad\'eeng ngh\'de s\'dc qu\'cbn Loa H\'b9, Gi\'b8m \'ae\'e8c c\'b8c \'ae\'ad\'ea
