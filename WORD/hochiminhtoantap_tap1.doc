\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa360\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'b8C N\'a6\'edC \'a7\'d5 QU\'e8C CH\'f1 NGH\'dcA
\line V\'b5 TRUNG QU\'e8C}{\cs17\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {
\insrsid1378858 1) M\'e9t ph\'c7n b\'b5i n\'b5y \'ae\'ad\'eec \'ae\'a8ng l\'b9i tr\'aan }{\i\insrsid1378858 Le Paria}{\insrsid1378858 , s\'e8 30, th\'b8ng 10-1924 d\'ad\'edi nhan \'ae\'d2: }{\i\insrsid1378858 Kh\'abng \'ae\'ad\'eec \'ae\'f4ng \'ae\'d5
n Trung Qu\'e8c}{\insrsid1378858 .}})}{\insrsid1378858 
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Nh\'f7ng s\'f9 bi\'d5n \'eb Trung Qu\'e8c c\'e3 hai m\'c6
t: s\'f9 xung \'ae\'e9t gi\'f7a c\'b8c t\'ad\'edng l\'dcnh Trung Qu\'e8c v\'b5 s\'f9 can thi\'d6p c\'f1a c\'b8c c\'ad\'eang qu\'e8c b\'aan ngo\'b5i. Ch\'ddnh m\'c6t sau n\'b5y l\'b5m cho ch\'f3ng ta quan t\'a9m h\'acn c\'b6, v\'d7 n\'e3 quy\'d5t \'ae\'de
nh cu\'e9c chi\'d5n tranh n\'e5i da n\'cau th\'det c\'e3 th\'d3 \'ae\'ada l\'b9i nh\'f7ng h\'cbu qu\'b6 nghi\'aam tr\'e4ng nh\'cat.
\par H\'b7y th\'f6 t\'e3m t\'bet l\'dech tr\'d7nh nh\'f7ng cu\'e9c can thi\'d6p c\'f1a n\'ad\'edc ngo\'b5i trong qu\'b8 kh\'f8 \'ae\'d3 t\'d7m ra nguy\'aan nh\'a9n th\'f9c t\'d5, l\'fd do ch\'ddnh c\'f1a s\'f9 can thi\'d6p hi\'d6n t\'b9i.
\par }\pard\plain \s25\qj \li0\ri0\sb200\sa120\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 M\'e9T S\'e8 NG\'b5Y TH\'b8NG
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd0\expndtw-4\insrsid1378858 1635, vua Anh g\'f6i th\'ad y\'aau c\'c7
u cho ph\'d0p bu\'abn b\'b8n \'eb Trung Qu\'e8c.
\par }\pard\plain \qj \fi-454\li851\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin851\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 1830, \'ae\'b9i s\'f8 Anh y\'aau c\'c7u cho ph\'d0
p nh\'cbp kh\'c8u thu\'e8c phi\'d6n v\'b5o Trung Qu\'e8c. Y\'aau c\'c7u b\'de Trung Qu\'e8c b\'b8c b\'e1.
\par 1836, ng\'ad\'eai Anh nh\'cbp kh\'c8u 20.280 h\'dfm thu\'e8c phi\'d6n l\'cbu v\'b5o Trung Qu\'e8c.
\par 1839, n\'ad\'edc Anh tuy\'aan chi\'d5n v\'edi Trung Qu\'e8c \'ae\'d3 b\'bet bu\'e9c n\'ad\'edc n\'b5y ph\'b6i nh\'cbn thu\'e8c phi\'d6n.
\par }\pard \qj \fi-312\li709\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin709\itap0 {\f37\fs20\insrsid1378858 1841, H\'ad\'acng C\'b6ng b\'de chi\'d5m \'aeo\'b9t, Trung Qu\'e8c ph\'b6i b\'e5i th\'ad\'eang 21.000.000 \'ae\'e5
ng \'ae\'abla chi\'d5n ph\'dd, trong \'ae\'e3 6.000.000 \'ae\'e5ng l\'b5 \'ae\'d2n v\'b5o gi\'b8 tr\'de s\'e8 thu\'e8c phi\'d6n b\'de ph\'b8 hu\'fb.
\par }\pard \qj \fi-454\li851\ri0\sa80\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin851\itap0 {\f37\fs20\insrsid1378858 1856, n\'ad\'edc Anh g\'a9y ra m\'e9t cu\'e9c chi\'d5n tranh m\'edi \'ae\'d3 bu\'e9c Trung Qu\'e8c ph\'b6i h\'ee
p ph\'b8p ho\'b8 vi\'d6c b\'b8n thu\'e8c phi\'d6n v\'b5 m\'eb c\'f6a bi\'d3n cho n\'ad\'edc ngo\'b5i v\'b5o bu\'abn b\'b8n.
\par 1860, qu\'a9n \'ae\'e9i Anh - Ph\'b8p chi\'d5m B\'bec Kinh. Nh\'ad\'eeng b\'e9: Anh - Ph\'b8p \'ae\'ad\'eec chi\'d5m \'ae\'e3ng \'ae\'b6o V\'ddcht\'abria. B\'e5i th\'ad\'eang: 800 tri\'d6u l\'ad\'eeng}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote 
\pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) }{\i\insrsid1378858 Tael:}{\insrsid1378858  \'a7\'acn v
\'de ti\'d2n t\'d6 c\'f2 c\'f1a Trung Qu\'e8c.}})}{\f37\fs20\insrsid1378858  cho Ph\'b8p v\'b5 10 tri\'d6u b\'b6ng cho Anh.
\par }\pard\plain \s22\qj \fi-454\li851\ri0\sa80\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin851\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 1874, Nh\'cbt B\'b6n t\'can c\'abng Trung Qu
\'e8c. Nh\'ad\'eeng b\'e9: b\'b7i b\'e1 ch\'f1 quy\'d2n c\'f1a Trung Qu\'e8c \'eb \'a7\'b5i Loan, v\'b5 \'ae\'b6o n\'b5y th\'b5nh thu\'e9c \'ae\'dea c\'f1a Nh\'cbt. B\'e5i th\'ad\'eang: 50 tri\'d6u l\'ad\'eeng.
\par }\pard\plain \qj \fi-454\li851\ri0\sa80\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin851\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 1876, chi\'d5n tranh v\'edi Nga. Nh\'ad\'eeng b\'e9
: l\'b7nh th\'e6 b\'de chi\'d5m \'ae\'e3ng. B\'e5i th\'ad\'eang: 900 tri\'d6u r\'f3p.
\par 1878, l\'b9i xung \'ae\'e9t v\'edi Anh. Nh\'ad\'eeng b\'e9: th\'f5a nh\'cbn tr\'de ngo\'b9i ph\'b8p quy\'d2n. B\'e5i th\'ad\'eang: 20 tri\'d6u l\'ad\'eeng.
\par 1885, Ph\'b8p t\'can c\'abng. Nh\'ad\'eeng b\'e9: b\'b7i b\'e1 ch\'f1 quy\'d2n Trung Qu\'e8c \'eb An Nam , n\'ad\'edc n\'b5y b\'de Ph\'b8p chi\'d5m l\'b5m thu\'e9c \'ae\'dea.
\par 1895, Nh\'cbt t\'can c\'abng. Nh\'ad\'eeng b\'e9: Trung Qu\'e8c h\'d5t ch\'f1 quy\'d2n \'eb Tri\'d2u Ti\'aan. N\'ad\'edc n\'b5y b\'de Nh\'cbt chi\'d5m l\'b5m thu\'e9c \'ae\'dea. B\'e5i th\'ad\'eang: 20 tri\'d6u l\'ad\'eeng.
\par 1895, Nga, Ph\'b8p v\'b5 \'a7\'f8c c\'efng t\'can c\'abng. Nh\'ad\'eeng b\'e9: th\'f5a nh\'cbn quy\'d2n x\'a9y d\'f9ng \'ae\'ad\'eang s\'bet. B\'e5i th\'ad\'eang: 3 t\'fb l\'ad\'eeng.
\par 1897, \'a7\'f8c x\'a9m l\'ad\'eec. Ki\'d2u Ch\'a9u b\'de chi\'d5m \'ae\'e3ng, ph\'b6i th\'f5a nh\'cbn quy\'d2n khai th\'b8c h\'c7m m\'e1.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 1897, Nga x\'a9m l\'ad\'eec. C\'f6a L\'f7 Thu\'cbn b\'de chi\'d5m.
\par 1897, Anh x\'a9m l\'ad\'eec. H\'b6i X\'a9m Uy b\'de chi\'d5m \'ae\'e3ng.
\par }\pard \qj \fi-454\li851\ri0\sa80\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin851\itap0 {\f37\fs20\insrsid1378858 1898, Ph\'b8p x\'a9m l\'ad\'eec. Th\'f5a nh\'cbn quy\'d2n thi\'d5t l\'cbp \'ae\'ad\'eang \'aei\'d6n t\'ddn \'eb
 Hoa Nam.
\par }\pard \qj \fi-454\li851\ri0\sa80\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin851\itap0 {\f37\fs20\insrsid1378858 1900, Can thi\'d6p v\'f2 trang c\'f1a Anh, Nga, \'a7\'f8c, Ph\'b8p, M\'fc, }{\f38\fs20\insrsid1378858 \'fd, \'b8}{
\f37\fs20\insrsid1378858 o v\'b5 Nh\'cbt (Cu\'e9c kh\'ebi ngh\'dca c\'f1a Ngh\'dca ho\'b5 \'aeo\'b5n}{\f37\fs20\super\insrsid1378858 52}{\f37\fs20\insrsid1378858 ). Qu\'a9n 
\par 
\par }\pard \qj \li851\ri0\sa80\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin851\itap0 {\f37\fs20\insrsid1378858 \'ae\'e9i n\'ad\'edc ngo\'b5i \'ae\'e3ng \'eb B\'bec Kinh v\'b5 \'eb c\'b8c c\'f6a bi\'d3n quan tr\'e4ng. B\'e5i th\'ad
\'eang: 450 tri\'d6u l\'ad\'eeng.
\par }\pard \qj \li851\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin851\itap0 {\f37\fs20\insrsid1378858 T\'f5 khi n\'e6 ra cu\'e9c chi\'d5n tranh th\'d5 gi\'edi, b\'e4n \'ae\'d5 qu\'e8c ch\'f1 ngh\'dca thay th\'d5 vi\'d6c \'a8
n c\'ad\'edp c\'abng khai v\'b5 v\'f2 trang b\'bbng vi\'d6c \'a8n c\'ad\'edp che \'ae\'cby v\'b5 ngo\'b9i giao. Ch\'f3ng th\'abng qua nh\'f7ng cu\'e9c h\'e9i ngh\'de, l\'c6ng l\'cf c\'ad\'edp b\'e3c Trung Qu\'e8c \'aeang \'eb trong t\'d7nh tr\'b9ng chia r
\'cf v\'b5 b\'de b\'e3 tay tr\'ad\'edc b\'e4n ch\'f3ng.
\par }\pard \qj \fi-454\li851\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin851\itap0 {\f37\fs20\insrsid1378858 1919, Hi\'d6p \'ad\'edc V\'d0cx\'a9y chuy\'d3n giao t\'cat c\'b6 nh\'f7ng t\'ab gi\'edi c\'f1a \'a7\'f8c \'eb
 Trung Qu\'e8c cho Nh\'cbt, m\'c6c d\'c7u ch\'ddnh Trung Qu\'e8c c\'f2ng l\'b5 m\'e9t n\'ad\'edc \'ae\'e5ng minh.
\par 1922, H\'e9i ngh\'de Oasinht\'acn th\'abng qua vi\'d6c c\'b8c n\'ad\'edc Anh, Ph\'b8p, M\'fc v\'b5 Nh\'cbt n\'bem l\'cay c\'b8c kho\'b6n thu nh\'cbp \'eb Trung Qu\'e8c v\'b5 n\'bem c\'b8c \'ae\'e9c quy\'d2n v\'d2 r\'ad\'eeu, mu\'e8i, v.v..
\par 1923, Th\'abng \'aei\'d6p c\'f1a c\'b8c \'ae\'b9i s\'f8 \'ae\'dfi cho Ph\'b8p, Anh, M\'fc, Nh\'cbt, v\'b5 B\'d8 quy\'d2n qu\'b6n l\'fd c\'b8c \'ae\'ad\'eang s\'bet Trung Qu\'e8c. Th\'b8ng 9 n\'a8m 1924, h\'b9m \'ae\'e9i c\'f1a c\'b8c c\'ad\'eang qu\'e8c n
\'e3i tr\'aan thao di\'d4n tr\'ad\'edc Qu\'b6ng Ch\'a9u.
\par }\pard\plain \s25\qj \li0\ri0\sb200\sa120\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'d7NH H\'d7NH TRUNG QU\'e8C
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ch\'f3ng ta \'ae\'b7 th\'cay r\'bbng, d\'ad\'edi nhi\'d2
u l\'fd do kh\'b8c nhau v\'b5 b\'bbng nhi\'d2u th\'f1 \'aeo\'b9n kh\'b8c nhau, c\'b8c n\'ad\'edc t\'ad b\'b6n ch\'f1 ngh\'dca can thi\'d6p v\'b5o Trung Qu\'e8c tr\'ad\'edc sau c\'f2ng v\'c9n ch\'d8 nh\'bbm \'aei t\'edi m\'e9t k\'d5t qu\'b6 l\'b5 b\'bet nh
\'ad\'eeng \'ae\'cat v\'b5 l\'cay ti\'d2n b\'e5i th\'ad\'eang.
\par B\'a9y gi\'ea h\'b7y nh\'d7n qua t\'d7nh h\'d7nh kinh t\'d5 v\'b5 t\'b5i ch\'ddnh c\'f1a c\'b8i n\'ad\'edc l\'edn \'cay, n\'ad\'edc c\'e3 m\'e9t n\'d2n v\'a8n minh l\'a9u \'ae\'eai v\'b5 hi\'d6n \'aeang l\'b5 \'ae\'e8i t\'ad\'eeng d\'dfm ng\'e3 c\'f1a b
\'e4n ch\'f3ng.
\par T\'f5 n\'a8m 1895, Trung Qu\'e8c \'ae\'b7 k\'fd k\'d5t 16 hi\'d6p \'ad\'edc vay m\'ad\'een, m\'b5 t\'e6ng s\'e8 l\'aan \'ae\'d5n:
\par }\pard \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\tqr\tx2552\tx2835\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 \tab 902.000.000 \tab phr\'a8ng,
\par \tab 61.500.000 \tab b\'b6ng Anh,
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\tqr\tx2552\tx2835\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 \tab 64.368.000 \tab \'ae\'abla,
\par \tab 115.000.000 \tab y\'aan,
\par \tab 1.763.000 \tab cuaron H\'b5 Lan.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Thu\'d5 quan, thu\'d5 ch\'ee, ti\'d2n thu v\'d2 \'ae\'ad\'eang s\'bet, l\'eei t\'f8c v\'d2 c\'abng nghi\'d6p, thu\'d5 r
\'ad\'eeu v\'b5 thu\'d5 thu\'e8c l\'b8, ti\'d2n thu v\'d2 b\'adu \'aei\'d6n v\'b5 ng\'a9n kh\'e8 qu\'e8c gia, thu\'d5 mu\'e8i, v.v. \'ae\'d2u ph\'b6i \'aeem ra b\'b6o \'ae\'b6m cho c\'b8i kho\'b6n vay m\'ad\'een \'cay.
\par Nh\'d7n v\'b5o b\'b6n \'ae\'e5 Trung Qu\'e8c, ta th\'cay r\'bbng h\'c7u h\'d5t c\'b8c h\'b6i c\'b6ng quan tr\'e4ng, h\'c7u h\'d5t c\'b8c v\'de tr\'dd chi\'d5n l\'ad\'eec, h\'c7u h\'d5t c\'b8c trung t\'a9m s\'b6n xu\'cat hi\'d6n \'ae\'b9i \'ae\'d2u b\'de n
\'ad\'edc ngo\'b5i chi\'d5m \'ae\'e3ng. Song b\'b6n \'ae\'e5 v\'c9n ch\'ada n\'e3i \'ae\'ad\'eec h\'d5t. B\'b6n \'ae\'e5 v\'c9n ch\'ada ch\'d8 r\'e2 \'ae\'ad\'eec \'b6nh h\'ad\'ebng c\'f1a t\'ad b\'b6n n\'ad\'edc ngo\'b5i lan r\'e9ng t\'edi \'ae\'a9u, c
\'f2ng ch\'ada ch\'d8 r\'e2 \'ae\'ad\'eec t\'c7m \'ae\'b9i b\'b8c c\'f1a b\'e4n \'ae\'b8nh thu\'aa c\'f1a n\'ad\'edc ngo\'b5i c\'e3 th\'d3 b\'ben t\'edi t\'cbn \'ae\'a9u.
\par }\pard\plain \s25\qj \li0\ri0\sb200\sa120\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 VI\'d6C BI\'d5N TRUNG QU\'e8C TH\'b5NH THU\'e9C \'a7\'deA

\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 M\'c6c d\'c7u Trung Qu\'e8c r\'cat suy nh\'ad\'eec, m\'c6
c d\'c7u n\'e9i b\'e9 Trung Qu\'e8c b\'de chia r\'cf, nh\'adng d\'c9u sao con s\'e8 11.139.000 km}{\f37\fs20\super\insrsid1378858 2}{\f37\fs20\insrsid1378858  c\'f1a n\'e3 c\'f2ng v\'c9n l\'b5 m\'e9t mi\'d5ng m\'e5i qu\'b8 to m\'b5 c\'b8i m\'e2m c\'f1a ch
\'f1 ngh\'dca \'ae\'d5 qu\'e8c th\'f9c d\'a9n kh\'abng th\'d3 nu\'e8t tr\'abi ngay m\'e9t c\'b8i \'ae\'ad\'eec. V\'b5 kh\'abng th\'d3 trong m\'e9t ng\'b5y m\'b5 \'ae\'c8y m\'e9t c\'b8ch t\'b5n b\'b9o 489.500.000 ng\'ad\'eai Trung Qu\'e8c v\'b5o xi\'d2ng x
\'ddch c\'f1a ch\'d5 \'ae\'e9 n\'ab l\'d6 thu\'e9c \'ae\'dea. Cho n\'aan ng\'ad\'eai ta c\'bet v\'f4n Trung Qu\'e8c ra: c\'b8ch n\'b5y ch\'cbm h\'acn nh\'adng kh\'abn h\'acn.
\par M\'e9t nguy\'aan nh\'a9n kh\'b8c l\'b5m ch\'cbm vi\'d6c bi\'d5n Trung Qu\'e8c th\'b5nh m\'e9t thu\'e9c \'ae\'dea c\'e3 t\'ddnh ch\'cat qu\'e8c t\'d5 l\'b5 s\'f9 tranh gi\'b5nh gi\'f7a c\'b8c n\'ad\'edc \'ae\'d5 qu\'e8c ch\'f1 ngh\'dca.
\par N\'ad\'edc Ph\'b8p \'ae\'b7 chi\'d5m \'ae\'ad\'eec \'a7\'abng D\'ad\'acng, mu\'e8n x\'a9m l\'ad\'eec mi\'d2n Nam Trung Qu\'e8c. Vi\'d6c x\'a9y d\'f9ng t\'e8n k\'d0m con \'ae\'ad\'eang s\'bet B\'bec K\'fa - V\'a9n Nam ph\'f1 l\'b5 m\'e9t b\'bbng ch\'f8ng v
\'d2 \'aei\'d2u \'ae\'e3.
\par N\'ad\'edc Anh hi\'d6n chi\'d5m \'ae\'ad\'eec H\'ad\'acng C\'b6ng, \'ddt nh\'cat l\'f3c n\'b5y c\'f2ng t\'b9m vui l\'dfng v\'edi l\'e8i n\'ab d\'dech kinh t\'d5, n\'e3 \'ae\'b7 ki\'d3m so\'b8t \'ae\'ad\'eec h\'c7u h\'d5t t\'cat c\'b6 c\'b8c ngu\'e5n s\'b6
n xu\'cat; v\'cby th\'d7 \'ddch g\'d7 m\'b5 ph\'b6i l\'f3ng t\'f3ng v\'d2 vi\'d6c \'ae\'e3ng qu\'a9n tr\'aan m\'e9t l\'b7nh th\'e6 v\'ab c\'efng r\'e9ng l\'edn n\'f7a? Nh\'adng kh\'abng \'ae\'eai n\'b5o Anh l\'b9i ch\'deu \'ae\'d3 cho Ph\'b8p tr\'eb th
\'b5nh m\'e9t c\'ad\'eang qu\'e8c th\'f9c d\'a9n th\'cbt s\'f9 \'eb ch\'a9u }{\f38\fs20\insrsid1378858 \'b8.}{\f37\fs20\insrsid1378858  V\'b5 b\'ebi v\'d7 }{\f38\fs20\insrsid1378858 \'ca}{\f37\fs20\insrsid1378858 n \'a7\'e9 \'ae\'b7 th\'f8c t\'d8nh \'ae
ang b\'bet \'ae\'c7u g\'b9t b\'e1 \'b8ch \'b8p b\'f8c kinh t\'d5 c\'f1a n\'ad\'edc Anh, cho n\'aan b\'e4n h\'b8m l\'eei n\'ad\'edc Anh ph\'b6i t\'d7m c\'b8ch v\'edt b\'ef l\'b9i \'eb Trung Qu\'e8c. N\'ad\'edc Nh\'cbt qu\'b8 \'ae\'abng d\'a9n v\'c9n l\'a8
m le chi\'d5m l\'cay v\'b5i t\'d8nh c\'f1a Trung Qu\'e8c, nh\'adng khi n\'b5o M\'fc l\'b9i ch\'deu \'ae\'d3 nh\'ad th\'d5, v\'d7 n\'e3 s\'cf l\'b5 m\'e9t m\'e8i nguy cho M\'fc. \'a7\'e8i v\'edi M\'fc, Trung Qu\'e8c l\'b5 m\'e9t th\'de tr\'ad\'eang v\'b5 c
\'e3 th\'d3 l\'b5 m\'e9t \'ae\'e5ng minh trong m\'e9t cu\'e9c xung \'ae\'e9t v\'edi Nh\'cbt B\'b6n.
\par }\pard\plain \s25\qj \li0\ri0\sb200\sa120\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'fd NGH\'dcA C\'f1A CU\'e9C CAN THI\'d6P HI\'d6N NAy

\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Trong m\'e9t cu\'e9c can thi\'d6p hi\'d6n nay, b\'e4n \'ae
\'d5 qu\'e8c nh\'bbm hai m\'f4c \'ae\'ddch. Tr\'ad\'edc h\'d5t, gi\'b5nh th\'aam nh\'f7ng nh\'ad\'eeng b\'e9 m\'edi, sau n\'f7a - v\'b5 t\'abi cho r\'bbng \'ae\'a9y l\'b5 \'aei\'d2u ch\'f1 y\'d5u - l\'cbt \'ae\'e6 T\'abn D\'cbt Ti\'aan. Ch\'f3ng ta bi\'d5
t r\'bbng c\'b8c ch\'ddnh ph\'f1 l\'aan thay nhau \'eb B\'bec Kinh lu\'abn lu\'abn v\'c9n th\'f9c hi\'d6n c\'e3 m\'e9t ch\'ddnh s\'b8ch l\'b5: b\'aan trong th\'d7 ch\'ddnh s\'b8ch h\'f1 b\'b9i, b\'aan ngo\'b5i th\'d7 khu\'cat ph\'f4c tr\'ad\'edc b\'e4n 
\'ae\'d5 qu\'e8c ch\'f1 ngh\'dca n\'ad\'edc ngo\'b5i.
\par Tr\'b8i l\'b9i, T\'abn D\'cbt Ti\'aan, "ng\'ad\'eai cha c\'f1a c\'b8ch m\'b9ng Trung Qu\'e8c", ng\'ad\'eai \'ae\'f8ng \'ae\'c7u ch\'ddnh ph\'f1 Qu\'b6ng Ch\'a9u, th\'d7 lu\'abn lu\'abn trung th\'b5nh v\'edi nh\'f7ng nguy\'aan l\'fd c\'f1a m\'d7nh, ngay c
\'b6 trong nh\'f7ng l\'f3c kh\'e3 kh\'a8n nh\'cat. C\'ad\'acng l\'dcnh c\'f1a \'ae\'b6ng \'abng - }{\i\f37\fs20\insrsid1378858 Qu\'e8c d\'a9n \'ae\'b6ng}{\f37\fs20\insrsid1378858  - l\'b5 m\'e9t c\'ad\'acng l\'dcnh c\'b6i c\'b8ch. C\'ad\'acng l\'dcnh \'ae
\'e3 g\'e5m nh\'f7ng \'aei\'d2u kho\'b6n ch\'e8ng \'ae\'d5 qu\'e8c v\'b5 ch\'e8ng qu\'a9n phi\'d6t m\'e9t c\'b8ch r\'e2 r\'d6t. \'a7\'b6ng \'ae\'e3 l\'edn ti\'d5ng tuy\'aan b\'e8 \'aeo\'b5n k\'d5t v\'edi c\'b8c d\'a9n t\'e9c b\'de \'b8p b\'f8c \'eb c\'b8
c n\'ad\'edc thu\'e9c \'ae\'dea v\'b5 v\'edi giai c\'cap v\'ab s\'b6n qu\'e8c t\'d5. \'a7\'b6ng \'ae\'e3 \'ae\'e5ng t\'d7nh v\'edi C\'b8ch m\'b9ng Nga: Th\'cbt l\'b5 m\'e9t t\'e9i l\'e7i kh\'abng th\'d3 tha th\'f8 \'ae\'ad\'eec! Ch\'f1 ngh\'dca \'ae\'d5
 qu\'e8c Ph\'b8p, k\'ce \'b8p b\'f8c nh\'a9n d\'a9n \'a7\'abng D\'ad\'acng, \'aeang lo ng\'b9i v\'d2 \'abng b\'b9n l\'b8ng gi\'d2ng kh\'e3 ch\'deu \'cay, v\'d7 nh\'f7ng t\'ad t\'ad\'ebng ph\'b8 ho\'b9i c\'f1a \'abng l\'b8ng gi\'d2ng c\'f2ng c\'e3 th\'d3
 xuy\'aan qua bi\'aan gi\'edi v\'b5 th\'a9m nh\'cbp v\'b5o nh\'f7ng ng\'ad\'eai n\'ab l\'d6 An Nam c\'f1a h\'e4. Trung Qu\'e8c c\'e3 bi\'aan gi\'edi chung v\'edi }{\f38\fs20\insrsid1378858 \'ca}{\f37\fs20\insrsid1378858 n \'a7\'e9 v\'b5 Tri\'d2u Ti\'aa
n. M\'e9t n\'ad\'edc Trung Hoa th\'e8ng nh\'cat, t\'f9 do v\'b5 h\'efng m\'b9nh s\'cf l\'b5 m\'b5n gi\'b8o \'ae\'c7u c\'f1a m\'e9t n\'ad\'edc Tri\'d2u Ti\'aan \'ae\'e9c l\'cbp v\'b5 m\'e9t n\'ad\'edc }{\f38\fs20\insrsid1378858 \'ca}{
\f37\fs20\insrsid1378858 n \'a7\'e9 gi\'b6i ph\'e3ng. \'a7\'d5 qu\'e8c Anh v\'b5 \'ae\'d5 qu\'e8c Nh\'cbt kh\'abng th\'d3 kh\'abng lo ng\'b9i v\'d2 \'aei\'d2u \'ae\'e3. Nguy c\'ac tuy c\'dfn xa, nh\'adng suy theo t\'ddnh ch\'cat r\'e9ng l\'edn \'cay, th
\'d7 c\'f2ng \'ae\'b7 l\'b5 m\'e9t m\'e8i nguy c\'ac th\'f9c t\'d5 r\'e5i.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ch\'ddnh v\'d7 th\'d5 m\'b5 ng\'b5y nay ng\'ad\'eai ta \'aeang t\'d7m c\'b8ch thanh to\'b8n T\'abn D\'cbt Ti\'aan v\'b5 
\'ae\'b6ng c\'f1a \'abng, c\'f2ng nh\'ad tr\'ad\'edc \'ae\'a9y ng\'ad\'eai ta \'ae\'b7 t\'d7m c\'b8ch b\'e3p ch\'d5t n\'ad\'edc Nga c\'b8ch m\'b9ng v\'cby.
\par }\pard\plain \s25\qj \li0\ri0\sb200\sa120\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 NH\'f7NG KH\'b6 N\'a1NG C\'f1A M\'e9T CU\'e9C CAN THI\'d6
P V\'f2 TRANG
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 C\'b8c c\'ad\'eang qu\'e8c \'ae\'d5 qu\'e8c ch\'f1 ngh\'dc
a theo nhau g\'f6i t\'e8i h\'cbu th\'ad. Ng\'ad\'eai ta huy \'ae\'e9ng c\'b8c h\'b9m \'ae\'e9i tr\'aan m\'c6t bi\'d3n Trung Qu\'e8c. Ng\'ad\'eai ta t\'cbp trung t\'b5u chi\'d5n v\'b5o c\'f6a b\'d3 Th\'ad\'eeng H\'b6i v\'b5 c\'f6a s\'abng D\'ad\'acng T\'f6
. C\'e3 l\'cf s\'cf c\'e3 m\'e9t cu\'e9c can thi\'d6p tr\'f9c ti\'d5p ch\'a8ng? \'a7i\'d2u \'ae\'e3 kh\'abng ch\'bec ch\'ben l\'bem. Trong c\'b8i \'a9m m\'adu m\'edi ch\'e8ng l\'b9i nh\'a9n d\'a9n Trung Qu\'e8c n\'b5y, Anh n\'bem vai tr\'df l\'b7nh \'ae
\'b9o. M\'b8c\'ae\'abnan s\'cf }{\i\f37\fs20\insrsid1378858 kh\'abng d\'b8m}{\f37\fs20\insrsid1378858  li\'d2u l\'dcnh ti\'d5n h\'b5nh m\'e9t cu\'e9c can thi\'d6p ra m\'c6t. \'a4ng ta \'ae\'b5nh ch\'d8 s\'cf ra s\'f8c gi\'f3p cho nh\'f7ng k\'ce th\'ef c
\'f1a T\'abn D\'cbt Ti\'aan, v\'b5 c\'b8i s\'b8ch l\'ad\'eec c\'e6 truy\'d2n c\'f1a ch\'ddnh s\'b8ch n\'ad\'edc Anh l\'b9i \'ae\'ad\'eec ti\'d5p t\'f4c th\'f9c hi\'d6n ch\'ea \'ae\'eei t\'d7nh tr\'b9ng \'ae\'f4c n\'ad\'edc b\'d0o c\'df.
\par }\pard\plain \s25\qj \li0\ri0\sb200\sa120\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 NH\'f7NG H\'cbU QU\'b6 C\'f1A VI\'d6C CAN THI\'d6P
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\expnd0\expndtw-4\insrsid1378858 Ch\'f1 ngh\'dca t\'ad b\'b6n qu\'e8c t
\'d5 \'aeang \'aei\'aan cu\'e5ng t\'ddch lu\'fc. K\'d5 ho\'b9ch c\'f1a c\'b8c nh\'b5 chuy\'aan m\'abn \'aeang t\'e6 ch\'f8c vi\'d6c n\'ab d\'dech c\'abng nh\'a9n n\'ad\'edc \'a7\'f8c. Ngo\'b9i giao \'ae\'c7y t\'ddnh ch\'cat can thi\'d6p - ngo\'b9i giao c
\'f1a c\'b8c tu\'c7n d\'ad\'acng h\'b9m, nh\'ad T\'abn D\'cbt Ti\'aan n\'e3i - \'aeang chu\'c8n b\'de n\'ab d\'dech nh\'f7ng ng\'ad\'eai lao \'ae\'e9ng da v\'b5ng. Vi\'d6c n\'ab d\'dech ho\'b5n to\'b5n giai c\'cap v\'ab s\'b6n \'a7\'f8c ch\'bec ch\'ben s
\'cf d\'c9n t\'edi vi\'d6c n\'ab d\'dech giai c\'cap v\'ab s\'b6n ch\'a9u M\'fc v\'b5 ch\'a9u \'a2u. K\'d5 ho\'b9ch \'a7aox\'ac}{\f37\fs20\expnd0\expndtw-4\super\insrsid1378858 53}{\f37\fs20\expnd0\expndtw-4\insrsid1378858  l\'b5 m\'e9t s\'f9 t\'can c\'ab
ng tr\'f9c ti\'d5p v\'b5o giai c\'cap c\'abng nh\'a9n. Vi\'d6c bi\'d5n Trung Qu\'e8c th\'b5nh thu\'e9c \'ae\'dea s\'cf khi\'d5n cho ch\'f1 ngh\'dca t\'ad b\'b6n ki\'d5m \'ae\'ad\'eec nh\'a9n c\'abng h\'d5t s\'f8c r\'ce m\'b9t, s\'cf h\'b9 th\'cap ti\'d2
n l\'ad\'acng \'eb ch\'a9u \'a2u v\'b5 ch\'a9u M\'fc, s\'cf c\'f1ng c\'e8 th\'d5 l\'f9c t\'ad b\'b6n. Vi\'d6c can thi\'d6p v\'b5o Trung Qu\'e8c l\'b5 m\'e9t cu\'e9c t\'can c\'abng tr\'f9c ti\'d5p v\'b5o giai c\'cap c\'abng nh\'a9n.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb240\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~NGUY\'d4N \'b8I QU\'e8C
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~T\'cbp san }{\i\insrsid1378858 Inprekorr, }{\insrsid1378858 ti
\'d5ng Ph\'b8p,
\par \~s\'e8 67, ng\'b5y 24-9-1924.
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par 
\par 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'a4NG CU\'e9C KHAI HO\'b8 GI\'d5T NG\'a6\'eaI
\par }\pard\plain \qj \li1418\ri0\sa240\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin1418\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\b\f37\fs20\insrsid1378858 \~Ng\'ad\'eai da tr\'beng khai ho\'b8 nh\'f7ng ng\'ad
\'eai da \'aeen nh\'ad th\'d5 n\'b5o - M\'e9t v\'b5i s\'f9 vi\'d6c m\'b5 nh\'f7ng s\'b8ch gi\'b8o khoa v\'d2 l\'dech s\'f6 kh\'abng n\'e3i \'ae\'d5n.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 N\'d5u l\'e8i h\'b5nh h\'d7nh theo ki\'d3u Lins\'ac c\'f1
a nh\'f7ng b\'e4n ng\'ad\'eai M\'fc h\'ccn h\'b9 \'ae\'e8i v\'edi nh\'f7ng ng\'ad\'eai da \'aeen l\'b5 m\'e9t h\'b5nh \'ae\'e9ng v\'ab nh\'a9n \'ae\'b9o, th\'d7 t\'abi kh\'abng c\'dfn bi\'d5t g\'e4i vi\'d6c nh\'f7ng ng\'ad\'eai \'a2u nh\'a9n danh \'ae
i khai ho\'b8 m\'b5 gi\'d5t h\'b5ng lo\'b9t nh\'f7ng ng\'ad\'eai d\'a9n ch\'a9u Phi l\'b5 c\'b8i g\'d7 n\'f7a.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\expnd0\expndtw-2\insrsid1378858 T\'f5 ng\'b5y ng\'ad\'eai da tr\'beng 
\'ae\'c6t ch\'a9n l\'aan b\'ea bi\'d3n l\'f4c \'ae\'dea c\'f1a ng\'ad\'eai da \'aeen th\'d7 l\'f4c \'ae\'dea \'ae\'e3 kh\'abng l\'f3c n\'b5o l\'b5 kh\'abng \'ae\'c9m m\'b8u. }{\f38\fs20\expnd0\expndtw-2\insrsid1378858 \'eb}{
\f37\fs20\expnd0\expndtw-2\insrsid1378858  \'ae\'e3, nh\'f7ng cu\'e9c t\'b5n s\'b8t h\'b5ng lo\'b9t \'ae\'ad\'eec Gi\'b8o h\'e9i c\'c7u ch\'f3c ph\'f3c l\'b5nh, \'ae\'ad\'eec b\'e4n vua ch\'f3a v\'b5 ngh\'de vi\'d6n ph\'aa chu\'c8n m\'e9t c\'b8ch h\'ee
p ph\'b8p, \'ae\'ad\'eec b\'e4n bu\'abn ng\'ad\'eai da \'aeen \'ae\'f1 m\'e4i h\'b9ng - t\'f5 b\'e4n bu\'abn n\'ab l\'d6 x\'ada kia, cho \'ae\'d5n b\'e4n quan cai tr\'de ng\'b5y nay \'eb thu\'e9c \'ae\'dea - ch\'a8m ch\'f3 thi h\'b5nh.
\par }\pard\plain \s25\qj \li0\ri0\sb200\sa120\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'a4N GI\'b8O
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ch\'ddnh l\'b5 \'ae\'d3 gieo r\'bec nh\'f7ng \'acn l\'b5
nh c\'f1a \'ae\'b9o Kit\'ab, m\'b5 v\'b5o kho\'b6ng n\'a8m 1442, nh\'f7ng t\'ad\'edng t\'b8 c\'f1a \'ae\'f8c vua T\'a9y Ban Nha r\'cat ngoan \'ae\'b9o \'ae\'b7 \'ae\'e6 b\'e9 l\'aan b\'ea bi\'d3n ch\'a9u Phi. Vi\'d6c truy\'d2n \'ae\'b9o c\'f1a h\'e4 b\'be
t \'ae\'c7u b\'bbng nh\'f7ng cu\'e9c t\'b5n s\'b8t. Theo l\'eai nh\'f7ng cu\'e8n nh\'cbt k\'fd h\'b5nh tr\'d7nh c\'f1a h\'e4, th\'d7: "... V\'b5 cu\'e8i c\'efng, \'a7\'f8c vua (l\'b5 ng\'ad\'eai v\'c9n h\'bbng th\'ad\'ebng c\'abng hu\'a9n nh\'f7ng c\'ab
ng cu\'e9c l\'b5m r\'b9ng r\'ec uy danh c\'f1a Ng\'b5i), \'ae\'b7 gi\'f3p cho nh\'f7ng b\'c7y t\'abi trung th\'b5nh c\'f1a Ng\'b5i chi\'d5n th\'beng \'ae\'ad\'eec k\'ce th\'ef. Ng\'b5i \'ae\'b7 ban danh v\'e4ng \'ae\'d3 \'ae\'b8p l\'b9i c\'abng lao c\'f1
a ch\'f3ng ta, \'ae\'b7 tr\'b6 c\'b8c kho\'b6n chi ph\'dd c\'f1a ch\'f3ng ta v\'b5 nh\'ea Ng\'b5i ch\'f3ng ta \'ae\'b7 b\'bet \'ae\'ad\'eec 165 ng\'ad\'eai v\'f5a \'ae\'b5n \'abng, \'ae\'b5n b\'b5 v\'b5 tr\'ce con, }{\i\f37\fs20\insrsid1378858 ch\'ada k
\'d3 m\'e9t s\'e8 \'ae\'abng b\'de gi\'d5t v\'b5 b\'de th\'ad\'acng".
\par }\pard \qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Nh\'f7ng k\'ce \'aei chinh ph\'f4c}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain 
\s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) }{\i\insrsid1378858 Conquistador:}{\insrsid1378858  Ch\'d8 nh\'f7ng t
\'ad\'edng t\'b8 T\'a9y Ban Nha h\'e5i th\'d5 k\'fb XV v\'b5 XVI \'ae\'b7 \'aei x\'a9m l\'ad\'eec Trung M\'fc v\'b5 Nam M\'fc.
\par 2) }{\i\insrsid1378858 Les J\'d0suites}{\insrsid1378858 : M\'e9t d\'dfng \'ae\'b9o Kit\'ab do Inga \'ae\'ac Loay\'abla, ng\'ad\'eai T\'a9y Ban Nha, th\'b5nh l\'cbp t\'f5 n\'a8m 1534, t\'e6 ch\'f8c theo ki\'d3u qu\'a9n \'ae\'e9i. Ngo\'b5i vi\'d6c truy\'d2
n gi\'b8o, d\'dfng n\'b5y c\'dfn c\'e3 nhi\'d2u h\'b5nh \'ae\'e9ng r\'cat d\'b7 man, t\'b5n \'b8c.}})}{\f37\fs20\insrsid1378858  ngoan \'ae\'b9o \'ae\'e3 \'ae\'b7 t\'b9o th\'b5nh m\'e9t th\'f8 th\'e3i t\'f4c.
\par Trong b\'b6n k\'aa nh\'f7ng c\'f1a c\'b6i t\'dech thu \'ae\'ad\'eec c\'f1a nh\'f7ng ng\'ad\'eai Gi\'aadu\'fdt}{\f37\fs20\super\insrsid1378858 2)}{\f37\fs20\insrsid1378858  Braxin, n\'a8m 1768 th\'d7 ngo\'b5i nh\'f7ng c\'a9y th\'cbp t\'f9 c\'f8u th\'d5 v
\'b5 nh\'f7ng \'ae\'e5 th\'ea kh\'b8c ra, c\'dfn c\'e3 nh\'f7ng con d\'cau b\'bbng s\'bet d\'efng \'ae\'d3 \'ae\'b8nh d\'cau l\'aan m\'c6t ng\'ad\'eai n\'ab l\'d6.
\par Trong m\'e9t th\'eai gian d\'b5i, c\'b8c h\'e9i "}{\i\f37\fs20\insrsid1378858 truy\'d2n b\'b8 \'ae\'b9o Kit\'ab"}{\f37\fs20\insrsid1378858  c\'f1a ng\'ad\'eai Anh \'ae\'b7 l\'cay vi\'d6c bu\'abn n\'ab l\'d6 l\'b5m ngu\'e5n l\'eei cho vi\'d6c th\'ea ph\'f4
ng truy\'d2n gi\'b8o c\'f1a h\'e4.
\par Ng\'b5y 12 th\'b8ng 2 n\'a8m 1835, gi\'b8o h\'e9i \'ae\'e9c l\'cbp c\'f1a Gi\'b8o khu Cr\'ddt S\'edcs\'ac (Nam Car\'ablin) \'ae\'b7 \'ae\'a8ng b\'b8o qu\'b6ng c\'b8o r\'bbng gi\'b8o h\'e9i s\'bep \'aeem b\'b8n m\'e9t m\'e3n h\'b5ng t\'f5 10 n\'ab l\'d6 
\'ae\'b7 quen vi\'d6c tr\'e5ng b\'abng. Th\'cbt ng\'ad\'eai ta c\'e3 th\'d3 k\'d3 ra kh\'abng bi\'d5t bao nhi\'aau s\'f9 vi\'d6c nh\'ad th\'d5.
\par Nh\'f7ng gi\'b8o h\'e9i \'eb B\'bec M\'fc \'ae\'d2u l\'b5 nh\'f7ng k\'ce th\'ef ki\'aan quy\'d5t nh\'cat ch\'e8ng vi\'d6c xo\'b8 b\'e1 ch\'d5 \'ae\'e9 n\'ab l\'d6.
\par }\pard\plain \s25\qj \li0\ri0\sb200\sa120\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'e4N VUA CH\'f3A
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 T\'f5 S\'b8cl\'ac Canh cho \'ae\'d5n L\'aa\'abp\'abn \'ae
\'d6 nh\'de, vua B\'d8, t\'f5 b\'b5 N\'f7 ho\'b5ng \'ae\'f8c h\'b9nh c\'f1a n\'ad\'edc Anh l\'b5 \'a3lidab\'d0t cho \'ae\'d5n Nap\'abl\'aa\'abng, t\'cat c\'b6 c\'b8i b\'e4n ng\'ad\'eai ng\'e5i tr\'aan ngai v\'b5ng \'cay \'ae\'d2u bu\'abn b\'b8n ng\'ad\'ea
i da \'aeen. T\'cat c\'b6 b\'e4n vua ch\'f3a \'aei chi\'d5m thu\'e9c \'ae\'dea \'ae\'d2u \'ae\'b7 k\'fd nh\'f7ng hi\'d6p \'ad\'edc v\'b5 \'ae\'b7 cho ph\'d0p \'ae\'e9c quy\'d2n kinh doanh th\'det ng\'ad\'eai da \'aeen.
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 "Ng\'b5y 27-8-1701, \'a7\'f8c vua T\'a9y Ban Nha r
\'cat ngoan \'ae\'b9o, v\'b5 \'a7\'f8c 
\par 
\par }\pard \s22\qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 vua Ph\'b8p r\'cat ngoan \'ae\'b9o \'ae\'b7 cho C\'abng ty ho\'b5ng gia \'eb Ghin\'aa \'ae\'ad\'eec \'ae\'e9c quy\'d2
n trong 10 n\'a8m ch\'eb nh\'f7ng ng\'ad\'eai da \'aeen trong c\'b8c thu\'e9c \'ae\'dea ch\'a9u M\'fc... \'ae\'d3 nh\'a9n \'ae\'e3 m\'b5 c\'b6 b\'e4n vua t\'abi \'ae\'d2u ki\'d5m \'ae\'ad\'eec nh\'f7ng m\'e3n l\'eei l\'edn...".
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 "\'a7\'f8c vua Anh nh\'cbn tr\'b8ch nhi\'d6m \'ae\'ada v
\'b5o \'ae\'cat M\'fc thu\'e9c T\'a9y Ban Nha 144.000 ng\'ad\'eai da \'aeen, c\'b6 nam l\'c9n n\'f7, \'ae\'f1 c\'b8c l\'f8a tu\'e6i, v\'edi gi\'b8 ti\'d2n m\'e7i \'ae\'c7u ng\'ad\'eai l\'b5 33 \'ae\'e5ng \'aaquy v\'b5 1/3 \'ae\'e5ng...".
\par }\pard\plain \s25\qj \li0\ri0\sb200\sa120\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'e4N BU\'a4N NG\'a6\'eaI DA \'a7EN
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 N\'a8m 1824, m\'e9t chi\'d5c t\'b5u bu\'abn ng\'ad\'eai da 
\'aeen v\'f5a l\'cay nh\'f7ng ng\'ad\'eai da \'aeen t\'f5 b\'ea bi\'d3n ch\'a9u Phi \'ae\'d3 \'ae\'ada \'aei \'a1ngti\'ac, th\'d7 b\'de m\'e9t tu\'c7n d\'ad\'acng h\'b9m \'aeu\'e6i theo. Trong khi \'aeu\'e6i theo, ng\'ad\'eai ta th\'cay c\'e3 nhi\'d2u chi
\'d5c th\'efng tr\'abi l\'d2nh b\'d2nh g\'c7n tu\'c7n d\'ad\'acng h\'b9m. Ng\'ad\'eai ta t\'ad\'ebng r\'bbng chi\'d5c t\'b5u bu\'abn ng\'ad\'eai da \'aeen \'ae\'b7 v\'f8t b\'e1 nh\'f7ng th\'efng n\'ad\'edc xu\'e8ng cho nh\'d1 b\'edt \'ae\'d3 d\'d4 ch\'b9
y tr\'e8n. Nh\'adng khi \'ae\'b7 c\'c6p s\'b8t \'ae\'ad\'eec chi\'d5c t\'b5u r\'e5i, th\'d7 ng\'ad\'eai ta nghe th\'cay ti\'d5ng r\'aan r\'d8 trong m\'e9t chi\'d5c th\'efng \'ae\'d3 tr\'aan boong t\'b5u: m\'eb ra th\'cay hai ng\'ad\'eai \'ae\'b5n b\'b5
 da \'aeen g\'c7n b\'de ch\'d5t ng\'b9t. T\'d0 ra chi\'d5c t\'b5u bu\'abn ng\'ad\'eai da \'aeen \'ae\'b7 ngh\'dc \'ae\'ad\'eec c\'b8ch \'ae\'e3 \'ae\'d3 cho nh\'d1 b\'edt t\'b5u.
\par }{\expnd0\expndtw-2\insrsid1378858 M\'e9t chi\'d5c t\'b5u Anh c\'f8u \'ae\'ad\'eec m\'e9t chi\'d5c t\'b5u bu\'abn ng\'ad\'eai da \'aeen b\'de \'ae\'bem. Ng\'ad\'eai ta c\'f8u c\'b6 nh\'f7ng ng\'ad\'eai da \'aeen l\'c9n thu\'fb th\'f1 tr\'aan t\'b5u. Nh
\'adng \'ae\'d5n khi th\'cay thi\'d5u l\'ad\'acng th\'f9c, ng\'ad\'eai ta li\'d2n quy\'d5t \'ae\'denh hy sinh nh\'f7ng ng\'ad\'eai da \'aeen. Ng\'ad\'eai ta b\'bet h\'e4 s\'bep h\'b5ng tr\'aan boong t\'b5u, r\'e5i d\'efng hai kh\'c8u s\'f3ng l\'edn b\'be
n h\'e4 m\'e9t c\'b8ch kh\'abng th\'ad\'acng x\'e3t g\'d7 c\'b6.
\par }\pard\plain \s25\qj \li0\ri0\sb200\sa120\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'d7NH C\'b6NH NH\'f7NG NG\'a6\'eaI N\'a4 L\'d6
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nh\'f7ng ng\'ad\'eai da \'aeen b\'de b\'bet \'ae\'d2u b\'de
 bu\'e9c c\'e6, bu\'e9c tay, bu\'e9c ch\'a9n v\'edi nhau, th\'b5nh t\'f5ng \'ae\'abi m\'e9t. R\'e5i ng\'ad\'eai ta l\'b9i d\'efng m\'e9t c\'b8i x\'ddch d\'b5i bu\'e9c th\'b5nh t\'f5ng chu\'e7i 20 hay 30 ng\'ad\'eai m\'e9t. Tr\'e3i nh\'ad th\'d5 r\'e5i, ng
\'ad\'eai ta dong h\'e4 ra t\'cbn b\'d5n t\'b5u. Ng\'ad\'eai ta nh\'d0t h\'e4 ch\'e5ng ch\'cat v\'b5o trong h\'c7m t\'b5u ch\'cbt ch\'e9i, t\'e8i om v\'b5 ngh\'d1t th\'eb. \'a7\'d3 "b\'b6o \'ae\'b6m v\'d6 sinh", ng\'ad\'eai ta d\'efng roi qu\'cbt h\'e4 t
\'edi t\'cap nh\'ad m\'ada \'ae\'d3 b\'bet h\'e4 ph\'b6i nh\'b6y nh\'b8o l\'aan m\'e7i ng\'b5y v\'b5i l\'c7n. \'a7\'d3 h\'dfng \'ae\'ad\'eec r\'e9ng ch\'e7, th\'ad\'eang th\'ad\'eang l\'b5, \'ae\'b5n \'abng b\'e3p c\'e6 l\'c9n nhau, v\'b5 \'ae\'b5n b\'b5
 th\'d7 d\'efng \'aeinh \'ae\'a9m th\'f1ng tr\'b8n nh\'f7ng ch\'de b\'aan c\'b9nh. Nh\'f7ng ng\'ad\'eai \'e8m b\'de coi l\'b5 h\'b5ng ho\'b8 \'ae\'b7 h\'ad h\'e1ng kh\'abng b\'b8n \'ae\'ad\'eec, b\'de qu\'bcng xu\'e8ng bi\'d3n. Khi bi\'d3n \'ae\'e9ng, ng
\'ad\'eai ta n\'d0m ng\'ad\'eai da \'aeen xu\'e8ng bi\'d3n \'ae\'d3 cho nh\'d1 t\'b5u. N\'e3i chung khi t\'b5u c\'c6p b\'d5n th\'d7 m\'e9t ph\'c7n t\'ad chuy\'d5n h\'b5ng da \'aeen \'ae\'b7 ch\'d5t g\'f4c v\'d7 b\'d6nh truy\'d2n nhi\'d4m hay ch\'d5t ng
\'b9t. Nh\'f7ng ng\'ad\'eai n\'ab l\'d6 c\'dfn s\'e8ng s\'e3t b\'de \'aeem \'ae\'e3ng d\'cau v\'b5 \'ae\'b8nh s\'e8 b\'bbng s\'bet nung \'ae\'e1 nh\'ad s\'f3c v\'cbt v\'cby, ng\'ad\'eai ta \'ae\'d5m h\'e4 b\'bbng t\'can, b\'bbng "ki\'d6n" ch\'f8 kh\'ab
ng ph\'b6i b\'bbng \'ae\'c7u ng\'ad\'eai. Th\'dd d\'f4 nh\'ad C\'abng ty B\'e5 \'a7\'b5o Nha \'eb Ghin\'aa, n\'a8m 1700 \'ae\'b7 k\'fd m\'e9t h\'eep \'ae\'e5ng l\'b5 s\'cf cung c\'cap 11.000 "t\'can" ng\'ad\'eai da \'aeen.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 H\'acn 15 tri\'d6u ng\'ad\'eai da \'aeen \'ae\'b7 b\'de ch
\'eb sang M\'fc trong nh\'f7ng \'aei\'d2u ki\'d6n nh\'ad v\'cby, \'ae\'e9 3 tri\'d6u \'ae\'b7 ch\'d5t d\'e4c \'ae\'ad\'eang hay b\'de n\'d0m xu\'e8ng bi\'d3n. C\'dfn nh\'f7ng k\'ce v\'d7 ch\'e8ng c\'f9 hay n\'e6i lo\'b9n m\'b5 b\'de gi\'d5t th\'d7 kh\'ab
ng k\'d3... L\'e8i bu\'abn b\'b8n nh\'ac nhu\'e8c \'ae\'e3 ch\'cam d\'f8t v\'b5o kho\'b6ng n\'a8m 1850 \'ae\'d3 nh\'ad\'eang ch\'e7 cho m\'e9t h\'d7nh th\'f8c n\'ab l\'d6 kh\'b8c ph\'e6 bi\'d5n h\'acn l\'b5: ch\'d5 \'ae\'e9 th\'f9c d\'a9n.
\par }\pard\plain \s25\qj \li0\ri0\sb200\sa120\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 CH\'d5 \'a7\'e9 TH\'f9C D\'a2N
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nh\'f7ng hi\'d6n t\'ad\'eeng t\'b5n kh\'e8c m\'b5 ch\'f3
ng t\'abi s\'bep k\'d3 ra \'ae\'a9y, n\'d5u kh\'abng ph\'b6i l\'b5 \'ae\'b7 \'ae\'ad\'eec ch\'f8ng minh b\'bbng nh\'f7ng t\'b5i li\'d6u kh\'abng th\'d3 ch\'e8i c\'b7i \'ae\'ad\'eec, n\'d5u kh\'abng ph\'b6i ch\'ddnh nh\'f7ng ng\'ad\'eai \'a2u k\'d3 l\'b9
i, th\'d7 ng\'ad\'eai ta kh\'e3 m\'b5 tin \'ae\'ad\'eec.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 M\'e9t nh\'b5 bu\'abn Ph\'b8p \'eb Ma\'aeag\'b8txca th\'ca
y trong k\'d0t b\'b9c c\'f1a h\'ben b\'de m\'cat tr\'e9m, \'ae\'b7 d\'efng \'aei\'d6n tra t\'can nhi\'d2u ng\'ad\'eai b\'b6n x\'f8 l\'b5m cho h\'ben m\'b5 h\'ben ng\'ea l\'b5 \'ae\'b7 l\'cay tr\'e9m. Sau \'ae\'e3 \'ddt l\'a9u, ng\'ad\'eai ta ph\'b8t hi
\'d6n ra r\'bbng ch\'ddnh con h\'ben \'ae\'b7 l\'cay.
\par M\'e9t vi\'aan quan cai tr\'de thu\'e9c \'ae\'dea \'ae\'b7 b\'bet m\'e9t ch\'de ng\'ad\'eai da \'aeen \'ae\'e9i m\'e9t h\'dfn \'ae\'b8 l\'edn \'ae\'f8ng su\'e8t ng\'b5y ngo\'b5i n\'beng chang chang. R\'e5i h\'ben sai \'aeem tr\'e3i ch\'de l\'b9i v\'b5
 sai \'ae\'e6 cao su n\'e3ng b\'e1ng v\'b5o b\'e9 ph\'cbn sinh d\'f4c c\'f1a ch\'de.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 M\'e9t t\'aan th\'f9c d\'a9n n\'e4 n\'e6i gi\'cbn v\'d7 kh\'abng th\'d3 b\'bet hai ng\'ad\'eai \'ae\'c7y t\'ed b\'b6n x
\'f8 c\'f1a h\'ben l\'b5m c\'abng kh\'abng, \'ae\'b7 \'aeem tr\'e3i hai ng\'ad\'eai \'ae\'e3 v\'b5o c\'e4c, gi\'e9i d\'c7u ho\'b6 l\'aan v\'b5 thi\'aau s\'e8ng.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Nh\'f7ng t\'aan th\'f9c d\'a9n kh\'b8c \'aeem nh\'d0t m\'d7n v\'b5o m\'e5m hay h\'cbu m\'abn nh\'f7ng ng\'ad\'eai da 
\'aeen v\'b5 \'ae\'e8t cho n\'e6.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd0\expndtw-2\insrsid1378858 M\'e9t vi\'aan ch\'f8c kia khoe l\'b5 m
\'e9t m\'d7nh h\'ben \'ae\'b7 gi\'d5t 150 ng\'ad\'eai b\'b6n x\'f8, ch\'c6t 60 b\'b5n tay, \'ae\'e3ng tr\'aan c\'a9y th\'cbp t\'f9 r\'cat nhi\'d2u \'ae\'b5n b\'b5 v\'b5 tr\'ce con, v\'b5 treo r\'cat nhi\'d2u x\'b8c ng\'ad\'eai \'ae\'b7 b\'de v\'bbm l\'aa
n t\'ad\'eang c\'b8c l\'b5ng m\'b5 h\'ben \'ae\'ad\'eec trao cho cai tr\'de. M\'e9t c\'abng ty khai kh\'c8n \'ae\'e5n \'aei\'d2n n\'e4 \'ae\'b7 l\'b5m ch\'d5t 4.500 ng\'ad\'eai lao \'ae\'e9ng b\'b6n x\'f8 t\'b9i ri\'aang m\'e9t \'ae\'e5n \'aei\'d2n c\'f1
a n\'e3.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Tr\'ad\'eang h\'eep ngo\'b9i l\'d6, c\'b8 bi\'d6t \'ad? Kh
\'abng ph\'b6i. \'a7\'e3 l\'b5 t\'f4c l\'d6 c\'f1a h\'e4. Nh\'adng ch\'f3ng ta h\'b7y k\'d3 m\'e9t v\'b5i t\'e9i \'b8c gi\'d5t ng\'ad\'eai h\'b5ng lo\'b9t m\'b5 ng\'ad\'eai ta kh\'abng th\'d3 \'ae\'e6 t\'b9i b\'b6n t\'ddnh d\'b7 man c\'f1a m\'e9t v\'b5i c
\'b8 nh\'a9n n\'b5o c\'b6, nh\'adng l\'b5 nh\'f7ng t\'e9i \'b8c m\'b5 to\'b5n b\'e9 ch\'d5 \'ae\'e9 ph\'b6i ch\'deu tr\'b8ch nhi\'d6m tr\'ad\'edc l\'dech s\'f6.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 M\'e9t nh\'b5 v\'a8n Ph\'b8p k\'d3 l\'b9i: "Trong x\'f8
 Angi\'aari c\'f1a ch\'f3ng ta \'eb s\'b8t b\'b7i sa m\'b9c, t\'abi \'ae\'b7 th\'cay nh\'ad sau: M\'e9t h\'abm, binh l\'ddnh b\'bet nh\'f7ng ng\'ad\'eai Ar\'cbp ch\'bcng m\'bec t\'e9i t\'d7nh g\'d7 ngo\'b5i c\'b8i t\'e9i \'ae\'b7 tr\'e8n tr\'b8nh s\'f9 t
\'b5n b\'b9o c\'f1a nh\'f7ng k\'ce \'ae\'b7 chinh ph\'f4c h\'e4. Vi\'aan quan n\'a8m ra l\'d6nh \'aeem gi\'d5t ngay kh\'abng c\'c7n \'aei\'d2u tra, x\'d0t x\'f6 g\'d7 c\'b6. V\'b5 \'ae\'a9y l\'b5 \'aei\'d2u \'ae\'b7 x\'b6y ra... H\'e4 b\'de b\'bet t\'ca
t c\'b6 l\'b5 30 ng\'ad\'eai. Ng\'ad\'eai ta \'ae\'b5o 30 h\'e8 \'eb b\'b7i c\'b8t r\'e5i \'aeem ch\'abn h\'e4 xu\'e8ng \'ae\'d5n c\'e6, tr\'c7n tru\'e5ng, \'ae\'c7u c\'b9o tr\'e4c, d\'ad\'edi tr\'eai n\'beng gi\'f7a tr\'ada. \'a7\'d3 gi\'f7 cho h\'e4 kh
\'abng ch\'d5t ngay, th\'d8nh tho\'b6ng ng\'ad\'eai ta l\'b9i \'aeem n\'ad\'edc t\'ad\'edi nh\'ad t\'ad\'edi c\'b6i b\'bep... N\'f6a gi\'ea sau, mi m\'bet h\'e4 s\'adng h\'f3p l\'aan, con m\'bet l\'dfi ra. L\'ad\'eci s\'adng v\'ef l\'aan \'ae\'c7y c\'b6 c
\'b8i mi\'d6ng m\'eb h\'b8 h\'e8c tr\'abng th\'cbt kh\'f1ng khi\'d5p... r\'e5i da n\'f8t ra, tr\'b8n th\'d7 v\'b5ng l\'aan nh\'ad th\'det l\'een quay...".
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 M\'e9t b\'e9 t\'e9c \'eb B\'a8ngghi kh\'abng th\'d3 cung c
\'cap \'ae\'ad\'eec \'ae\'f1 s\'e8 cao su cho \'ae\'e5n \'aei\'d2n. \'a7\'e5n \'aei\'d2n n\'b5y mu\'e8n bu\'e9c h\'e4 ph\'b6i n\'e9p cho \'ae\'f1 s\'e8 thi\'d5u, li\'d2n b\'bet 58 ph\'f4 n\'f7 v\'b5 10 tr\'ce em gi\'f7 l\'b5m con tin. Nh\'f7ng con tin n
\'b5y b\'de nh\'e8t v\'b5o ch\'e7 thi\'d5u kh\'abng kh\'dd, thi\'d5u \'b8nh s\'b8ng, thi\'d5u \'a8n v\'b5 ngay c\'b6 n\'ad\'edc u\'e8ng c\'f2ng thi\'d5u n\'f7a. Th\'d8nh tho\'b6ng ng\'ad\'eai ta l\'b9i \'ae\'d5n \'ae\'b8nh \'ae\'cbp h\'e4. Theo b\'e4n th
\'f9c d\'a9n n\'e3i th\'d7 ti\'d5ng k\'aau la c\'f1a h\'e4 d\'efng \'ae\'d3 th\'abi th\'f3c c\'abng vi\'d6c. Sau ba tu\'c7n ch\'deu \'aeau \'ae\'edn kh\'e8c li\'d6t, 58 ph\'f4 n\'f7 v\'b5 2 tr\'ce em ch\'d5t.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 N\'a8m \'ae\'e3 h\'b9n h\'b8n. M\'efa m\'b5ng m\'cat c\'b6
. To\'b5n v\'efng \'ae\'e3 \'eb ch\'a9u Phi b\'de kh\'e8n kh\'e6. Ng\'ad\'eai ta ph\'b6i \'a8n c\'e1 v\'b5 r\'d4 c\'a9y. C\'b8c c\'f4 gi\'b5 ch\'d5t v\'d7 \'ae\'e3i l\'b6. Th\'d5 m\'b5 ch\'ddnh ph\'f1 khai ho\'b8 v\'c9n c\'f8 b\'bet ph\'b6i n\'e9p thu\'d5
. Nh\'f7ng ng\'ad\'eai d\'a9n \'aeang b\'de h\'b9n h\'b8n b\'e1 l\'b9i cho ch\'ddnh ph\'f1 ru\'e9ng \'ae\'cat, v\'ad\'ean t\'ad\'eec, nh\'b5 c\'f6a v\'b5 tr\'e8n v\'b5o n\'f3i. Vi\'aan quan cai tr\'de \'ae\'ada ch\'e3 s\'a8n v\'b5 l\'ddnh v\'b5o truy n
\'b7 v\'b5 t\'d7m th\'cay h\'e4 trong m\'e9t c\'b8i hang. Ng\'ad\'eai ta b\'ccn hun cho h\'e4 ch\'d5t.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 N\'a8m 1895, ng\'ad\'eai Anh \'ae\'b7 t\'b5n s\'b8
t 3.000 ng\'ad\'eai Matab\'aal\'aa}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) T\'aan g\'e4i chung nh\'f7ng b\'e9 l\'b9c thu\'e9c gi\'e8ng ng\'ad\'eai Caferes \'eb mi\'d2n \'a7\'abng Nam ch\'a9u Phi, gi\'f7a hai con s\'abng Lanhp\'abp\'ab v\'b5 D\'a8mbed
\'ac.}})}{\f37\fs20\insrsid1378858  n\'e6i lo\'b9n \'ae\'b7 ra \'ae\'c7u h\'b5ng h\'e4.
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 T\'f5 1901 \'ae\'d5n 1906, ng\'ad\'eai \'a7\'f8c 
\'ddt ra c\'f2ng \'ae\'b7 t\'b5n s\'b8t \'ae\'d5n 15.000 d\'a9n Herer\'ab \'eb T\'a9y Phi.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 N\'a8m 1911, ng\'ad\'eai }{\f38\fs20\insrsid1378858 \'fd}{
\f37\fs20\insrsid1378858 , trong c\'e3 3 ng\'b5y m\'b5 \'ae\'b7 bi\'d5n ngo\'b9i \'ab Masiya th\'b5nh l\'df s\'b8t sinh, 4.000 ng\'ad\'eai b\'b6n x\'f8 b\'de gi\'d5t \'eb \'ae\'e3.
\par Nh\'f7ng cu\'e9c t\'b5n s\'b8t \'ae\'b9i quy m\'ab \'ae\'e3 \'ae\'ad\'eec n\'aau l\'aan th\'b5nh nguy\'aan t\'bec ch\'ddnh tr\'de. \'a7\'e3 l\'b5 ch\'ddnh s\'b8ch gi\'d5t s\'b9ch. M\'e9t ch\'ddnh ph\'f1 \'eb C\'b8p \'ae\'b7 tuy\'aan b\'e8: "N\'d5u ng\'ad
\'eai b\'b6n x\'f8 m\'b5 \'aei v\'b5o con \'ae\'ad\'eang kh\'abng tu\'a9n l\'d6nh v\'b5 n\'e6i lo\'b9n, th\'d7 h\'e4 s\'cf b\'de th\'bcng tay qu\'d0t s\'b9ch kh\'e1i n\'ad\'edc h\'e4, v\'b5 s\'cf c\'e3 nh\'f7ng d\'a9n t\'e9c kh\'b8c \'ae\'d5n thay th\'d5
 h\'e4".
\par Ng\'b5y nay, 10 n\'a8m sau cu\'e9c chi\'d5n tranh \'ae\'dfi "quy\'d2n d\'a9n t\'e9c t\'f9 quy\'d5t", th\'d7 ng\'ad\'eai T\'a9y Ban Nha v\'b5 ng\'ad\'eai Ph\'b8p v\'c9n ti\'d5p t\'f4c cu\'e9c x\'a9m chi\'d5m \'ae\'c9m m\'b8u n\'ad\'edc Mar\'e8c, d\'ad\'ed
i con m\'bet bao che c\'f1a nh\'f7ng k\'ce tai to m\'c6t l\'edn \'eb H\'e9i qu\'e8c li\'aan}{\f37\fs20\super\insrsid1378858 54}{\f37\fs20\insrsid1378858 .
\par L\'dech s\'f6 vi\'d6c ng\'ad\'eai \'a2u x\'a9m chi\'d5m ch\'a9u Phi - c\'f2ng nh\'ad b\'cat c\'f8 l\'dech s\'f6 x\'a9m chi\'d5m thu\'e9c \'ae\'dea n\'b5o - th\'d7 t\'f5 \'ae\'c7u \'ae\'d5n cu\'e8i \'ae\'d2u \'ae\'ad\'eec vi\'d5t b\'bbng m\'b8u nh\'f7ng ng
\'ad\'eai b\'b6n x\'f8.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Sau nh\'f7ng cu\'e9c t\'b5n s\'b8t th\'bcng tay th\'d7 ch\'ddnh nh\'f7ng ch\'d5 \'ae\'e9 lao 
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 d\'dech, khu\'a9n v\'b8c, lao \'ae\'e9ng kh\'e6 sai, r\'ad
\'eeu c\'e5n, b\'d6nh giang mai ti\'d5p t\'f4c ho\'b5n th\'b5nh c\'abng cu\'e9c t\'b5n ph\'b8 c\'f1a s\'f9 nghi\'d6p khai ho\'b8. K\'d5t qu\'b6 t\'cat nhi\'aan c\'f1a ch\'d5 \'ae\'e9 gh\'aa t\'ebm \'ae\'e3 l\'b5 s\'f9 ti\'aau di\'d6t gi\'e8ng da \'aeen.

\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 K\'d3 ra th\'d7 th\'aam v\'b5o nh\'f7ng s\'f9 vi\'d6c \'ae
\'e3 m\'e9t v\'b5i con s\'e8, c\'f2ng t\'e8t, nh\'adng c\'f2ng th\'cbt l\'b5 \'aeau \'ae\'edn. Ng\'ad\'eai ta s\'cf th\'cay r\'bbng m\'e9t v\'b5i t\'aan th\'f9c d\'a9n gi\'b5u c\'e3 l\'aan nhanh ch\'e3ng th\'d7 c\'f2ng \'ae\'f3ng v\'b5o l\'f3c d\'a9n s
\'e8 nh\'f7ng mi\'d2n b\'de b\'e3c l\'e9t gi\'b6m b\'edt \'aei kh\'abng ph\'b6i l\'b5 kh\'abng nhanh ch\'e3ng. T\'f5 1783 \'ae\'d5n 1793, C\'abng ty Liv\'d0cp\'abn \'ae\'b7 ki\'d5m \'ae\'ad\'eec ch\'f5ng 1.117.700 b\'b6ng b\'bbng c\'b8ch bu\'abn b\'b8n n
\'ab l\'d6. C\'f2ng trong th\'eai gian \'ae\'e3, d\'a9n s\'e8 trong v\'efng c\'abng ty \'ae\'e3 \'ae\'c6t ch\'a9n \'ae\'d5n, \'ae\'b7 m\'cat \'aei 304.000 ng\'ad\'eai. Trong 9 n\'a8m, vua L\'aa\'abp\'abn \'a7\'d6 nh\'de \'ae\'b7 b\'e3c l\'e9t x\'f8 C\'ab
ngg\'ab \'ae\'ad\'eec 3.179.120 b\'b6ng.
\par N\'a8m 1908, d\'a9n s\'e8 x\'f8 C\'abngg\'ab thu\'e9c B\'d8 l\'b5 20 tri\'d6u, \'ae\'d5n n\'a8m 1911, ch\'d8 c\'dfn c\'e3 8.500.000 th\'abi. Trong x\'f8 C\'abngg\'ab thu\'e9c Ph\'b8p, nh\'f7ng b\'e9 t\'e9c g\'e5m c\'e3 40.000 ng\'ad\'eai m\'b5 trong 2 n
\'a8m ch\'d8 c\'dfn l\'b9i c\'e3 20.000 ng\'ad\'eai, nhi\'d2u b\'e9 t\'e9c kh\'b8c kh\'abng c\'dfn l\'cay m\'e9t ng\'ad\'eai.
\par N\'a8m 1904, d\'a9n s\'e8 H\'abtent\'ab l\'b5 20.000 ng\'ad\'eai, ch\'d8 trong 7 n\'a8m b\'de \'ae\'ab h\'e9, c\'dfn l\'b9i c\'e3 9.700 ng\'ad\'eai.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~NGUY\'d4N \'b8I QU\'e8C
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'cbp san }{\i\insrsid1378858 Inprekorr,}{\insrsid1378858  ti\'d5
ng Ph\'b8p,
