\cs17\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1)  C\'e3 hai b\'b6n 
}{\i\insrsid1378858 Th\'ad g\'f6i \'abng Ut\'acr\'a9y:}{\insrsid1378858  m\'e9t b\'b6n \'ae\'a8ng b\'b8o }{\i\insrsid1378858 Le Populaire}{\insrsid1378858 , ng\'b5y 14-10-1919; m\'e9t b\'b6n \'ae\'d2 ng\'b5y 16-10-1919, l\'adu t\'b9i Kho l\'adu tr\'f7 qu
\'e8c gia Ph\'b8p. N\'e9i dung c\'ac b\'b6n gi\'e8ng nhau, nh\'adng b\'b6n \'ae\'d2 ng\'b5y 16-10-1919 d\'b5i h\'acn, phong ph\'f3 h\'acn.}})}{\insrsid1378858 
\par }\pard\plain \s1\qr \fi397\li0\ri425\sa200\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin425\lin0\itap0 \b\i\f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\b0\fs20\insrsid1378858 BIARIT, ng\'b5y 16 th\'b8
ng 10 n\'a8m 1919
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i\f37\fs20\insrsid1378858 \'a4ng Ut\'acr\'a9y,
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'a7ang ngh\'d8 m\'b8t xa Pari, m\'b7i t\'edi h\'abm nay t
\'abi m\'edi \'ae\'ad\'eec tin v\'d2 c\'b8c cu\'e9c th\'b6o lu\'cbn c\'f1a Ngh\'de vi\'d6n ng\'b5y 18 th\'b8ng 9, \'eb \'ae\'e3, \'abng \'ae\'b7 c\'abng k\'ddch t\'abi k\'dech li\'d6t v\'b5 th\'ab b\'d8. T\'abi kh\'abng h\'aci \'ae\'a9u n\'aau ra \'ae\'a9
y nh\'f7ng l\'eai tho\'b8 m\'b9 t\'f5 mi\'d6ng \'abng phun ra, n\'d5u kh\'abng v\'d7 trong khi c\'abng k\'ddch t\'abi, th\'d7 \'ae\'e5ng th\'eai \'abng c\'f2ng \'ae\'b7 c\'abng k\'ddch t\'ea nh\'cbt b\'b8o \'ae\'b8ng t\'abn k\'ddnh \'ae\'b7 r\'e9ng l\'ad
\'eeng d\'b5nh nh\'f7ng c\'e9t b\'b8o cho b\'b5i vi\'d5t g\'c7n \'ae\'a9y c\'f1a t\'abi.
\par C\'b8c b\'b5i vi\'d5t c\'f1a t\'abi \'ae\'d2u c\'e3 k\'fd t\'aan, v\'b5 t\'abi \'ae\'b5ng ho\'b5ng \'ae\'dfi cho ri\'aang m\'d7nh tr\'b8ch nhi\'d6m v\'d2 c\'b8c b\'b5i b\'b8o \'ae\'e3. \'a4ng hi\'d3u r\'bbng m\'e9t t\'ea b\'b8o Ph\'b8p x\'f8ng \'ae\'b8
ng v\'edi c\'b8i t\'aan c\'f1a n\'e3 ph\'b6i ti\'d5p nh\'cbn m\'e9t c\'b8ch v\'ab t\'ad m\'e4i s\'f9 th\'cbt, b\'cat k\'d3 t\'f5 ph\'dda n\'b5o t\'edi, d\'ef nh\'f7ng s\'f9 th\'cbt \'ae\'e3 l\'b5m ph\'cbt \'fd nh\'f7ng k\'ce b\'de v\'b9ch m\'c6t. Trong c
\'b8c b\'b5i vi\'d5t c\'f1a m\'d7nh, t\'abi kh\'abng c\'e3 nh\'f7ng gi\'b6 thi\'d5t v\'ab c\'a8n c\'f8, t\'abi ch\'d8 \'ae\'ada ra nh\'f7ng s\'f9 vi\'d6c ch\'ddnh x\'b8c m\'b5 \'abng \'ae\'d2u bi\'d5t v\'b5 \'abng \'ae\'b7 kh\'abng tranh c\'b7i, v\'d7 
\'abng kh\'abng th\'d3 tranh c\'b7i n\'e6i.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Trong nh\'f7ng \'aei\'d2u ki\'d6n nh\'ad v\'cby, kh\'ab
ng ph\'b6i t\'abi \'ae\'denh b\'f3t chi\'d5n v\'edi \'abng, t\'abi ch\'d8 mu\'e8n nh\'b7 nh\'c6n v\'b5 \'abn ho\'b5 \'ae\'c6t ra cho \'abng v\'b5i c\'a9u h\'e1i. T\'abi s\'cf tr\'b8nh kh\'abng n\'e6i n\'e3ng la l\'e8i ch\'f6i r\'f1a, \'ae\'b8p l\'b9i s
\'f9 th\'ab t\'f4c b\'bbng s\'f9 th\'ab t\'f4c, v\'d7 nh\'ad v\'cby l\'b5 t\'f9 h\'b9 gi\'b8 m\'d7nh: kh\'abng ph\'b6i h\'d4 c\'f8 n\'d0m \'ae\'ad\'eec b\'efn l\'aan \'ae\'dech th\'f1 l\'b5 m\'d7nh c\'e3 l\'fd \'ae\'a9u.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Tr\'ad\'edc h\'d5t, \'abng \'ae\'b7 n\'e3i v\'b5 nh\'bec l\'b9i r\'bbng t\'abi b\'de truy n\'b7 b\'aan \'a7\'abng D\'ad
\'acng v\'d7 c\'b8c ho\'b9t \'ae\'e9ng ch\'e8ng Ph\'b8p. N\'b5y! Xin \'abng h\'b7y cho t\'abi bi\'d5t l\'b5 v\'b5o l\'f3c n\'b5o, do to\'b5 \'b8n n\'b5o, v\'b5 ho\'b9t \'ae\'e9ng ch\'e8ng Ph\'b8p \'ae\'e3 l\'b5 g\'d7?
\par }{\f37\fs20\lang1043\langfe1033\langnp1043\insrsid1378858 \'a7\'e3 l\'b5 c\'a9u h\'e1i \'ae\'c7u ti\'aan. N\'d5u \'abng kh\'abng th\'d3 tr\'b6 l\'eai c\'a9u h\'e1i tr\'aan cho tho\'b6 \'ae\'b8ng, ngh\'dca l\'b5 c\'e3 b\'bbng c\'f8 ch\'f8ng minh, th\'d7
 cho ph\'d0p t\'abi h\'e1i \'abng r\'cat nh\'b7 nh\'c6n r\'bbng k\'ce n\'b5o trong hai ta, ng\'ad\'eai vu kh\'e8ng hay ng\'ad\'eai b\'de vu kh\'e8ng, x\'f8ng \'ae\'b8ng v\'edi danh hi\'d6u th\'bbng kh\'e8n n\'b9n? T\'abi r\'cat mu\'e8n ch\'e4n cho \'ab
ng m\'e9t t\'ddnh ng\'f7 \'ae\'f3ng v\'edi \'ae\'c6c t\'ddnh c\'f1a \'abng m\'b5 kh\'abng l\'b5m \'abng ph\'cbt \'fd, nh\'adng t\'abi kh\'abng t\'d7m th\'cay trong t\'f5 v\'f9ng ti\'d5ng Ph\'b8p nh\'f7ng t\'f5 n\'b5o kh\'b8c th\'cbt th\'ddch \'ae\'b8
ng ngo\'b5i t\'f5 th\'bbng n\'e3i l\'b8o, v\'b5 t\'abi bu\'e9c ph\'b6i n\'e3i v\'edi \'abng, kh\'abng ch\'f3t th\'ef h\'bbn v\'b5 s\'ee h\'b7i, m\'b5 th\'bcng th\'ben v\'b5 m\'c6t \'ae\'e8i m\'c6t, r\'bbng \'abng \'ae\'b7 n\'e3i l\'b8o, r\'bbng \'abng l
\'b5 m\'e9t th\'bbng n\'e3i l\'b8o.
\par T\'abi \'aeo\'b8n tr\'ad\'edc \'ae\'ad\'eec chi\'d5n thu\'cbt c\'f1a \'abng v\'b5 t\'abi l\'b5m cho n\'e3 m\'cat hi\'d6u l\'f9c ngay t\'f5 \'ae\'c7u: \'abng \'ae\'f5ng tr\'e8n n\'cap \'ae\'bbng sau th\'b8i \'ae\'e9 tr\'dech th\'ad\'eeng v\'b5 khinh b\'d8
. Nh\'a9n c\'b8ch c\'f1a \'abng v\'b5 c\'f1a t\'abi \'ae\'d2u kh\'abng li\'aan quan g\'d7 \'ae\'d5n v\'can \'ae\'d2 n\'b5y: \'ae\'a9y ch\'d8 l\'b5 vi\'d6c x\'b8c minh s\'f9 th\'cbt v\'b5 ch\'d8 c\'e3 s\'f9 th\'cbt m\'b5 th\'abi.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\lang1043\langfe1033\langnp1043\insrsid1378858 B\'a9y gi\'ea t\'abi n\'e3i th
\'aam: gi\'b8 nh\'ad t\'abi \'ae\'b7 b\'de truy n\'b7 hay b\'de k\'d5t \'b8n \'aei n\'f7a \'eb b\'aan \'a7\'abng D\'ad\'acng v\'d2 c\'b8i m\'b5 b\'e4n th\'f9c d\'a9n Ph\'b8p v\'ab li\'aam s\'d8 g\'e4i l\'b5 ch\'e8ng Ph\'b8p th\'d7 t\'abi c\'f2ng ch\'bc
ng c\'e3 g\'d7 ph\'b6i h\'e6 th\'d1n, tr\'b8i l\'b9i t\'abi c\'dfn 
\par }\pard \s15\qj \li0\ri0\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\lang1043\langfe1033\langnp1043\insrsid1378858 t\'f9 h\'b5o v\'d2 vi\'d6c \'ae\'e3: v\'d7 \'ae\'e8i v\'edi b\'e4n th\'f9c d\'a9n, ch\'e8ng Ph\'b8p c\'e3
 ngh\'dca l\'b5 c\'abng khai t\'e8 c\'b8o nh\'f7ng \'fd \'ae\'denh v\'ab nh\'a9n \'ae\'b9o v\'b5 nh\'f7ng h\'b5nh \'ae\'e9ng ch\'f3ng kh\'abng d\'b8m th\'f3 nh\'cbn, nh\'f7ng \'fd \'ae\'denh l\'b5m t\'e6n th\'ad\'acng nghi\'aam tr\'e4ng \'ae\'d5n danh ti
\'d5ng t\'e8t \'ae\'d1p c\'f1a n\'ad\'edc Ph\'b8p cao th\'ad\'eeng v\'b5 ph\'b6n l\'b9i m\'e9t c\'b8ch b\'d8 \'e6i nh\'f7ng l\'fd t\'ad\'ebng cao c\'b6 v\'d2 t\'f9 do v\'b5 c\'abng l\'fd m\'b5 to\'b5n th\'d5 gi\'edi nh\'d7n nh\'cbn \'eb n\'ad\'edc Ph\'b8
p.
\par }\pard \s15\qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\lang1043\langfe1033\langnp1043\insrsid1378858 V\'a9ng, th\'ada \'abng Ut\'acr\'a9y, c\'e3 nh\'f7ng l\'eai k\'d5t \'b8n l\'b5m v\'ce vang ch
\'f8 kh\'abng l\'b5m \'ab nh\'f4c. \'a4ng c\'e3 nh\'f7ng v\'dd d\'f4 v\'d2 \'aei\'d2u n\'b5y trong m\'e4i th\'eai
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\lang1043\langfe1033\langnp1043\insrsid1378858 \'ae\'b9i v\'b5 \'eb m\'e4i n
\'ad\'edc, \'abng c\'e3 th\'d3 t\'d7m \'ae\'ad\'eec d\'d4 d\'b5ng nh\'f7ng v\'dd d\'f4 \'ae\'e3 ngay trong l\'dech s\'f6 n\'ad\'edc Ph\'b8p. Nh\'f7ng ho\'b9t \'ae\'e9ng ch\'e8ng Ph\'b8p! }{\f37\insrsid1378858 Kh\'abng ai m\'bec l\'f5a n\'f7a \'ae\'a9u! 
\'a7\'b7 \'ae\'d5n l\'f3c ph\'b6i ki\'d5m nh\'f7ng l\'fd do kh\'b8c th\'abi!...
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-256\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \'a4ng l\'b9i n\'e3i ti\'d5p r\'bbng: "V\'edi t\'ad c\'b8
ch \'ae\'b9i bi\'d3u \'a7\'abng D\'ad\'acng, t\'abi kh\'abng th\'d3 ch\'cap nh\'cbn trong Ngh\'de vi\'d6n n\'b5y d\'ad lu\'cbn cho r\'bbng x\'f8 \'a7\'abng D\'ad\'acng b\'de n\'ad\'edc Ph\'b8p ng\'ad\'eec \'ae\'b7i v\'b5 ng\'ad\'eai An Nam kh\'abng \'ae
\'ad\'eec h\'ad\'ebng m\'e4i quy\'d2n t\'f9 do ph\'ef h\'eep v\'edi s\'f9 ph\'b8t tri\'d3n ch\'ddnh tr\'de c\'f1a \'ae\'b9i ch\'f3ng. \'a7\'abng D\'ad\'acng d\'ad\'edi s\'f9 che ch\'eb c\'f1a n\'ad\'edc Ph\'b8p \'aeang \'aei theo s\'e8 ph\'cbn c\'f1a n
\'e3 trong ho\'b5 b\'d7nh, v\'b5 ch\'f8ng c\'ed h\'efng h\'e5n nh\'cat r\'bbng n\'e3 h\'b9nh ph\'f3c, th\'ada c\'b8c Ng\'b5i, c\'b8c Ng\'b5i \'ae\'b7 t\'f5ng \'ae\'ad\'eec ch\'f8ng ki\'d5n qua nhi\'d6t t\'d7nh c\'f1a ng\'ad\'eai An Nam sang b\'b6o v\'d6 n
\'ad\'edc Ph\'b8p trong c\'acn}{\insrsid1378858  }{\f37\fs20\insrsid1378858 nguy bi\'d5n"}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0
\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) Ch\'d8 nh\'f7ng ng\'ad\'eai Vi\'d6t Nam b\'de b\'bet \'aei l\'ddnh chi\'d5n v\'b5 l\'ddnh th\'ee sang Ph\'b8p v
\'b5 m\'e9t s\'e8 thu\'e9c \'ae\'dea c\'f1a Ph\'b8p, tham gia Chi\'d5n tranh th\'d5 gi\'edi th\'f8 nh\'cat.}})}{\f37\fs20\insrsid1378858 .
\par }\pard\plain \s15\qj \li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'a4ng \'ae\'b9i di\'d6n cho ai. Ph\'b6i ch\'a8ng l\'b5 cho hai m
\'ad\'aci tri\'d6u ng\'ad\'eai An Nam kh\'abng h\'d2 bi\'d5t ngay c\'b6 t\'aan c\'f1a \'abng, tr\'f5 v\'b5i c\'abng ch\'f8c hay v\'b5i t\'aan xin x\'e1 hay l\'b5 cho m\'e9t nh\'f3m c\'f6 tri c\'f1a \'abng \'eb Nam K\'fa?
\par }\pard \s15\qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 \'a7\'f5ng n\'e3i l\'b5 x\'f8 \'a7\'abng D\'ad\'acng b\'de n\'ad\'edc Ph\'b8p ng\'ad\'eec \'ae\'b7i, m\'b5 ph\'b6i n\'e3i l
\'b5 n\'e3 b\'de nh\'f7ng ng\'ad\'eai Ph\'b8p x\'cau s\'e8ng b\'b8m v\'b5o n\'e3 ng\'ad\'eec \'ae\'b7i; hai vi\'d6c \'cay kh\'abng ph\'b6i l\'b5 m\'e9t. \'a4ng c\'e3 n\'bem \'ae\'ad\'eec s\'f9 kh\'b8c bi\'d6t \'ae\'e3 hay kh\'abng?
\par }\pard\plain \qj \fi397\li0\ri0\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 V\'d7 \'abng \'ae\'b7 n\'e3i \'ae\'d5n t\'f9 do v\'b5 ho\'b5 b
\'d7nh trong c\'a9u d\'c9n \'eb tr\'aan, v\'cby cho t\'abi h\'e1i \'abng r\'bbng: sau khi so s\'b8nh v\'edi ch\'d5 \'ae\'e9 b\'b8o ch\'dd do \'ae\'b9o lu\'cbt ng\'b5y 29 th\'b8ng 7 n\'a8m 1881 quy \'ae\'denh, li\'d6u ng\'ad\'eai ta c\'dfn c\'e3 th\'d3 ch
\'e8ng ch\'d5 \'ae\'ad\'eec n\'f7a kh\'abng r\'bbng ch\'d5 \'ae\'e9 b\'b8o ch\'dd b\'b6n x\'f8 do s\'bec l\'d6nh ng\'b5y 30 th\'b8ng 12 n\'a8m 1918 v\'b5 c\'b8c \'aei\'d2u kho\'b6n 214 \'ae\'d5n 217 c\'f1a Lu\'cbt h\'d7nh An Nam m\'edi ban h\'b5nh (}{
\i\f37\fs20\insrsid1378858 Journal officiel de l'Indochine - Francaise}{\f37\fs20\super\insrsid1378858 6}{\f37\fs20\insrsid1378858 , s\'e8 ng\'b5y 1 th\'b8ng 8 n\'a8m 1917) kh\'abng ph\'b6i l\'b5 m\'e9t ch\'d5 \'ae\'e9 ho\'b5n to\'b5n kho\'b8 mi\'d6ng v
\'b5 b\'adng b\'ddt s\'f9 th\'cbt v\'b5 v\'d7 v\'cby, n\'e3 kh\'abng x\'b8c nh\'cbn t\'f5 \'ae\'c7u \'ae\'d5n cu\'e8i nh\'f7ng \'aei\'d2u t\'abi \'ae\'b7 n\'e3i v\'d2 n\'b9n nh\'e5i s\'e4 d\'a9n da v\'b5ng trong b\'b5i b\'b8o c\'f1a t\'abi m\'b5 nh\'a9n 
\'ae\'e3 \'abng \'ae\'b7 nham hi\'d3m c\'b8o gi\'b8c t\'ea }{\i\f37\fs20\insrsid1378858 Le Populaire}{\f37\fs20\super\insrsid1378858 7}{\f37\fs20\insrsid1378858  tr\'ad\'edc Ngh\'de vi\'d6n.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Xin \'abng hi\'d3u cho r\'bbng, t\'abi kh\'abng l\'b5m c
\'b8i vi\'d6c c\'b7i nhau v\'edi \'abng v\'d2 ng\'abn t\'f5: t\'abi \'ae\'ada \'abng tr\'eb v\'d2 v\'edi c\'b8c v\'a8n b\'b6n. \'a4ng nh\'e5i s\'e4 d\'a9n da v\'b5ng ch\'f3ng t\'abi, nh\'ad b\'e4n \'a7\'f8c \'ae\'b7 t\'f5ng c\'e8 nh\'e5i s\'e4 nh\'f7ng ng
\'ad\'eai da tr\'beng trong v\'efng }{\f38\insrsid1378858 \'b8}{\insrsid1378858 c\'aeen}{\cs17\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) T\'aan m\'e9t qu\'cbn \'eb mi\'d2n \'a7\'abng B\'bec n\'ad\'edc Ph\'b8p, b\'de \'a7\'f8c chi\'d5m trong Chi\'d5n tranh th\'d5 gi\'edi th\'f8 nh\'cat.}})}{\insrsid1378858  nh
\'adng v\'ab hi\'d6u v\'b5 xin \'abng nh\'ed cho r\'bbng, trong s\'e8 c\'e9ng t\'b8c vi\'aan c\'f1a ch\'f3ng, c\'e3 m\'e9t trong s\'e8 c\'b8c b\'b9n \'ae\'e5ng nghi\'d6p c\'f2 c\'f1a \'abng \'eb c\'b8c c\'ac quan d\'a9n s\'f9 c\'b8c thu\'e9c \'ae\'de
a, anh ta l\'b5 h\'e4c tr\'df \'ae\'ad\'eec c\'cap b\'bbng c\'f1a Tr\'ad\'eang Thu\'e9c \'ae\'dea. }{\f38\insrsid1378858 \'b8}{\insrsid1378858 i ch\'b5! \'a4ng th\'ddch vi\'d6n d\'c9n c\'b8c ho\'b9t \'ae\'e9ng ch\'e8ng Ph\'b8p! Th\'d7 \'ae\'cay, v\'b6 l
\'b9i l\'b5 nh\'f7ng th\'f8 ch\'ddnh c\'e8ng.
\par }\pard \s15\qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 Kh\'abn ngoan h\'acn l\'b5 \'abng h\'b7y im \'aei, \'ae\'f5ng n\'e3i v\'d2 vi\'d6c s\'f6 d\'f4ng ng\'ad\'eai An Nam tr\'aan 
\'ae\'cat Ph\'b8p. Ph\'b6i ch\'a8ng khi Ch\'ddnh ph\'f1 tham kh\'b6o \'fd ki\'d5n c\'f1a t\'ad\'edng Penn\'accanh v\'b5 m\'e9t t\'ad\'edng kh\'b8c v\'d2 v\'can \'ae\'d2 n\'b5y th\'d7 \'abng \'ae\'b7 ki\'aan quy\'d5t ch\'e8ng l\'b9i vi\'d6c thi h\'b5nh b
\'b6n d\'f9 \'b8n, cho r\'bbng d\'f9 \'b8n kh\'abng th\'d3 th\'f9c hi\'d6n \'ae\'ad\'eec, r\'bbng b\'aan \'ae\'e3 kh\'abng \'ae\'f1 l\'ddnh An Nam \'ae\'d3 b\'b6o v\'d6 \'a7\'abng D\'ad\'acng, v\'a9n v\'a9n v\'b5 v\'a9n v\'a9n... \'a4ng s\'ee \'ae\'e5ng b
\'b5o t\'abi, trong th\'eai gian \'eb Ph\'b8p, kh\'abng kh\'e1i kh\'abng so s\'b8nh th\'b8i \'ae\'e9 ki\'aau c\'a8ng c\'f1a nh\'f7ng ng\'ad\'eai Ph\'b8p \'eb \'a7\'abng D\'ad\'acng v\'edi s\'f9 nh\'b7 nh\'c6n tuy\'d6t v\'eai v\'b5 ph\'d0p l\'dech s\'f9
 cao qu\'fd c\'f1a nh\'f7ng ng\'ad\'eai Ph\'b8p ch\'a9n ch\'ddnh tr\'aan \'ae\'cat Ph\'b8p. Uy th\'d5 c\'f1a b\'e4n th\'f9c d\'a9n tr\'ad\'edc \'ae\'b7, sau \'ae\'e3 m\'edi \'ae\'d5n T\'e6 qu\'e8c, c\'e3 ph\'b6i v\'cby kh\'abng?
\par }\pard \s15\qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 C\'dfn v\'d2 v\'can \'ae\'d2 ho\'b5 b\'d7nh, t\'abi b\'e1 qua cho \'abng r\'cat nhi\'d2u s\'f9 vi\'d6c kh\'b8c, v\'b5 kh\'ab
ng ph\'b6i l\'b5 nh\'f7ng vi\'d6c nh\'e1 \'ae\'a9u, t\'abi ch\'d8 xin h\'e1i: li\'d6u \'abng c\'e3 th\'d3 ph\'f1 nh\'cbn hai s\'f9 vi\'d6c l\'edn x\'b6y ra trong chi\'d5n tranh kh\'abng ? \'a7\'e3 l\'b5 m\'adu toan n\'e6i d\'cby c\'f1a Duy T\'a9n, sau 
\'ae\'e3, \'abng vua kh\'e8n kh\'e6 m\'cat n\'ad\'edc b\'de \'ae\'b5y ra \'ae\'b6o R\'aauyni\'abng}{\super\insrsid1378858 8}{\insrsid1378858 , v\'b5 vi\'d6c ng\'ad\'eai An Nam chi\'d5m t\'d8nh Th\'b8i Nguy\'aan}{\super\insrsid1378858 9}{\insrsid1378858 . 
\'a4ng b\'b6o x\'f8 \'a7\'abng D\'ad\'acng \'aeang \'aei theo s\'e8 ph\'cbn c\'f1a n\'e3 m\'e9t c\'b8ch y\'aan \'e6n. Ph\'b6i ch\'a8ng \'abng kh\'abng nh\'d7n th\'cay r\'bbng, ngay trong c\'b8i cung \'aei\'d6n Hu\'d5 c\'f2 k\'fc v\'b5 t\'e8i t\'a8m, m\'b5
 cu\'e9c s\'e8ng t\'ef h\'b7m, tr\'f4y l\'b9c \'ae\'b7 nh\'can ch\'d7m nh\'f7ng ng\'ad\'eai s\'e8ng trong \'ae\'e3 v\'b5o s\'f9 nhu nh\'ad\'eec, \'ae\'d5n n\'e7i h\'e4 d\'f6ng d\'adng tr\'ad\'edc m\'e4i vi\'d6c di\'d4n ra b\'aan ngo\'b5i, c\'f2ng
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 kh\'abng ph\'b6i kh\'abng c\'e3 \'fd \'ae\'denh h\'ad\'edng s
\'e8 ph\'cbn \'ae\'cat n\'ad\'edc theo c\'b8ch kh\'b8c m\'b5 \'abng ch\'bcng th\'ddch. \'a7i\'d2u \'ae\'e3 ch\'f8ng t\'e1 r\'bbng, ng\'ad\'eai ta \'ae\'b7 ch\'b8n ng\'cay nh\'f7ng cung c\'b8ch t\'b5n b\'b9o m\'b5 \'abng l\'b5 k\'ce bi\'d6n h\'e9.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \'a4ng \'ae\'b7 vi\'d6n d\'c9n \'abng Anbe Xar\'ab v\'b5 t
\'cat c\'b6 nh\'f7ng ng\'ad\'eai An Nam su\'e8t ba m\'ad\'aci n\'a8m nay \'ae\'b7 nu\'abi s\'e8ng \'abng nh\'ad m\'e9t con m\'e4t ng\'a9n s\'b8ch b\'bbng nh\'f7ng kho\'b6n thu\'d5 do h\'e4 \'ae\'e3ng g\'e3p, m\'b5 \'abng kh\'abng bi\'d5t.
\par \'a4ng h\'b7y t\'d8nh ng\'e9 \'aei, \'abng Anbe Xar\'ab \'ae\'e8i v\'edi t\'abi kh\'abng xa l\'b9 g\'d7. Gi\'f7a c\'b8c \'fd ki\'d5n c\'f1a \'abng v\'b5 c\'f1a \'abng Anbe Xar\'ab c\'e3 c\'b6 kho\'b6ng c\'b8ch c\'f1a hai \'ae\'e8i c\'f9c. Trong d\'a9n ch
\'f3ng An Nam, ng\'ad\'eai ta \'ae\'e5n r\'bbng \'abng d\'dfm ng\'e3 c\'b8i gh\'d5 to\'b5n quy\'d2n \'a7\'abng D\'ad\'acng v\'b5 h\'e4 run s\'ee khi ngh\'dc \'ae\'d5n tai ho\'b9 m\'b5 Ch\'ddnh ph\'f1 "m\'c9u qu\'e8c" s\'cf g\'a9y ra m\'e9t c\'b8ch v\'ab 
\'fd th\'f8c cho d\'a9n An Nam n\'d5u c\'f6 \'abng l\'b5m ng\'ad\'eai k\'d5 v\'de \'abng Anbe Xar\'ab.
\par T\'abi \'ae\'b7 c\'e3 \'fd ki\'d5n v\'d2 ch\'ddnh s\'b8ch cai tr\'de c\'f1a \'abng Xar\'ab khi t\'abi tuy\'aan b\'e8 ho\'b5n to\'b5n \'f1ng h\'e9 nh\'f7ng l\'eai ph\'b8t ng\'abn c\'f1a v\'de ngh\'de s\'dc x\'b7 h\'e9i \'ae\'b8ng k\'ddnh Mariu\'fdt Mut\'aa
 \'ae\'ad\'eec t\'cat c\'b6 \'ae\'e5ng b\'b5o t\'abi r\'cat y\'aau m\'d5n v\'b5 k\'ddnh tr\'e4ng: y\'aau m\'d5n v\'b5 k\'ddnh tr\'e4ng ch\'d8 v\'d7 \'abng ta b\'aanh v\'f9c s\'f9 nghi\'d6p chung c\'f1a n\'ad\'edc ch\'f3ng t\'abi, \'abng ta kh\'abng c\'e3
 v\'b5 kh\'abng bao gi\'ea nh\'ad \'abng, c\'f8 mu\'e8n c\'e3 nh\'f7ng quan h\'d6 v\'edi ch\'ddnh quy\'d2n thu\'e9c \'ae\'dea \'ae\'b7 cho ph\'d0p \'abng c\'e3 th\'d3 mua chu\'e9c v\'b5i c\'abng ch\'f8c v\'b5 v\'b5i t\'aan An Nam}{\insrsid1378858  }{
\f37\fs20\insrsid1378858 quen th\'e3i xin x\'e1, b\'bbng nh\'f7ng \'a9n hu\'d6 nh\'e1 m\'e4n.
\par Sau nh\'f7ng v\'a8n b\'b6n v\'b5 s\'f9 ki\'d6n c\'f4 th\'d3 t\'abi n\'aau ra \'eb tr\'aan, li\'d6u \'abng c\'e3 c\'dfn ti\'d5p t\'f4c kh\'a8ng kh\'a8ng r\'bbng c\'b8c c\'abng d\'a9n Mut\'aa v\'b5 L\'abnggh\'aa \'ae\'b7 n\'e3i nh\'f7ng \'aei\'d2u sai tr
\'b8i n\'f7a hay th\'abi?
\par Xin ch\'b5o \'abng.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 NGUY\'d4N \'b8I QU\'e8C
\par }\pard\plain \s15\ql \li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'b5i li\'d6u \'ae\'b8nh m\'b8y,\line ti\'d5ng Ph\'b8p.\line B
\'b6n ch\'f4p l\'adu t\'b9i\line Vi\'d6n H\'e5 Ch\'dd Minh.
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs20\insrsid1378858  }{\insrsid1378858 
