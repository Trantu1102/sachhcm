t l\'b5ng, ph\'b8 hu\'fb 3.000}{\f37\fs20\cgrid0\insrsid1378858  }{\i\f37\fs20\cgrid0\insrsid1378858 c\'a9y chu\'e8i (th\'f8c \'a8n d\'f9 tr\'f7 duy nh\'cat).
\par C\'b5n qu\'d0t l\'b5ng Cuya: \'ae\'e8t l\'b5ng, ph\'b8 tr\'f4i}{\f37\fs20\cgrid0\insrsid1378858  }{\i\f37\fs20\cgrid0\insrsid1378858 v\'ad\'ean tr\'b9i.}{\f37\fs20\cgrid0\insrsid1378858 
\par }{\i\f37\fs20\cgrid0\insrsid1378858 C\'b5n qu\'d0t Ancoong: n\'d0m bom xu\'e8ng l\'b5ng, r\'e5i ph\'b8 tr\'f4i}{\f37\fs20\cgrid0\insrsid1378858  }{\i\f37\fs20\cgrid0\insrsid1378858 v\'ad\'ean tr\'b9i.}{\f37\fs20\cgrid0\insrsid1378858 
\par }{\i\f37\fs20\cgrid0\insrsid1378858 C\'b5n qu\'d0t d\'a9n Examphami: ph\'b8 s\'b9ch l\'b5ng m\'b9c.}{\f37\fs20\cgrid0\insrsid1378858 
\par }{\i\f37\fs20\cgrid0\insrsid1378858 V\'efng B\'abma \'ae\'e8t ph\'b8 v\'b5 gi\'d5t ng\'ad\'eai.}{\f37\fs20\cgrid0\insrsid1378858 
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd0\expndtw-4\cgrid0\insrsid1378858 H\'eep ph\'b8p ho\'b8 vi\'d6c c\'ad
\'edp b\'e3c, ti\'aau di\'d6t c\'e3 h\'d6 th\'e8ng d\'a9n c\'ad, ph\'b8 tr\'f4i m\'e9t c\'b8ch c\'e3 t\'e6 ch\'f8c nh\'f7ng l\'b5ng m\'b9c, ph\'ad\'acng ph\'b8p l\'b5 nh\'ad th\'d5 \'ae\'e3.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 M\'ad\'eai s\'b8u n\'a8m sau, nh\'f7ng h\'b5nh \'ae
\'e9ng b\'d8 \'e6i nh\'ad th\'d5 l\'b9i \'ae\'ad\'eec ng\'ad\'eai ta n\'aau ra tr\'ad\'edc ngh\'de vi\'d6n Ph\'b8p.
\par Th\'b8ng 12 n\'a8m 1921, ngh\'de s\'dc da \'aeen Boan\'edp \'ae\'b7 n\'e3i trong m\'e9t b\'b5i di\'d4n v\'a8n c\'b6m \'ae\'e9ng nh\'ad sau:
\par }{\i\f37\fs20\cgrid0\insrsid1378858 "D\'a9n }{\f37\fs20\cgrid0\insrsid1378858 s\'e8 }{\i\f37\fs20\cgrid0\insrsid1378858 b\'de l\'f4i \'aei v\'d7 b\'d6nh t\'cbt, v\'b5 nh\'cat l\'b5 v\'d7 ch\'d5 \'ae\'e9 m\'b5 h\'e4 ph\'b6i ch\'deu \'ae\'f9ng t\'f5 khi b
\'de chi\'d5m \'ae\'e3ng... Ch\'d5 \'ae\'e9}{\f37\fs20\cgrid0\insrsid1378858  }{\i\f37\fs20\cgrid0\insrsid1378858 b\'bet phu khu\'a9n v\'b8c, s\'f9 b\'e3c l\'e9t n\'c6ng n\'d2 c\'f1a c\'b8c c\'abng ty khai kh\'c8n \'ae\'e5n \'aei\'d2n \'ae\'b7 gi\'d5t nh
\'f7ng ng\'ad\'eai b\'b6n x\'f8...".}{\f37\fs20\cgrid0\insrsid1378858 
\par Ng\'b5y 22 th\'b8ng 10 n\'a8m 1921, quy\'d2n B\'e9 tr\'ad\'ebng thu\'e9c \'ae\'dea \'ae\'b7 ra m\'e9t s\'bec l\'d6nh quy \'ae\'denh r\'bbng m\'e9t c\'abng nh\'a9n b\'b6n x\'f8 \'ae\'b7 \'ae\'ad\'eec tr\'b6 c\'abng \'ae\'d3 l\'b5m m\'e9t c\'abng vi\'d6c n
\'b5o \'ae\'e3 m\'b5 kh\'abng l\'b5m tr\'dfn th\'d7 c\'e3 th\'d3 b\'de b\'bet giam v\'b5 truy t\'e8 v\'d2 t\'e9i l\'f5a \'ae\'b6o.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 \'a4ng Anbe Xar\'ab - B\'e9 tr\'ad\'ebng B\'e9 thu
\'e9c \'ae\'dea - \'ae\'b7 ph\'b6i th\'f3 nh\'cbn r\'bbng d\'a9n c\'ad kh\'e8n kh\'e6 c\'f1a thu\'e9c \'ae\'dea \'ae\'b7 s\'bep di\'d6t vong. \'a4ng \'ae\'b7 ra s\'f8c g\'b8n cho t\'d7nh tr\'b9ng d\'a9n c\'ad b\'de di\'d6t vong d\'c7n \'aei \'ae\'e3, l
\'b5 do thi\'d5u v\'d6 sinh, v\'b5 \'abng vi\'d5t:
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i\f37\fs20\cgrid0\insrsid1378858 "Vi\'d6c s\'a8n s\'e3c v\'f4ng v\'d2}{
\f37\fs20\cgrid0\insrsid1378858  }{\i\f37\fs20\cgrid0\insrsid1378858 v\'b5 b\'c8n th\'d8u \'ae\'e8i v\'edi ph\'f4 n\'f7 khi sinh n\'eb... l\'b5m cho h\'e4 kh\'abng sinh \'ae\'ce n\'f7a; c\'dfn}{\f37\fs20\cgrid0\insrsid1378858  }{
\i\f37\fs20\cgrid0\insrsid1378858 tr\'ce con}{\f37\fs20\cgrid0\insrsid1378858  }{\i\f37\fs20\cgrid0\insrsid1378858 l\'f3c s\'ac sinh kh\'abng \'ae\'ad\'eec}{\f37\fs20\cgrid0\insrsid1378858  }{\i\f37\fs20\cgrid0\insrsid1378858 ch\'a8m nom chu \'ae\'b8o n
\'aan \'ae\'b7 ch\'d5t nhi\'d2u... Trong s\'e8 d\'a9n c\'ad b\'b6n x\'f8 \'ae\'b7 b\'de b\'d6nh ng\'f1 l\'b5m cho ch\'d5t m\'dfn d\'c7n \'aei, th\'d7 b\'d6nh c\'f3m l\'b9i c\'dfn s\'b8t h\'b9i th\'aam h\'b5ng v\'b9n ng\'ad\'eai n\'f7a".}{
\f37\fs20\cgrid0\insrsid1378858 
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 \'a7\'d3 s\'f6a ch\'f7a t\'d7nh tr\'b9ng \'ae\'e3
, ng\'ad\'eai ta \'ae\'b7 l\'b5m \'ae\'ad\'eec nh\'f7ng g\'d7? Ng\'ad\'eai ta \'ae\'b7 x\'a9y d\'f9ng \'ae\'ad\'eec m\'e9t nh\'b5 th\'ad\'acng \'ae\'e9c nh\'cat, v\'edi 79 gi\'ad\'eang \'eb Bradavin, th\'f1 \'ae\'ab c\'f1a thu\'e9c \'ae\'dea! Th\'d5 m\'b5
 v\'edi c\'b8c d\'a9n c\'ad \'aeang \'aei \'ae\'d5n ch\'e7 di\'d6t vong \'ae\'e3, trong chi\'d5n tranh, ng\'ad\'eai ta l\'b9i c\'dfn t\'d7m \'ae\'ad\'eec c\'b8ch l\'cay \'aei 18.000 ng\'ad\'eai - t\'cat nhi\'aan l\'b5 nh\'f7ng ng\'ad\'eai l\'b5nh m\'b9
nh nh\'cat v\'b5 v\'b9m v\'ec nh\'cat - \'ae\'d3 l\'b5m m\'e5i cho \'ae\'b9i b\'b8c, 313.000 phr\'a8ng ti\'d2n c\'ad\'ecng b\'f8c l\'b9c quy\'aan \'ae\'d3 c\'f8u gi\'f3p c\'b8c mi\'d2n b\'de t\'b5n ph\'b8 \'eb Ph\'b8p, 7.323.000 phr\'a8ng ti\'d2n c\'ab
ng tr\'b8i c\'ad\'ecng b\'f8c, 53.000 t\'can h\'b5ng ho\'b8, \'ae\'cay l\'b5 ch\'ada k\'d3 kh\'abng bi\'d5t bao nhi\'aau l\'b5 ng\'b5y \'aei phu \'ae\'d3 chuy\'aan ch\'eb nh\'f7ng \'ae\'e5 \'ae\'b7 tr\'adng thu.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 \'a7\'e3 l\'b5 nh\'f7ng "sai l\'c7m v\'d2 nguy\'aa
