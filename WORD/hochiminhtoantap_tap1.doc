\clbrdrt\brdrnone \clbrdrl\brdrnone \clbrdrb\brdrs\brdrw10 \clbrdrr\brdrnone \cltxlrtb\clftsWidth3\clwWidth2997\clshdrawnil \cellx13694\row }\pard\plain \s32\ql \li0\ri0\sa120\widctlpar
\tqc\tx4320\tqr\tx8640\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f42\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 
\par }}\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 BL\'a1NG,}{\fs18\insrsid1378858  }{
\b\fs18\insrsid1378858 Giuyn}{\fs18\insrsid1378858  (1881-1960): Tham gia \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p n\'a8m 1905; \'ae\'b9i bi\'d3u tham d\'f9 \'a7\'b9i h\'e9i \'a7\'b6ng X\'b7 h\'e9i \'eb Xtraxbua v\'b5 Tua n\'a8m 1920, thu\'e9c ph\'b8i Qu\'e8c t
\'d5 th\'f8 ba. N\'a8m 1921, \'ae\'ad\'eec b\'c7u v\'b5o Ban l\'b7nh \'ae\'b9o c\'f1a \'a7\'b6ng C\'e9ng s\'b6n Ph\'b8p \'eb \'a7\'b9i h\'e9i to\'b5n qu\'e8c h\'e4p \'eb M\'b8cx\'a9y. Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\fs18\insrsid1378858 i Qu
\'e8c \'ae\'ad\'eec c\'f6 l\'b5m tr\'ee l\'fd cho Bl\'a8ng khi l\'b5m Ch\'f1 t\'dech phi\'aan h\'e4p s\'b8ng ng\'b5y 30-12-1921. V\'d2 sau, \'abng b\'e1 \'a7\'b6ng C\'e9ng s\'b6n, l\'b5m th\'ad k\'fd c\'abng \'aeo\'b5n v\'b5 vi\'d5t b\'b8o.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 B\'a4, }{\b\f37\fs18\insrsid1378858 Phil\'ddp }{
\f37\fs18\insrsid1378858 : \'a7\'ad\'eec B\'e9 Thu\'e9c \'ae\'dea c\'f6 l\'b5m To\'b5n quy\'d2n \'a7\'abng D\'ad\'acng ng\'b5y 1-7-1902, ch\'ddnh th\'f8c nh\'cbm ch\'f8c ng\'b5y 15-10-1902. Ph.B\'ab l\'b5m To\'b5n quy\'d2n \'a7\'abng D\'ad\'acng \'ae\'d5
n ng\'b5y 25-6-1908.
\par B\'a4\'a7OANH, }{\b\f37\fs18\insrsid1378858 P\'abn}{\f37\fs18\insrsid1378858 : Vi\'aan ch\'f8c cao c\'cap c\'f1a ch\'ddnh quy\'d2n th\'f9c d\'a9n Ph\'b8p \'eb \'a7\'abng D\'ad\'acng; l\'b5m quy\'d2n To\'b5n quy\'d2n \'a7\'abng D\'ad\'acng t\'f5 th\'b8
ng 4 \'ae\'d5n th\'b8ng 9-1922, t\'f5 khi M\'abrix\'ac L\'abng v\'d2 Ph\'b8p cho \'ae\'d5n khi M\'d0clanh sang thay. B\'ab\'aeoanh l\'b5m T\'e6ng Gi\'b8m \'ae\'e8c nh\'b5 b\'a8ng n\'a8m 1931, Ch\'f1 t\'dech c\'b8c nh\'b5 b\'a8ng \'eb \'a7\'abng D\'ad\'ac
ng t\'f5 n\'a8m 1941 \'ae\'d5n n\'a8m 1944.
\par }{\f37\fs18\expnd0\expndtw-2\insrsid1378858 B\'a4N\'a7UIN, }{\b\f37\fs18\expnd0\expndtw-2\insrsid1378858 St\'aanli }{\f37\fs18\expnd0\expndtw-2\insrsid1378858 (1867-1947): L\'b7nh t\'f4 c\'f1a nh\'f7ng ng\'ad\'eai b\'b6o th\'f1 Anh; Th\'f1 t\'ad\'ed
ng Anh n\'a8m 1923-1924, 1924-1929 v\'b5 1935-1937; l\'b5 ng\'ad\'eai \'f1ng h\'e9 ch\'ddnh s\'b8ch thu\'e9c \'ae\'dea v\'b5 khuy\'d5n kh\'ddch can thi\'d6p v\'f2 trang ch\'e8ng c\'b8ch m\'b9ng Trung Qu\'e8c n\'a8m 1924-1927. B\'abn\'aeuin \'ae\'b7 c\'c7
m \'ae\'c7u v\'f4 \'ae\'b5n \'b8p cu\'e9c t\'e6ng b\'b7i c\'abng c\'f1a giai c\'cap c\'abng nh\'a9n v\'b5 cu\'e9c b\'b7i c\'abng c\'f1a c\'abng nh\'a9n m\'e1 n\'a8m 1926; c\'e3 th\'b8i \'ae\'e9 th\'ef \'ae\'dech v\'edi Li\'aan X\'ab n\'a8m 1927; th\'f9c h
\'b5nh ch\'ddnh s\'b8ch khuy\'d5n kh\'ddch b\'e4n x\'a9m l\'ad\'eec }{\f38\fs18\expnd0\expndtw-2\insrsid1378858 \'fd,}{\f37\fs18\expnd0\expndtw-2\insrsid1378858  \'a7\'f8c v\'b5 \'a9m m\'adu c\'a9u k\'d5t v\'edi n\'ad\'edc \'a7\'f8c H\'ddtle ch\'dca m\'f2
i nh\'e4n x\'a9m l\'ad\'eec c\'f1a \'a7\'f8c v\'b5o Li\'aan X\'ab.
\par BRAO, }{\b\f37\fs18\expnd0\expndtw-2\insrsid1378858 Gi\'abn}{\f37\fs18\expnd0\expndtw-2\insrsid1378858  (1800-1859): M\'e9t trong nh\'f7ng ng\'ad\'eai \'ae\'cau tranh gi\'b6i ph\'e3ng ng\'ad\'eai da \'aeen \'eb M\'fc, t\'e6 ch\'f8c ra H\'e9i \'ae\'ca
u tranh th\'f1 ti\'aau ch\'d5 \'ae\'e9 n\'ab l\'d6, l\'cbp nh\'b5 tr\'ad\'eang cho ng\'ad\'eai da \'aeen, gi\'f3p ng\'ad\'eai n\'ab l\'d6 ch\'b9y tr\'e8n l\'b8nh n\'b9n sang Cana\'aea. Brao c\'c7m \'ae\'c7u m\'e9t to\'b8n ng\'ad\'eai da tr\'beng v\'b5 da 
\'aeen \'ae\'b8nh chi\'d5m kho v\'f2 kh\'dd c\'f1a ch\'ddnh ph\'f1 bang Vi\'d5cginia. Trong khi \'ae\'b8nh nhau, Brao b\'de b\'bet v\'b5 hai con trai b\'de gi\'d5t. Ng\'b5y 2-12-1859, b\'de x\'f6 treo c\'e6.
\par }{\f37\fs18\insrsid1378858 BU\'a7IN\'a4, }{\b\f37\fs18\insrsid1378858 Lu-i Pie, Emil\'ac - Gabrien}{\f37\fs18\insrsid1378858  (1875-?): T\'e8t nghi\'d6p tr\'ad\'eang c\'b8c sinh ng\'f7 ph\'ad\'acng \'a7\'abng, sang \'a7\'abng D\'ad\'acng t\'f5 n\'a8
m 1901; l\'b5m Ph\'e3 C\'abng s\'f8 t\'d8nh Th\'f5a Thi\'aan n\'a8m 1910; sau \'ae\'e3 l\'b5m nhi\'d2u vi\'d6c v\'edi t\'ad c\'b8ch l\'b5 quan ch\'f8c c\'f1a ch\'ddnh quy\'d2n th\'f9c d\'a9n Ph\'b8p \'eb \'a7\'abng D\'ad\'acng.
\par }\pard\plain \s29\qc \li0\ri0\sa240\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 CAI\'a4, }{\b\f37\fs18\insrsid1378858 Gi\'abd\'d0
p Mari \'a4gu\'fdtxt\'ac}{\f37\fs18\insrsid1378858  (1863-1944): Nhi\'d2u l\'c7n l\'b5m B\'e9 tr\'ad\'ebng B\'e9 T\'b5i ch\'ddnh trong Ch\'ddnh ph\'f1 Ph\'b8p. N\'a8m 1911, l\'b5m Th\'f1 t\'ad\'edng. Trong nh\'f7ng n\'a8m Chi\'d5n tranh th\'d5 gi\'edi th
\'f8 nh\'cat, \'aei c\'abng c\'b8n \'eb Nam M\'fc v\'b5 \'eb Italia. B\'de kh\'b6 nghi n\'aan Ch\'ddnh ph\'f1 Cl\'aam\'a8ngx\'ab b\'bet giam n\'a8m 1917; b\'de k\'d5t \'b8n l\'b5 ti\'d5p tay kh\'abng t\'f9 nguy\'d6n cho k\'ce th\'ef n\'a8m 1920. M\'cay n
\'a8m sau \'ae\'ad\'eec tha, r\'e5i l\'b9i \'ae\'ad\'eec b\'c7u l\'b5m ngh\'de vi\'aan v\'b5 B\'e9 tr\'ad\'ebng B\'e9 T\'b5i ch\'ddnh n\'a8m 1925, sau l\'b5m Ch\'f1 t\'dech U\'fb ban T\'b5i ch\'ddnh c\'f1a Th\'ad\'eeng ngh\'de vi\'d6n \'ae\'d5n n\'a8
m 1940.
\par CANH, }{\b\f37\fs18\insrsid1378858 S\'b8cl\'ac}{\f37\fs18\insrsid1378858  (1500-1558): Ho\'b5ng \'ae\'d5 T\'a9y Ban Nha, c\'e3 tham v\'e4ng l\'b5m b\'b8 ch\'f1 th\'d5 gi\'edi, \'ae\'b7 g\'a9y nhi\'d2u cu\'e9c chi\'d5n tranh v\'edi Ph\'b8p, \'a7\'f8c, Th
\'e6 Nh\'dc K\'fa, Tuynidi, Angi\'aari, v.v..
\par CARAKHAN, }{\b\f37\fs18\insrsid1378858 L\'d0p Mikhail\'abv\'ddch}{\f37\fs18\insrsid1378858  (1889-1937): Nh\'b5 ho\'b9t \'ae\'e9ng ngo\'b9i giao X\'abvi\'d5t, U\'fb vi\'aan Trung \'ad\'acng \'a7\'b6ng C\'e9ng s\'b6n Li\'aan X\'ab. Ho\'b9t \'ae\'e9ng c\'b8
ch m\'b9ng t\'f5 n\'a8m 1904; tham gia C\'b8ch m\'b9ng Th\'b8ng M\'ad\'eai n\'a8m 1917. Th\'ad k\'fd \'a7o\'b5n \'ae\'b9i bi\'d3u X\'abvi\'d5t t\'b9i cu\'e9c \'ae\'b5m ph\'b8n ho\'b5 b\'d7nh \'eb Br\'d0t. Trong nh\'f7ng n\'a8m 1918-1920 v\'b5 1927-1934, l
\'b5 Th\'f8 tr\'ad\'ebng B\'e9 Ngo\'b9i giao. T\'f5 1923-1926, \'a7\'b9i s\'f8 Li\'aan X\'ab t\'b9i Trung Qu\'e8c; t\'f5 1937, \'a7\'b9i s\'f8 Li\'aan X\'ab t\'b9i Th\'e6 Nh\'dc K\'fa.
\par }\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 CASANH, }{\b\fs18\insrsid1378858 M\'b8cxen}{
\fs18\insrsid1378858  (1869-1958): Nh\'b5 ho\'b9t \'ae\'e9ng xu\'cat s\'bec c\'f1a phong tr\'b5o c\'abng nh\'a9n Ph\'b8p v\'b5 qu\'e8c t\'d5. T\'f5 n\'a8m 1912 \'ae\'d5n 1918, bi\'aan t\'cbp vi\'aan b\'b8o }{\i\fs18\insrsid1378858 L'Humanit\'d0}{
\fs18\insrsid1378858  , c\'ac quan trung \'ad\'acng c\'f1a \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p v\'b5 n\'a8m 1918 l\'b5m ch\'f1 b\'f3t t\'ea b\'b8o \'ae\'e3. Casanh l\'b5 m\'e9t trong nh\'f7ng ng\'ad\'eai t\'ddch c\'f9c \'f1ng h\'e9 v\'b5 gi\'f3p \'ae\'ec Nguy
\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\fs18\insrsid1378858 i Qu\'e8c trong th\'eai gian ho\'b9t \'ae\'e9ng \'eb Ph\'b8p.
\par }\pard\plain \qj \fi397\li425\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 N\'a8m 1920, v\'edi t\'ad c\'b8ch l\'b5 \'ae\'b9i bi
\'d3u c\'f1a \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p, Casanh tham gia \'a7\'b9i h\'e9i l\'c7n th\'f8 II Qu\'e8c t\'d5 C\'e9ng s\'b6n t\'f5 n\'a8m 1924 \'ae\'d5n n\'a8m 1943, U\'fb vi\'aan Ban Ch\'cap h\'b5nh Qu\'e8c t\'d5 C\'e9ng s\'b6n.
\par T\'f5 n\'a8m 1921, Casanh li\'aan t\'f4c \'ae\'ad\'eec b\'c7u l\'b5m U\'fb vi\'aan Ban Ch\'cap h\'b5nh Trung \'ad\'acng v\'b5 U\'fb vi\'aan B\'e9 Ch\'ddnh tr\'de \'a7\'b6ng C\'e9ng s\'b6n Ph\'b8p.
\par }\pard\plain \s15\qj \fi397\li425\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 N\'a8m 1957, Casanh \'ae\'ad\'eec \'a7\'b6ng v\'b5
 Nh\'b5 n\'ad\'edc Li\'aan X\'ab t\'c6ng Hu\'a9n ch\'ad\'acng L\'aanin.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-282\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 CL\'a3M\'a1NGX\'a4,}{\f37\fs18\insrsid1378858  }{
\b\f37\fs18\insrsid1378858 Gi\'e3ocgi\'ac B\'a8nggia}{\f37\fs18\insrsid1378858  (1841-1929): V\'e8n l\'b5 th\'c7y thu\'e8c, tham gia ho\'b9t \'ae\'e9ng ch\'ddnh tr\'de sau ng\'b5y \'ae\'d5 ch\'d5 th\'f8 hai s\'f4p \'ae\'e6 (4-9-1870), ngh\'de s\'dc c\'ca
p ti\'d5n trong Qu\'e8c h\'e9i, thu\'e9c ph\'b8i c\'f9c t\'b6, d\'f9a v\'b5o nh\'f7ng cu\'e9c l\'cbt \'ae\'e6 nhi\'d2u b\'e9 tr\'ad\'ebng v\'b5 l\'b5m B\'e9 tr\'ad\'ebng B\'e9 N\'e9i v\'f4 (1906-1909). Cl\'aam\'a8ngx\'ab ch\'f1 tr\'ad\'acng ra b\'b8o }{
\i\f37\fs18\insrsid1378858 L'Homme libre}{\f37\fs18\insrsid1378858  (1913), \'ae\'c7u Chi\'d5n tranh th\'d5 gi\'edi th\'f8 nh\'cat l\'b5 b\'b8o }{\i\f37\fs18\insrsid1378858 L'Homme enchain\'d0, }{\f37\fs18\insrsid1378858 t\'e8 c\'b8o ch\'d5 \'ae\'e9 ki
\'d3m duy\'d6t. N\'a8m 1920, b\'de th\'cat b\'b9i trong tranh c\'f6 t\'e6ng th\'e8ng, Cl\'aam\'a8ngx\'ab ra n\'ad\'edc ngo\'b5i v\'b5 vi\'d5t s\'b8ch.
\par }{\f38\fs18\insrsid1378858 CO\'e3C\'a7IE,}{\f37\fs18\insrsid1378858  }{\b\f37\fs18\insrsid1378858 H\'a8ngri}{\f37\fs18\insrsid1378858  (1840-1925): Nh\'b5 \'a7\'abng ph\'ad\'acng h\'e4c ng\'ad\'eai Ph\'b8p, t\'b8c gi\'b6 c\'f1a nhi\'d2u cu\'e8n s\'b8ch v
\'d2 ph\'ad\'acng \'a7\'abng, \'ae\'c6c bi\'d6t l\'b5 Trung Qu\'e8c.
\par C\'a4NGXT\'a1NGTANH I (1868-1923): Vua Hy L\'b9p; n\'e8i ng\'abi vua cha l\'b5 Gio\'e3cgi\'ac I n\'a8m 1913. N\'a8m 1917, b\'de b\'bet \'aei \'ae\'b5y, sau tr\'eb v\'d2 l\'aan ng\'abi n\'a8m 1920 v\'b5 tho\'b8i v\'de n\'a8m 1922.
\par }{\f38\fs18\insrsid1378858 C\'a4NTR\'beC}{\f37\fs18\insrsid1378858 , }{\b\f37\fs18\insrsid1378858 Al\'d5chx\'a8ng\'aer\'ac Vaxili\'aav\'ddch}{\f37\fs18\insrsid1378858  (1873-1920): Ph\'c7n t\'f6 qu\'a9n ch\'f1, m\'e9t trong nh\'f7ng k\'ce c\'c7m \'ae\'c7
u c\'b8c th\'d5 l\'f9c ph\'b6n c\'b8ch m\'b9ng \'eb Nga, tay sai c\'f1a kh\'e8i \'ae\'e5ng minh \'ae\'d5 qu\'e8c (1918-1919), ti\'d5p tay cho h\'b5nh \'ae\'e9ng can thi\'d6p c\'f1a c\'b8c n\'ad\'edc \'ae\'d5 qu\'e8c v\'b5 g\'a9y ra n\'e9i chi\'d5n ch\'e8
ng l\'b9i ch\'ddnh quy\'d2n X\'abvi\'d5t sau C\'b8ch m\'b9ng Th\'b8ng M\'ad\'eai.
\par }\pard\plain \s15\qj \fi397\li425\ri0\sa80\sl-282\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 Nh\'f7ng \'ae\'eet t\'can c\'abng c\'f1a H\'e5
ng qu\'a9n \'ae\'b7 l\'b5m l\'f9c l\'ad\'eeng c\'f1a C\'abntr\'bec tan r\'b7. C\'abntr\'bec b\'de b\'bet l\'b5m t\'ef binh v\'b5 ng\'b5y 7-2-1920, b\'de x\'f6 b\'ben theo quy\'d5t \'ae\'denh c\'f1a U\'fb ban C\'b8ch m\'b9ng I\'d5cc\'f3txc\'ac (Li\'aan X
\'ab).
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-282\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 D
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-282\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 DIN\'a4VI\'d0P}{\f37\fs18\insrsid1378858 , }{
\b\f37\fs18\insrsid1378858 Ra\'ae\'abm\'adxl\'acxki G.E}{\f37\fs18\insrsid1378858 . (1883-1936): Gia nh\'cbp \'a7\'b6ng c\'abng nh\'a9n d\'a9n ch\'f1 - x\'b7 h\'e9i Nga n\'a8m 1901. Sau C\'b8ch m\'b9ng Th\'b8ng M\'ad\'eai, l\'b5 Ch\'f1 t\'dech X\'abvi\'d5
t P\'aatr\'abgr\'b8t, U\'fb vi\'aan B\'e9 Ch\'ddnh tr\'de Ban Ch\'cap h\'b5nh Trung \'ad\'acng \'a7\'b6ng C\'e9ng s\'b6n Nga (b), Ch\'f1 t\'dech Ban Ch\'cap h\'b5nh Qu\'e8c t\'d5 C\'e9ng s\'b6n. Hai l\'c7n b\'de khai tr\'f5 kh\'e1i \'a7\'b6ng C\'e9ng s
\'b6n v\'b5 \'ae\'ad\'eec ph\'f4c h\'e5i; n\'a8m 1934, b\'de khai tr\'f5 h\'bcn kh\'e1i \'a7\'b6ng C\'e9ng s\'b6n.
\par }\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-282\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 DUY T\'a2N}{\fs18\insrsid1378858 
 (1900-1945): T\'f8c Nguy\'d4n V\'dcnh San, vua th\'f8 11 nh\'b5 Nguy\'d4n t\'f5 n\'a8m 1907 \'ae\'d5n n\'a8m 1916. Duy T\'a9n l\'b5 ng\'ad\'eai y\'aau n\'ad\'edc v\'b5 c\'e3 tinh th\'c7n d\'a9n t\'e9c. N\'a8m 1916, c\'efng Th\'b8i Phi\'aan v\'b5 Tr\'c7
n Cao V\'a9n trong t\'e6 ch\'f8c Vi\'d6t Nam quang ph\'f4c h\'e9i d\'f9a v\'b5o s\'e8 binh l\'ddnh b\'de m\'e9 sang Ph\'b8p t\'e6 ch\'f8c kh\'ebi ngh\'dca \'eb Hu\'d5 v\'b5 mi\'d2n Nam Trung K\'fa. C\'abng vi\'d6c b\'de b\'b9i l\'e9, kh\'ebi ngh\'dca kh
\'abng th\'b5nh, Duy T\'a9n b\'de th\'f9c d\'a9n Ph\'b8p \'ae\'b5y sang \'ae\'b6o R\'aauyni\'abng (ch\'a9u Phi). Duy T\'a9n l\'b5 ng\'ad\'eai ham h\'e4c v\'b5 c\'e3 \'fd ch\'dd. Trong Chi\'d5n tranh th\'d5 gi\'edi th\'f8 hai, gia nh\'cbp qu\'a9n \'ae\'e9
i \'a7\'e5ng minh ch\'e8ng ph\'b8t x\'ddt; n\'a8m 1945, m\'cat v\'d7 tai n\'b9n m\'b8y bay \'eb ch\'a9u Phi.
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'a7
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 \'a7\'b8CL\'a5,}{\f37\fs18\insrsid1378858  }{
\b\f37\fs18\insrsid1378858 \'a4guytxt\'ac E\'aeua}{\f37\fs18\insrsid1378858  (1875-1940): Ng\'ad\'eai Ph\'b8p, c\'f6 nh\'a9n v\'a8n ch\'ad\'acng. N\'a8m 1906, sang \'a7\'abng D\'ad\'acng v\'b5o ng\'b9ch 4 quan cai tr\'de. \'a7\'b8cl\'ac l\'b5m C\'abng s
\'f8 t\'d8nh Th\'b8i Nguy\'aan, ch\'f1 tr\'ad\'acng \'ae\'b5n \'b8p \'ae\'c9m m\'b8u cu\'e9c n\'e6i d\'cby c\'f1a binh l\'ddnh ng\'ad\'eai Vi\'d6t do Tr\'denh V\'a8n C\'can ch\'d8 huy, th\'b8ng 8-1917.
\par }{\f38\fs18\insrsid1378858 \'a7\'b8CUYN,}{\f37\fs18\insrsid1378858  }{\b\f37\fs18\insrsid1378858 S\'b8cl\'ac}{\f37\fs18\insrsid1378858  (1809-1882): Nh\'b5 sinh v\'cbt h\'e4c v\'dc \'ae\'b9i ng\'ad\'eai Anh; ng\'ad\'eai s\'b8ng l\'cbp khoa sinh v\'cbt h
\'e4c duy v\'cbt, l\'fd thuy\'d5t v\'d2 s\'f9 ti\'d5n h\'e3a c\'f1a gi\'e8ng lo\'b5i v\'b5 cu\'e9c \'ae\'cau tranh gi\'f7a c\'b8c gi\'e8ng lo\'b5i. \'a7\'b8cuyn k\'dech li\'d6t b\'b8c b\'e1 nh\'f7ng quan \'aei\'d3m duy t\'a9m c\'f1a gi\'b8o h\'e9i v\'d2
 ngu\'e5n g\'e8c lo\'b5i ng\'ad\'eai v\'b5 c\'b8c sinh v\'cbt. \'a7\'b8cuyn tr\'d7nh b\'b5y nh\'f7ng lu\'cbn \'aei\'d3m khoa h\'e4c c\'f1a m\'d7nh trong t\'b8c ph\'c8m }{\i\f37\fs18\insrsid1378858 Ngu\'e5n g\'e8c c\'b8c lo\'b5i}{\f37\fs18\insrsid1378858 
 (1859).
\par }{\f38\fs18\insrsid1378858 \'a7AOX\'a5,}{\f37\fs18\insrsid1378858  }{\b\f37\fs18\insrsid1378858 S\'b8cl\'ac Ghit\'ac}{\f37\fs18\insrsid1378858  (1865-1951): Nh\'b5 t\'b5i ch\'ddnh v\'b5 ho\'b9t \'ae\'e9ng ch\'ddnh tr\'de M\'fc. (Xem ch\'f3 th\'ddch s\'e8
 53).
\par \'a7}{\f38\fs18\insrsid1378858 \'d2 TH\'b8M}{\f37\fs18\insrsid1378858  t\'f8c Ho\'b5ng Hoa Th\'b8m (1862-1913): Ng\'ad\'eai l\'b7nh \'ae\'b9o phong tr\'b5o kh\'ebi ngh\'dca n\'abng d\'a9n \'eb Y\'aan Th\'d5 (H\'b5 B\'bec), m\'e9t phong tr\'b5o \'ae\'ca
u tranh y\'aau n\'ad\'edc quy\'d5t li\'d6t v\'b5 b\'d2n b\'d8 c\'f1a n\'abng d\'a9n Vi\'d6t Nam; b\'de tay sai th\'f9c d\'a9n Ph\'b8p \'b8m h\'b9i n\'a8m 1913.
\par }{\f38\fs18\insrsid1378858 \'a7\'e9I V\'a1N}{\f37\fs18\insrsid1378858 : M\'e9t trong nh\'f7ng ng\'ad\'eai ch\'d8 huy cu\'e9c kh\'ebi ngh\'dca B\'b7i S\'cby (1885-1889) thu\'e9c t\'d8nh H\'adng Y\'aan c\'f2, do Nguy\'d4n Thi\'d6n Thu\'cbt l\'b7nh \'ae\'b9
o. N\'a8m 1889, b\'de kh\'f1ng b\'e8, \'a7\'e9i V\'a8n tr\'b8 h\'b5ng, \'ae\'ad\'eec Ph\'b8p c\'cap cho 500 qu\'a9n \'ae\'d3 \'ae\'b8nh l\'b9i ngh\'dca qu\'a9n. \'a7\'e9i V\'a8n mang to\'b5n b\'e9 qu\'a9n l\'ddnh v\'b5 v\'f2 kh\'dd gia nh\'cbp ngh\'dca qu
\'a9n Ho\'b5ng Hoa Th\'b8m \'ae\'b8nh l\'b9i qu\'a9n Ph\'b8p.
\par }\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 \'a7\'a5 VAL\'a5RA, }{\b\fs18\insrsid1378858 Im
\'acn}{\fs18\insrsid1378858  (1882-1975): Nh\'b5 y\'aau n\'ad\'edc Aixlen, th\'f1 l\'dcnh cu\'e9c n\'e6i d\'cby c\'f1a nh\'f7ng ng\'ad\'eai t\'d7nh nguy\'d6n Aixlen n\'a8m 1916, l\'b7nh t\'f4 \'a7\'b6ng Xin P\'aain n\'a8m 1918. \'a4ng hai l\'c7n l\'b5m Th
\'f1 t\'ad\'edng Aix\'aclen v\'b5 quy\'d5t \'ae\'denh Aix\'aclen \'ae\'f8ng trung l\'cbp trong Chi\'d5n tranh th\'d5 gi\'edi th\'f8 hai. N\'a8m 1959, l\'b5 T\'e6ng th\'e8ng v\'b5 n\'a8m 1966, \'ae\'ad\'eec b\'c7u l\'b9i l\'b5m T\'e6ng th\'e8ng n\'ad\'ed
c C\'e9ng ho\'b5 Aix\'aclen.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 \'a7UME, }{\b\f37\fs18\insrsid1378858 P\'abn}{
\f37\fs18\insrsid1378858  (1857-1932): Ngh\'de s\'dc Qu\'e8c h\'e9i Ph\'b8p (ph\'b8i c\'cap ti\'d5n) n\'a8m 1888, 1895; B\'e9 tr\'ad\'ebng B\'e9 T\'b5i ch\'ddnh n\'a8m 1895-1896, 1921-1922; To\'b5n quy\'d2n \'a7\'abng D\'ad\'acng n\'a8m 1896-1902; Ch\'f1
 t\'dech Th\'ad\'eeng vi\'d6n n\'a8m 1927; T\'e6ng th\'e8ng n\'a8m 1931; t\'b8c gi\'b6 cu\'e8n s\'b8ch }{\i\f37\fs18\insrsid1378858 Indochine - Francaise}{\f37\fs18\insrsid1378858 . B\'de \'b8m s\'b8t n\'a8m 1932.
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 G
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 G\'b8CNI\'a3,}{\f37\fs18\insrsid1378858  }{
\b\f37\fs18\insrsid1378858 Phr\'a8ngxi}{\f37\fs18\insrsid1378858  (1839-1873): S\'dc quan h\'b6i qu\'a9n Ph\'b8p tham gia \'ae\'b8nh chi\'d5m B\'bec K\'fa l\'c7n th\'f8 nh\'cat, b\'de qu\'a9n ta gi\'d5t ch\'d5t \'eb g\'c7n C\'c7u Gi\'cay (H\'b5 N\'e9i) n
\'a8m 1873.
\par }{\f38\fs18\insrsid1378858 G\'a1NG\'a7I,}{\f37\fs18\insrsid1378858  }{\b\f37\fs18\insrsid1378858 M\'abhan\'ae\'b8t, Karamsan}{\f37\fs18\insrsid1378858  (1869-1948): Nh\'b5 tri\'d5t h\'e4c, nh\'b5 v\'a8n, nh\'b5 ho\'b9t \'ae\'e9ng n\'e6i ti\'d5ng c\'f1
a phong tr\'b5o gi\'b6i ph\'e3ng d\'a9n t\'e9c }{\f38\fs18\insrsid1378858 \'ca}{\f37\fs18\insrsid1378858 n \'a7\'e9. \'a7\'d3 ch\'e8ng l\'b9i th\'f9c d\'a9n Anh, gi\'b5nh \'ae\'e9c l\'cbp d\'a9n t\'e9c, G\'a8ng\'aei ch\'f1 tr\'ad\'acng kh\'abng d\'efng b
\'b9o l\'f9c v\'b5 kh\'abng coi b\'b9o l\'f9c l\'b5 ph\'ad\'acng th\'f8c \'ae\'cau tranh ch\'ddnh tr\'de. Trong phong tr\'b5o \'ae\'cau tranh gi\'b6i ph\'e3ng d\'a9n t\'e9c \'eb }{\f38\fs18\insrsid1378858 \'ca}{\f37\fs18\insrsid1378858 n \'a7\'e9
 (1919-1922), G\'a8ng\'aei tr\'eb th\'b5nh l\'b7nh t\'f4 c\'f1a \'a7\'b6ng Qu\'e8c \'ae\'b9i v\'b5 gi\'f7 vai tr\'df quan tr\'e4ng trong vi\'d6c bi\'d5n \'a7\'b6ng n\'b5y th\'b5nh m\'e9t t\'e6 ch\'f8c qu\'c7n ch\'f3ng ch\'e8ng \'ae\'d5 qu\'e8c. H\'e4
c thuy\'d5t \'ae\'d2 kh\'b8ng ti\'aau c\'f9c c\'f1a G\'a8ng\'aei tr\'eb th\'b5nh t\'ad t\'ad\'ebng ch\'ddnh c\'f1a \'a7\'b6ng Qu\'e8c \'ae\'b9i trong cu\'e9c \'ae\'cau tranh cho n\'d2n \'ae\'e9c l\'cbp }{\f38\fs18\insrsid1378858 \'ca}{
\f37\fs18\insrsid1378858 n \'a7\'e9. N\'a8m 1946, G\'a8ng\'aei tuy\'aan b\'e8 kh\'abng nh\'cat thi\'d5t ch\'d8 d\'efng ph\'ad\'acng ph\'b8p \'ae\'cau tranh kh\'abng b\'b9o l\'f9c. G\'a8ng\'aei c\'e3 \'b6nh h\'ad\'ebng v\'b5 uy t\'ddn l\'edn \'eb }{
\f38\fs18\insrsid1378858 \'ca}{\f37\fs18\insrsid1378858 n \'a7\'e9. Nh\'a9n d\'a9n }{\f38\fs18\insrsid1378858 \'ca}{\f37\fs18\insrsid1378858 n \'a7\'e9 suy t\'abn l\'b5 Mah\'b8tma ngh\'dca l\'b5 "T\'a9m h\'e5n v\'dc \'ae\'b9i". N\'a8m 1948, b\'de b\'e4
n ph\'b6n \'ae\'e9ng \'b8m s\'b8t.
\par }{\f38\fs18\insrsid1378858 GHINB\'a4,}{\f37\fs18\insrsid1378858  }{\b\f37\fs18\insrsid1378858 H\'a8ngri}{\f37\fs18\insrsid1378858  (1885-1938): Ng\'ad\'eai Ph\'b8p; n\'a8m 1916, tham gia h\'e9i ngh\'de Kientan. \'a7\'c7u nh\'f7ng n\'a8m 20 l\'b5 ph\'e3
ng vi\'aan b\'b8o }{\i\f37\fs18\insrsid1378858 L'Humanit\'d0}{\f37\fs18\insrsid1378858  \'eb \'a7\'f8c. Sau chuy\'d3n sang ph\'b8i t\'acr\'e8txk\'ddt, ti\'d5p t\'f4c l\'b5m b\'b8o.
\par }\pard \qj \fi-425\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 {\f37\fs18\insrsid1378858 GIA LONG (1762-1820): T\'f8c Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 nh, \'ae\'b9i di
\'d6n c\'f1a th\'d5 l\'f9c \'ae\'dea ch\'f1 phong ki\'d5n \'ae\'b7 b\'de phong tr\'b5o T\'a9y S\'acn l\'cbt \'ae\'e6. \'a7\'d3 ch\'e8ng l\'b9i T\'a9y S\'acn, kh\'abi ph\'f4c ch\'d5 \'ae\'e9 phong ki\'d5n, Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{
\f37\fs18\insrsid1378858 nh \'ae\'b7 c\'c7u c\'f8u qu\'a9n x\'a9m l\'ad\'eec Xi\'aam (1784); \'f1ng h\'e9 qu\'a9n x\'a9m l\'ad\'eec Thanh; c\'a9u k\'d5t v\'edi t\'ad b\'b6n Ph\'b8p v\'b5 k\'fd v\'edi Ph\'b8p b\'b6n hi\'d6p \'ad\'edc n\'a8m 1787. B\'b6n hi
\'d6p \'ad\'edc g\'e5m 10 kho\'b6n, n\'e9i dung ch\'f1 y\'d5u l\'b5:
\par }\pard \qj \fi397\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 {\f37\fs18\insrsid1378858 -  Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 nh nh\'ad\'eeng h\'bcn cho Ph\'b8p \'ae\'b6
o C\'abn L\'abn; c\'f6a bi\'d3n H\'e9i An v\'b5 cam k\'d5t \'ae\'d3 cho t\'ad b\'b6n Ph\'b8p n\'bem \'ae\'e9c quy\'d2n bu\'abn b\'b8n tr\'aan c\'b6 n\'ad\'edc, cung c\'cap binh l\'ddnh v\'b5 l\'ad\'acng th\'f9c cho Ph\'b8p khi c\'e3 chi\'d5n tranh.
\par }\pard\plain \s15\qj \fi397\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 -  Ch\'ddnh ph\'f1 Ph\'b8p nh\'cbn gi\'f3p Nguy
\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\fs18\insrsid1378858 nh 4 t\'b5u chi\'d5n v\'b5 m\'e9t \'ae\'e9i qu\'a9n ch\'e8ng l\'b9i phong tr\'b5o T\'a9y S\'acn.
\par Sau khi \'ae\'b5n \'b8p \'ae\'ad\'eec phong tr\'b5o T\'a9y S\'acn (1802), Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\fs18\insrsid1378858 nh l\'aan ng\'abi, hi\'d6u l\'b5 Gia Long, m\'eb \'ae\'c7u nh\'b5 Nguy\'d4n, tri\'d2u vua cu\'e8i c\'efng \'eb Vi\'d6
t Nam.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 GI\'e3PPHR\'a5,}{\f37\fs18\insrsid1378858  }{
\b\f37\fs18\insrsid1378858 Gi\'abd\'d0p Gi\'becc\'ac X\'aaxer\'ac}{\f37\fs18\insrsid1378858  (1852-1931): Th\'e8ng ch\'d5 Ph\'b8p, \'ae\'b7 t\'f5ng \'eb B\'bec K\'fa, Xu\'ae\'a8ng, Ma\'aeag\'b8txca t\'f5 nh\'f7ng n\'a8m \'ae\'c7u th\'d5 k\'fb XX; T\'e6
ng tham m\'adu tr\'ad\'ebng qu\'a9n \'ae\'e9i v\'b5 Ph\'e3 Ch\'f1 t\'dech H\'e9i \'ae\'e5ng Qu\'e8c ph\'dfng t\'e8i cao Ph\'b8p n\'a8m 1911. Sau khi \'ae\'ad\'eec phong Th\'e8ng ch\'d5 n\'a8m 1917, Gi\'e3pphr\'ac sang c\'abng c\'b8n \'eb M\'fc.
\par }{\f38\fs18\insrsid1378858 GI\'a5NUIY,}{\f37\fs18\insrsid1378858  }{\b\f37\fs18\insrsid1378858 Rig\'abn \'ae\'ac}{\f37\fs18\insrsid1378858 : \'a7\'ab \'ae\'e8c h\'b6i qu\'a9n Ph\'b8p \'ae\'b7 \'aeem chi\'d5n thuy\'d2n \'ae\'d5n b\'ben ph\'b8 c\'b6ng \'a7
\'b5 N\'bdng n\'a8m 1858, m\'eb \'ae\'c7u cu\'e9c chi\'d5n tranh x\'a9m l\'ad\'eec c\'f1a th\'f9c d\'a9n Ph\'b8p \'eb Vi\'d6t Nam.
\par }{\f38\fs18\insrsid1378858 GU\'a7\'a5}{\f37\fs18\insrsid1378858 , }{\b\f37\fs18\insrsid1378858 \'a3mil\'ac }{\f37\fs18\insrsid1378858 (1870-1941): Ng\'ad\'eai Ph\'b8p, tham gia H\'e9i tam \'aei\'d3m, Ph\'e3 \'a7\'e8c l\'fd th\'b5nh ph\'e8, U\'fb vi\'aan U
\'fb ban th\'ad\'eang tr\'f9c c\'f1a \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p. }{\f38\fs18\insrsid1378858 \'eb }{\f37\fs18\insrsid1378858 \'a7\'b9i h\'e9i Tua, 1920, Gu\'ae\'ac b\'e1 phi\'d5u cho Qu\'e8c t\'d5 th\'f8 hai.
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 H
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 H\'b5M NGHI}{\f37\fs18\insrsid1378858  (1871-1944): T
\'f8c Nguy\'d4n \'a6ng L\'dech, vua th\'f8 8 nh\'b5 Nguy\'d4n, ng\'ad\'eai \'ae\'f8ng \'ae\'c7u phe ch\'f1 chi\'d5n ch\'e8ng th\'f9c d\'a9n Ph\'b8p trong tri\'d2u \'ae\'d7nh Hu\'d5. Khi kinh \'ae\'ab Hu\'d5 th\'cat th\'f1 (th\'b8ng 7-1885), H\'b5m Nghi c
\'efng T\'abn Th\'cat Thuy\'d5t ra ph\'dda B\'bec t\'e6 ch\'f8c kh\'b8ng chi\'d5n. B\'de th\'f9c d\'a9n Ph\'b8p l\'efng b\'bet, ph\'b6i l\'b8nh \'eb v\'efng r\'f5ng n\'f3i t\'d8nh Qu\'b6ng B\'d7nh, xu\'e8ng Chi\'d5u C\'c7n v\'ad\'acng k\'aau g\'e4i v\'a8
n th\'a9n, s\'dc phu v\'b5 nh\'a9n d\'a9n ch\'e8ng Ph\'b8p. Th\'b8ng 11-1888, b\'de th\'f9c d\'a9n Ph\'b8p b\'bet, sau \'ae\'e3 \'ae\'b5y sang Angi\'aa (th\'f1 ph\'f1 c\'f1a Angi\'aari \'eb B\'bec Phi).
\par }\pard \qj \fi-425\li425\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 {\f38\fs18\insrsid1378858 H\'a1ML\'d0T}{\f37\fs18\insrsid1378858 : Nh\'a9n v\'cbt ch\'ddnh trong v\'eb bi k\'dech c\'efng t\'aan c\'f1a \'ae
\'b9i v\'a8n h\'b5o Anh S\'d5chxpia. Nh\'a9n v\'cbt H\'a8ml\'d0t t\'ad\'eeng tr\'adng cho l\'dfng trung hi\'d5u v\'b5 qu\'b6 c\'b6m c\'f1a m\'e9t thanh ni\'aan ho\'b5ng t\'e9c trong cu\'e9c \'ae\'cau tranh ch\'e8ng l\'b9i t\'e9i \'b8c v\'b5 s\'f9 l\'f5a l
\'e4c trong tri\'d2u \'ae\'d7nh n\'ad\'edc \'a7an M\'b9ch \'ae\'c7u th\'d5 k\'fb XVII.
\par HUYG\'a4, }{\b\f37\fs18\insrsid1378858 V\'ddchto }{\f37\fs18\insrsid1378858 (1802-1885): Nh\'b5 v\'a8n Ph\'b8p; nh\'b5 l\'fd lu\'cbn v\'b5 ch\'f1 so\'b8i c\'f1a tr\'ad\'eang ph\'b8i th\'ac ca l\'b7ng m\'b9n Ph\'b8p; t\'b8c gi\'b6 c\'f1a nhi\'d2u t\'cbp th
\'ac, k\'dech, ti\'d3u thuy\'d5t n\'e6i ti\'d5ng. C\'b8c t\'b8c ph\'c8m c\'f1a Huyg\'ab \'ae\'b6 k\'ddch ch\'d5 \'ae\'e9 \'ae\'ad\'acng th\'eai, l\'aan \'b8n nh\'f7ng k\'ce t\'b5n b\'b9o gi\'b5y x\'d0o l\'aan h\'b9nh ph\'f3c con ng\'ad\'eai v\'b5 \'ae\'c6
t l\'dfng tin v\'b5o con ng\'ad\'eai c\'e3 kh\'b6 n\'a8ng t\'f5 b\'e3ng t\'e8i v\'ad\'acn l\'aan nh\'f7ng \'ae\'d8nh cao c\'f1a \'b8nh s\'b8ng ch\'a9n l\'fd v\'b5 \'ae\'b9o \'ae\'f8c.
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 K
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 KH\'b6I \'a7\'deNH}{\f37\fs18\insrsid1378858 
 (1882-1925): T\'f8c Nguy\'d4n B\'f6u \'a7\'b6o, vua th\'f8 12 nh\'b5 Nguy\'d4n. N\'a8m 1916, \'ae\'ad\'eec ng\'ad\'eai Ph\'b8p \'ae\'ada l\'aan ng\'abi v\'b5 \'ae\'f8ng \'ae\'c7u tri\'d2u \'ae\'d7nh \'ae\'d5n n\'a8m 1925. Kh\'b6i \'a7\'denh l\'b5 m\'e9
t ho\'b5ng \'ae\'d5 b\'b9c nh\'ad\'eec, ho\'b5n to\'b5n ph\'f4 thu\'e9c v\'b5o ng\'ad\'eai Ph\'b8p.
\par }{\f38\fs18\insrsid1378858 KH\'e6NG T\'f6}{\f37\fs18\insrsid1378858  (511- 479 TCN): T\'aan Kh\'a9u, ng\'ad\'eai n\'ad\'edc L\'e7, s\'e8ng v\'b5o \'ae\'eai nh\'b5 Chu th\'eai Chi\'d5n qu\'e8c (Trung Qu\'e8c). H\'e4c r\'e9ng, t\'b5i cao, l\'b5 ng\'ad\'ea
i s\'b8ng l\'cbp ra \'ae\'b9o Kh\'e6ng - m\'e9t trong ba gi\'b8o ph\'b8i l\'edn nh\'cat Trung Qu\'e8c (Kh\'e6ng gi\'b8o, Ph\'cbt gi\'b8o, L\'b7o gi\'b8o). \'a7\'b9o Kh\'e6ng l\'b5 n\'d2n t\'b6ng t\'ad t\'ad\'ebng ch\'ddnh th\'e8ng c\'f1a ch\'d5 \'ae\'e9
 phong ki\'d5n Trung Qu\'e8c v\'b5 \'b6nh h\'ad\'ebng s\'a9u r\'e9ng trong nhi\'d2u n\'ad\'edc ch\'a9u }{\f38\fs18\insrsid1378858 \'b8.}{\f37\fs18\insrsid1378858  \'a7\'b9o Kh\'e6ng \'ae\'d2 cao l\'dfng \'b8i qu\'e8c trung th\'c7n, ph\'a9n \'ae\'denh r
\'b9ch r\'dfi quan h\'d6 vua - t\'abi, cha - con, ch\'e5ng - v\'ee, coi th\'ad\'eang ph\'f4 n\'f7 v\'b5 ng\'ad\'eai lao \'ae\'e9ng.
\par }{\f38\fs18\insrsid1378858 K\'a5RIS\'a5NA,}{\f37\fs18\insrsid1378858  }{\b\f37\fs18\insrsid1378858 Rama}{\f37\fs18\insrsid1378858  (1857-?): Nh\'b5 tri\'d5t h\'e4c, nh\'b5 v\'a8n, nh\'b5 ho\'b9t \'ae\'e9ng ch\'ddnh tr\'de }{\f38\fs18\insrsid1378858 \'ca}{
\f37\fs18\insrsid1378858 n \'a7\'e9 n\'e6i ti\'d5ng, ch\'f1 tr\'ad\'acng \'ae\'cau tranh \'ae\'dfi gi\'b6i ph\'e3ng v\'d2 ch\'ddnh tr\'de v\'b5 k\'aau g\'e4i \'aeo\'b5n k\'d5t d\'a9n t\'e9c. N\'a8m 1909, b\'de ch\'ddnh quy\'d2n thu\'e9c \'ae\'dea Anh tr
\'f4c xu\'cat kh\'e1i }{\f38\fs18\insrsid1378858 \'ca}{\f37\fs18\insrsid1378858 n \'a7\'e9.
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 L
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 LAN\'d0TX\'a1NG}{\f37\fs18\insrsid1378858 , }{
\b\f37\fs18\insrsid1378858 Gi\'a8ng Mari \'a1ngtoan \'ae\'ac}{\f37\fs18\insrsid1378858  (1843-1919): Nh\'b5 t\'f9 nhi\'aan h\'e4c, th\'c7y thu\'e8c v\'b5 nh\'b5 ch\'ddnh tr\'de Ph\'b8p; To\'b5n quy\'d2n \'a7\'abng D\'ad\'acng n\'a8m 1891-1894; B\'e9 tr
\'ad\'ebng B\'e9 H\'b5ng h\'b6i n\'a8m 1899-1902; gi\'b8m \'ae\'e8c ch\'ddnh tr\'de b\'b8o }{\i\f37\fs18\insrsid1378858 Si\'cccle}{\f37\fs18\insrsid1378858  n\'a8m 1906; t\'b8c gi\'b6 c\'f1a nhi\'d2u c\'abng tr\'d7nh khoa h\'e4c.
\par }{\f38\fs18\insrsid1378858 L\'b7O T\'f6:}{\f37\fs18\insrsid1378858  T\'f8c L\'fd \'a7am, ng\'ad\'eai s\'e8ng \'ae\'e5ng th\'eai v\'edi Kh\'e6ng T\'f6 th\'eai Chi\'d5n qu\'e8c (Trung Qu\'e8c); l\'b5 quan coi kho s\'b8ch v\'b5 s\'b8ng l\'cbp ra \'ae\'b9o L
\'b7o l\'b5 m\'e9t trong ba gi\'b8o ph\'b8i l\'edn nh\'cat \'eb Trung Qu\'e8c. \'a7\'b9o L\'b7o \'ae\'ad\'eec Trang T\'f6 ph\'b8t tri\'d3n theo ch\'f1 ngh\'dca y\'d5m th\'d5, tho\'b8t t\'f4c. \'a7\'b9o L\'b7o khuy\'aan con ng\'ad\'eai kh\'abng n\'aan l
\'b5m tr\'b8i v\'edi "\'ae\'b9o" (v\'ab vi), t\'f8c quy lu\'cbt t\'f9 nhi\'aan. Sau n\'b5y c\'b8c m\'abn \'ae\'d6 c\'f1a L\'b7o T\'f6 bi\'d5n "v\'ab vi" th\'b5nh "xu\'cat th\'d5" - c\'e3 t\'ddnh ch\'cat m\'aa t\'ddn, huy\'d2n b\'dd, d\'efng b\'efa ch\'f3
, thu\'cbt ph\'b8p m\'aa ho\'c6c d\'a9n ch\'f3ng.
\par }{\f38\fs18\expnd0\expndtw-2\insrsid1378858 L\'a3 \'a7\'b9I H\'b5NH }{\f37\fs18\expnd0\expndtw-2\insrsid1378858 (941-1005): T\'f8c L\'aa Ho\'b5n, danh t\'ad\'edng nh\'b5 \'a7inh. L\'aa Ho\'b5n l\'b5 ng\'ad\'eai ch\'d8 huy cu\'e9c kh\'b8ng chi\'d5n ch\'e8
ng qu\'a9n T\'e8ng (Trung Qu\'e8c) x\'a9m l\'ad\'eec l\'c7n th\'f8 nh\'cat v\'b5 l\'cbp nhi\'d2u chi\'d5n c\'abng vang d\'e9i t\'b9i \'b6i Chi L\'a8ng v\'b5 tr\'aan s\'abng B\'b9ch \'a7\'bbng. L\'aa Ho\'b5n \'ae\'ad\'eec Th\'b8i h\'cbu D\'ad\'acng V\'a9
n Nga v\'b5 c\'b8c t\'ad\'edng l\'dcnh suy t\'abn l\'aan ng\'abi vua m\'eb \'ae\'c7u nh\'b5 Ti\'d2n L\'aa (980-1009).
\par }{\f38\fs18\insrsid1378858 L\'a3 L\'eeI}{\f37\fs18\insrsid1378858  (1385-1433): Anh h\'efng d\'a9n t\'e9c. N\'a8m 1406, nh\'b5 Minh (Trung Qu\'e8c) x\'a9m l\'ad\'eec n\'ad\'edc ta. N\'a8m 1418, sau qu\'b8 tr\'d7nh chu\'c8n b\'de v\'b5 v\'cbn \'ae\'e9ng nh
\'a9n d\'a9n, L\'aa L\'eei \'ae\'ad\'eec Nguy\'d4n Tr\'b7i gi\'f3p s\'f8c \'ae\'b7 ph\'cat c\'ea kh\'ebi ngh\'dca \'eb Lam S\'acn (Thanh Ho\'b8). \'a7\'ad\'eec \'ae\'abng \'ae\'b6o c\'b8c t\'c7ng l\'edp nh\'a9n d\'a9n \'f1ng h\'e9, cu\'e9c kh\'ebi ngh\'dc
a \'ae\'b7 nhanh ch\'e3ng chuy\'d3n th\'b5nh cu\'e9c chi\'d5n tranh gi\'b6i ph\'e3ng d\'a9n t\'e9c. Cu\'e9c kh\'b8ng chi\'d5n k\'d0o d\'b5i 10 n\'a8m (1418-1428) v\'b5 k\'d5t th\'f3c th\'beng l\'eei, l\'cbt \'ae\'e6 \'b8ch th\'e8ng tr\'de c\'f1a nh\'b5
 Minh.
\par }\pard\plain \s15\qj \fi397\li425\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 Sau khi chi\'d5n th\'beng qu\'a9n Minh, ng\'b5
y 29-4-1428, L\'aa L\'eei l\'aan ng\'abi vua v\'b5 l\'cbp ra tri\'d2u L\'aa \'ae\'ada ch\'d5 \'ae\'e9 phong ki\'d5n Vi\'d6t Nam l\'aan giai \'aeo\'b9n ph\'b8t tri\'d3n th\'denh v\'ad\'eeng.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\expnd0\expndtw-2\insrsid1378858 L\'a3NIN,}{
\f37\fs18\expnd0\expndtw-2\insrsid1378858  }{\b\f37\fs18\expnd0\expndtw-2\insrsid1378858 Vla\'aeimia Il\'ddch}{\f37\fs18\expnd0\expndtw-2\insrsid1378858  (1870-1924): L\'b7nh t\'f4 thi\'aan t\'b5i c\'f1a giai c\'cap v\'ab s\'b6n v\'b5 nh\'a9n d\'a9n lao 
\'ae\'e9ng to\'b5n th\'d5 gi\'edi, ng\'ad\'eai s\'b8ng l\'cbp ra \'a7\'b6ng C\'e9ng s\'b6n Li\'aan X\'ab v\'b5 Nh\'b5 n\'ad\'edc c\'abng n\'abng \'ae\'c7u ti\'aan trong l\'dech s\'f6 lo\'b5i ng\'ad\'eai, v\'b5 s\'b8ng l\'cbp ra Qu\'e8c t\'d5 C\'e9ng s\'b6
n. K\'d5 t\'f4c s\'f9 nghi\'d6p c\'f1a C.M\'b8c v\'b5 Ph.\'a1ngghen, V.I.L\'aanin \'ae\'b7 \'ae\'cau tranh ki\'aan quy\'d5t \'ae\'d3 b\'b6o v\'d6 tinh th\'c7n c\'b8ch m\'b9ng c\'f1a ch\'f1 ngh\'dca M\'b8c, ch\'e8ng l\'b9i m\'e4i s\'f9 xuy\'aan t\'b9c c
\'f1a b\'e4n c\'ac h\'e9i ch\'f1 ngh\'dca v\'b5 ph\'b8t tri\'d3n thi\'aan t\'b5i c\'b6 ba b\'e9 ph\'cbn h\'eep th\'b5nh ch\'f1 ngh\'dca M\'b8c (tri\'d5t h\'e4c m\'b8cx\'ddt, kinh t\'d5 ch\'ddnh tr\'de h\'e4c m\'b8cx\'ddt, v\'b5 ch\'f1 ngh\'dca x\'b7 h\'e9
i khoa h\'e4c), gi\'b6i quy\'d5t \'ae\'f3ng \'ae\'ben v\'d2 l\'fd lu\'cbn v\'b5 th\'f9c ti\'d4n c\'b8c v\'can \'ae\'d2 \'ae\'c6t ra cho c\'b8ch m\'b9ng v\'ab s\'b6n trong th\'eai \'ae\'b9i \'ae\'d5 qu\'e8c ch\'f1 ngh\'dca.
\par }\pard\plain \s15\qj \fi397\li425\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 L\'aanin \'ae\'c6c bi\'d6t ch\'f3 \'fd v\'b5 \'ae
\'b7 \'ae\'ada ra nhi\'d2u lu\'cbn \'aei\'d3m quan tr\'e4ng v\'d2 phong tr\'b5o \'ae\'cau tranh c\'f1a c\'b8c d\'a9n t\'e9c thu\'e9c \'ae\'dea v\'b5 ph\'f4 thu\'e9c. Trong b\'b6n }{\i\fs18\insrsid1378858 S\'ac th\'b6o nh\'f7ng lu\'cbn c\'ad\'acng v\'d2 v
\'can \'ae\'d2 d\'a9n t\'e9c v\'b5 v\'can \'ae\'d2 thu\'e9c \'ae\'dea}{\fs18\insrsid1378858  \'ae\'ad\'eec tr\'d7nh b\'b5y t\'b9i \'a7\'b9i h\'e9i II c\'f1a Qu\'e8c t\'d5 C\'e9ng s\'b6n (1920), V.I.L\'aanin \'ae\'b7 n\'aau ra nh\'f7ng v\'can \'ae\'d2 c
\'ac b\'b6n c\'f1a phong tr\'b5o gi\'b6i ph\'e3ng d\'a9n t\'e9c.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 L\'a3\'a4P\'a4N II}{\f37\fs18\insrsid1378858 
 (1835-1909): Qu\'e8c v\'ad\'acng B\'d8 t\'f5 n\'a8m 1865, ng\'ad\'eai t\'e6 ch\'f8c nh\'f7ng cu\'e9c t\'can c\'abng \'ae\'b8nh chi\'d5m v\'efng Trung Phi v\'b5 C\'abngg\'ab.
\par }{\f38\fs18\insrsid1378858 LI\'a4T\'a2Y}{\f37\fs18\insrsid1378858 , }{\b\f37\fs18\insrsid1378858 Lu-i Uybe G\'abngdav\'ac}{\f37\fs18\insrsid1378858  ( 1854-1934): Th\'e8ng ch\'d5 Ph\'b8p; c\'e3 m\'c6t nhi\'d2u n\'a8m \'eb c\'b8c thu\'e9c \'ae\'dea c\'f1
a Ph\'b8p. N\'a8m 1894, Li\'abt\'a9y sang \'a7\'abng D\'ad\'acng. N\'a8m 1912, l\'b5m T\'ad l\'d6nh qu\'a9n \'ae\'e9i Ph\'b8p \'eb Mar\'e8c. N\'a8m 1916-1917, l\'b5m B\'e9 tr\'ad\'ebng B\'e9 Chi\'d5n tranh. B\'bbng nh\'f7ng h\'b5nh \'ae\'e9ng qu\'a9n phi
\'d6t h\'d5t s\'f8c t\'b5n b\'b9o, Li\'abt\'a9y ch\'d8 huy nh\'f7ng cu\'e9c \'ae\'b5n \'b8p \'ae\'c9m m\'b8u c\'b8c cu\'e9c n\'e6i d\'cby \'ae\'dfi gi\'b6i ph\'e3ng, ch\'e8ng th\'f9c d\'a9n Ph\'b8p \'eb c\'b8c thu\'e9c \'ae\'dea.
\par }{\f38\fs18\expnd0\expndtw-2\insrsid1378858 L\'ddPN\'d5CH,}{\f37\fs18\expnd0\expndtw-2\insrsid1378858  }{\b\f37\fs18\expnd0\expndtw-2\insrsid1378858 C\'b8c}{\f37\fs18\expnd0\expndtw-2\insrsid1378858  (1871-1919): Nh\'b5 ho\'b9t \'ae\'e9ng xu\'cat s\'bec c
\'f1a phong tr\'b5o c\'abng nh\'a9n \'a7\'f8c v\'b5 qu\'e8c t\'d5, chi\'d5n s\'dc \'ae\'cau tranh t\'ddch c\'f9c ch\'e8ng ch\'f1 ngh\'dca c\'ac h\'e9i, ch\'f1 ngh\'dca qu\'a9n phi\'d6t v\'b5 chi\'d5n tranh \'ae\'d5 qu\'e8c. L\'ddpn\'d5ch l\'b5 m\'e9
t trong nh\'f7ng nh\'b5 t\'e6 ch\'f8c v\'b5 l\'b7nh \'ae\'b9o nh\'e3m "Xp\'b8ctaqu\'fdt" c\'b8ch m\'b9ng, l\'b5 m\'e9t trong nh\'f7ng ng\'ad\'eai s\'b8ng l\'cbp \'a7\'b6ng C\'e9ng s\'b6n \'a7\'f8c v\'b5 l\'b7nh \'ae\'b9o cu\'e9c kh\'ebi ngh\'dca c\'f1a c
\'abng nh\'a9n n\'a8m 1919; b\'de k\'ce th\'ef gi\'d5t h\'b9i trong nh\'b5 t\'ef.
\par }\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 L\'a4I, }{\b\fs18\insrsid1378858 Gio\'e3cgi\'ac}{
\fs18\insrsid1378858  (1863-1945): Ng\'ad\'eai Anh; \'ae\'b9i bi\'d3u Qu\'e8c h\'e9i n\'a8m 1890, theo khuynh h\'ad\'edng c\'cap ti\'d5n, ch\'f1 tr\'ad\'acng \'ae\'b5n \'b8p \'ae\'c9m m\'b8u cu\'e9c n\'e6i d\'cby c\'f1a ng\'ad\'eai B\'abc. N\'a8m 1905, l
\'b5m B\'e9 tr\'ad\'ebng B\'e9 Th\'ad\'acng m\'b9i; sau \'ae\'e3 l\'b5m B\'e9 tr\'ad\'ebng B\'e9 Qu\'a9n nhu (1915), B\'e9 tr\'ad\'ebng B\'e9 Qu\'e8c ph\'dfng (1916), Th\'f1 t\'ad\'edng (1916). Sau chi\'d5n tranh, L\'abi Gio\'e3cgi\'ac d\'f9 H\'e9i ngh
\'de V\'d0cx\'a9y (1919), l\'b5m th\'f1 l\'dcnh \'a7\'b6ng T\'f9 do Anh v\'b5 vi\'d5t h\'e5i k\'fd.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 L\'a4NG, }{\b\f37\fs18\insrsid1378858 M\'abrix\'ac}{
\f37\fs18\insrsid1378858  (? -1923): B\'e9 Thu\'e9c \'ae\'dea Ph\'b8p c\'f6 M.L\'abng l\'b5m To\'b5n quy\'d2n \'a7\'abng D\'ad\'acng th\'b8ng 12-1919; ch\'ddnh th\'f8c nh\'cbm ch\'f8c t\'f5 th\'b8ng 12-1919. Khi v\'d2 Ph\'b8p c\'abng c\'b8n, qua C\'abl
\'abngb\'ab b\'de ch\'d5t, l\'f3c ch\'ada h\'d5t nhi\'d6m k\'fa To\'b5n quy\'d2n \'a7\'abng D\'ad\'acng th\'b8ng 1-1923.
\par }{\f38\fs18\expnd0\expndtw-4\insrsid1378858 L\'a4NGGH\'a3,}{\f37\fs18\expnd0\expndtw-4\insrsid1378858  }{\b\f37\fs18\expnd0\expndtw-4\insrsid1378858 Gi\'a8ng}{\f37\fs18\expnd0\expndtw-4\insrsid1378858  (1876-1938): Lu\'cbt s\'ad, nh\'b5 b\'b8o, \'ae\'b6
ng vi\'aan \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p thu\'e9c ph\'b8i Giuyn Ghex\'ae\'ac (ph\'b8i trung). T\'b9i \'a7\'b9i h\'e9i Tua n\'a8m 1920, L\'abnggh\'aa b\'e1 phi\'d5u cho Qu\'e8c t\'d5 th\'f8 hai v\'b5 v\'c9n tham gia \'a7\'b6ng X\'b7 h\'e9i. N\'a8m 1934, 
\'a7\'b6ng C\'e9ng s\'b6n Ph\'b8p l\'cbp M\'c6t tr\'cbn nh\'a9n d\'a9n ch\'e8ng ph\'b8t x\'ddt, L\'abnggh\'aa l\'b5 ng\'ad\'eai \'f1ng h\'e9 v\'b5 tham gia M\'c6t tr\'cbn cho \'ae\'d5n khi qua \'ae\'eai.
\par }{\f37\fs18\insrsid1378858 L\'a5B\'a4NG, }{\b\f37\fs18\insrsid1378858 Guyxtave}{\f37\fs18\insrsid1378858  (1841-1931): Th\'c7y thu\'e8c, nh\'b5 x\'b7 h\'e9i h\'e4c Ph\'b8p, t\'b8c gi\'b6 m\'e9t s\'e8 t\'b8c ph\'c8m v\'d2 n\'d2n v\'a8n minh Ar\'cbp, }{
\f38\fs18\insrsid1378858 \'ca}{\f37\fs18\insrsid1378858 n \'a7\'e9, v.v..
\par L\'a5BROONG, }{\b\f37\fs18\insrsid1378858 Anbe}{\f37\fs18\insrsid1378858  (1871-1950): H\'e4c Tr\'ad\'eang b\'b8ch khoa, k\'fc s\'ad m\'e1, ngh\'de s\'dc Qu\'e8c h\'e9i t\'f5 n\'a8m 1900, B\'e9 tr\'ad\'ebng B\'e9 thu\'e9c \'ae\'dea (1911-1914), Ch\'f1 t
\'dech Th\'ad\'eeng vi\'d6n (1931), T\'e6ng th\'e8ng (1932-1940), b\'de \'a7\'f8c b\'bet \'aei \'ae\'b5y (1944-1945).
\par }{\f38\fs18\expnd0\expndtw-2\insrsid1378858 L\'f3CX\'a1MBUA}{\f37\fs18\expnd0\expndtw-2\insrsid1378858 , }{\b\f37\fs18\expnd0\expndtw-2\insrsid1378858 R\'abda}{\f37\fs18\expnd0\expndtw-2\insrsid1378858  (1871-1919): Nh\'b5 ho\'b9t \'ae\'e9ng l\'e7i l\'b9
c c\'f1a phong tr\'b5o c\'abng nh\'a9n Ba Lan, \'a7\'f8c v\'b5 qu\'e8c t\'d5, m\'e9t trong nh\'f7ng th\'f1 l\'dcnh c\'b8nh t\'b6 c\'f1a Qu\'e8c t\'d5 th\'f8 hai. Ngay t\'f5 \'ae\'c7u cu\'e9c Chi\'d5n tranh th\'d5 gi\'edi th\'f8 nh\'cat b\'b5 \'ae\'b7 \'ae
\'f8ng tr\'aan l\'cbp tr\'ad\'eang qu\'e8c t\'d5 ch\'f1 ngh\'dca, l\'b5 m\'e9t trong nh\'f7ng ng\'ad\'eai c\'e3 s\'b8ng ki\'d5n l\'cbp ra nh\'e3m "Qu\'e8c t\'d5", sau \'ae\'e6i t\'aan l\'b5 nh\'e3m "Xp\'b8ctaqu\'fdt", r\'e5i l\'b9i \'ae\'e6i l\'b5 h\'e9
i "Xp\'b8ctaqu\'fdt". Sau C\'b8ch m\'b9ng th\'b8ng 11-1918 \'eb \'a7\'f8c, b\'b5 gi\'f7 vai tr\'df l\'b7nh \'ae\'b9o trong \'a7\'b9i h\'e9i th\'b5nh l\'cbp \'a7\'b6ng C\'e9ng s\'b6n \'a7\'f8c. Th\'b8ng 1- 1919, b\'b5 b\'de b\'bet v\'b5 b\'de b\'e4n ph\'b6
n c\'b8ch m\'b9ng s\'b8t h\'b9i.
\par }{\f38\fs18\insrsid1378858 L\'fd}{\f37\fs18\insrsid1378858  B\'a4N }{\b\f37\fs18\insrsid1378858 (L\'fd Nam \'a7\'d5)}{\f37\fs18\insrsid1378858  : C\'dfn g\'e4i l\'b5 L\'fd B\'dd, qu\'aa t\'d8nh Th\'b8i B\'d7nh. N\'a8m 542, L\'fd B\'abn l\'b7nh \'ae\'b9
o cu\'e9c kh\'ebi ngh\'dca ch\'e8ng qu\'a9n x\'a9m l\'ad\'eec nh\'b5 L\'ad\'acng (Trung Qu\'e8c), gi\'b6i ph\'e3ng \'ae\'cat n\'ad\'edc. N\'a8m 544, L\'fd B\'abn l\'aan ng\'abi vua, x\'adng l\'b5 Nam Vi\'d6t \'ae\'d5, t\'aan n\'ad\'edc l\'b5 V\'b9n Xu\'a9
n. N\'a8m 545, nh\'b5 L\'ad\'acng l\'b9i \'aeem qu\'a9n sang x\'a9m l\'ad\'eec. V\'d7 th\'d5 y\'d5u, cu\'e9c kh\'b8ng chi\'d5n c\'f1a nh\'a9n d\'a9n ta b\'de th\'cat b\'b9i. L\'fd B\'abn ph\'b6i lui v\'d2 v\'efng V\'dcnh Ph\'f3 v\'b5 m\'cat t\'b9i \'ae
\'a9y.
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 M
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 M\'b8C,}{\f37\fs18\insrsid1378858  }{
\b\f37\fs18\insrsid1378858 C\'b8c}{\f37\fs18\insrsid1378858  (1818-1883): L\'b7nh t\'f4 c\'f1a giai c\'cap v\'ab s\'b6n th\'d5 gi\'edi, nh\'b5 t\'ad t\'ad\'ebng v\'dc \'ae\'b9i, ng\'ad\'eai s\'b8ng l\'cbp ch\'f1 ngh\'dca c\'e9ng s\'b6n khoa h\'e4c. M\'b8
c l\'b5 ng\'ad\'eai s\'b8ng t\'b9o ra l\'fd lu\'cbn c\'b8ch m\'b9ng v\'ab s\'b6n. T\'f5 s\'f9 ph\'a9n t\'ddch s\'f8 m\'d6nh l\'dech s\'f6 c\'f1a giai c\'cap v\'ab s\'b6n, M\'b8c \'ae\'b7 \'ae\'d2 ra h\'e4c thuy\'d5t v\'d2 chuy\'aan ch\'ddnh v\'ab s\'b6n l
\'b5 c\'abng c\'f4 c\'f1a b\'ad\'edc qu\'b8 \'ae\'e9 c\'b8ch m\'b9ng t\'f5 ch\'f1 ngh\'dca t\'ad b\'b6n sang ch\'f1 ngh\'dca x\'b7 h\'e9i. T\'f5 s\'f9 ph\'a9n t\'ddch x\'b7 h\'e9i t\'ad b\'b6n, M\'b8c \'ae\'d2 ra h\'e4c thuy\'d5t v\'d2 gi\'b8 tr\'de th
\'c6ng d\'ad.
\par }\pard\plain \s15\qj \fi397\li425\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 M\'b8c kh\'abng ch\'d8 l\'b5 nh\'b5 l\'fd lu\'cb
n thi\'aan t\'b5i m\'b5 tr\'ad\'edc h\'d5t M\'b8c l\'b5 nh\'b5 c\'b8ch m\'b9ng v\'dc \'ae\'b9i. N\'a8m 1847, M\'b8c v\'b5 \'a1ngghen gia nh\'cbp}{\i\fs18\insrsid1378858  Li\'aan minh nh\'f7ng ng\'ad\'eai c\'e9ng s\'b6n}{\fs18\insrsid1378858 . N\'a8
m 1864, M\'b8c s\'b8ng l\'cbp v\'b5 l\'b5 linh h\'e5n c\'f1a }{\i\fs18\insrsid1378858 Qu\'e8c t\'d5 th\'f8 nh\'cat}{\fs18\insrsid1378858 , M\'b8c \'ae\'b7 \'ae\'cau tranh ch\'e8ng c\'b8c th\'f8 ch\'f1 ngh\'dca c\'ac h\'e9i trong phong tr\'b5o c\'abng nh
\'a9n, ch\'e8ng b\'e4n v\'ab ch\'ddnh ph\'f1 v\'b5 \'ae\'denh ra s\'b8ch l\'ad\'eec c\'b8ch m\'b9ng cho cu\'e9c \'ae\'cau tranh c\'f1a giai c\'cap c\'abng nh\'a9n.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 M\'b8C\'a7\'a4NAN,}{\f37\fs18\insrsid1378858  }{
\b\f37\fs18\insrsid1378858 Gi\'aam Ramx\'a9y}{\f37\fs18\insrsid1378858  (1866-1937): Ng\'ad\'eai l\'b7nh \'ae\'b9o \'a7\'b6ng C\'abng nh\'a9n \'ae\'e9c l\'cbp Anh v\'b5 C\'abng \'ae\'b6ng Anh; \'f1ng h\'e9 ch\'ddnh s\'b8ch h\'eep t\'b8c giai c\'cap v\'b5
 c\'b8i g\'e4i l\'b5 "ch\'f1 ngh\'dca x\'b7 h\'e9i nh\'cbp d\'c7n v\'b5o ch\'f1 ngh\'dca t\'ad b\'b6n". N\'a8m 1924 v\'b5 1929-1935 l\'b5m Th\'f1 t\'ad\'edng. M\'b8c\'ae\'abnan \'ae\'b7 ra s\'f8c b\'b6o v\'d6 l\'cbp tr\'ad\'eang c\'f1a ch\'f1 ngh\'dca 
\'ae\'d5 qu\'e8c Anh v\'b5 \'ae\'b7 gieo r\'bec nh\'f7ng \'b6o t\'ad\'ebng c\'b6i l\'ad\'acng ch\'f1 ngh\'dca trong phong tr\'b5o c\'abng nh\'a9n Anh.
\par MAN\'a7ENXTAM, }{\b\f37\fs18\insrsid1378858 \'a4x\'ddp}{\f37\fs18\insrsid1378858  (1891-1938): Sinh trong m\'e9t gia \'ae\'d7nh th\'ad\'acng gia Nga. L\'b5m th\'ac t\'f5 tr\'ce; n\'a8m 1909, c\'e3 th\'ac in tr\'aan b\'b8o l\'c7n \'ae\'c7u ti\'aan. Sau C
\'b8ch m\'b9ng Th\'b8ng M\'ad\'eai, tham gia c\'b8c c\'ac quan tuy\'aan truy\'d2n v\'a8n ho\'b8; s\'b8ng t\'b8c nhi\'d2u th\'d3 lo\'b9i, nghi\'aan c\'f8u v\'a8n h\'e4c v\'b5 vi\'d5t b\'b8o.
\par }\pard \qj \fi397\li425\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 {\f37\fs18\insrsid1378858 Man\'aeenxtam g\'c6p Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 i Qu\'e8c \'ae\'d3 ph\'e1
ng v\'can th\'b8ng 12-1923 v\'b5 vi\'d5t b\'b5i \'ae\'a8ng tr\'aan b\'b8o }{\i\f37\fs18\insrsid1378858 Ogoniok.}{\f37\fs18\insrsid1378858 
\par }\pard \qj \fi-425\li425\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 {\f38\fs18\insrsid1378858 M\'b9}{\f38\fs18\expnd0\expndtw-4\insrsid1378858 NH T\'f6}{\f37\fs18\expnd0\expndtw-4\insrsid1378858  (372-289): T
\'aan Kha, quan \'ae\'b9i th\'c7n th\'eai Chi\'d5n qu\'e8c (Trung Qu\'e8c). \'a4ng c\'e3 t\'b5i h\'efng bi\'d6n, \'ae\'b7 \'aei kh\'bep \'ae\'cat n\'ad\'edc Trung Hoa tuy\'aan truy\'d2n, ph\'b8t tri\'d3n tri\'d5t l\'fd c\'f1a Kh\'e6ng T\'f6 l\'aan th\'b5
nh Qu\'e8c gi\'b8o. \'a4ng c\'e3 c\'a9u n\'e3i n\'e6i ti\'d5ng: "D\'a9n vi qu\'fd, x\'b7 t\'bec th\'f8 chi, qu\'a9n vi khinh" (L\'eei \'ddch c\'f1a d\'a9n tr\'ad\'edc h\'d5t, sau \'ae\'e3 \'ae\'d5n l\'eei \'ddch c\'f1a nh\'b5 n\'ad\'edc, l\'eei \'ddch c
\'f1a vua kh\'abng \'ae\'b8ng k\'d3).}{\f37\fs18\insrsid1378858 
\par }\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-312\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 MANUINXKI, }{\b\fs18\insrsid1378858 \'a7
imitri Dakhail\'abv\'ddch}{\fs18\insrsid1378858  (1883-1959): \'a7\'b6ng vi\'aan \'a7\'b6ng C\'abng nh\'a9n d\'a9n ch\'f1 - x\'b7 h\'e9i Nga cu\'e8i n\'a8m 1903. Sau \'ae\'e3 b\'de b\'bet, b\'de \'aei \'ae\'b5y, r\'e5i v\'ad\'eet ng\'f4c, s\'e8ng l\'ad
u vong v\'b5 g\'c6p L\'aanin \'eb Pari. N\'a8m 1912, b\'dd m\'cbt tr\'eb v\'d2 Nga. C\'b8ch m\'b9ng Th\'b8ng M\'ad\'eai Nga th\'b5nh c\'abng, L\'aanin c\'f6 Manuinxki ra m\'c6t tr\'cbn l\'b5m Ch\'ddnh u\'fb "\'ae\'e1" r\'e5i l\'b5m Th\'f8 tr\'ad\'ebng B
\'e9 L\'ad\'acng th\'f9c, H\'e9i tr\'ad\'ebng Ch\'f7 th\'cbp \'ae\'e1. N\'a8m 1921, \'ae\'ad\'eec c\'f6 l\'b5m B\'dd th\'ad th\'f8 nh\'cat \'a7\'b6ng C\'e9ng s\'b6n Ucraina. T\'f5 n\'a8m 1922, chuy\'d3n sang c\'abng t\'b8c \'eb Qu\'e8c t\'d5 C\'e9ng s\'b6
n. N\'a8m 1924, l\'b5 U\'fb vi\'aan Ban Ch\'cap h\'b5nh Qu\'e8c t\'d5 C\'e9ng s\'b6n, n\'a8m 1928, l\'b5 B\'dd th\'ad Ban Ch\'cap h\'b5nh Qu\'e8c t\'d5 C\'e9ng s\'b6n. Ba m\'ad\'aci n\'a8m li\'d2n l\'b5 U\'fb vi\'aan Trung \'ad\'acng \'a7\'b6ng C\'e9ng s
\'b6n Li\'aan X\'ab.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-312\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 MAR\'a1NG}{\f37\fs18\insrsid1378858 , }{
\b\f37\fs18\insrsid1378858 R\'acn\'aa}{\f37\fs18\insrsid1378858  (1887-1960): Nh\'b5 v\'a8n Ph\'b8p, ng\'ad\'eai g\'e8c Guyan (thu\'e9c \'ae\'dea c\'f1a Ph\'b8p \'eb ch\'a9u M\'fc Latinh). \'a7\'c7u nh\'f7ng n\'a8m 20, Mar\'a8ng c\'e3 t\'ad t\'ad\'ebng ti
\'d5n b\'e9, ph\'aa ph\'b8n ch\'ddnh s\'b8ch ph\'b6n \'ae\'e9ng c\'f1a ch\'ddnh quy\'d2n th\'f9c d\'a9n \'ae\'e8i v\'edi c\'b8c n\'ad\'edc thu\'e9c \'ae\'dea. B\'de th\'f9c d\'a9n Ph\'b8p g\'a9y \'b8p l\'f9c, Mar\'a8ng t\'f5 b\'e1 quan \'aei\'d3m ti\'d5
n b\'e9, quay l\'b9i ph\'f4c v\'f4 l\'eei \'ddch c\'f1a ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c. T\'b8c ph\'c8m }{\i\f37\fs18\insrsid1378858 Batuala}{\f37\fs18\insrsid1378858  xu\'cat b\'b6n l\'c7n \'ae\'c7u n\'a8m 1921, \'ae\'ad\'eec Nguy\'d4n }{
\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 i Qu\'e8c \'ae\'b8nh gi\'b8 cao. Sau khi Mar\'a8ng \'aei v\'b5o con \'ae\'ad\'eang tho\'b8i ho\'b8, Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 i Qu\'e8c nhi\'d2u l\'c7n nh
\'bec t\'edi Mar\'a8ng v\'edi th\'b8i \'ae\'e9 ph\'aa ph\'b8n.
\par }{\f38\fs18\insrsid1378858 M\'a1NGGIANH}{\f37\fs18\insrsid1378858 , }{\b\f37\fs18\insrsid1378858 S\'b8cl\'ac}{\f37\fs18\insrsid1378858  (1866-1925) : T\'ad\'edng Ph\'b8p. Sau khi t\'e8t nghi\'d6p tr\'ad\'eang v\'e2 b\'de Xanh Xia, M\'a8nggianh l\'b5m vi
\'d6c nhi\'d2u n\'a8m \'eb c\'b8c n\'ad\'edc ch\'a9u Phi \'aeen, \'eb B\'bec K\'fa (1901-1904), l\'b5m ph\'e3 Cao u\'fb Ph\'b8p \'eb Mar\'e8c n\'a8m 1912. Trong nh\'f7ng n\'a8m \'eb c\'b8c thu\'e9c \'ae\'dea c\'f1a Ph\'b8p, M\'a8nggianh ch\'f1 tr\'ad\'ac
ng \'ae\'b5n \'b8p t\'b5n b\'b9o c\'b8c cu\'e9c n\'e6i d\'cby c\'f1a ng\'ad\'eai b\'b6n x\'f8 v\'d7 gi\'b6i ph\'e3ng d\'a9n t\'e9c, ch\'e8ng ch\'f1 ngh\'dca th\'f9c d\'a9n.
\par }\pard\plain \s15\qj \fi397\li425\ri0\sa80\sl-312\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 M\'a8nggianh l\'b5m T\'e6ng thanh tra qu\'a9n \'ae
\'e9i Ph\'b8p \'eb c\'b8c thu\'e9c \'ae\'dea v\'b5 U\'fb vi\'aan H\'e9i \'ae\'e5ng Qu\'e8c ph\'dfng n\'ad\'edc Ph\'b8p \'ae\'c7u nh\'f7ng n\'a8m 20.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 M\'d0CLANH,}{\f37\fs18\insrsid1378858  }{
\b\f37\fs18\insrsid1378858 M\'b8cxian H\'a8ngri}{\f37\fs18\insrsid1378858  (1860-?): Tham gia qu\'a9n \'ae\'e9i n\'a8m 1880-1885. L\'b5m vi\'aan ch\'f8c \'eb nhi\'d2u thu\'e9c \'ae\'dea c\'f1a Ph\'b8p (Tahiti, C\'abngg\'ab, Gua\'ae\'acl\'f3p, T\'a9
y Phi, ch\'a9u Phi x\'ddch \'ae\'b9o, Ma\'aeag\'b8txca) v\'b5 To\'b5n quy\'d2n \'a7\'abng D\'ad\'acng n\'a8m 1923-1925.
\par }{\f38\fs18\insrsid1378858 M\'a3}{\f38\fs18\expnd0\expndtw-2\insrsid1378858 RICH}{\f37\fs18\expnd0\expndtw-2\insrsid1378858 , }{\b\f37\fs18\expnd0\expndtw-2\insrsid1378858 V\'ddchto X\'aalextanh}{\f37\fs18\expnd0\expndtw-2\insrsid1378858  (1876-1933): Nh
\'b5 b\'b8o Ph\'b8p, \'ae\'b6ng vi\'aan \'a7\'b6ng X\'b7 h\'e9i; \'ae\'b9i bi\'d3u c\'f1a qu\'cbn Xen t\'b9i \'a7\'b9i h\'e9i l\'c7n th\'f8 XVIII \'a7\'b6ng X\'b7 h\'e9i \'eb Tua, b\'e1 phi\'d5u cho Qu\'e8c t\'d5 th\'f8 ba \'ae\'ad\'eec b\'c7u v\'b5
o Ban l\'b7nh \'ae\'b9o c\'f1a \'a7\'b6ng C\'e9ng s\'b6n n\'a8m 1920-1921 v\'b5 H\'e9i \'ae\'e5ng qu\'b6n tr\'de b\'b8o }{\i\f37\fs18\expnd0\expndtw-2\insrsid1378858 L'Humanit\'d0.}{\f37\fs18\expnd0\expndtw-2\insrsid1378858  N\'a8m}{
\f37\fs18\insrsid1378858  1923, b\'de khai tr\'f5 kh\'e1i \'a7\'b6ng C\'e9ng s\'b6n.
\par }\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 M\'a4NGTEXKI\'a5,}{\fs18\insrsid1378858  }{
\b\fs18\insrsid1378858 S\'b8cl\'ac Lu-i}{\fs18\insrsid1378858  (1689-1755): Nh\'b5 x\'b7 h\'e9i h\'e4c t\'ad s\'b6n l\'e7i l\'b9c c\'f1a Ph\'b8p, nh\'b5 kinh t\'d5 v\'b5 nh\'b5 v\'a8n... \'a7\'b9i di\'d6n c\'f1a ph\'b8i Khai s\'b8ng th\'d5 k\'fb XVIII, nh
\'b5 l\'fd lu\'cbn c\'f1a ch\'f1 ngh\'dca qu\'a9n ch\'f1 l\'cbp hi\'d5n.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 MUXTAPHA }{\f37\fs18\insrsid1378858 (1881-1938): C
\'dfn c\'e3 t\'aan K\'aaman Atatuy\'d5ch, ngh\'dca l\'b5 "Cha c\'f1a ng\'ad\'eai Th\'e6 Nh\'dc K\'fa". H\'e4c tr\'ad\'eang qu\'a9n s\'f9 Xal\'abn\'ddch. N\'a8m 1905, t\'e8t nghi\'d6p Vi\'d6n H\'b5n l\'a9m qu\'a9n s\'f9 v\'edi qu\'a9n h\'b5m \'ae\'b9i u
\'fd. N\'a8m 1915, l\'b5 t\'ad l\'d6nh binh \'aeo\'b5n th\'f8 7 qu\'a9n Palextin, \'ae\'b8nh th\'beng li\'aan qu\'a9n Anh - Ph\'b8p \'eb qu\'c7n \'ae\'b6o Galip\'abli. K\'aaman l\'b7nh \'ae\'b9o c\'b8ch m\'b9ng d\'a9n t\'e9c t\'ad s\'b6n Th\'e6 Nh\'dc K
\'fa ch\'e8ng ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c n\'ad\'edc ngo\'b5i v\'b5 b\'e4n m\'b9i b\'b6n phong ki\'d5n trong n\'ad\'edc, k\'d5t th\'f3c th\'beng l\'eei n\'a8m 1922. Sau \'ae\'e3 l\'b5m T\'e6ng th\'e8ng n\'ad\'edc Th\'e6 Nh\'dc K\'fa \'ae\'e9c l\'cb
p. K\'aaman ch\'f1 tr\'ad\'acng x\'a9y d\'f9ng v\'b5 c\'f1ng c\'e8 t\'d7nh h\'f7u ngh\'de v\'edi Li\'aan X\'ab. Nh\'adng K\'aaman v\'c9n mang \'fd th\'f8c h\'d6 c\'f1a giai c\'cap t\'ad s\'b6n, c\'cam c\'b8c h\'e9i c\'abng nh\'a9n ho\'b9t \'ae\'e9ng v\'b5
 \'ae\'b5n \'b8p nh\'f7ng cu\'e9c b\'b7i c\'abng c\'f1a ng\'ad\'eai lao \'ae\'e9ng.
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 N
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 NAP\'a4L\'a3\'a4NG,}{\f37\fs18\insrsid1378858  }{
\b\f37\fs18\insrsid1378858 Lu-i B\'abnap\'b8ct\'ac}{\f37\fs18\insrsid1378858  (1769-1821): Nh\'b5 qu\'a9n s\'f9 n\'e6i ti\'d5ng c\'f1a Ph\'b8p. N\'a8m 1785, t\'e8t nghi\'d6p tr\'ad\'eang ph\'b8o binh v\'edi qu\'a9n h\'b5m thi\'d5u u\'fd. Tham gia c\'b8
ch m\'b9ng Ph\'b8p n\'a8m 1789 v\'b5 nhanh ch\'e3ng tr\'eb th\'b5nh m\'e9t vi\'aan t\'ad\'edng tr\'ce n\'bem quy\'d2n ch\'d8 huy t\'e8i cao qu\'a9n \'ae\'e9i. N\'a8m 1799, t\'e6 ch\'f8c \'ae\'b6o ch\'ddnh v\'b5 n\'a8m 1804, tuy\'aan b\'e8 thi\'d5t l\'cb
p ch\'d5 \'ae\'e9 \'ae\'e9c t\'b5i. Nap\'abl\'aa\'abng \'ae\'b7 l\'abi k\'d0o n\'ad\'edc Ph\'b8p v\'b5o nh\'f7ng cu\'e9c chi\'d5n tranh chi\'d5m \'ae\'e3ng l\'b7nh th\'e6 nhi\'d2u n\'ad\'edc ch\'a9u \'a2u. N\'a8m 1812, th\'cat b\'b9i trong cu\'e9c chi\'d5
n tranh x\'a9m l\'ad\'eec n\'ad\'edc Nga. N\'a8m 1814, b\'de li\'aan qu\'a9n ch\'a9u \'a2u \'ae\'b8nh b\'b9i. N\'a8m 1815, chi\'d5m l\'b9i ng\'abi ho\'b5ng \'ae\'d5 nh\'adng sau th\'cat b\'b9i t\'b9i Oat\'d0cl\'ab (22-6-1815) l\'b9i b\'de l\'cbt \'ae\'e6.

\par }\pard \qj \fi-425\li425\ri0\sa80\sl-288\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 {\f38\fs18\insrsid1378858 NGHI\'a3U:}{\f37\fs18\insrsid1378858  M\'e9t \'abng vua mang nhi\'d2u t\'ddnh huy\'d2n tho\'b9i trong l\'dech s\'f6
 Trung Qu\'e8c th\'eai m\'b9t k\'fa C\'abng x\'b7 th\'de t\'e9c. \'a4ng n\'e6i ti\'d5ng v\'d2 l\'dfng y\'aau n\'ad\'edc, nh\'a9n t\'f5. Th\'eai \'abng tr\'de v\'d7, \'ae\'cat n\'ad\'edc thanh b\'d7nh, nh\'a9n d\'a9n no \'cam. \'a4ng nh\'ad\'eang l\'b9i ng
\'abi vua cho \'abng Thu\'can ch\'f8 kh\'abng truy\'d2n l\'b9i cho con.
\par }{\f38\fs18\insrsid1378858 NG\'a4 B\'e9I PHU}{\f37\fs18\insrsid1378858  (1874-1939): Qu\'aa t\'d8nh S\'acn \'a7\'abng (Trung Qu\'e8c), thu\'e9c ph\'b8i qu\'a9n phi\'d6t B\'bec D\'ad\'acng h\'d6 Tr\'f9c (t\'d8nh Tr\'f9c L\'d6). N\'a8m 1920, Ng\'ab B\'e9
i Phu \'ae\'b8nh th\'beng ph\'b8i qu\'a9n phi\'d6t \'a7o\'b5n K\'fa Thu\'fe r\'e5i thao t\'f3ng ch\'ddnh ph\'f1 qu\'a9n phi\'d6t B\'bec D\'ad\'acng, l\'b5m tay sai cho \'ae\'d5 qu\'e8c Anh - M\'fc. Ng\'ab B\'e9i Phu ch\'f1 tr\'ad\'acng t\'b5n s\'b8t d\'b7
 man c\'abng nh\'a9n \'ae\'ad\'eang s\'bet B\'bec Kinh - V\'f2 H\'b8n n\'a8m 1923. N\'a8m 1926, qu\'a9n Qu\'e8c d\'a9n xu\'cat ph\'b8t t\'f5 Qu\'b6ng \'a7\'abng ti\'d5n h\'b5nh B\'bec ph\'b9t, \'ae\'b8nh th\'beng ph\'b8i qu\'a9n phi\'d6t Ng\'ab B\'e9i
 Phu.
\par }{\f38\fs18\insrsid1378858 NG\'a4 QUY\'d2N}{\f37\fs18\insrsid1378858  (899-944): Anh h\'efng d\'a9n t\'e9c, m\'e9t t\'ad\'edng l\'dcnh t\'b5i gi\'e1i, ch\'dd l\'edn, m\'adu cao, qu\'aa \'eb \'a7\'ad\'eang L\'a9m (nay thu\'e9c Ba V\'d7, H\'b5 N\'e9i). Tr
\'ad\'edc nguy c\'ac x\'a9m l\'ad\'eec c\'f1a nh\'b5 Nam H\'b8n, Ng\'ab Quy\'d2n \'ae\'b7 h\'b9 th\'b5nh \'a7\'b9i La, gi\'d5t k\'ce b\'b8n n\'ad\'edc Ki\'d2u C\'abng Ti\'d4n, tr\'f5 m\'e8i ho\'b9 b\'aan trong, \'e6n \'ae\'denh t\'d7nh h\'d7nh trong n\'ad
\'edc v\'b5 g\'cap r\'f3t chu\'c8n b\'de l\'f9c l\'ad\'eeng kh\'b8ng chi\'d5n. Ng\'ab Quy\'d2n l\'b5 ng\'ad\'eai t\'e6 ch\'f8c chi\'d5n d\'dech B\'b9ch \'a7\'bbng l\'dech s\'f6. Chi\'d5n th\'beng oanh li\'d6t tr\'aan s\'abng B\'b9ch \'a7\'bbng \'ae\'b7 
\'ae\'b8nh b\'b9i m\'adu \'ae\'e5 x\'a9m l\'ad\'eec c\'f1a nh\'b5 Nam H\'b8n, ch\'cam d\'f8t m\'e9t th\'eai k\'fa m\'cat n\'ad\'edc k\'d0o d\'b5i h\'acn ngh\'d7n n\'a8m v\'b5 m\'eb \'ae\'c7u giai \'aeo\'b9n \'ae\'e9c l\'cbp d\'a9n t\'e9c.
\par }{\f38\fs18\insrsid1378858 NGUY\'d4N KH\'beC V\'d6}{\f37\fs18\insrsid1378858  (1896-? ): Sinh \'eb t\'d8nh Tr\'b5 Vinh, \'ae\'e7 ti\'d5n s\'dc lu\'cbt khoa n\'a8m 1921, ti\'d5n s\'dc khoa ch\'ddnh tr\'de v\'b5 kinh t\'d5 n\'a8m 1922. Th\'b8ng 6-1948, Nguy
\'d4n Kh\'bec V\'d6 tham gia c\'b8c ch\'ddnh ph\'f1 b\'ef nh\'d7n do th\'f9c d\'a9n Ph\'b8p l\'cbp ra, l\'b5m B\'e9 tr\'ad\'ebng B\'e9 T\'ad ph\'b8p r\'e5i Ph\'e3 Th\'f1 t\'ad\'edng ki\'aam B\'e9 tr\'ad\'ebng B\'e9 T\'ad ph\'b8p, sau \'ae\'e3 l\'b5m \'a7
\'b9i s\'f8 c\'f1a ch\'ddnh quy\'d2n S\'b5i G\'dfn \'eb Anh n\'a8m 1952-1954.
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 P
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 PASA, }{\b\f37\fs18\insrsid1378858 \'a1ngve}{
\f37\fs18\insrsid1378858  (1882-1922): Ch\'d8 huy qu\'a9n Th\'e6 Nh\'dc K\'fa \'eb v\'efng C\'b8pcad\'ac n\'a8m 1914 v\'b5 b\'b6o v\'d6 eo bi\'d3n \'a7\'b8c\'aeanen n\'a8m 1915-1916; c\'e3 t\'ad t\'ad\'ebng th\'e8ng nh\'cat ng\'ad\'eai Th\'e6 Nh\'dc K\'fa
 \'eb Trung }{\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858  v\'b5 }{\f38\fs18\insrsid1378858 \'e8}{\f37\fs18\insrsid1378858 tt\'abman. Nhi\'d2u l\'c7n \'ae\'d5n M\'b8txc\'acva, mu\'e8n li\'aan k\'d5t nh\'f7ng ng\'ad\'eai b\'abns\'aav\'dd
ch theo l\'cbp tr\'ad\'eang d\'a9n t\'e9c. \'a7\'ad\'eec nh\'b5 n\'ad\'edc Nga X\'abvi\'d5t gi\'f3p \'ae\'ec, Pasa \'ae\'b8nh th\'beng k\'ce th\'ef \'ae\'ad\'eec \'ae\'d5 qu\'e8c Anh \'f1ng h\'e9. Th\'b8ng 10-1921, Pasa ch\'e8ng l\'b9i H\'e5ng qu\'a9n v
\'b5 ch\'ddnh quy\'d2n X\'abvi\'d5t b\'de t\'f6 vong.
\par PAXT\'a5, }{\b\f37\fs18\insrsid1378858 Lu-i}{\f37\fs18\insrsid1378858  (1822-1895): Nh\'b5 ho\'b8 h\'e4c v\'b5 nh\'b5 sinh v\'cbt h\'e4c l\'e7i l\'b9c c\'f1a n\'ad\'edc Ph\'b8p v\'b5 c\'f1a lo\'b5i ng\'ad\'eai. Sau nhi\'d2u n\'a8m nghi\'aan c\'f8u, Paxt
\'ac kh\'b8m ph\'b8 nhi\'d2u b\'dd \'c8n trong vi\'d6c l\'aan men; nh\'f7ng k\'d5t qu\'b6 t\'d7m t\'dfi khoa h\'e4c c\'f1a Paxt\'ac v\'d2 c\'b8c b\'d6nh truy\'d2n nhi\'d4m v\'b5 m\'abn vi tr\'efng h\'e4c, l\'b5m \'ae\'b6o l\'e9n ng\'b5nh y h\'e4c v\'b5 gi
\'b6i ph\'c9u h\'e4c. Paxt\'ac c\'dfn nghi\'aan c\'f8u th\'b5nh c\'abng nh\'f7ng b\'d6nh c\'f1a con t\'bbm v\'b5 g\'b5, ph\'b8t minh ra thu\'e8c ti\'aam ph\'dfng v\'b5 ch\'e8ng n\'e4c \'ae\'e9c c\'f1a ch\'e3 d\'b9i. T\'f5 1888, \'eb Ph\'b8p th\'b5nh l\'cb
p Vi\'d6n Paxt\'ac, trung t\'a9m nghi\'aan c\'f8u vi tr\'efng h\'e4c.
\par }{\f38\fs18\insrsid1378858 P\'a3T\'a5R\'e8P,}{\f37\fs18\insrsid1378858  }{\b\f37\fs18\insrsid1378858 Rac\'abnnic\'e8p Ph\'aa\'aeo:}{\f37\fs18\insrsid1378858  Ng\'ad\'eai Nga; \'ae\'b6ng vi\'aan \'a7\'b6ng C\'e9ng s\'b6n (b); \'a7\'b9i bi\'d3u d\'f9 \'a7
\'b9i h\'e9i l\'c7n th\'f8 V Qu\'e8c t\'d5 C\'e9ng s\'b6n, \'ae\'ad\'eec \'a7\'b9i h\'e9i b\'c7u l\'b5 U\'fb vi\'aan d\'f9 khuy\'d5t Ban Ch\'cap h\'b5nh Qu\'e8c t\'d5 C\'e9ng s\'b6n n\'a8m 1924; tham d\'f9 nhi\'d2u phi\'aan h\'e4p m\'eb r\'e9ng c\'f1a h
\'e9i ngh\'de \'a7o\'b5n Ch\'f1 t\'dech Ban Ch\'cap h\'b5nh Qu\'e8c t\'d5 C\'e9ng s\'b6n n\'a8m 1925-1927. H\'e9i ngh\'de m\'eb r\'e9ng l\'c7n th\'f8 4 c\'f1a \'a7o\'b5n Ch\'f1 t\'dech Ban Ch\'cap h\'b5nh Qu\'e8c t\'d5 c\'e9ng s\'b6n n\'a8m 1924 quy\'d5t 
\'ae\'denh c\'f6 P\'aat\'acr\'e8p tham gia Ban ph\'ad\'acng \'a7\'abng. H\'e9i ngh\'de m\'eb r\'e9ng l\'c7n th\'f8 6, n\'a8m 1926, \'a7o\'b5n Ch\'f1 t\'dech Ban Ch\'cap h\'b5nh Qu\'e8c t\'d5 C\'e9ng s\'b6n c\'f6 P\'aat\'acr\'e8p v\'b5o Ban B\'dd th\'ad c
\'f1a Qu\'e8c t\'d5 C\'e9ng s\'b6n ki\'aam T\'e6ng th\'ad k\'fd Ban ph\'ad\'acng \'a7\'abng.
\par }{\f38\fs18\insrsid1378858 PHALIE}{\f37\fs18\insrsid1378858 , }{\b\f38\fs18\insrsid1378858 \'b8}{\b\f37\fs18\insrsid1378858 cm\'a8ng}{\f37\fs18\insrsid1378858  (1841-1931): \'a7\'b9i bi\'d3u ph\'b8i C\'e9ng ho\'b5 trong Qu\'e8c h\'e9i Ph\'b8p (1876), Ch
\'f1 t\'dech Qu\'e8c h\'e9i (1883), nhi\'d2u l\'c7n l\'b5m B\'e9 tr\'ad\'ebng (1882-1892), Ch\'f1 t\'dech Th\'ad\'eeng vi\'d6n (1889), T\'e6ng th\'e8ng (1906-1913).
\par }{\f38\fs18\insrsid1378858 PHAN B\'e9I CH\'a2U}{\f37\fs18\insrsid1378858  (1867-1940): Nh\'b5 y\'aau n\'ad\'edc, qu\'aa \'eb Nam \'a7\'b5n, Ngh\'d6 An; ng\'ad\'eai kh\'ebi x\'ad\'edng ch\'f1 tr\'ad\'acng \'a7\'abng du; n\'a8m 1905, l\'cbp Duy t\'a9n h\'e9
i theo ki\'d3u qu\'a9n ch\'f1 l\'cbp hi\'d5n; n\'a8m 1912, l\'cbp Vi\'d6t Nam quang ph\'f4c h\'e9i, theo \'ae\'ad\'eang l\'e8i qu\'a9n ch\'f1 t\'ad s\'b6n thay th\'d5 H\'e9i Duy t\'a9n; n\'a8m 1924, c\'b6i t\'e6 Vi\'d6t Nam quang ph\'f4c h\'e9i th\'b5
nh Vi\'d6t Nam Qu\'e8c d\'a9n \'ae\'b6ng; th\'b8ng 12-1924, sau khi ti\'d5p x\'f3c v\'edi Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 i Qu\'e8c, Phan B\'e9i Ch\'a9u ch\'f1 tr\'ad\'acng chuy\'d3n ho\'b9t \'ae\'e9ng theo \'ae\'ad\'ea
ng l\'e8i c\'b8ch m\'b9ng m\'edi. Nh\'adng b\'de \'ae\'dech b\'bet n\'aan ch\'f1 tr\'ad\'acng kh\'abng th\'b5nh. N\'a8m 1925, b\'de to\'b5 \'b8n th\'f9c d\'a9n x\'f6 t\'f6 h\'d7nh sau h\'b9 xu\'e8ng chung th\'a9n r\'e5i giam l\'e1ng \'eb Hu\'d5.
\par }\pard\plain \s16\qj \fi397\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Trong th\'eai gian \'eb Hu\'d5, Phan B\'e9i Ch\'a9u th
\'ad\'eang nh\'bec \'ae\'d5n Nguy\'d4n }{\f38\insrsid1378858 \'b8}{\insrsid1378858 i Qu\'e8c v\'b5 b\'b5y t\'e1 l\'dfng tin t\'ad\'ebng v\'b5o ch\'f1 ngh\'dca x\'b7 h\'e9i trong cu\'e8n s\'b8ch }{\i\insrsid1378858 Ch\'f1 ngh\'dca x\'b7 h\'e9i}{
\insrsid1378858  do \'abng vi\'d5t n\'a8m 1935.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 PHAN CH\'a2U TRINH}{\f37\fs18\insrsid1378858 
 (1872-1926): Nh\'b5 y\'aau n\'ad\'edc, qu\'aa t\'d8nh Qu\'b6ng Nam (nay l\'b5 Qu\'b6ng Nam - \'a7\'b5 N\'bdng), \'ae\'e7 ph\'e3 b\'b6ng n\'a8m 1901. N\'a8m 1903, l\'b5m Th\'f5a bi\'d6n B\'e9 L\'d4. N\'a8m 1905, c\'b8o quan v\'d2 qu\'aa ho\'b9t \'ae\'e9
ng ch\'ddnh tr\'de. N\'a8m 1906, sau chuy\'d5n \'aei Nh\'cbt v\'d2, Phan Ch\'a9u Trinh ra s\'f8c tuy\'aan truy\'d2n ch\'f1 tr\'ad\'acng c\'b6i c\'b8ch v\'b5 tr\'eb th\'b5nh m\'e9t trong nh\'f7ng ng\'ad\'eai c\'c7m \'ae\'c7u xu h\'ad\'edng c\'b6i l\'ad\'ac
ng \'eb n\'ad\'edc ta \'ae\'c7u th\'d5 k\'fb XX. N\'a8m 1908, khi phong tr\'b5o ch\'e8ng thu\'d5 c\'f1a n\'abng d\'a9n Trung K\'fa b\'de \'ae\'b5n \'b8p, Phan Ch\'a9u Trinh b\'de th\'f9c d\'a9n Ph\'b8p b\'bet \'ae\'b5y ra C\'abn \'a7\'b6o; n\'a8m 1911, nh
\'ea c\'e3 Li\'aan minh nh\'a9n quy\'d2n Ph\'b8p can thi\'d6p, \'ae\'ad\'eec tr\'b6 t\'f9 do v\'b5 sang c\'ad tr\'f3 t\'b9i Ph\'b8p. N\'a8m 1925, v\'d2 n\'ad\'edc v\'b5 m\'cat t\'b9i S\'b5i G\'dfn n\'a8m 1926.
\par }{\f38\fs18\insrsid1378858 PHAN \'a7\'d7NH PH\'efNG}{\f37\fs18\insrsid1378858  (1847-1895): M\'e9t s\'dc phu y\'aau n\'ad\'edc n\'e6i ti\'d5ng cu\'e8i th\'d5 k\'fb XIX; nhi\'d6t li\'d6t h\'ad\'ebng \'f8ng phong tr\'b5o C\'c7n V\'ad\'acng c\'f1a vua H\'b5
m Nghi n\'a8m 1885, t\'e6 ch\'f8c kh\'ebi ngh\'dca ch\'e8ng th\'f9c d\'a9n Ph\'b8p, l\'cbp c\'a8n c\'f8 \'eb v\'efng r\'f5ng n\'f3i H\'ad\'acng S\'acn - H\'ad\'acng Kh\'aa, t\'d8nh H\'b5 T\'dcnh. Phan \'a7\'d7nh Ph\'efng \'ae\'b7 v\'ad\'eet nhi\'d2
u gian kh\'e6, duy tr\'d7 cu\'e9c chi\'d5n \'ae\'cau g\'c7n 10 n\'a8m; b\'de th\'ad\'acng trong m\'e9t tr\'cbn \'ae\'b8nh r\'e5i l\'a9m b\'d6nh m\'cat ng\'b5y 28-12-1895.
\par }{\f38\fs18\insrsid1378858 PHAN V\'a1N TR\'a6\'eaNG}{\f37\fs18\insrsid1378858  (1876-1933): Sinh trong m\'e9t gia \'ae\'d7nh y\'aau n\'ad\'edc, qu\'aa huy\'d6n T\'f5 Li\'aam, H\'b5 N\'e9i; sang Ph\'b8p n\'a8m 1908, v\'f5a l\'b5m vi\'d6c, v\'f5a ti\'d5p t
\'f4c h\'e4c th\'aam. N\'a8m 1914, b\'de b\'bet \'aei l\'ddnh; v\'d7 nghi ho\'b9t \'ae\'e9ng ch\'e8ng Ph\'b8p n\'aan b\'de t\'ef 11 th\'b8ng. Sau ra kh\'e1i t\'ef (tr\'beng \'b8n), nh\'adng \'ae\'d5n n\'a8m 1919 m\'edi \'ae\'ad\'eec gi\'b6i ng\'f2. Phan V
\'a8n Tr\'ad\'eang ho\'b5n th\'b5nh lu\'cbn \'b8n ti\'d5n s\'dc lu\'cbt v\'b5 l\'b5m lu\'cbt s\'ad \'eb To\'b5 th\'ad\'eeng th\'c8m Pari. N\'a8m 1923, v\'d2 n\'ad\'edc; n\'a8m 1925, thay Nguy\'d4n An Ninh l\'b5m gi\'b8m \'ae\'e8c ch\'ddnh tr\'de b\'b8o }{
\i\f37\fs18\insrsid1378858 La Cloche f\'aal\'d0e}{\f37\fs18\insrsid1378858  xu\'cat b\'b6n \'eb S\'b5i G\'dfn, cho \'ae\'a8ng to\'b5n v\'a8n }{\i\f37\fs18\insrsid1378858 Tuy\'aan ng\'abn c\'f1a \'a7\'b6ng c\'e9ng s\'b6n}{\f37\fs18\insrsid1378858  c\'f1a M
\'b8c v\'b5 \'a1ngghen; \'ae\'a8ng l\'b9i nhi\'d2u b\'b5i c\'f1a c\'b8c nh\'b5 ho\'b9t \'ae\'e9ng c\'e9ng s\'b6n Ph\'b8p \'ae\'b7 xu\'cat b\'b6n \'eb Ph\'b8p. Phan V\'a8n Tr\'ad\'eang c\'e3 c\'b6m t\'d7nh v\'edi Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{
\f37\fs18\insrsid1378858 i Qu\'e8c t\'f5 khi m\'edi \'ae\'d5n Ph\'b8p v\'b5 c\'efng ho\'b9t \'ae\'e9ng y\'aau n\'ad\'edc ch\'e8ng th\'f9c d\'a9n \'eb Pari; \'f1ng h\'e9 C\'b8ch m\'b9ng Th\'b8ng M\'ad\'eai Nga, t\'b8n th\'b5nh \'ae\'ad\'eang l\'e8i c\'f1
a Qu\'e8c t\'d5 C\'e9ng s\'b6n v\'b5 ki\'aan quy\'d5t \'ae\'cau tranh ch\'e8ng ch\'f1 ngh\'dca th\'f9c d\'a9n Ph\'b8p tr\'aan l\'cbp tr\'ad\'eang ti\'d5n b\'e9. Th\'b8ng 5-1926, b\'b8o }{\i\f37\fs18\insrsid1378858 La Cloche f\'aal\'d0e}{
\f37\fs18\insrsid1378858  \'ae\'e6i t\'aan l\'b5}{\i\f37\fs18\insrsid1378858  L'Annam}{\f37\fs18\insrsid1378858 , v\'c9n do Phan V\'a8n Tr\'ad\'eang l\'b5m gi\'b8m \'ae\'e8c m\'e9t th\'eai gian, ti\'d5p t\'f4c t\'abn ch\'d8 v\'b5 m\'f4c \'ae\'ddch c\'f1
a t\'ea b\'b8o tr\'ad\'edc.
\par }{\f38\fs18\insrsid1378858 PHR\'a1NGX\'a5,}{\f37\fs18\insrsid1378858  }{\b\f37\fs18\insrsid1378858 Anat\'abn}{\f37\fs18\insrsid1378858  (1844-1924): Nh\'b5 v\'a8n Ph\'b8p, gi\'b6i th\'ad\'ebng N\'abben v\'d2 v\'a8n h\'e4c n\'a8m 1921. N\'a8
m 1921 tham gia \'a7\'b6ng C\'e9ng s\'b6n Ph\'b8p. T\'b8c gi\'b6 c\'f1a nhi\'d2u ti\'d3u thuy\'d5t n\'e6i ti\'d5ng. C\'b8c t\'b8c ph\'c8m c\'f1a Anat\'abn Phr\'a8ngx\'ac th\'cam nhu\'c7n ch\'f1 ngh\'dca nh\'a9n \'ae\'b9o cao qu\'fd, \'ae\'c6t ra nh\'f7
ng v\'can \'ae\'d2 x\'b7 h\'e9i v\'b5 ch\'ddnh tr\'de to l\'edn c\'f1a \'ae\'c7u th\'d5 k\'fb XX. V\'a8n phong c\'f1a \'abng trong s\'b8ng, nh\'d1 nh\'b5ng v\'b5 gi\'d4u c\'eet s\'a9u s\'bec.
\par PIE (1672-1725): C\'dfn g\'e4i l\'b5 Pie \'ae\'b9i \'ae\'d5; nh\'b5 c\'b6i c\'b8ch n\'e6i ti\'d5ng c\'f1a n\'ad\'edc Nga cu\'e8i th\'d5 k\'fb XVII, \'ae\'c7u th\'d5 k\'fb XVIII. K\'d5 v\'de ng\'abi vua n\'a8m 1682, ch\'ddnh th\'f8c \'ae\'a8ng quang n\'a8
m 1689. Trong th\'eai gian tr\'de v\'d7, Pie \'ae\'b7 ti\'d5n h\'b5nh c\'b6i c\'b8ch to\'b5n di\'d6n \'ae\'cat n\'ad\'edc: th\'b5nh l\'cbp th\'ad\'eeng vi\'d6n, ph\'a9n chia khu v\'f9c h\'b5nh ch\'ddnh, x\'a9y d\'f9ng kinh \'ae\'ab m\'edi, \'ae\'b5o k\'aa
nh, \'ae\'bep \'ae\'cbp, m\'eb x\'ad\'ebng luy\'d6n kim, khai kho\'b8ng, \'ae\'e3ng t\'b5u, x\'a9y d\'f9ng qu\'a9n \'ae\'e9i th\'ad\'eang tr\'f9c, ph\'b8t tri\'d3n h\'b9m \'ae\'e9i, qu\'b6n l\'fd nh\'b5 th\'ea v\'b5 th\'f9c hi\'d6n ch\'ddnh s\'b8ch m\'eb
 c\'f6a v\'d2 c\'abng nghi\'d6p, th\'ad\'acng m\'b9i. Nh\'f7ng c\'b6i c\'b8ch c\'f1a Pie \'ae\'b7 r\'f3t ng\'ben kho\'b6ng c\'b8ch t\'f4t h\'cbu c\'f1a n\'ad\'edc Nga v\'edi c\'b8c n\'ad\'edc ph\'ad\'acng T\'a9y.
\par PLAT\'a4NG (427-347 TCN): Nh\'b5 tri\'d5t h\'e4c duy t\'a9m c\'e6 \'ae\'b9i Hy L\'b9p. Plat\'abng d\'efng l\'fd thuy\'d5t c\'f1a t\'abn gi\'b8o cho r\'bbng th\'ad\'eeng \'ae\'d5 s\'b8ng t\'b9o th\'d5 gi\'edi \'ae\'d3 \'ae\'e8i l\'cbp v\'edi quan ni\'d6
m duy v\'cbt v\'d2 v\'f2 tr\'f4 v\'ab c\'efng v\'ab t\'cbn; d\'efng th\'c7n h\'e4c \'ae\'e8i l\'cbp v\'edi quy\'d5t \'ae\'denh lu\'cbn. L\'fd lu\'cbn x\'b7 h\'e9i c\'f1a Plat\'abng nh\'bbm l\'b5m cho n\'d2n th\'e8ng tr\'de c\'f1a qu\'fd t\'e9c \'ae\'ad
\'eec v\'dcnh vi\'d4n. Trong h\'e4c thuy\'d5t v\'d2 nh\'b5 n\'ad\'edc l\'fd t\'ad\'ebng, Plat\'abng qu\'b6 quy\'d5t r\'bbng tr\'cbt t\'f9 x\'b7 h\'e9i ph\'b6i d\'f9a tr\'aan 3 \'ae\'bcng c\'cap: 1. Nh\'f7ng nh\'b5 tri\'d5t h\'e4c ch\'cap ch\'ddnh, 2. V
\'d6 binh; 3. N\'abng d\'a9n v\'b5 th\'ee th\'f1 c\'abng, v.v.. \'a7\'bcng c\'cap 1 cai tr\'de; \'ae\'bcng c\'cap 2 gi\'f7 g\'d7n tr\'cbt t\'f9; \'ae\'bcng c\'cap th\'f8 3 s\'b6n xu\'cat. \'a4ng coi s\'f9 ph\'a9n tranh nh\'bbm l\'b5m cho ch\'d5 \'ae\'e9 b
\'e3c l\'e9t n\'ab l\'d6 v\'dcnh vi\'d4n \'cay l\'b5 "t\'f9 nhi\'aan v\'b5 b\'cat di b\'cat d\'dech".
\par }\pard \qj \fi-425\li425\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 {\f38\fs18\expnd0\expndtw-4\insrsid1378858 PO\'a1NGCAR\'a3,}{\f37\fs18\expnd0\expndtw-4\insrsid1378858  }{
\b\f37\fs18\expnd0\expndtw-4\insrsid1378858 Raym\'abng}{\f37\fs18\expnd0\expndtw-4\insrsid1378858  (1860-1934): Tr\'b9ng s\'ad Ph\'b8p, ngh\'de s\'dc Qu\'e8c h\'e9i, B\'e9 tr\'ad\'ebng B\'e9 Gi\'b8o d\'f4c (1893-1894); B\'e9 tr\'ad\'ebng B\'e9 T\'b5i ch
\'ddnh (1894-1895, 1906); Th\'f1 t\'ad\'edng ph\'f4 tr\'b8ch B\'e9 Ngo\'b9i giao (1912-1913); T\'e6ng th\'e8ng (1913-1920). Lu\'abn lu\'abn th\'f9c hi\'d6n ch\'ddnh s\'b8ch \'ae\'e8i ngo\'b9i c\'f9c h\'f7u, n\'aan c\'e3 t\'aan "Po\'a8ngcar\'aa hi\'d5u chi
\'d5n". Nh\'f7ng n\'a8m 1922-1924, l\'b9i l\'b5m Th\'f1 t\'ad\'edng ph\'f4 tr\'b8ch ngo\'b9i giao. T\'f5 n\'a8m 1929, r\'f3t kh\'e1i ch\'ddnh tr\'ad\'eang v\'d2 vi\'d5t h\'e5i k\'fd.
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 R
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 RIVIE, }{\b\f37\fs18\insrsid1378858 H\'a8ngri}{
\f37\fs18\insrsid1378858 : S\'dc quan h\'b6i qu\'a9n Ph\'b8p tham gia \'ae\'b8nh chi\'d5m B\'bec K\'fa l\'c7n th\'f8 hai, b\'de qu\'a9n ta gi\'d5t ch\'d5t \'eb g\'c7n C\'c7u Gi\'cay (H\'b5 N\'e9i) n\'a8m 1883.
\par R\'a4I, }{\b\f37\fs18\insrsid1378858 Manaben\'aera N\'b8t}{\f37\fs18\insrsid1378858  (1892-1948): Ng\'ad\'eai }{\f38\fs18\insrsid1378858 \'ca}{\f37\fs18\insrsid1378858 n \'a7\'e9, tham gia phong tr\'b5o \'ae\'cau tranh ch\'e8ng \'ae\'d5 qu\'e8c Anh t\'f5
 n\'a8m 1910. N\'a8m 1915, s\'e8ng \'eb n\'ad\'edc ngo\'b5i v\'b5 tham gia phong tr\'b5o c\'e9ng s\'b6n. \'a7\'b7 d\'f9 c\'b8c \'a7\'b9i h\'e9i II, III, IV, V Qu\'e8c t\'d5 C\'e9ng s\'b6n. N\'a8m 1922, \'ae\'ad\'eec b\'c7u l\'b5 U\'fb vi\'aan d\'f9 khuy
\'d5t Ban Ch\'cap h\'b5nh Qu\'e8c t\'d5 C\'e9ng s\'b6n. N\'a8m 1924, \'ae\'ad\'eec b\'c7u l\'b5 U\'fb vi\'aan ch\'ddnh th\'f8c Ban Ch\'cap h\'b5nh Qu\'e8c t\'d5 C\'e9ng s\'b6n.
\par }\pard\plain \s16\qj \fi397\li425\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Sau b\'e1 \'a7\'b6ng C\'e9ng s\'b6n, tham gia phong tr
\'b5o \'ae\'cau tranh ch\'e8ng \'ae\'d5 qu\'e8c Anh theo xu h\'ad\'edng t\'ad s\'b6n.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 R\'f3TX\'a4,}{\f37\fs18\insrsid1378858  }{
\b\f37\fs18\insrsid1378858 Gi\'a8ng Gi\'bec}{\f37\fs18\insrsid1378858  (1712-1778): Nh\'b5 v\'a8n, nh\'b5 tri\'d5t h\'e4c Ph\'b8p n\'e6i ti\'d5ng. R\'f3tx\'ab b\'b5i x\'ddch gi\'b8o h\'e9i v\'b5 cho r\'bbng nguy\'aan nh\'a9n c\'f1a s\'f9 kh\'abng c\'abng 
b\'bbng trong x\'b7 h\'e9i l\'b5 ch\'d5 \'ae\'e9 t\'ad h\'f7u l\'edn, t\'f5 \'ae\'e3 n\'b6y sinh m\'a9u thu\'c9n trong x\'b7 h\'e9i. R\'f3tx\'ab \'ae\'d2 cao d\'a9n ch\'f1 t\'ad s\'b6n, t\'ddnh nh\'a9n \'ae\'b9o v\'b5 l\'fd t\'ad\'ebng ho\'b8 x\'b7 h\'e9
i c\'e9ng s\'b6n nguy\'aan thu\'fb.
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 S
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 S}{\f38\fs18\insrsid1378858 \'b8CL\'a5 I}{
\f37\fs18\insrsid1378858  (1600-1649): Vua Anh t\'f5 n\'a8m 1625; ng\'ad\'eai tri\'d6t \'ae\'d3 \'ae\'cau tranh \'ae\'d3 duy tr\'d7 ch\'d5 \'ae\'e9 phong ki\'d5n. Trong C\'b8ch m\'b9ng t\'ad s\'b6n Anh, S\'b8cl\'ac I b\'de h\'b9 b\'d6 v\'b5 \'ae\'ada ra x
\'d0t x\'f6 v\'edi m\'f8c \'b8n t\'f6 h\'d7nh cho m\'e9t ho\'b5ng \'ae\'d5 b\'b9o ch\'f3a, k\'ce th\'ef c\'f1a nh\'a9n d\'a9n.
\par }\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 S\'d5CHXPIA,}{\fs18\insrsid1378858  }{
\b\fs18\insrsid1378858 Uyliam}{\fs18\insrsid1378858  (1564-1616): Nh\'b5 v\'a8n, nh\'b5 th\'ac, nh\'b5 vi\'d5t k\'dech v\'dc \'ae\'b9i c\'f1a n\'ad\'edc Anh th\'eai \'ae\'b9i Ph\'f4c h\'adng; t\'b8c gi\'b6 c\'f1a nhi\'d2u v\'eb h\'b5i k\'dech: }{
\i\fs18\insrsid1378858 U\'e6ng s\'f8c y\'aau \'ae\'ad\'acng}{\fs18\insrsid1378858  (1591), }{\i\fs18\insrsid1378858 Gi\'cac m\'e9ng \'ae\'aam h\'cc}{\fs18\insrsid1378858  (1594), }{\i\fs18\insrsid1378858 Ch\'b5ng th\'ad\'acng gia th\'b5nh V\'acnid\'ac}{
\fs18\insrsid1378858  (1594) ... v\'b5 c\'f1a nhi\'d2u v\'eb bi k\'dech: }{\i\fs18\insrsid1378858 R\'abm\'aa\'ab v\'b5 Giuyli\'d0t }{\fs18\insrsid1378858 (1594-1595), }{\i\fs18\insrsid1378858 H\'a8ml\'d0t}{\fs18\insrsid1378858  (1601}{
\i\fs18\insrsid1378858 ), \'a4tenl\'ab}{\fs18\insrsid1378858  (1604), }{\i\fs18\insrsid1378858 Vua Lia}{\fs18\insrsid1378858  (1607)...
\par }{\f38\fs18\insrsid1378858 S\'a5VALI\'a3,}{\fs18\insrsid1378858  }{\b\fs18\insrsid1378858 \'a4guyxt\'ac}{\fs18\insrsid1378858  (1873-1956): Nh\'b5 du l\'dech v\'b5 th\'f9c v\'cbt h\'e4c Ph\'b8p; \'aei nhi\'d2u n\'ad\'edc ch\'a9u Phi, nghi\'aan c\'f8u v
\'d2 \'ae\'dea l\'fd, th\'f9c v\'cbt. S\'acvali\'aa \'ae\'b7 \'ae\'d5n \'a7\'abng D\'ad\'acng v\'b5 \'ae\'d3 l\'b9i m\'e9t s\'e8 c\'abng tr\'d7nh khoa h\'e4c c\'e3 gi\'b8 tr\'de.
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T
\par }\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 TH\'b5NH TH\'b8I}{\fs18\insrsid1378858 
 (1879-1954): T\'f8c Nguy\'d4n B\'f6u L\'a9n, vua th\'f8 10 nh\'b5 Nguy\'d4n n\'a8m 1889-1907. Th\'b5nh Th\'b8i l\'b5 ng\'ad\'eai y\'aau n\'ad\'edc v\'b5 c\'e3 tinh th\'c7n d\'a9n t\'e9c. N\'a8m 1907, Th\'b5nh Th\'b8i b\'de th\'f9c d\'a9n Ph\'b8p \'ae\'b5
y sang \'ae\'b6o R\'aauyni\'abng (ch\'a9u Phi). N\'a8m 1947, \'ae\'ad\'eec \'ae\'ada v\'d2 mi\'d2n Nam nh\'adng ph\'b6i s\'e8ng t\'b9i S\'b5i G\'dfn; m\'cat ng\'b5y 24-3-1954.
\par }{\f38\fs18\insrsid1378858 THU\'caN:}{\fs18\insrsid1378858  M\'e9t \'abng vua mang nhi\'d2u t\'ddnh huy\'d2n tho\'b9i trong l\'dech s\'f6 Trung Qu\'e8c th\'eai m\'b9t k\'fa C\'abng x\'b7 th\'de t\'e9c, l\'b5 ng\'ad\'eai c\'e3 c\'abng t\'d7m ra c\'b8ch c
\'a9n, \'aeo th\'e8ng nh\'cat. Sau nh\'ad\'eang ng\'abi cho \'abng V\'f2, m\'e9t th\'ad\'eeng th\'ad t\'b5i ba, \'ae\'f8c \'ae\'e9 ch\'f8 kh\'abng truy\'d2n l\'b9i cho con.
\par }{\f38\fs18\insrsid1378858 TIL\'beC,}{\fs18\insrsid1378858  }{\b\fs18\insrsid1378858 Bai G\'a8ngga\'aea}{\fs18\insrsid1378858  (1856-1920): M\'e9t trong nh\'f7ng l\'b7nh t\'f4 phong tr\'b5o d\'a9n t\'e9c }{\f38\fs18\insrsid1378858 \'ca}{
\fs18\insrsid1378858 n \'a7\'e9 h\'d7nh th\'b5nh t\'f5 cu\'e8i th\'d5 k\'fb XIX, t\'cbp h\'eep nh\'f7ng ph\'c7n t\'f6 ti\'d3u t\'ad s\'b6n v\'b5 tr\'dd th\'f8c ngh\'cco, ch\'f1 tr\'ad\'acng \'ae\'cau tranh kh\'abng tho\'b6 hi\'d6p v\'edi th\'f9c d\'a9
n Anh. Do thi\'d5u l\'fd lu\'cbn v\'b5 kh\'abng li\'aan h\'d6 v\'edi phong tr\'b5o qu\'c7n ch\'f3ng n\'aan \'ae\'b7 \'aei v\'b5o ho\'b9t \'ae\'e9ng v\'ab ch\'ddnh ph\'f1, kh\'f1ng b\'e8 c\'b8 nh\'a9n, th\'cbm ch\'dd s\'f6 d\'f4ng c\'b6 nh\'f7ng h\'d7nh th
\'f8c t\'abn gi\'b8o ph\'b6n \'ae\'e9ng l\'b5m l\'eei kh\'dd tuy\'aan truy\'d2n n\'aan d\'c7n d\'c7n phong tr\'b5o b\'de tho\'b8i ho\'b8. Til\'bec c\'dfn l\'b5 m\'e9t nh\'b5 v\'a8n v\'b5 vi\'d5t nhi\'d2u t\'b8c ph\'c8m b\'d7nh lu\'cbn v\'d2 t\'abn gi\'b8
o.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 T\'a4N D\'cbT TI\'a3N}{\f37\fs18\insrsid1378858 
 (1866-1925): T\'f8c T\'abn Trung S\'acn, nh\'b5 c\'b8ch m\'b9ng d\'a9n t\'e9c d\'a9n ch\'f1 Trung Qu\'e8c, ng\'ad\'eai l\'b7nh \'ae\'b9o C\'b8ch m\'b9ng T\'a9n H\'eei (1911) l\'cbt \'ae\'e6 tri\'d2u \'ae\'b9i phong ki\'d5n M\'b7n Thanh; s\'b8ng l\'cb
p thuy\'d5t Tam d\'a9n v\'b5 t\'e6 ch\'f8c Trung Qu\'e8c c\'b8ch m\'b9ng \'ae\'e5ng minh h\'e9i (sau c\'b6i t\'e6 th\'b5nh Qu\'e8c d\'a9n \'ae\'b6ng). N\'a8m 1912, \'ae\'ad\'eec b\'c7u l\'b5m T\'e6ng th\'e8ng l\'a9m th\'eai Trung Hoa d\'a9n qu\'e8c, sau 
\'ae\'e3 t\'f5 ch\'f8c. N\'a8m 1916, t\'e6 ch\'f8c Ch\'ddnh ph\'f1 Qu\'b6ng \'a7\'abng, \'ae\'ad\'eec c\'f6 l\'b5m \'a7\'b9i Nguy\'aan so\'b8i. T\'abn Trung S\'acn ch\'f1 tr\'ad\'acng \'aeo\'b5n k\'d5t v\'edi n\'ad\'edc Nga X\'abvi\'d5t, \'a7\'b6ng C\'e9
ng s\'b6n, qu\'c7n ch\'f3ng n\'abng d\'a9n, c\'abng nh\'a9n v\'b5 xo\'b8 b\'e1 c\'b8c hi\'d6p \'ad\'edc b\'cat b\'d7nh \'ae\'bcng v\'edi n\'ad\'edc ngo\'b5i.
\par }\pard \qj \fi-425\li425\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 {\f38\fs18\insrsid1378858 T\'e8NG DUY T\'a2N}{\f37\fs18\insrsid1378858  (1838-1892): M\'e9t s\'dc phu y\'aau n\'ad\'edc \'ae\'b7 t\'ddch c
\'f9c h\'ad\'ebng \'f8ng phong tr\'b5o C\'c7n v\'ad\'acng c\'f1a vua H\'b5m Nghi (1885), c\'efng v\'edi nhi\'d2u v\'a8n th\'a9n, s\'dc phu gi\'ad\'acng cao c\'ea kh\'ebi ngh\'dca \'eb v\'efng n\'f3i H\'e5ng L\'dcnh, Thanh H\'e3a (1885-1892), v\'b5 tr\'eb
 th\'b5nh th\'f1 l\'dcnh ch\'ddnh c\'f1a phong tr\'b5o. Th\'b8ng 9-1892, b\'de \'ae\'dech v\'a9y b\'bet v\'b5 x\'f6 t\'f6 ng\'b5y 5-10-1892.
\par }\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 T\'a5RANH}{\b\fs18\insrsid1378858 , Anbe \'a3\'ae
ua}{\fs18\insrsid1378858  (1889-1971): Ng\'ad\'eai Ph\'b8p, \'ae\'b9i bi\'d3u d\'f9 \'a7\'b9i h\'e9i l\'c7n th\'f8 XVIII \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p \'eb Tua, \'ae\'ad\'eec b\'c7u l\'b5m U\'fb vi\'aan ch\'ddnh th\'f8c Ban l\'b7nh \'ae\'b9o c\'f1a \'a7
\'b6ng theo Qu\'e8c t\'d5 th\'f8 ba, U\'fb vi\'aan Trung \'ad\'acng \'a7\'b6ng C\'e9ng s\'b6n Ph\'b8p n\'a8m 1925-1926, U\'fb vi\'aan B\'e9 Ch\'ddnh tr\'de Trung \'ad\'acng \'a7\'b6ng n\'a8m 1923-1924. N\'a8m 1928, b\'de khai tr\'f5 kh\'e1i \'a7\'b6ng C
\'e9ng s\'b6n. N\'a8m 1934, tham gia \'a7\'b6ng X\'b7 h\'e9i.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 TR\'c7N \'a7\'d5 QU\'fc}{\f37\fs18\insrsid1378858  (t
\'f8c Tr\'c7n Qu\'fc hay Tr\'c7n Ng\'e7i): Ng\'ad\'eai \'ae\'b7 c\'efng Tr\'c7n Qu\'fd Kho\'b8ng n\'e8i ti\'d5p nhau l\'b7nh \'ae\'b9o kh\'b8ng chi\'d5n ch\'e8ng qu\'a9n Minh n\'a8m 1407-1414, c\'b6 hai b\'de b\'bet. Tr\'c7n Ng\'e7i b\'de gi\'d5t v\'b5 Tr
\'c7n Qu\'fd Kho\'b8ng nh\'b6y xu\'e8ng s\'abng t\'f9 t\'f6.
\par }{\f38\fs18\insrsid1378858 TR\'c7N NH\'a2N T\'a4NG}{\f37\fs18\insrsid1378858  (1258-1308). T\'aan l\'b5 Kh\'a9m, vua nh\'b5 Tr\'c7n t\'f5 n\'a8m 1278; ng\'ad\'eai hai l\'c7n tr\'f9c ti\'d5p l\'b7nh \'ae\'b9o cu\'e9c kh\'b8ng chi\'d5n ch\'e8ng qu\'a9n x
\'a9m l\'ad\'eec Nguy\'aan M\'abng; sau nh\'ad\'eang ng\'abi cho con v\'b5 tu t\'b9i n\'f3i Y\'aan T\'f6; s\'b8ng l\'cbp ra thi\'d2n ph\'b8i Tr\'f3c L\'a9m. Tr\'c7n Nh\'a9n T\'abng c\'dfn l\'b5 nh\'b5 th\'ac xu\'cat s\'bec.
\par }{\f38\fs18\insrsid1378858 TR\'c7N QU\'fd C\'b8P}{\f37\fs18\insrsid1378858  (1870-1908): Qu\'aa \'eb Qu\'b6ng Nam (nay l\'b5 Qu\'b6ng Nam - \'a7\'b5 N\'bdng), \'ae\'e7 ti\'d5n s\'dc, ham th\'ddch t\'d7m hi\'d3u nh\'f7ng t\'ad t\'ad\'ebng ti\'d5n b\'e9 c
\'f1a T\'a9y \'a2u. Tr\'c7n Qu\'fd C\'b8p th\'ad\'eang \'aei v\'b5o qu\'c7n ch\'f3ng di\'d4n thuy\'d5t, v\'cbn \'ae\'e9ng c\'b6i c\'b8ch x\'b7 h\'e9i, tuy\'aan truy\'d2n tinh th\'c7n y\'aau n\'ad\'edc. N\'a8m 1908, b\'de Ph\'b8p \'ae\'ada v\'b5o Kh\'b8
nh Ho\'b5 l\'b5m gi\'b8o th\'f4 \'ae\'d3 c\'bet \'ae\'f8t quan h\'d6 v\'edi phong tr\'b5o ch\'e8ng thu\'d5 \'eb Qu\'b6ng Nam. Do nh\'f7ng t\'ad t\'ad\'ebng v\'b5 ho\'b9t \'ae\'e9ng ti\'d5n b\'e9 c\'f1a Tr\'c7n Qu\'fd C\'b8p, th\'f9c d\'a9n Ph\'b8p gh\'d0
p v\'b5o t\'e9i "ph\'b6n ngh\'dech", x\'f6 t\'f6 ng\'b5y 5-5-1908.
\par }\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 TR\'a6NG TR\'beC, TR\'a6NG NH\'de:}{
\fs18\insrsid1378858  Hai ch\'de em, l\'b7nh t\'f4 cu\'e9c kh\'ebi ngh\'dca c\'f1a nh\'a9n d\'a9n ta ch\'e8ng \'b8ch th\'e8ng tr\'de c\'f1a phong ki\'d5n ph\'ad\'acng B\'bec, nh\'b5 \'a7\'abng H\'b8n, \'ae\'c7u c\'abng nguy\'aan.
\par }\pard\plain \qj \fi397\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 D\'ad\'edi s\'f9 l\'b7nh \'ae\'b9o c\'f1a Hai B\'b5 Tr
\'adng, nh\'a9n d\'a9n ta \'ae\'b7 gi\'b5nh l\'b9i \'ae\'ad\'eec n\'d2n \'ae\'e9c l\'cbp t\'f5 tay nh\'b5 H\'b8n, Tr\'adng Tr\'bec \'ae\'ad\'eec t\'abn l\'b5m vua (Tr\'adng V\'ad\'acng) \'ae\'e3ng \'ae\'ab \'eb M\'aa Linh (huy\'d6n Y\'aan L\'b7ng, V\'dc
nh Ph\'f3).
\par Sau hai n\'a8m gi\'b5nh \'ae\'ad\'eec \'ae\'e9c l\'cbp, nh\'b5 H\'b8n l\'b9i \'aeem qu\'a9n x\'a9m l\'ad\'eec n\'ad\'edc ta. Hai B\'b5 Tr\'adng \'ae\'b7 l\'b7nh \'ae\'b9o nh\'a9n d\'a9n chi\'d5n \'ae\'cau anh d\'f2ng g\'c7n m\'e9t n\'a8m. Nh\'adng v\'d7 s
\'f8c y\'d5u qu\'a9n ta \'ae\'b7 b\'de tan v\'ec, Hai B\'b5 Tr\'adng \'ae\'b7 ch\'d5t \'eb c\'f6a s\'abng H\'b8t (th\'b8ng 5-43).
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 U
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 UT\'a5R\'a2Y,}{\f37\fs18\insrsid1378858  }{
\b\f37\fs18\insrsid1378858 Ecn\'d5xt\'ac:}{\f37\fs18\insrsid1378858  Ng\'ad\'eai Ph\'b8p, tham gia H\'e9i \'ae\'e5ng thu\'e9c \'ae\'dea Nam K\'fa v\'b5 l\'b5 \'ae\'b9i bi\'d3u c\'f1a H\'e9i \'ae\'e5ng thu\'e9c \'ae\'dea Nam K\'fa trong H\'b9 ngh\'de vi
\'d6n Ph\'b8p. Ut\'acr\'a9y l\'b5 m\'e9t \'ae\'b9i \'ae\'dea ch\'f1, d\'efng quy\'d2n th\'d5 chi\'d5m 2000 ha \'ae\'cat l\'cbp \'ae\'e5n \'aei\'d2n \'eb Nam B\'e9. V\'d2 ch\'ddnh tr\'de, Ut\'acr\'a9y l\'b5 m\'e9t vi\'aan ch\'f8c th\'f9c d\'a9n c\'f9c k
\'fa ph\'b6n \'ae\'e9ng.
\par UYNX\'a5N, }{\b\f37\fs18\insrsid1378858 Vu\'aer\'ab}{\f37\fs18\insrsid1378858  (1856-1924): T\'e6ng th\'e8ng M\'fc n\'a8m 1913-1921. D\'ad\'edi th\'eai Uynx\'acn, v\'d2 \'ae\'e8i n\'e9i, Ch\'ddnh ph\'f1 M\'fc \'ae\'b7 thi h\'b5nh ch\'ddnh s\'b8ch \'ae\'b5
n \'b8p d\'b7 man phong tr\'b5o c\'abng nh\'a9n; v\'d2 \'ae\'e8i ngo\'b9i, thi h\'b5nh ch\'ddnh s\'b8ch \'a8n c\'ad\'edp v\'b5 b\'b5nh tr\'ad\'edng, can thi\'d6p th\'ab b\'b9o v\'b5o c\'abng vi\'d6c n\'e9i b\'e9 c\'f1a c\'b8c n\'ad\'edc kh\'b8c, \'ae\'c6
c bi\'d6t l\'b5 v\'edi c\'b8c n\'ad\'edc ch\'a9u M\'fc Latinh.
\par }\pard \qj \fi397\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 {\f37\fs18\insrsid1378858 N\'a8m 1918, Uynx\'acn \'ae\'ada ra "Ch\'ad\'acng tr\'d7nh 14 \'aei\'d3m". Th\'f9c ch\'cat ch\'ad\'acng tr\'d7nh n
\'b5y l\'b5 thi\'d5t l\'cbp \'b8ch th\'e8ng tr\'de c\'f1a M\'fc tr\'aan th\'d5 gi\'edi, ch\'e8ng l\'b9i n\'ad\'edc Nga X\'abvi\'d5t m\'edi ra \'ae\'eai. Ch\'ddnh s\'b8ch n\'b5y \'ae\'ad\'eec che \'ae\'cby b\'bbng nh\'f7ng l\'eai l\'cf m\'fc mi\'d2u nh\'ad
 "d\'a9n ch\'f1", "quy\'d2n d\'a9n t\'e9c t\'f9 quy\'d5t".
\par N\'a8m 1920, Uynx\'acn b\'de th\'cat b\'b9i trong cu\'e9c b\'c7u c\'f6 t\'e6ng th\'e8ng v\'b5 th\'abi ho\'b9t \'ae\'e9ng ch\'ddnh tr\'de.
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 V
\par }\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 VAREN, }{\b\fs18\insrsid1378858 Al\'d5chx\'a8ng
\'aer\'ac Cl\'e8t \'ae\'ac}{\fs18\insrsid1378858  (1870-1947):Lu\'cbt s\'ad, nh\'b5 b\'b8o, \'ae\'b6ng vi\'aan \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p, d\'f9 \'a7\'b9i h\'e9i Xtraxbua v\'b5 Tua (thu\'e9c ph\'b8i L\'abnggh\'aa), kh\'abng t\'b8n th\'b5nh Qu\'e8c t
\'d5 C\'e9ng s\'b6n. To\'b5n quy\'d2n \'a7\'abng D\'ad\'acng n\'a8m 1925. Sau b\'e1 \'a7\'b6ng X\'b7 h\'e9i; \'ae\'b9i bi\'d3u c\'f1a \'a7\'b6ng X\'b7 h\'e9i c\'cap ti\'d5n trong Qu\'e8c h\'e9i n\'a8m 1945-1946, B\'e9 tr\'ad\'ebng n\'a8m 1946.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 VAY\'a1NG CUTUYARI\'a3,}{\f37\fs18\insrsid1378858  }{
\b\f37\fs18\insrsid1378858 P\'abn}{\f37\fs18\insrsid1378858  (1892-1937): M\'e9t trong nh\'f7ng ng\'ad\'eai s\'b8ng l\'cbp \'a7\'b6ng C\'e9ng s\'b6n Ph\'b8p; nguy\'aan ngh\'de s\'dc Qu\'e8c h\'e9i Ph\'b8p, c\'f9u Ch\'f1 nhi\'d6m b\'b8o }{
\i\f37\fs18\insrsid1378858 L'Humanit\'d0;}{\f37\fs18\insrsid1378858  l\'b5 ng\'ad\'eai gi\'edi thi\'d6u Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 i Qu\'e8c v\'b5o \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p (1919). T\'b9i \'a7\'b9i h\'e9
i Tua n\'a8m 1920, l\'b5 m\'e9t trong nh\'f7ng ng\'ad\'eai \'ae\'cau tranh b\'b6o v\'d6 ch\'f1 tr\'ad\'acng \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p gia nh\'cbp Qu\'e8c t\'d5 C\'e9ng s\'b6n v\'b5 \'f1ng h\'e9 b\'b5i ph\'b8t bi\'d3u c\'f1a Nguy\'d4n }{
\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 i Qu\'e8c \'eb \'a7\'b9i h\'e9i n\'b5y. Vay\'a8ng Cutuyari\'aa c\'dfn l\'b5 ng\'ad\'eai t\'ddch c\'f9c gi\'f3p \'ae\'ec Nguy\'d4n }{\f38\fs18\insrsid1378858 \'b8}{\f37\fs18\insrsid1378858 i Qu\'e8
c khi Ng\'ad\'eai tho\'b8t kh\'e1i nh\'b5 ng\'f4c H\'e5ng C\'abng l\'aan Th\'ad\'eeng H\'b6i, b\'bet li\'aan l\'b9c v\'edi t\'e6 ch\'f8c \'ae\'d3 \'ae\'d5n Li\'aan X\'ab.
\par }{\f38\fs18\insrsid1378858 VINH\'a3 \'a7\'e8CT\'a4NG,}{\f37\fs18\insrsid1378858  }{\b\f37\fs18\insrsid1378858 P\'abn}{\f37\fs18\insrsid1378858 . P\'abn Vinh\'aa \'a7\'e8ct\'abng l\'b5 b\'f3t danh c\'f1a P\'abn Echi\'aan Vinh\'aa (1839 - 1943): Ng\'ad\'ea
i Ph\'b8p; h\'e4c d\'ad\'eec v\'b5 ph\'f4c v\'f4 trong ng\'b5nh h\'b5ng h\'b6i t\'f5 n\'a8m 1880. T\'f5 n\'a8m 1889 - 1893, l\'b5m vi\'d6c \'eb ch\'a9u Phi, s\'b8ng t\'b8c v\'a8n h\'e4c, \'ae\'b7 xu\'cat b\'b6n 10 cu\'e8n ti\'d3u thuy\'d5t. Trong ho\'b9t 
\'ae\'e9ng ch\'ddnh tr\'de, Vinh\'aa \'a7\'e8ct\'abng tham gia ph\'b8i c\'cap ti\'d5n c\'f9c t\'b6, t\'b8c gi\'b6 cu\'e8n }{\i\f37\fs18\insrsid1378858 Vinh quang c\'f1a l\'ad\'eci g\'ad\'acm}{\f37\fs18\insrsid1378858 , xu\'cat b\'b6n l\'c7n \'ae\'c7u n
\'a8m 1900, \'ae\'ad\'eec c\'b8c nh\'b5 nghi\'aan c\'f8u l\'dech s\'f6 \'eb Ph\'b8p xem l\'b5 cu\'e8n s\'b8ch \'ae\'c7u ti\'aan c\'abng khai ch\'e8ng ch\'f1 ngh\'dca th\'f9c d\'a9n.
\par V\'a4ITINXKI }{\b\f37\fs18\insrsid1378858 (\'a7arkhin), Grig\'abri Naum\'abv\'ddch}{\f37\fs18\insrsid1378858  (1893-1953): Ng\'ad\'eai Nga, tham gia \'a7\'b6ng C\'e9ng s\'b6n Nga (b) n\'a8m 1918. N\'a8m 1920, l\'b5m Th\'ad k\'fd Ban ph\'ad\'acng \'a7\'ab
ng c\'f1a Qu\'e8c t\'d5 C\'e9ng s\'b6n; Ph\'e3 Ti\'d3u ban Vi\'d4n \'a7\'abng c\'f1a Ban ph\'ad\'acng \'a7\'abng. Nh\'f7ng n\'a8m 20, V\'abitinxki \'ae\'d5n Trung Qu\'e8c v\'edi t\'ad c\'b8ch \'ae\'b9i bi\'d3u c\'f1a Qu\'e8c t\'d5 C\'e9ng s\'b6n l\'b5m vi
\'d6c v\'edi Trung \'ad\'acng \'a7\'b6ng C\'e9ng s\'b6n Trung Qu\'e8c. T\'f5 nh\'f7ng n\'a8m 30, l\'b5m c\'abng t\'b8c khoa h\'e4c v\'b5 gi\'b8o d\'f4c \'eb Li\'aan X\'ab.
\par }\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 V\'a4NTE, }{\b\fs18\insrsid1378858 Phr\'a8
ngxoa Mari Aru\'aa \'ae\'ac}{\fs18\insrsid1378858  (1694-1778): Nh\'b5 v\'a8n, nh\'b5 tri\'d5t h\'e4c xu\'cat s\'bec, nh\'b5 t\'ad t\'ad\'ebng c\'f1a tr\'b5o l\'adu tri\'d5t h\'e4c "\'b8nh s\'b8ng" \'eb Ph\'b8p th\'d5 k\'fb XVIII. \'a7\'b6 k\'ddch ch\'d5 
\'ae\'e9 phong ki\'d5n, ph\'aa ph\'b8n s\'a9u s\'bec gi\'b8o h\'e9i, \'ae\'dfi h\'e1i t\'f9 do, b\'d7nh \'ae\'bcng nh\'adng kh\'abng tri\'d6t \'ae\'d3, v\'c9n ch\'f1 tr\'ad\'acng b\'b6o ho\'b5ng v\'b5 duy tr\'d7 t\'abn gi\'b8o.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 V\'a4R\'e8PXKI,}{\f37\fs18\insrsid1378858  }{
\b\f37\fs18\insrsid1378858 Vasl\'b8p Vaslav\'abv\'ddch}{\f37\fs18\insrsid1378858  (1871-1923): Nh\'b5 ho\'b9t \'ae\'e9ng \'a7\'b6ng C\'e9ng s\'b6n Li\'aan X\'ab, nh\'b5 ph\'aa b\'d7nh v\'a8n h\'e4c, nh\'b5 ngo\'b9i giao; tham gia \'aeo\'b5n \'ae\'b9i bi
\'d3u Li\'aan X\'ab t\'b9i H\'e9i ngh\'de L\'abdann\'ac (1922-1923); b\'de qu\'a9n b\'b9ch v\'d6 ph\'b8t x\'ddt b\'ben ch\'d5t \'eb L\'abdann\'ac ng\'b5y 10-5-1923.
\par VRANGHEN, }{\b\f37\fs18\insrsid1378858 Pi\'e8t Nic\'ablai\'aav\'ddch}{\f37\fs18\insrsid1378858  (1878-1928): T\'ad\'edng trong qu\'a9n \'ae\'e9i Nga ho\'b5ng, m\'e9t ph\'c7n t\'f6 qu\'a9n ch\'f1. Trong th\'eai k\'fa v\'f2 trang can thi\'d6p c\'f1a n\'ad
\'edc ngo\'b5i v\'b5 n\'e9i chi\'d5n \'eb Li\'aan X\'ab, Vranghen l\'b5 tay ch\'a9n c\'f1a \'ae\'d5 qu\'e8c Anh, Ph\'b8p v\'b5 M\'fc. N\'a8m 1920, l\'b5 T\'e6ng t\'ad l\'d6nh c\'b8c l\'f9c l\'ad\'eeng v\'f2 trang b\'b9ch v\'d6 mi\'d2n Nam n\'ad\'ed
c Nga. Sau khi b\'de H\'e5ng qu\'a9n \'ae\'b8nh tan \'eb B\'bec Tavr\'ddch v\'b5 Cr\'adm, Vranghen \'ae\'b7 ch\'b9y ra n\'ad\'edc ngo\'b5i.
\par }{\f38\fs18\insrsid1378858 V\'f2:}{\f37\fs18\insrsid1378858  M\'e9t \'abng vua mang nhi\'d2u t\'ddnh huy\'d2n tho\'b9i trong l\'dech s\'f6 Trung Qu\'e8c th\'eai m\'b9t k\'fa c\'abng x\'b7 th\'de t\'e9c, n\'e6i ti\'d5ng v\'d2 l\'dfng y\'aau n\'ad\'edc v
\'b5 \'ae\'f8c nh\'a9n t\'f5; c\'e3 nhi\'d2u c\'abng lao t\'e6 ch\'f8c \'ae\'bep \'ae\'aa, x\'a9y \'ae\'cbp ph\'dfng ch\'e8ng b\'b7o l\'f4t, h\'b9n h\'b8n b\'b6o v\'d6 m\'efa m\'b5ng.
\par }\pard\plain \s29\qc \li0\ri0\sb320\sa240\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 X
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 XANH, }{\b\f37\fs18\insrsid1378858 Luyxi\'aang:}{
\f37\fs18\insrsid1378858  To\'b5n quy\'d2n Ph\'b8p \'eb Tuynidi.
\par XAR\'a4, }{\b\f37\fs18\insrsid1378858 Anbe}{\f37\fs18\insrsid1378858  (1872-1962): To\'b5n quy\'d2n Ph\'b8p t\'b9i \'a7\'abng D\'ad\'acng trong nh\'f7ng n\'a8m 1911-1914 v\'b5 1917-1919. Trong nh\'f7ng n\'a8m 20, l\'b5 B\'e9 tr\'ad\'ebng B\'e9 Thu\'e9c 
\'ae\'dea, n\'a8m 1936, l\'b5 Th\'f1 t\'ad\'edng Ph\'b8p, n\'a8m 1951, l\'b5 Ch\'f1 t\'dech H\'e9i \'ae\'e5ng Li\'aan hi\'d6p Ph\'b8p.
\par }\pard\plain \s28\qj \fi-425\li425\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XELI\'a3, }{\b\insrsid1378858 Lui}{\insrsid1378858 
 (1885-1978): \'a7\'b6ng vi\'aan \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p, t\'b8n th\'b5nh nh\'f7ng quan \'aei\'d3m c\'f1a Casanh - Phr\'e8txa; tham gia Qu\'e8c t\'d5 th\'f8 ba; \'ae\'b9i bi\'d3u \'a7\'b6ng b\'e9 Xen tham gia \'a7\'b9i h\'e9i l\'c7n th\'f8 XVIII 
\'eb Tua v\'b5 \'ae\'ad\'eec b\'c7u v\'b5o Ban l\'b7nh \'ae\'b9o \'a7\'b6ng C\'e9ng s\'b6n Ph\'b8p n\'a8m 1920, n\'a8m 1922-1924; U\'fb vi\'aan Trung \'ad\'acng \'a7\'b6ng n\'a8m 1925-1926; U\'fb vi\'aan B\'e9 Ch\'ddnh tr\'de Trung \'ad\'acng \'a7\'b6ng n
\'a8m 1923-1926. N\'a8m 1929, ra kh\'e1i \'a7\'b6ng C\'e9ng s\'b6n; sau tr\'eb l\'b9i \'a7\'b6ng X\'b7 h\'e9i r\'e5i l\'b9i b\'de khai tr\'f5 kh\'e1i \'a7\'b6ng X\'b7 h\'e9i.
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\insrsid1378858 XITR\'a4\'a3N,}{\f37\fs18\insrsid1378858  }{
\b\f37\fs18\insrsid1378858 \'a1ng\'aer\'aa}{\f37\fs18\insrsid1378858  (1878-1935): K\'fc s\'ad v\'b5 nh\'b5 c\'abng nghi\'d6p Ph\'b8p. N\'a8m 1915, l\'cbp x\'ad\'ebng s\'b6n xu\'cat v\'f2 kh\'dd. Sau Chi\'d5n tranh th\'d5 gi\'edi th\'f8 nh\'ca
t (1914-1918), chuy\'d3n sang s\'b6n xu\'cat xe ch\'b9y x\'ddch, r\'e5i xe h\'aci. S\'b6n ph\'c8m c\'f1a Xitr\'ab\'aan c\'e3 ti\'d5ng \'eb Ph\'b8p v\'b5 tr\'aan th\'d5 gi\'edi.
\par }\pard\plain \s18\qj \fi-425\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 XTALIN, }{\b\fs18\insrsid1378858 I\'abx\'ddp V
\'ddchxari\'abn\'abv\'ddch}{\fs18\insrsid1378858  (1879-1953): M\'e9t trong nh\'f7ng nh\'b5 ho\'b9}{\fs18\expnd0\expndtw-2\insrsid1378858 t \'ae\'e9ng n\'e6i ti\'d5ng c\'f1a \'a7\'b6ng C\'e9ng s\'b6n v\'b5 Nh\'b5 n\'ad\'edc Li\'aan X\'ab. N\'a8
m 1898, gia nh\'cbp \'a7\'b6ng C\'abng nh\'a9n d\'a9n ch\'f1 - x\'b7 h\'e9i Nga r\'e5i tr\'eb th\'b5nh \'ae\'b6ng vi\'aan b\'abns\'aav\'ddch sau \'a7\'b9i h\'e9i l\'c7n th\'f8 II c\'f1a \'a7\'b6ng. Th\'eai k\'fa chu\'c8n b\'de ti\'d5n h\'b5nh C\'b8ch m
\'b9ng Th\'b8ng M\'ad\'eai Nga, l\'b5 U\'fb vi\'aan Trung t\'a9m qu\'a9n s\'f9 c\'b8ch m\'b9ng. Th\'eai k\'fa n\'ad\'edc ngo\'b5i v\'f2 trang can thi\'d6p v\'b5 n\'e9i chi\'d5n, l\'b5 U\'fb vi\'aan H\'e9i \'ae\'e5ng Qu\'a9n s\'f9 c\'b8ch m\'b9ng. N\'a8
m 1922, l\'b5 T\'e6ng B\'dd th\'ad Ban Ch\'cap h\'b5nh Trung \'ad\'acng \'a7\'b6ng C\'e9ng s\'b6n (b) Nga. Trong chi\'d5n tranh b\'b6o v\'d6 T\'e6 qu\'e8c (1941-1945) l\'b5 Ch\'f1 t\'dech U\'fb ban Qu\'e8c ph\'dfng v\'b5 l\'b5 U\'fb vi\'aan nh\'a9n d\'a9
n Qu\'e8c ph\'dfng Li\'aan X\'ab, T\'e6ng t\'ad l\'d6nh t\'e8i cao c\'b8c l\'f9c l\'ad\'eeng v\'f2 trang Li\'aan X\'ab. Xtalin c\'dfn l\'b5 t\'b8c gi\'b6 c\'f1a nhi\'d2u t\'b8c ph\'c8m l\'fd lu\'cbn.}{\fs18\insrsid1378858 
\par }\pard\plain \qj \fi-425\li425\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin425\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 
\par }\pard \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 
\par }}