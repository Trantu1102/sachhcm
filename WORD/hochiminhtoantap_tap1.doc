\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Trong s\'e8 c\'b8c d\'a9n t\'e9c s\'e8ng \'eb B\'be
c Phi, ch\'d8 ng\'ad\'eai B\'d0cbe bi\'d5t \'ae\'d5n nguy\'aan t\'bec t\'ad h\'f7u nh\'adng h\'e4 ch\'d8 l\'b5 thi\'d3u s\'e8 chi\'d5m kho\'b6ng m\'e9t ph\'c7n ba s\'e8 d\'a9n Angi\'aari v\'b5 kho\'b6ng ba ph\'c7n 14 \'ae\'cat \'aeai c\'e3 th\'d3 canh t
\'b8c \'ae\'ad\'eec \'eb thu\'e9c \'ae\'dea n\'b5y.
\par Quan h\'d6 ru\'e9ng \'ae\'cat c\'f1a ng\'ad\'eai Tuynidi, ng\'ad\'eai Ar\'cbp Angi\'aari v\'b5 ng\'ad\'eai Mar\'e8c n\'e3i chung d\'f9a tr\'aan c\'ac s\'eb ch\'f1 ngh\'dca c\'e9ng s\'b6n nguy\'aan thu\'fb: Theo kinh th\'b8nh \'ae\'b9o Ixlam, ru\'e9ng \'ae
\'cat thu\'e9c v\'d2 Tr\'eai, v\'b5 con ng\'ad\'eai ch\'d8 c\'e3 quy\'d2n s\'f6 d\'f4ng nh\'f7ng g\'d7 m\'b5 anh ta c\'e3 th\'d3 l\'cay t\'f5 \'ae\'e3 b\'bbng lao \'ae\'e9ng c\'f1a m\'d7nh. Nh\'ad v\'cby, ru\'e9ng \'ae\'cat l\'b5 s\'eb h\'f7u c\'f1a c\'ab
ng x\'b7 v\'b5 kh\'abng b\'de tr\'adng thu. M\'e7i ng\'ad\'eai \'ae\'d2u \'ae\'ad\'eec nh\'cbn m\'e9t m\'b6nh \'ae\'cat v\'b5 \'ae\'ad\'eec s\'f6 d\'f4ng to\'b5n b\'e9 s\'b6n ph\'c8m c\'f1a m\'b6nh \'ae\'cat \'ae\'e3. Nh\'adng anh ta kh\'abng \'ae\'ad\'ee
c mua ru\'e9ng c\'f1a ng\'ad\'eai kh\'b8c. Kh\'abng \'ae\'ad\'eec b\'b8n \'ae\'cat c\'f1a m\'d7nh. Ng\'ad\'eai gi\'f7 ru\'e9ng \'ae\'cat \'ae\'e3 ch\'d5t \'aei th\'d7 ru\'e9ng \'ae\'cat l\'b9i tr\'eb th\'b5nh s\'eb h\'f7u c\'f1a c\'abng x\'b7. Ph\'ad\'ac
ng th\'f8c s\'eb h\'f7u t\'cbp th\'d3 \'ae\'e3 \'ae\'ad\'eec g\'e4i l\'b5 "\'b8cs\'ac" \'eb Angi\'aari, "habu" \'eb Tuynidi v\'b5 Mar\'e8c.
\par Ch\'d5 \'ae\'e9 thu\'e9c \'ae\'dea c\'f1a Ph\'b8p \'ae\'b7 ph\'b8 v\'ec t\'ddnh t\'cbp th\'d3 c\'f1a d\'a9n b\'b6n x\'f8 v\'b5 thay v\'b5o \'ae\'e3 b\'bbng s\'f9 c\'ad\'edp \'aeo\'b9t tr\'beng tr\'een.
\par Ti\'d5p theo b\'b9o l\'f9c v\'b5 t\'b5n ph\'b8 th\'ad\'eang m\'eb \'ae\'c7u cu\'e9c x\'a9m l\'ad\'eec, nh\'f7ng ng\'ad\'eai n\'abng d\'a9n B\'bec Phi b\'bet \'ae\'c7u th\'cay m\'d7nh b\'de nh\'f7ng k\'ce du \'ae\'b7ng, phi\'aau l\'adu v\'b5 cho vay n\'c6
ng l\'b7i, t\'e3m l\'b9i, l\'b5 to\'b5n b\'e9 c\'c6n b\'b7 c\'f1a ch\'ddnh qu\'e8c ti\'d5n c\'abng. B\'e4n th\'f9c d\'a9n, r\'e8t cu\'e9c l\'b5 k\'ce chi\'d5n th\'beng v\'b5 nh\'f7ng ng\'ad\'eai d\'a9n b\'b6n x\'f8 ph\'b6i ngoan ngo\'b7n ph\'f4c t\'ef
ng ch\'f3ng v\'b5 nh\'ad\'eang \'ae\'cat cho ch\'f3ng.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 N\'a8m 1848, Angi\'aari l\'c7n \'ae\'c7u ti\'aan ch\'deu s\'f8c \'d0p c\'f1a cu\'e9c ti\'d5n c\'abng ki\'d3u \'cay c\'f1
a nh\'f7ng k\'ce \'aei khai ho\'b8. \'a7\'e3 l\'b5 13.500 k\'ce kh\'e8n c\'efng \'ae\'b7 \'aee do\'b9 th\'b5nh ph\'e8 Pari v\'b5 nh\'f7ng ng\'ad\'eai m\'b5 c\'b8c x\'ad\'ebng m\'b8y th\'f1 \'ae\'ab kh\'abng ch\'f8a n\'e6i. Ngo\'b5i chi ph\'dd \'aei \'ae
\'ad\'eang v\'b5 n\'aci c\'ad tr\'f3 kh\'abng m\'cat ti\'d2n, h\'e4 c\'dfn \'ae\'ad\'eec nh\'cbn gia s\'f3c, ti\'d2n \'f8ng tr\'ad\'edc, h\'b9t gi\'e8ng, c\'abng c\'f4 lao \'ae\'e9ng v\'b5 t\'f5 4 \'ae\'d5n 12 h\'d0cta \'ae\'cat l\'cay c\'f1a nh\'f7ng ng
\'ad\'eai n\'abng d\'a9n Angi\'aari.
\par Sau n\'a8m 1870, nh\'f7ng ng\'ad\'eai And\'b8tx\'ac di c\'ad c\'f2ng \'ae\'e3ng vai tr\'df th\'f9c d\'a9n \'ae\'e3. T\'cat nhi\'aan, h\'e4 \'ae\'b8ng \'ae\'ad\'eec tr\'e4ng th\'de h\'acn nh\'f7ng ng\'ad\'eai \'ae\'c7u ti\'aan, nh\'adng h\'e4 c\'f2ng kh
\'abng k\'d0m nguy hi\'d3m h\'acn \'ae\'e8i v\'edi n\'abng d\'a9n b\'b6n x\'f8, v\'d7 to\'b5n b\'e9 ru\'e9ng \'ae\'cat m\'b5 h\'e4 \'ae\'ad\'eec chia l\'b5 l\'cay c\'f1a n\'abng d\'a9n \'ae\'dea ph\'ad\'acng. Ti\'d5p theo \'ae\'e3, ng\'b5y c\'b5ng nhi\'d2
u b\'e4n th\'f9c d\'a9n tham lam, l\'aan \'ae\'ad\'eang \'aei t\'d7m h\'b9nh ph\'f3c tr\'aan s\'f9 ph\'b8 s\'b6n c\'f1a nh\'f7ng ng\'ad\'eai Ar\'cbp.
\par D\'a9n thu\'e9c \'ae\'dea b\'de ph\'b8 s\'b6n b\'bbng nhi\'d2u c\'b8ch: do "lu\'cbt ph\'b8p" h\'b5nh ch\'ddnh c\'f1a Ch\'ddnh ph\'f1 b\'b6o h\'e9, do nh\'f7ng h\'b5nh \'ae\'e9ng c\'b8 nh\'a9n c\'f1a b\'e4n \'ae\'dea ch\'f1 v\'b5 ho\'b9t \'ae\'e9ng c\'f1
a nh\'f7ng nh\'e3m ng\'ad\'eai b\'b6n x\'f8 \'ae\'b7 tr\'eb th\'b5nh 
\par }\pard \qj \li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 ch\'e7 d\'f9a c\'f1a ch\'d5 \'ae\'e9 thu\'e9c \'ae\'dea.
\par }\pard \qj \fi397\li0\ri0\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ch\'d8 ri\'aang \'eb Angi\'aari v\'b5 Tuynidi, ch\'d5 \'ae\'e9 thu\'e9c \'ae\'dea ch\'ddnh th\'f8c \'ae\'b7 l\'cay c\'bep c
\'f1a n\'abng d\'a9n b\'b6n x\'f8 kho\'b6ng: 1 tri\'d6u 600 ngh\'d7n h\'d0cta \'ae\'cat nguy\'aan c\'f1a n\'abng d\'a9n s\'f6 d\'f4ng, 2 tri\'d6u 700 ngh\'d7n h\'d0cta r\'f5ng c\'abng, 800 ngh\'d7n h\'d0cta \'ae\'cat c\'abng.
\par N\'ad\'edc Mar\'e8c m\'edi b\'de chia c\'bet kh\'abng l\'a9u, \'ae\'b7 b\'de c\'ad\'edp 545 ngh\'d7n h\'d0cta ru\'e9ng \'ae\'cat.
\par S\'f9 c\'ad\'edp \'aeo\'b9t nh\'f7ng ng\'ad\'eai b\'b6n x\'f8 di\'d4n ra nhanh \'ae\'d5n ch\'e3ng m\'c6t v\'b5 v\'edi nh\'f7ng quy m\'ab kh\'f1ng khi\'d5p.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 N\'a8m 1870, 500 ngh\'d7n h\'d0cta \'ae\'cat c\'f1a d\'a9n thu\'e9c \'ae\'dea b\'de t\'dech thu c\'efng m\'e9t l\'f3c. T
\'f5 n\'a8m 1895 \'ae\'d5n 1910, 192 ngh\'d7n h\'d0cta \'ae\'cat c\'f1a Angi\'aari chuy\'d3n sang tay ng\'ad\'eai Ph\'b8p. T\'f5 1919 \'ae\'d5n 1923, ch\'d5 \'ae\'e9 thu\'e9c \'ae\'dea \'ae\'b7 chi\'d5m c\'f1a d\'a9n Mar\'e8c 72.700 h\'d0cta.
\par }{\f37\fs20\expnd0\expndtw-4\insrsid1378858\charrsid7745866 \'a7\'d3 chi\'d5m \'ae\'cat, ch\'d5 \'ae\'e9 thu\'e9c \'ae\'dea Ph\'b8p l\'f3c th\'d7 s\'f6 d\'f4ng m\'b8nh kho\'d0, l\'f3c th\'d7 d\'efng v\'f2 l\'f9c. Ng\'ad\'eai B\'d0cbe v\'b5 ng\'ad\'eai Ar
\'cbp Angi\'aari b\'de d\'e5n t\'edi}{\f37\fs20\insrsid1378858\charrsid7745866 
\par }\pard\plain \s15\qj \li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd0\expndtw-4\insrsid1378858 r\'efng n\'f3i v\'b5 tri\'d2n \'ae\'e5i. V\'b5 l
\'b7nh th\'e6 \'ae\'ad\'eec t\'ad\'edc \'aeo\'b9t ki\'d3u \'cay kh\'e1i nh\'f7ng ng\'ad\'eai ch\'f1 h\'eep ph\'b8p, r\'aci v\'b5o tay nh\'f7ng t\'aan th\'f9c d\'a9n ch\'a9u \'a2u.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \'a7\'e8i v\'edi ng\'ad\'eai Tuynidi, ng\'ad\'eai ta th
\'ad\'eang s\'f6 d\'f4ng nh\'f7ng m\'b8nh kho\'d0 ki\'d3u nh\'ad sau: 25 khu ru\'e9ng c\'f1a ng\'ad\'eai Tuynidi l\'b5m th\'b5nh m\'e9t habu t\'cbp th\'d3. Nh\'f7ng ng\'ad\'eai n\'abng d\'a9n canh t\'b8c \'ae\'cat \'aeai \'cay \'ae\'ad\'eec h\'ad\'ebng m
\'e9t ph\'c7n m\'efa m\'b5ng, ph\'c7n kh\'b8c d\'b5nh cho ph\'f3c l\'eei x\'b7 h\'e9i, gi\'b8o d\'f4c, x\'a9y nh\'b5, ph\'ad\'acng ti\'d6n th\'abng tin v\'b5 nh\'f7ng x\'dd nghi\'d6p c\'e3 \'fd ngh\'dca t\'cbp th\'d3 kh\'b8c nhau.
\par Habu t\'cbp th\'d3 kh\'abng th\'d3 \'ae\'ad\'eec s\'f6 d\'f4ng cho c\'b8 nh\'a9n, nh\'adng c\'e3 th\'d3 \'ae\'ad\'eec chuy\'d3n t\'f5 m\'e9t x\'dd nghi\'d6p t\'cbp th\'d3 sang x\'dd nghi\'d6p kh\'b8c, v\'d7 \'ae\'e3 l\'b5 do l\'eei \'ddch c\'abng c\'e9
ng. V\'d2 sau Ph\'f1 to\'b5n quy\'d2n c\'f8 l\'cay c\'ed d\'efng cho l\'eei \'ddch c\'abng c\'e9ng m\'e7i khi c\'c7n l\'cay \'ae\'cat c\'f1a ng\'ad\'eai b\'b6n x\'f8 cho b\'e4n ch\'f1 \'ae\'e5n \'aei\'d2n. M\'e9t th\'dd d\'f4: m\'e9t nh\'b5 b\'b8o v\'b5
 ch\'f1 \'ae\'e5n \'aei\'d2n, khi th\'cay ng\'ad\'eai d\'a9n b\'b6n x\'f8 t\'f5 ch\'e8i b\'b8n \'ae\'cat cho h\'ben, m\'b5 h\'ben l\'b9i mu\'e8n mua cho m\'d7nh, li\'d2n \'ae\'d5n nh\'ea b\'b9n - l\'b5 vi\'aan c\'abng s\'f8 t\'d8nh \'cay. T\'aan n\'b5y li
\'d2n ra ngay m\'e9t s\'bec l\'d6nh tr\'adng thu \'ae\'cat \'cay cho l\'eei \'ddch c\'abng c\'e9ng, \'aeu\'e6i ng\'ad\'eai d\'a9n b\'b6n x\'f8 ra kh\'e1i m\'b6nh \'ae\'cat \'cay v\'b5 chuy\'d3n cho ng\'ad\'eai b\'b9n c\'f1a m\'d7nh.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Ch\'d5 \'ae\'e9 thu\'e9c \'ae\'dea \'cay \'aeem l\'b9i l
\'eei \'ddch g\'d7 cho nh\'f7ng ng\'ad\'eai n\'abng d\'a9n ngh\'cco Ph\'b8p? Kh\'abng! Ch\'d8 c\'e3 nh\'f7ng t\'aan ch\'ddnh kh\'b8ch b\'c8n th\'d8u, nh\'f7ng b\'e4n con bu\'abn tham lam v\'b5 t\'ad b\'b6n l\'edn \'ae\'ad\'eec l\'eei m\'b5 th\'abi.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Nh\'f7ng c\'abng ty \'ae\'e5n \'aei\'d2n l\'edn chi\'d5
m nh\'f7ng khu \'ae\'cat \'aeai m\'aanh m\'abng, kh\'abng ph\'b6i nh\'bbm l\'b5m cho n\'e3 s\'b6n sinh, m\'b5 ch\'d8 v\'edi m\'f4c ti\'aau \'ae\'c7u c\'ac. Ng\'b5y l\'b9i ng\'b5y, ch\'f3ng l\'b5m cho d\'a9n b\'b6n x\'f8 ph\'b8 s\'b6n, nu\'e8t t\'ad\'ac
i nh\'f7ng t\'aan th\'f9c d\'a9n nh\'e1 v\'b5 \'ae\'b8nh l\'f5a ngay c\'b6 Ch\'ddnh ph\'f1. Th\'dd d\'f4: C\'abng ty Gi\'acnev\'ac chi\'d5m h\'acn 20.000 h\'d0cta; c\'abng ty Habra v\'b5 M\'b8ct\'ac: 24.000 h\'d0cta; c\'abng ty Ph\'b8p - Angi\'aa
ri: 90.000 h\'d0cta; c\'abng ty to\'b5n Angi\'aari: 10.000 h\'d0cta; c\'abng ty M\'b8cx\'a9y: 100.000 h\'d0cta.
\par }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  Tuynidi, 55 ch\'f1 \'ae\'e5n \'aei\'d2n Ph\'b8p chi\'d5m 355.000 h\'d0cta \'ae\'cat, 30 ch\'f1 \'ae\'e5n \'aei\'d2n kh\'b8c chi\'d5m 160.000 h\'d0cta r\'f5ng.
\par C\'abng ty th\'ad\'acng m\'b9i \'aei\'d2n \'ae\'dea chi\'d5m ph\'c7n l\'edn \'ae\'cat mi\'d2n Cadablanca, Rab\'b8t v\'b5 Madagan. Ti\'d5p theo l\'b5 T\'e6ng c\'abng ty Ph\'b8p \'eb Mar\'e8c. C\'abng ty n\'b5y mua c\'f1a d\'a9n b\'b6n x\'f8 m\'e7i h\'d0
cta gi\'b8 t\'f5 20 \'ae\'d5n 30 phr\'a8ng v\'b5 sau m\'e9t th\'eai gian ng\'ben b\'b8n l\'b9i v\'edi gi\'b8 1.000 v\'b5 1.200 phr\'a8ng trong m\'e9t v\'b5i th\'b8ng l\'b7i t\'edi 858.000 phr\'a8ng m\'b5 l\'f3c \'ae\'c7u s\'e8 v\'e8n l\'b5 1 tri\'d6u v
\'b5 m\'edi ch\'d8 s\'f6 d\'f4ng m\'e9t ph\'c7n t\'ad s\'e8 v\'e8n \'ae\'e3.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 M\'e9t ngh\'de s\'dc Qu\'e8c h\'e9i Ph\'b8p \'ae\'ad\'ee
c nh\'ad\'eeng m\'e1 qu\'c6ng s\'bet \'eb Khamri. \'a4ng ta b\'b8n l\'b9i cho m\'e9t c\'abng ty \'ae\'d3 khai th\'b8c v\'edi gi\'b8 10 tri\'d6u phr\'a8ng. Nh\'f7ng ng\'ad\'eai n\'abng d\'a9n b\'b6n x\'f8 c\'e3 \'ae\'cat \'aeai thu\'e9c khu m\'e1 \'cay, ch
\'d8 \'ae\'ad\'eec l\'dcnh 112,5 phr\'a8ng m\'e9t n\'a8m ti\'d2n cho thu\'aa \'ae\'cat.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 M\'e9t lu\'cbt s\'ad Ph\'b8p giao cho nh\'a9n vi\'aan c
\'f1a m\'d7nh mua \'ae\'cat \'ae\'d3 l\'b5m t\'b5i s\'b6n ri\'aang v\'edi gi\'b8 20 phr\'a8ng. \'a7\'cat \'cay n\'bbm gi\'f7a habu c\'abng c\'e9ng. Bi\'d5t r\'bbng \'ae\'cat \'aeai \'eb \'ae\'e3 kh\'abng c\'e3 ranh gi\'edi r\'e2 r\'d6t, ng\'ad\'eai ph\'f4
c v\'f4 ph\'b8p lu\'cbt c\'f1a ch\'f3ng g\'a9y ra nh\'f7ng chuy\'d6n kh\'e3 kh\'a8n v\'b5 l\'abi cu\'e8n nh\'f7ng ng\'ad\'eai n\'abng d\'a9n v\'b5o qu\'b8 tr\'d7nh ki\'d6n t\'f4ng r\'cat t\'e8n k\'d0m v\'d2 ph\'a9n \'ae\'denh ranh gi\'edi. \'a7\'bet \'ae
\'d5n n\'e7i nh\'f7ng ng\'ad\'eai n\'abng d\'a9n ngh\'cco cu\'e8i c\'efng ph\'b6i b\'b8n l\'b9i \'ae\'cat c\'f1a m\'d7nh v\'d7 vi\'d6c ki\'d6n t\'f4ng \'ae\'b7 l\'b5m t\'e8n 11.000 phr\'a8ng. \'a4ng lu\'cbt s\'ad v\'edi s\'f9 gi\'f3p \'ae\'ec c\'f1a hai m
\'ad\'aci phr\'a8ng v\'b5 m\'e9t ch\'f3t gi\'b6 d\'e8i, tr\'eb th\'b5nh ng\'ad\'eai ch\'f1 c\'b6 m\'e9t l\'b5ng, v\'b5 nh\'f7ng ng\'ad\'eai n\'abng d\'a9n c\'dfn c\'b6m th\'cay h\'b9nh ph\'f3c, v\'d7 kh\'abng b\'de \'aeu\'e6i kh\'e1i m\'b6nh \'ae\'cat 
\'cay v\'b5 \'ae\'ad\'eec \'ae\'d3 l\'b9i l\'b5m vi\'d6c v\'edi t\'ad c\'b8ch l\'b5 ng\'ad\'eai n\'ab l\'d6.
\par Nh\'f7ng tr\'ad\'eang h\'eep t\'ad\'acng t\'f9 nh\'ad v\'cby th\'ad\'eang th\'cay \'eb c\'b8c thu\'e9c \'ae\'dea v\'b5 ch\'f3ng t\'abi c\'dfn c\'e3 th\'d3 \'ae\'ada ra nhi\'d2u th\'dd d\'f4 n\'f7a, kh\'abng k\'d0m ph\'c7n b\'aa b\'e8i.
\par Nh\'f7ng t\'aan \'ae\'dea ch\'f1 bi\'d5t r\'e2 l\'b5, d\'a9n b\'b6n x\'f8 lu\'abn lu\'abn lo s\'ee b\'de tr\'adng thu. V\'d7 v\'cby, khi n\'b5o h\'e4 mu\'e8n chi\'d5m \'ae\'cat, h\'e4 s\'f6 d\'f4ng lu\'cbt v\'d2 tr\'adng thu nh\'ad m\'e9t con ngo\'b8o 
\'e9p. D\'a9n b\'b6n x\'f8 t\'cat nhi\'aan mu\'e8n b\'b8n \'ae\'cat c\'f1a m\'d7nh v\'edi gi\'b8 r\'ce m\'b9t, c\'dfn h\'acn l\'b5 \'ae\'d3 cho ch\'ddnh quy\'d2n h\'b5nh ch\'ddnh b\'e7ng ch\'e8c l\'b5m m\'d7nh ph\'b8 s\'b6n.
\par B\'e4n \'ae\'dea ch\'f1 th\'d8nh tho\'b6ng d\'efng "c\'b8c \'aei\'d3m chi\'d5n l\'ad\'eec". Ch\'f3ng \'ae\'c6t tay v\'b5o nh\'f7ng n\'aci c\'e3 th\'d3 x\'a9y d\'f9ng c\'b8c c\'abng tr\'d7nh Nh\'b5 n\'ad\'edc: nh\'b5 ga, \'ae\'ad\'eang s\'b8, kho t\'b5ng v
\'b5 ch\'ee. Khi ch\'ddnh quy\'d2n mu\'e8n x\'a9y d\'f9ng m\'e9t trong nh\'f7ng c\'abng tr\'d7nh \'cay, n\'e3 ph\'b6i tr\'b6 to\'b5n b\'bbng v\'b5ng, v\'d7 n\'e3 c\'e3 th\'d3 tr\'adng thu v\'b5 \'aeu\'e6i d\'a9n b\'b6n x\'f8, nh\'adng kh\'abng d\'b8m s
\'ea \'ae\'d5n s\'eb h\'f7u c\'f1a b\'e4n th\'f9c d\'a9n.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 V\'b5 nh\'ad v\'cby, b\'e4n \'ae\'c7u c\'ac v\'ac v\'d0t c\'b6 hai tay.
\par T\'d7nh c\'b6nh n\'abng d\'a9n c\'b8c thu\'e9c \'ae\'dea \'ae\'e3 nh\'ad th\'d5 n\'b5o? Th\'cbt l\'b5 kh\'f1ng khi\'d5p. Kh\'e3 c\'e3 th\'d3 n\'e3i \'ae\'ad\'eec r\'bbng ai trong s\'e8 h\'e4: ng\'ad\'eai An Nam \'eb \'a7\'abng D\'ad\'acng, ng\'ad\'eai da 
\'aeen \'eb C\'abngg\'ab hay l\'b5 X\'aan\'aagan, hay l\'b5 ng\'ad\'eai b\'b6n x\'f8 \'eb B\'bec Phi - b\'de b\'e3c l\'e9t nhi\'d2u h\'acn.
\par Gi\'f7a nh\'f7ng ng\'ad\'eai \'cay c\'e3 m\'e9t c\'b8i chung:
\par 1- T\'cat c\'b6 h\'e4 b\'de d\'e5n \'ae\'d5n t\'d7nh c\'b6nh con v\'cbt th\'e5.
\par 2- H\'e4 kh\'abng ch\'d8 b\'de nh\'f7ng k\'ce chi\'d5n th\'beng b\'e3c l\'e9t, m\'b5 c\'dfn b\'de nh\'f7ng ng\'ad\'eai b\'b6n x\'f8 b\'e3c l\'e9t n\'f7a: nh\'f7ng k\'ce ch\'aci tr\'e9i, nh\'f7ng t\'aan k\'ce c\'ad\'edp m\'b5 n\'d5u thi\'d5u nh\'f7ng k\'ce
 n\'b5y th\'d7 kh\'abng th\'d3 c\'e3 s\'f9 \'ae\'ab h\'e9 n\'b5o c\'f1a n\'ad\'edc ngo\'b5i.
\par C\'b8c vi\'aan ch\'f8c, quan l\'b9i, b\'e4n t\'ad s\'b6n m\'edi v\'b5 b\'e4n ng\'ad\'eai b\'b6n x\'f8 cho vay n\'c6ng l\'b7i k\'d5t th\'f3c c\'abng vi\'d6c \'a8n c\'ad\'edp c\'f1a b\'e4n ng\'ad\'eai da tr\'beng, v\'b5 n\'abng d\'a9n n\'d5u tho\'b8t \'ae
\'ad\'eec \'b8ch b\'e4n n\'b5y th\'d7 l\'b9i r\'aci v\'b5o tay b\'e4n kh\'b8c.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'de \'aeu\'e6i kh\'e1i nh\'f7ng \'ae\'e5ng ru\'e9ng \'ae
\'ad\'eec t\'ad\'edi n\'ad\'edc tr\'ef ph\'f3, s\'e8ng chen ch\'f3c \'eb nh\'f7ng \'ae\'e5ng b\'bbng ch\'cbt ch\'e9i v\'b5 nh\'f7ng v\'efng r\'f5ng n\'f3i x\'ac x\'b8c, n\'abng d\'a9n nh\'f7ng thu\'e9c \'ae\'dea \'ae\'e3 s\'e8ng trong c\'b6nh kh\'e8n c
\'efng gh\'aa g\'edm. Nh\'f7ng ng\'ad\'eai n\'b5o trong s\'e8 h\'e4 c\'dfn l\'b9i m\'e9t m\'c8u \'ae\'cat con n\'b5o th\'d7 c\'f2ng nhanh ch\'e3ng b\'de t\'ad\'edc \'aeo\'b9t l\'a9u d\'b5i. T\'fb su\'cat cho vay b\'bbng ti\'d2n c\'f2ng nh\'ad b\'bbng hi
\'d6n v\'cbt c\'e3 t\'ddnh \'a8n c\'ad\'edp kh\'abng th\'d3 t\'ad\'ebng t\'ad\'eeng \'ae\'ad\'eec: t\'f5 20 \'ae\'d5n 200% (ng\'ad\'eai ch\'a9u \'a2u cho vay l\'cay l\'b7i 20%, ng\'ad\'eai Do Th\'b8i 35%, ng\'ad\'eai Kabin 75%, ng\'ad\'eai M\'abdab\'dd
t 80% v\'b5 \'eb n\'aci h\'ceo l\'b8nh t\'edi 200%). Ki\'d3u \'a8n c\'ad\'edp \'ae\'e3 g\'e4i l\'b5 ranhia. Do t\'fb su\'cat l\'b7i qu\'b8 cao, ng\'ad\'eai n\'abng d\'a9n kh\'abng bao gi\'ea tr\'b6 xong n\'ee. L\'f3c \'ae\'e3, ng\'ad\'eai cho vay l\'b7i 
\'ae\'d5n chi\'d5m ru\'e9ng v\'b5 tr\'eb th\'b5nh cam\'d0tx\'b8t, c\'dfn ng\'ad\'eai ch\'f1 c\'f2 th\'b5nh cam\'d0t. Cam\'d0t ti\'d5p t\'f4c c\'b5y c\'cay m\'b6nh \'ae\'cat c\'f1a m\'d7nh, nh\'adng ph\'b6i n\'e9p ng\'ad\'eai ch\'f1 m\'edi b\'e8n ph\'c7n n
\'a8m m\'efa m\'b5ng.
\par T\'d6 c\'ad\'edp b\'e3c thu\'e9c \'ae\'dea l\'b5m t\'cat c\'b6 m\'e4i th\'f8 \'ae\'d3 l\'b5m cho ng\'ad\'eai n\'abng d\'a9n kh\'abng th\'d3 s\'e8ng n\'e6i. L\'cay c\'ed l\'cbp t\'ddn d\'f4ng n\'abng nghi\'d6p, }{\expnd0\expndtw-2\insrsid1378858 th\'cbt s
\'f9 ch\'d8 ph\'f4c v\'f4 b\'e4n gi\'b5u c\'e3, b\'f4ng ph\'d6, ch\'ddnh quy\'d2n l\'b9i c\'dfn \'ae\'c6t th\'aam m\'f8c ph\'f4 thu 10% \'ae\'e8i v\'edi ng\'ad\'eai vay ti\'d2n, ri\'aang kh\'abng c\'e3 kho\'b6n \'ae\'e3 m\'f8c vay l\'b7i \'ae\'b7 qu\'b8 n
\'c6ng. R\'f5ng l\'b5 s\'eb h\'f7u c\'f1a Nh\'b5 n\'ad\'edc v\'b5 nh\'f7ng ng\'ad\'eai \'ae\'e8n c\'f1i b\'de d\'e5n v\'b5o c\'b6nh ch\'d5t \'ae\'e3i. Nh\'f7ng ng\'ad\'eai ch\'a8n nu\'abi kh\'abng c\'e3 \'ae\'e5ng c\'e1, bu\'e9c ph\'b6i b\'b8n gia s\'f3c 
\'aei v\'b5 ho\'b5n to\'b5n ph\'b8 s\'b6n. Vi\'d6c ch\'a8n nu\'abi b\'de \'ae\'b8nh thu\'d5, m\'e7i \'ae\'c7u con v\'cbt ch\'a8n nu\'abi c\'f1a ng\'ad\'eai d\'a9n b\'b6n x\'f8 ph\'b6i n\'e9p thu\'d5 n\'f6a phr\'a8ng \'ae\'d5n m\'e9t phr\'a8ng Ph\'b8p.}{
\insrsid1378858 
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Nh\'f7ng ng\'ad\'eai d\'a9n mi\'d2n n\'f3i, b\'de c\'b8
c dinh c\'ac Nh\'b5 n\'ad\'edc v\'a9y quanh, m\'b5 ranh gi\'edi th\'d7 r\'cat tu\'fa ti\'d6n, s\'e8ng ngh\'d1t th\'eb. N\'d5u trong r\'f5ng tr\'ce con \'aei tr\'aan \'ae\'ad\'eang s\'bet ho\'c6c con c\'f5u ch\'b9y qua ranh gi\'edi l\'b5 l\'cbp t\'f8c b
\'de l\'abi th\'abi v\'b5 b\'de n\'e9p ph\'b9t. N\'a8m 1909, \'eb Angi\'aari c\'e3 28.527 v\'f4 ph\'b9t x\'a9m ph\'b9m r\'f5ng, trong \'ae\'e3 c\'e3 13.451 v\'f4 l\'cay c\'e1 v\'b5 7.098 v\'f4 l\'cay g\'e7. N\'a8m 1910, ng\'ad\'eai Angi\'aari n\'e9
p 540.000 phr\'a8ng ti\'d2n ph\'b9t v\'d7 nh\'f7ng vi\'d6c \'ae\'e3.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Ch\'ada h\'d5t. Ng\'ad\'eai n\'abng d\'a9n B\'bec Phi c\'df
n ph\'b6i \'aei canh g\'b8c r\'f5ng 
\par cho ch\'f1 \'ae\'e5n \'aei\'d2n, di\'d6t ch\'a9u ch\'cau tr\'aan \'ae\'e5ng ru\'e9ng c\'f1a ng\'ad\'eai ch\'a9u \'a2u, khu\'a9n v\'b8c kh\'abng c\'abng cho b\'e4n quan l\'b9i, c\'abng ch\'f8c, l\'b5m ngh\'dca v\'f4 c\'b6nh s\'b8t \'ae\'d3 b\'b6o v\'d6 nh
\'f7ng b\'cat \'ae\'e9ng s\'b6n c\'f1a b\'e4n b\'e3c l\'e9t v\'b5 \'b8p b\'f8c.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 B\'de t\'d6 cho vay n\'c6ng l\'b7i \'ae\'cc n\'d0n; b\'de
 nh\'f7ng t\'d6 n\'b9n x\'b7 h\'e9i l\'b5m ki\'d6t s\'f8c: n\'a8m 1907, \'eb th\'b5nh ph\'e8 Cadablanca ch\'d8 c\'e3 s\'b8u qu\'b8n r\'ad\'eeu, n\'a8m 1913 c\'e3 161 qu\'b8n r\'ad\'eeu, nh\'b5 c\'b6i t\'b9o, b\'d6nh giang mai, b\'d6nh ho lao c\'f2ng ph
\'b8t tri\'d3n nh\'ad th\'d5; b\'de ki\'d6t qu\'d6 v\'d7 n\'b9n kh\'e6 sai li\'aan mi\'aan; b\'de n\'b9n \'ae\'e3i th\'ad\'eang xuy\'aan l\'b5m m\'cat s\'f8c, c\'b8c b\'b9n B\'bec Phi \'aeang \'eb tr\'aan con \'ae\'ad\'eang ng\'bec ngo\'b6i. N\'b9n t\'f6
 vong cao l\'b5 m\'e9t b\'bbng ch\'f8ng. Ng\'ad\'eai B\'bec Phi s\'cf bi\'d5n kh\'e1i m\'c6t \'ae\'cat, n\'d5u giai c\'cap v\'ab s\'b6n gi\'b8c ng\'e9 kh\'abng \'ae\'d5n c\'f8u h\'e4 kh\'e1i n\'d2n "v\'a8n minh" qu\'b8i v\'cbt.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nguy\'d4n \'b8i Qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'b9p ch\'dd }{\i\insrsid1378858 Qu\'e8c t\'d5 n\'abng d\'a9n,}{
\insrsid1378858 
\par ti\'d5ng Nga, s\'e8 3 v\'b5 4 n\'a8m 1924.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 S\'f9 PH\'b8 S\'b6N C\'f1A CH\'d5 \'a7\'e9\line TH\'f9
C D\'a2N PH\'b8P
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-294\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Vi\'d6c thay \'ae\'e6i m\'edi \'ae\'a9y c\'f1a ch\'ddnh ph
\'f1 Po\'a8ngcar\'aa \'ae\'b7 kh\'abng kh\'e1i c\'e3 nh\'f7ng vang d\'e9i sang c\'b8c thu\'e9c \'ae\'dea. N\'ad\'edc Ph\'b8p lu\'abn lu\'abn t\'f9 cho m\'d7nh l\'b5 m\'e9t c\'ad\'eang qu\'e8c th\'f9c d\'a9n }{\i\f37\fs20\insrsid1378858 s\'e8 m\'e9t bi\'d5
t c\'b8ch th\'f9c d\'a9n}{\f37\fs20\insrsid1378858 . Ngay c\'b6 \'abng Anbe Xar\'ab c\'f2ng v\'cby, \'abng ta lu\'abn lu\'abn khoe m\'d7nh l\'b5 ng\'ad\'eai Ph\'b8p }{\i\f37\fs20\insrsid1378858 s\'e8 m\'e9t}{\f37\fs20\insrsid1378858  bi\'d5t c\'b8
ch khai th\'b8c thu\'e9c \'ae\'dea. \'a7\'d3 l\'b5m c\'abng vi\'d6c khai th\'b8c \'cay, \'abng ta \'ae\'dfi ph\'b6i c\'e3 4 t\'fb phr\'a8ng. \'a7\'d3 t\'d7m cho ra m\'e3n ti\'d2n \'cay, \'abng ta \'ae\'b7 vi\'d5t m\'e9t cu\'e8n s\'b8ch d\'b5y nh\'f7ng
 674 trang. }{\f38\fs20\insrsid1378858 \'ca}{\f37\fs20\insrsid1378858 y th\'d5 m\'b5 v\'de b\'e9 tr\'ad\'ebng v\'dc \'ae\'b9i \'cay l\'b9i v\'f5a b\'de \'aeu\'e6i ra kh\'e1i \'ae\'b6ng c\'f1a \'abng ta v\'d7 \'abng ta \'ae\'b7 b\'e1 phi\'d5u cho quan th
\'c7y l\'b5 Po\'a8ngcar\'aa. R\'e5i c\'b8i \'abng Po\'a8ngcar\'aa b\'b9c b\'cfo n\'b5y c\'f2ng l\'b9i v\'f5a m\'edi \'aeu\'e6i v\'de b\'e9 tr\'ad\'ebng v\'dc \'ae\'b9i \'cay ra kh\'e1i ch\'ddnh ph\'f1 n\'e8t. Th\'d5 l\'b5 v\'de b\'e9 tr\'ad\'ebng v\'dc 
\'ae\'b9i \'cay b\'de c\'b8ch tu\'e9t h\'d5t c\'b6, ch\'bcng \'ae\'ad\'eec m\'e9t t\'fd n\'b5o, c\'f2ng ch\'bcng khai th\'b8c \'ae\'ad\'eec thu\'e9c \'ae\'dea n\'b5o c\'f1a \'abng ta. Thay th\'d5 \'abng ta l\'b5 m\'e9t anh l\'ddnh, xin l\'e7i, m\'e9t "
\'ae\'b9i t\'b8 kh\'abng t\'aan tu\'e6i". Vi\'d6c c\'b8ch ch\'f8c n\'b5y m\'e9t l\'c7n n\'f7a l\'b9i ch\'f8ng t\'e1 cho ch\'f3ng ta th\'cay r\'bbng ch\'d5 \'ae\'e9 th\'f9c d\'a9n Ph\'b8p \'ae\'b7 ph\'b8 s\'b6n.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-294\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Trong khi ch\'ea \'ae\'eei m\'e9t c\'b8i g\'d7 t\'e8t \'ae
\'d1p h\'acn, d\'a9n Ph\'b8p m\'e7i n\'a8m ph\'b6i n\'e9p h\'acn 237.000.000 phr\'a8ng (ng\'a9n s\'b8ch n\'a8m 1923) cho B\'e9 Thu\'e9c \'ae\'dea c\'f1a h\'e4, h\'acn 1.172.186.000 cho c\'b8c \'ae\'e9i qu\'a9n thu\'e9c \'ae\'dea v\'b5 nh\'f7ng kho\'b6
n chi ph\'dd \'eb Mar\'e8c, t\'e6ng c\'e9ng l\'b5 1.409.186.000 phr\'a8ng.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-294\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Th\'d5 l\'b5 m\'e7i ng\'ad\'eai Ph\'b8p - b\'cat lu\'cb
n gi\'b5u hay ngh\'cco, gi\'b5 hay tr\'ce, nam hay n\'f7 - \'ae\'d2u b\'de b\'bet bu\'e9c m\'e7i n\'a8m ph\'b6i \'ae\'e3ng h\'acn 36 phr\'a8ng cho c\'b8i qu\'fc "S\'f8 m\'d6nh khai ho\'b8". \'a7\'d3 l\'b5m l\'eei cho ai? C\'e8 nhi\'aan kh\'abng ph\'b6i l
\'b5 \'ae\'d3 l\'b5m l\'eei cho ng\'ad\'eai \'ae\'e3ng thu\'d5 v\'b5 c\'b5ng kh\'abng ph\'b6i l\'b5 l\'b5m l\'eei cho n\'ad\'edc Ph\'b8p. L\'b8t n\'f7a, ch\'f3ng t\'abi xin ch\'f8ng minh \'aei\'d2u \'ae\'e3.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Th\'dd d\'f4, n\'a8m 1922, t\'e6ng gi\'b8 tr\'de th\'ad\'acng nghi\'d6p c\'f1a c\'b8c thu\'e9c \'ae\'dea Ph\'b8p l\'b5
 4.358.105.000 phr\'a8ng, trong \'ae\'e3:
