\par }{\insrsid1378858 \cell }\pard\plain \ql \li0\ri0\widctlpar\intbl\aspalpha\aspnum\faauto\adjustright\rin0\lin0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \trowd \lastrow \ts11\trleft0\trftsWidth1 \clvertalt\clbrdrt
