\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'a2M \'a7\'deA TH\'f9C D\'a2N
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 M\'e9t ngh\'de s\'dc Ph\'b8p \'ae\'b7 n\'e3
i v\'d2 Angi\'aari: "}{\f38\fs20\cgrid0\insrsid1378858 \'eb}{\f37\fs20\cgrid0\insrsid1378858  tr\'aan th\'d5 gi\'edi, kh\'abng c\'e3 d\'a9n t\'e9c chi\'d5n b\'b9i n\'b5o b\'de k\'ce chi\'d5n th\'beng ng\'ad\'eec \'ae\'b7i h\'b5nh h\'b9 b\'bbng d\'a9n t
\'e9c thu\'e9c \'ae\'dea !". \'a7i\'d2u \'cay \'ae\'f3ng v\'edi ng\'ad\'eai "Bic\'ab"}{\cs17\f37\fs20\super\cgrid0\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0
\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 1) Ngh\'dca l\'b5 con d\'aa con (b\'e4n th\'f9c d\'a9n d\'efng \'ae\'d3 g\'e4i m\'e9t c\'b8ch khinh mi\'d6t
 ng\'ad\'eai Angi\'aari).}})}{\f37\fs20\cgrid0\insrsid1378858  \'eb Angi\'aari v\'b5 c\'f2ng \'ae\'f3ng v\'edi ng\'ad\'eai "Nh\'b5 qu\'aa"}{\cs17\f37\fs20\super\cgrid0\insrsid1378858 2{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0
\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 2) Hai ch\'f7 \'93Nh\'b5 qu\'aa\'94 trong nguy\'aan b\'b6n vi\'d5t b\'bbng ti\'d5ng Vi\'d6t.}})}{
\f37\fs20\cgrid0\insrsid1378858  \'eb \'a7\'abng D\'ad\'acng. M\'e9t ng\'ad\'eai Ph\'b8p kh\'b8c vi\'d5t: "Ch\'f3ng ta tr\'eb n\'aan \'ae\'b8ng gh\'d0t kh\'abng ch\'deu \'ae\'ad\'eec ... H\'d7nh nh\'ad ch\'f3ng ta ch\'d8 l\'b5m cho ng\'ad\'eai b\'b6n x
\'f8 kh\'abng ai ch\'deu n\'e6i s\'f9 c\'e3 m\'c6t c\'f1a ta. }{\f38\fs20\cgrid0\insrsid1378858 \'eb}{\f37\fs20\cgrid0\insrsid1378858  ch\'a9u \'a2u, ng\'ad\'eai ta coi gi\'e8ng ng\'ad\'eai da v\'b5ng nh\'ad l\'b5 ch\'f8a \'ae\'f9ng t\'cat c\'b6 nh\'f7
ng th\'e3i l\'f5a l\'e4c x\'b6o tr\'b8. }{\f38\fs20\cgrid0\insrsid1378858 \'ca}{\f37\fs20\cgrid0\insrsid1378858 y th\'d5 m\'b5 ch\'ddnh ch\'f3ng ta c\'f2ng r\'cat \'ddt ch\'f3 \'fd t\'e1 ra l\'b5 m\'d7nh ngay th\'bcng th\'b5nh th\'cbt".
\par }{\f37\fs20\expnd0\expndtw-4\cgrid0\insrsid1378858 \'a7\'eai s\'e8ng \'eb thu\'e9c \'ae\'dea ch\'d8 l\'b5m nh\'f7ng t\'cbt x\'cau c\'f1a con ng\'ad\'eai ph\'b8t tri\'d3n: nh\'f7ng k\'ce \'ae\'b7 quen m\'efi chi\'d5n tranh l\'b9i c\'b5ng kh\'abng c\'dfn g
\'d7 l\'b5 \'fd th\'f8c \'ae\'b9o \'ae\'f8c, c\'b5ng tru\'fe l\'b9c, b\'cat l\'ad\'acng v\'b5 \'ae\'e9c \'b8c; b\'e4n con bu\'abn v\'b5 nh\'f7ng tay l\'adu manh kh\'b8c c\'b5ng th\'ddch th\'f3 c\'ad\'edp b\'e3c v\'b5 tr\'e9m c\'bep. }{
\f38\fs20\expnd0\expndtw-4\cgrid0\insrsid1378858 \'eb }{\f37\fs20\expnd0\expndtw-4\cgrid0\insrsid1378858 b\'aan Ph\'b8p, h\'e4 \'ddt c\'e3 d\'dep \'ae\'d3 l\'b5m nh\'f7ng vi\'d6c \'ae\'e3, v\'b5 h\'e4 s\'ee c\'b6nh s\'b8t h\'acn! }{
\f38\fs20\expnd0\expndtw-4\cgrid0\insrsid1378858 \'eb}{\f37\fs20\expnd0\expndtw-4\cgrid0\insrsid1378858  \'a7\'abng D\'ad\'acng nhi\'d2u khi b\'e4n n\'b5y ch\'d8 c\'e3 m\'e9t m\'d7nh v\'edi v\'b5i ng\'ad\'eai An Nam tr\'aan m\'e9t con thuy\'d2
n hay trong m\'e9t l\'b5ng h\'ceo l\'b8nh n\'b5o \'ae\'e3, n\'aan h\'e4 c\'b5ng c\'ad\'edp b\'e3c t\'b5n b\'b9o h\'acn t\'aan c\'ad\'edp ch\'a9u \'a2u \'eb gi\'f7a ch\'ee b\'f3a \'ae\'abng ng\'ad\'eai, v\'b5 h\'e4 c\'b5ng t\'b5n nh\'c9n h\'acn v\'edi nh
\'f7ng ng\'ad\'eai d\'a9n qu\'aa d\'b8m kh\'b8ng c\'f9 l\'b9i h\'e4.
\par }\pard\plain \s27\ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 *\line *   *
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-288\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\expnd0\expndtw-4\cgrid0\insrsid1378858 T\'cat c\'b6 nh\'f7ng ng
\'ad\'eai Ph\'b8p sang \'a7\'abng D\'ad\'acng \'ae\'d2u ngh\'dc r\'bbng ng\'ad\'eai An Nam l\'b5 h\'b9ng ng\'ad\'eai h\'ccn h\'b9 h\'acn h\'e4 v\'b5 ph\'b6i l\'b5m n\'ab l\'d6 cho h\'e4. H\'e4 coi ng\'ad\'eai An Nam nh\'ad nh\'f7ng s\'f3c v\'cbt ph\'b6i 
\'aei\'d2u khi\'d3n b\'bbng roi v\'e4t.
\par }{\f37\fs20\cgrid0\insrsid1378858 Ph\'c7n \'ae\'abng ng\'ad\'eai Ph\'b8p \'eb \'ae\'a9y \'ae\'b7 quen t\'f9 cho m\'d7nh l\'b5 thu\'e9c m\'e9t t\'c7ng l\'edp qu\'fd t\'e9c m\'edi, c\'e3 \'ae\'c6c quy\'d2n.
\par Nh\'b5 du l\'dech xa l\'b9 ch\'ada am hi\'d3u x\'f8 n\'b5y s\'cf r\'cat \'ae\'e7i ng\'b9c nhi\'aan th\'cay ng\'ad\'eai \'a2u, d\'ef l\'b5 binh s\'dc hay th\'f9c d\'a9n, h\'e4 th\'ad\'eang ch\'bcng c\'e3 c\'b8ch \'ae\'e8i x\'f6 n\'b5o kh\'b8c v\'edi ng\'ad
\'eai b\'b6n x\'f8 h\'acn l\'b5 c\'b8ch \'ae\'e8i x\'f6 v\'edi t\'abi t\'ed c\'f1a h\'e4. \'a7\'e8i v\'edi h\'e4, h\'d7nh nh\'ad ng\'ad\'eai b\'e5i l\'b5 \'ae\'b9i bi\'d3u cho c\'b6 ch\'f1ng t\'e9c da v\'b5ng. Ph\'b6i \'ae\'ad\'eec tai nghe ng\'ad\'eai Ph
\'b8p \'eb \'a7\'abng D\'ad\'acng n\'e3i v\'d2 ng\'ad\'eai "da v\'b5ng" th\'d7 m\'edi bi\'d5t \'ae\'ad\'eec h\'e4 khinh b\'d8 ng\'ad\'eai ta \'ae\'d5n th\'d5 n\'b5o. Ph\'b6i \'ae\'ad\'eec m\'bet th\'cay c\'b8ch \'ae\'e8i x\'f6 c\'f1a ng\'ad\'eai Ph\'b8
p khi h\'e4 g\'c6p ng\'ad\'eai b\'b6n x\'f8, ngay c\'b6 \'eb nh\'f7ng n\'aci ng\'ad\'eai n\'b5y \'ae\'ad\'eec c\'e3 quy\'d2n nh\'ad h\'e4, th\'d7 m\'edi bi\'d5t h\'e4 th\'ab b\'b9o \'ae\'d5n \'ae\'a9u!
\par }\pard \qj \fi397\li0\ri0\sl-288\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Ng\'ad\'eai \'a2u n\'b5o c\'f2ng r\'cat quan t\'a9m \'ae\'d5n th\'b8i \'ae\'e9 ph\'f4c t\'efng v\'b5 
\par }\pard \qj \li0\ri0\sl-288\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 cung k\'ddnh c\'f1a ng\'ad\'eai b\'b6n x\'f8. Ng\'ad\'eai An Nam \'eb th\'b5nh th\'de c\'f2ng nh\'ad \'eb th\'abn qu
\'aa \'ae\'d2u b\'bet bu\'e9c ph\'b6i ng\'b6 n\'e3n tr\'ad\'edc m\'c6t h\'e4. Qu\'b8 qu\'bet h\'acn, ng\'ad\'eai ta d\'efng c\'b6 \'ae\'d5n g\'cby hay b\'bet b\'e1 t\'ef ng\'ad\'eai b\'b6n x\'f8 n\'b5o s\'ac su\'cat kh\'abng t\'e1 l\'dfng cung k\'ddnh 
\'ae\'e8i v\'edi h\'e4!
\par }\pard \qj \fi397\li0\ri0\sl-288\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 D\'ef c\'e3 k\'ddnh c\'c8n v\'b5 ngoan ngo\'b7n \'ae\'d5n \'ae\'a9u ch\'a8ng n\'f7a, ng\'ad\'eai An Nam c\'f2
ng ch\'bcng l\'b5m v\'f5a l\'dfng ch\'f1 m\'d7nh \'ae\'ad\'eec. N\'d5u ph\'b9m l\'e7i hay ch\'d8 sai l\'c7m \'ae\'abi ch\'f3t, h\'e4 l\'b5m sao m\'b5 gi\'b6ng gi\'b6i, m\'b5 ph\'a9n tr\'c7n n\'e6i l\'dfng th\'b5nh th\'cbt c\'f1a m\'d7nh ? Nh\'adng n\'d5
u ng\'ad\'eai Ph\'b8p n\'e3i n\'a8ng kh\'e3 hi\'d3u th\'d7 ch\'bcng l\'cf m\'e9t ng\'ad\'eai da tr\'beng l\'b9i ph\'b6i t\'f9 nh\'cbn l\'e7i \'ad? C\'e3 m\'e9t c\'b8ch d\'d4 hi\'d3u nhau \'ae\'acn gi\'b6n h\'acn: \'ae\'e3 l\'b5 c\'b8i batoong. V\'b5 l\'f3
c n\'b5o ng\'ad\'eai ta c\'f2ng d\'efng \'ae\'d5n n\'e3.
\par }\pard \qc \li0\ri0\sb120\sa80\sl-288\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *   *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-288\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 M\'e9t nh\'a9n vi\'aan qu\'a9n s\'f9 vi\'d5t r\'bbng: Ng\'ad\'eai An Nam r\'cat hi\'d2n 
\par }\pard \qj \li0\ri0\sa80\sl-288\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 l\'b5nh, r\'cat ngoan ngo\'b7n; tuy th\'d5, ng\'ad\'eai ta ch\'d8 n\'e3i chuy\'d6n v\'edi h\'e4 b\'bbng
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-288\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\cgrid0\insrsid1378858 nh\'f7ng c\'b8i \'ae\'b8 \'ae\'ddt. Anh ta l
\'b9i n\'e3i th\'aam: Su\'e8t ng\'b5y ng\'ad\'eai ta v\'b8c g\'cby v\'b5 d\'efng s\'e8ng g\'ad\'acm \'ae\'d3 n\'d6n ng\'ad\'eai An Nam b\'bet h\'e4 l\'b5m vi\'d6c.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-294\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 Ng\'ad\'eai ta \'ae\'b7 tr\'abng th\'cay c
\'b8c vi\'aan s\'dc quan h\'b5nh h\'b9 c\'b8c c\'f4 gi\'b5 hi\'d2n l\'b5nh v\'b5 t\'f3m r\'a9u th\'c7y c\'f3ng m\'b5 k\'d0o trong khi h\'e4 \'aeang h\'b5nh l\'d4.
\par }\pard\plain \s27\ql \li0\ri0\sb120\sl-294\slmult0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 *\line *    *
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-294\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 \'a4ng Cu\'e8ctel\'acm\'a8ng k\'d3 chuy\'d6
n m\'e9t c\'b8ch m\'d8a mai: T\'abi c\'e3 quen m\'e9t Ng\'b5i c\'e3 m\'e9t l\'e8i khai ho\'b8 th\'cbt \'ae\'b8ng h\'e4c t\'cbp. Khi Ng\'b5i ta ra kh\'e1i c\'f6a, c\'b8c xe k\'d0o, theo m\'e9t th\'e3i quen nh\'ad nh\'f7ng ng\'ad\'eai \'ae\'b8nh xe ng\'f9a 
\'eb b\'aan Ph\'b8p, x\'ab \'ae\'d5n m\'eai Ng\'b5i. B\'f9c m\'d7nh qu\'b8, Ng\'b5i n\'bem ch\'bec batoong trong tay, qu\'cbt v\'b5o nh\'f7ng ng\'ad\'eai culi, v\'b5 th\'f5a bi\'d5t r\'bbng nh\'f7ng ng\'ad\'eai culi kh\'e8n kh\'e6 n\'b5y ch\'bcng th\'d3 
\'a8n mi\'d5ng tr\'b6 mi\'d5ng v\'edi Ng\'b5i, Ng\'b5i ta c\'b5ng ra tay qu\'cbt. Bu\'e6i chi\'d2u Ng\'b5i mu\'e8n \'aei ch\'aci, nh\'adng culi xe \'ae\'b7 bi\'d5t t\'ddnh Ng\'b5i, kh\'abng d\'b8m l\'b9i g\'c7n Ng\'b5i n\'f7a. Th\'d5 l\'b5 Ng\'b5i l\'b9
i v\'edi h\'e4, r\'e5i c\'c7m c\'b8i g\'cby qu\'fd ho\'b8 c\'f1a Ng\'b5i, qu\'cbt l\'aan l\'adng h\'e4 \'ae\'d3 d\'b9y d\'e7 cho h\'e4 bi\'d5t ph\'b6i \'ae\'d5n h\'c7u Ng\'b5i. Ng\'b5i \'cay b\'b6o: "V\'b6 l\'b9i, bi\'d5t l\'b5m th\'d5 n\'b5o \'ae\'ad\'ee
c v\'edi c\'b8i h\'b9ng ng\'ad\'eai \'cay, d\'ef ch\'f3ng \'ae\'b7 g\'c7n g\'f2i ch\'f3ng m\'d7nh b\'cay l\'a9u nay m\'b5 v\'c9n ch\'ada d\'b8m \'a8n th\'det quay!". Ng\'ad\'eai ta nghe th\'cay v\'ab s\'e8 ng\'ad\'eai Ph\'b8p, v\'b5 kh\'abng ph\'b6i l\'b5
 h\'b9ng k\'d0m c\'e1i g\'d7 \'ae\'a9u- l\'fd lu\'cbn nh\'ad th\'d5 \'ae\'cay.
\par ... Khi "nh\'f7ng ng\'ad\'eai t\'f5ng \'eb B\'bec K\'fa" vui \'ae\'efa tr\'aan t\'b5u th\'d7 d\'ad\'edi m\'b9n t\'b5u ph\'dda b\'aan ph\'b6i c\'e3 v\'b5i chi\'d5c thuy\'d2n b\'b8n hoa qu\'b6, \'e8c h\'d5n. \'a7\'d3 \'ae\'ada h\'b5ng \'ae\'d5n t\'cb
n tay ch\'f3ng t\'abi, nh\'f7ng ng\'ad\'eai An Nam bu\'e9c gi\'e1 \'ae\'f9ng h\'b5ng v\'b5o \'ae\'c7u ng\'e4n s\'b5o r\'e5i gi\'ac l\'aan. Ch\'f3ng t\'abi ch\'d8 vi\'d6c ch\'e4n m\'b5 th\'abi. Nh\'adng \'ae\'b8ng l\'cf ph\'b6i tr\'b6 ti\'d2n, th\'d7 ng
\'ad\'eai ta l\'b9i c\'e3 nh\'b7 \'fd b\'e1 v\'b5o gi\'e1 \'ae\'f1 th\'f8 nh\'ad sau: nh\'f7ng \'e8ng t\'c8u thu\'e8c l\'b8, khuy qu\'c7n, m\'c8u thu\'e8c l\'b8. (C\'e3 l\'cf h\'e4 l\'b5m nh\'ad th\'d5 \'ae\'d3 d\'b9y cho ng\'ad\'eai b\'b6n x\'f8 t\'dd
nh ngay th\'cbt trong vi\'d6c mua b\'b8n ch\'a8ng!). \'a7\'abi khi, \'ae\'d3 mua vui, m\'e9t anh s\'e8p ph\'ac n\'b5o \'ae\'e3 h\'bet c\'b6 m\'e9t th\'efng n\'ad\'edc s\'abi xu\'e8ng l\'adng nh\'f7ng ng\'ad\'eai b\'b8n h\'b5ng kh\'e8n kh\'e6. L\'cbp t\'f8
c c\'e3 nh\'f7ng ti\'d5ng r\'f3 l\'aan v\'d7 \'aeau \'ae\'edn, nh\'f7ng m\'b8i ch\'cco vung l\'aan lo\'b9n x\'b9 \'ae\'d3 b\'aci tr\'b8nh, l\'b5m cho nh\'f7ng chi\'d5c thuy\'d2n va s\'c7m v\'b5o nhau.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Ngay ph\'dda d\'ad\'edi t\'abi, m\'e9t ng\'ad\'eai An Nam b\'de b\'e1ng t\'f5 \'ae\'c7u \'ae\'d5n ch\'a9
n, ph\'b8t \'aei\'aan l\'aan, mu\'e8n lao xu\'e8ng bi\'d3n. Ng\'ad\'eai anh c\'f1a anh ta, qu\'aan c\'b6 nguy hi\'d3m, bu\'abng tay ch\'cco \'abm l\'cay anh ta v\'b5 ra s\'f8c \'ae\'cc anh ta xu\'e8ng l\'dfng thuy\'d2n. Cu\'e9c v\'cbt l\'e9n ch\'ada \'ae
\'c7y hai gi\'a9y v\'f5a k\'d5t th\'f3c th\'d7 m\'e9t th\'efng n\'ad\'edc s\'abi n\'f7a \'ae\'ad\'eec h\'bet b\'ebi m\'e9t b\'b5n tay chu\'c8n x\'b8c l\'b9i d\'e9i xu\'e8ng k\'ce b\'cat h\'b9nh. T\'abi th\'cay anh ta l\'a8n l\'e9n trong thuy\'d2n, v\'d5
t th\'ad\'acng tr\'ac c\'b6 th\'det v\'edi nh\'f7ng ti\'d5ng k\'aau kh\'abng c\'dfn g\'d7 l\'b5 c\'f1a con ng\'ad\'eai n\'f7a! V\'b5 c\'b6nh \'ae\'e3 khi\'d5n ch\'f3ng t\'abi c\'ad\'eai; v\'edi ch\'f3ng t\'abi, \'aei\'d2u \'ae\'e3 c\'e3 v\'ce c\'f9c k\'fa
 ng\'e9 ngh\'dcnh. Qu\'b6 th\'cbt ch\'f3ng t\'abi \'ae\'b7 c\'e3 t\'a9m h\'e5n th\'f9c d\'a9n!...
\par }\pard \qc \li0\ri0\sb120\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 M\'e9t ng\'ad\'eai l\'ddnh kh\'b8c k\'d3: "Trong th\'eai k\'fa t\'abi \'eb \'ae\'e3 (B\'bec K\'fa) kh\'ab
ng c\'e3 tu\'c7n n\'b5o l\'b5 kh\'abng c\'e3 v\'b5i c\'b8i \'ae\'c7u r\'aci.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Trong t\'cat c\'b6 nh\'f7ng c\'b6nh t\'ad\'eeng \'ae\'e3, t\'abi ch\'d8 c\'dfn nh\'ed \'ae\'ad\'eec m\'e9t \'aei
\'d2u, l\'b5 ch\'f3ng ta c\'dfn t\'b5n b\'b9o, c\'dfn d\'b7 man h\'acn c\'b6 nh\'f7ng t\'aan c\'ad\'edp bi\'d3n. T\'b9i sao l\'b9i c\'e3 nh\'f7ng h\'b5nh vi qu\'b8i \'b8c \'ae\'d5n th\'d5 \'ae\'e8i v\'edi m\'e9t k\'ce b\'de k\'d5t \'b8n s\'bep ph\'b6i ch
\'d5t? T\'b9i sao l\'b9i c\'e3 nh\'f7ng cu\'e9c h\'b5nh h\'b9 th\'d3 x\'b8c, t\'b9i sao ph\'b6i gi\'b6i nh\'f7ng \'aeo\'b5n t\'ef \'aei b\'aau kh\'bep c\'b8c l\'b5ng m\'b9c?".
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'b8C QuAN CAI TR\'de
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-288\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 T\'abi \'ae\'b7 n\'e3i chuy\'d6n v\'d2 c\'b8
c \'abng ngh\'de thanh li\'aam. B\'a9y gi\'ea, t\'abi ph\'b6i n\'e3i \'ae\'d5n c\'b8c quan cai tr\'de c\'e3 \'ae\'b9o \'ae\'f8c. Nh\'ad c\'b8c b\'b9n bi\'d5t \'ae\'cay, \'ae\'d3 b\'b6o v\'d6 cho m\'e9t ch\'d5 \'ae\'e9 c\'ad\'edp b\'e3c, ph\'b6i c\'e3 qu
\'a9n \'a8n c\'ad\'edp. Ho\'b9 ho\'bbn c\'e3 m\'e9t vi\'aan quan cai tr\'de n\'b5o l\'b9i th\'cbt th\'b5 v\'b5 hi\'d3u bi\'d5t h\'acn, l\'cbp t\'f8c vi\'aan \'cay b\'de \'ae\'b5n lang s\'e3i quan th\'c7y hay b\'cc b\'b9n xua \'aeu\'e6i \'aei ngay. Th\'b5
nh th\'f6 ra 99% quan cai tr\'de l\'b5 qu\'a9n tr\'e9m c\'bep, ch\'d8 ngh\'dc \'ae\'d5n b\'e3c l\'e9t d\'a9n b\'b6n x\'f8 \'ae\'d3 l\'b5m gi\'b5u, ch\'bcng ki\'aang n\'d3 g\'d7 t\'b5i s\'b6n, quy\'d2n l\'eei, t\'f9 do, \'ae\'eai s\'e8ng c\'f1a nh\'f7ng ng
\'ad\'eai b\'de cai tr\'de c\'b6.
\par M\'e9t vi\'aan quan cai tr\'de \'eb B\'bec K\'fa \'ae\'b7 t\'ad\'edc \'aeo\'b9t c\'f1a m\'e9t l\'b5ng m\'cay h\'d0cta tr\'e5ng m\'dda \'ae\'d3 cho m\'e9t l\'b5ng c\'abng gi\'b8o. R\'e5i l\'b7o ta l\'b9i b\'bet b\'e1 t\'ef nh\'f7ng k\'ce b\'de t\'ad\'edc 
\'aeo\'b9t kh\'e6 s\'eb v\'d7 nh\'f7ng ng\'ad\'eai n\'b5y d\'b8m \'aei ki\'d6n. Ch\'ada \'ae\'f1, ng\'b5i c\'dfn b\'bet h\'e4 tr\'b6 thu\'d5 m\'b7i \'ae\'d5n n\'a8m 1910 cho nh\'f7ng \'ae\'cat m\'b5 ng\'b5i \'ae\'b7 c\'ad\'edp c\'f1a h\'e4 t\'f5 n\'a8
m 1895 v\'b5 n\'a8m 1900.
\par }\pard \qc \li0\ri0\sb120\sa80\sl-288\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-288\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 M\'e9t vi\'aan c\'abng s\'f8 \'eb L\'b5o bu\'e9c 25 ng\'ad\'eai An Nam v\'b5o t\'e9i h\'e9i h\'e4p l\'b5
m bi\'d3u t\'d7nh. Th\'d5 m\'b5 ch\'ddnh \'abng ta, vi\'aan c\'abng s\'f8, \'ae\'b7 b\'b5y ra m\'e9t \'a9m m\'adu t\'ad\'ebng t\'ad\'eeng, cho ti\'d2n k\'ce t\'e8 c\'b8o, r\'e5i h\'b5nh h\'b9 tra t\'can b\'bet nh\'f7ng ng\'ad\'eai b\'de c\'b8o ph\'b6i nh
\'cbn nh\'f7ng l\'eai th\'f3 t\'e9i gi\'b6 m\'b9o. Vi\'d6c h\'ccn m\'b9t \'cay, ch\'ddnh vi\'aan c\'abng s\'f8 c\'f2ng \'ae\'b7 th\'f5a nh\'cbn. Nh\'adng \'abng ta ch\'bcng ph\'b6i lo l\'beng g\'d7 v\'d2 vi\'d6c \'cay c\'b6; v\'b5 \'abng c\'f8 ti\'d5p t
\'f4c nh\'f7ng vi\'d6c gian \'b8c c\'f1a m\'d7nh. 
\par }\pard \qj \fi397\li0\ri0\sa80\sl-266\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 L\'cay c\'ed l\'b5 ph\'b6i gi\'f7 g\'d7n tr\'cbt t\'f9 an ninh trong \'ae\'dea h\'b9t, \'abng ta \'ae\'b7
 h\'b9 l\'d6nh b\'bet t\'cat c\'b6 nh\'f7ng ng\'ad\'eai An Nam kh\'abng ph\'b6i l\'b5 ng\'ad\'eai c\'ad tr\'f3 trong v\'efng m\'b5 hay lai v\'b7ng t\'edi \'ae\'e3, v\'b5 c\'f8 vi\'d6c b\'ben nh\'f7ng k\'ce toan ch\'b9y tr\'e8n. Trong m\'e9t tu\'c7
n, hai ng\'ad\'eai An Nam b\'de gi\'d5t, v\'b5 m\'e9t ng\'ad\'eai b\'de tr\'e4ng th\'ad\'acng, \'ae\'d2u do b\'de b\'ben g\'c7n.
\par }{\f37\fs20\expnd0\expndtw-4\cgrid0\insrsid1378858 T\'cat c\'b6 nh\'f7ng ng\'ad\'eai An Nam b\'de b\'bet \'ae\'d2u b\'de coi nh\'ad phi\'d5n lo\'b9n c\'b6.
\par }\pard \qc \li0\ri0\sb120\sa80\sl-266\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-266\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 M\'e9t quan cai tr\'de kh\'b8c nghe tin m\'e9t ng\'ad\'eai An Nam \'ae\'b7 b\'de to\'b5 \'b8n do \'ab
ng ta l\'b5m ch\'f1 to\'b9 k\'d5t \'b8n 6 n\'a8m kh\'e6 sai, nay \'ae\'ad\'eec to\'b5 th\'ad\'eeng th\'c8m cho tr\'beng \'b8n. C\'b8u ti\'d5t l\'aan, \'abng ta cho b\'bet ng\'ad\'eai b\'b6n x\'f8 \'ae\'e3 t\'e8ng c\'e6 v\'b5o t\'ef. L\'b5m xong, \'abng xu
\'e8ng t\'b5u v\'d2 Ph\'b8p, \'ae\'d3 l\'b9i ng\'ad\'eai b\'b6n x\'f8 \'eb trong t\'ef, trong ng\'f4c k\'ddn, ch\'bcng th\'ccm h\'e1i han g\'d7 c\'b6.
\par }\pard \qc \li0\ri0\sb120\sa80\sl-266\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-266\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 M\'e9t vi\'aan kh\'a9m s\'f8, can t\'e9i \'a8n h\'e8i l\'e9, h\'b5nh hung, bi\'d3n th\'f1, l\'b5m 
\par v\'b5 s\'f6 d\'f4ng gi\'cay t\'ea gi\'b6 m\'b9o, l\'b9i \'ae\'ad\'eec t\'c6ng \'ae\'d6 tam \'ae\'bcng b\'bec \'ae\'c8u b\'e9i tinh v\'b5 th\'a8ng l\'aan ch\'f8c quy\'d2n to\'b5n quy\'d2n.
\par }\pard \qc \li0\ri0\sb120\sa80\sl-266\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 M\'e9t vi\'aan c\'abng s\'f8 kh\'b8c n\'bem trong tay c\'b6 quy\'d2n h\'b5nh c\'f1a t\'e6ng \'ae\'e8c, th
\'c8m ph\'b8n, m\'e2 t\'dfa v\'b5 \'ae\'e9i tr\'ad\'ebng th\'f3c thu\'d5. }{\f38\fs20\cgrid0\insrsid1378858 \'ab}{\f37\fs20\cgrid0\insrsid1378858 ng ta l\'eei d\'f4ng quy\'d2n h\'b5nh c\'f1a m\'d7nh ch\'bcng m\'e9t ai gi\'b8m s\'b8t \'ae\'d3 b\'bet b\'ed
, b\'e1 t\'ef hay k\'d5t \'b8n m\'e9t c\'b8ch v\'e2 \'aeo\'b8n ng\'ad\'eai An Nam \'ae\'c6ng b\'e3p n\'c6n h\'e4. \'a4ng ta \'ae\'cam \'ae\'b8, l\'cay g\'cby \'ae\'cbp nh\'f7ng thanh ni\'aan An Nam "t\'d7nh nguy\'d6n" kh\'abng hi\'d3u nh\'f7ng c\'a9u \'ab
ng ta n\'e3i. \'a4ng ta h\'b5nh h\'b9 l\'ddnh, \'ae\'cbp \'ae\'c7u h\'e4 v\'b5o t\'ad\'eang, t\'f3m t\'e3c h\'e4 m\'b5 k\'d0o. }{\f38\fs20\cgrid0\insrsid1378858 \'ab}{\f37\fs20\cgrid0\insrsid1378858 ng ta l\'cay thanh ki\'d5m l\'d6nh c\'f1a m\'d7nh \'ae
\'a9m n\'b8t \'ae\'efi nh\'f7ng ng\'ad\'eai t\'ef \'ae\'d3 l\'cay kh\'c8u cung.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-266\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 D\'ad\'edi tr\'eai n\'beng chang chang, \'aeo\'b5n t\'ef kh\'e8n kh\'e6, g\'c7y g\'df, r\'b8ch r\'ad\'ed
i, d\'cby l\'b5m vi\'d6c t\'f5 t\'ea m\'ea s\'b8ng \'ae\'d5n t\'cbn \'ae\'aam khuya, c\'e6 \'aeeo g\'abng, ch\'a9n xi\'d2ng x\'ddch, tay c\'dfng ng\'ad\'eai n\'e4 v\'b5o v\'edi ng\'ad\'eai kia, \'aeang \'d7 \'b9ch k\'d0o
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-266\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\cgrid0\insrsid1378858 m\'e9t qu\'b6 l\'a8n to t\'ad\'edng tr\'aan l
\'edp \'ae\'b8 s\'e1i d\'b5y. Quan cai tr\'de t\'edi, v\'ab c\'ed l\'cay chi\'d5c batoong to t\'ad\'edng c\'f1a ng\'b5i \'ae\'cbp th\'bcng tay, ch\'f6i m\'beng h\'e4 l\'b5 l\'ad\'eai bi\'d5ng.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 M\'e9t h\'abm, v\'f5a m\'edi c\'f9 m\'e9t nh
\'a9n vi\'aan ng\'ad\'eai Ph\'b8p xong, ch\'bcng bi\'d5t tr\'f3t c\'acn th\'denh n\'e9 l\'aan \'ae\'c7u ai, ng\'b5i v\'ed ngay l\'cay m\'e9t c\'b8i th\'ad\'edc k\'ce b\'bbng s\'bet \'ae\'cbp g\'b7y ng\'e3n tay m\'e9t vi\'aan th\'ad k\'fd kh\'e8n kh\'e6 ng
\'ad\'eai An Nam.
\par Nh\'f7ng l\'ddnh kh\'e8 xanh l\'b5m ch\'bcng v\'f5a l\'dfng ng\'b5i, ng\'b5i cho \'aeem ch\'abn \'ae\'f8ng \'ae\'d5n t\'cbn c\'e6, hay cho \'aeem tr\'e3i ch\'c6t v\'b5o c\'e9t \'ae\'b8nh cho \'ae\'d5n g\'c7n ch\'d5t.
\par Ng\'b5i \'ae\'b7 ph\'b9m kh\'abng bi\'d5t bao nhi\'aau t\'e9i \'b8c \'ae\'d5n n\'e7i ng\'ad\'eai An Nam \'eb t\'d8nh ng\'b5i cai tr\'de ph\'b6i n\'e6i d\'cby. H\'b5ng tr\'a8m ng\'ad\'eai Ph\'b8p v\'b5 An Nam \'ae\'b7 ph\'b6i hy sinh, v\'b5 thi\'d6t h\'b9
i c\'e3 \'ae\'d5n h\'b5ng tri\'d6u b\'b9c.
\par C\'b8c b\'b9n c\'e3 bi\'d5t n\'ad\'edc C\'e9ng ho\'b5 Ph\'b8p \'ae\'b7 cho t\'aan s\'b8t nh\'a9n \'cay l\'b5m g\'d7 kh\'abng ? Sau cu\'e9c n\'e6i d\'cby, n\'ad\'edc C\'e9ng ho\'b5 Ph\'b8p \'ae\'b7 cho h\'ben l\'b5m ch\'b8nh ch\'f1 kh\'b6o c\'b8c tr\'ad
\'eang h\'e4c l\'edn \'eb B\'bec K\'fa, r\'e5i th\'d7 l\'b5m \'ae\'e6ng l\'fd v\'a8n ph\'dfng c\'f1a quan th\'e8ng \'ae\'e8c, ngh\'de vi\'aan h\'e9i \'ae\'e5ng thu\'e9c \'ae\'dea \'eb Nam K\'fa ki\'aam gi\'b8m \'ae\'e8c u\'fb nhi\'d6m c\'b8c nh\'b5 m\'b8
y r\'ad\'eeu.
\par }\pard \qc \li0\ri0\sb120\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 M\'e9t chuy\'d6n kh\'b8c... Th\'abi, k\'d3 th\'d5 \'ae\'f1 r\'e5i. Ch\'f3ng ta h\'b7y ng\'f5ng l\'b9i \'ae
\'a9y v\'b5 sang ch\'ad\'acng kh\'b8c, \'ae\'d3 thay \'ae\'e6i m\'e3n \'aei m\'e9t ch\'f3t.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\b\f37\fs20\cgrid0\insrsid1378858 \column 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 \'a1N B\'b8M V\'b5 H\'e7N \'a7\'e9N
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 \'a4ng Vinh\'aa \'a7\'e8ct\'abng, nguy\'aa
n ngh\'de s\'dc Ph\'b8p n\'e3i: "N\'d5u \'aeem so s\'b8nh v\'edi b\'e4n vi\'aan ch\'f8c thu\'e9c \'ae\'dea, th\'d7 nh\'f7ng qu\'a9n c\'ad\'edp \'ae\'ad\'eang c\'dfn l\'b5 nh\'f7ng ng\'ad\'eai l\'ad\'acng thi\'d6n!". \'a4ng \'cay n\'e3i ch\'dd l\'fd \'ae
\'cay.
\par }\pard\plain \s18\qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs20\insrsid1378858 Ng\'ad\'eai n\'abng d\'a9n An Nam \'ae\'e3ng \'ae\'ad
\'eec m\'e9t tr\'a8m \'ae\'e5ng b\'b9c thu\'d5, th\'d7 \'ae\'d5n b\'b6y m\'ad\'aci \'ae\'e5ng b\'de ng\'e8n ngay v\'b5o vi\'d6c tr\'b6 l\'ad\'acng v\'b5 kinh ph\'dd thuy\'aan chuy\'d3n cho vi\'aan ch\'f8c, \'cay l\'b5 ch\'ada k\'d3 c\'b8c kho\'b6n tr\'ee
 c\'cap cho qu\'fc h\'adu b\'e6ng l\'b5m cho ng\'ad\'eai d\'a9n c\'b5ng b\'de h\'f3t m\'b8u t\'b5n nh\'c9n th\'aam n\'f7a.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 Ng\'ad\'eai ta c\'cap h\'e4c b\'e6ng cho c
\'b8c c\'cbu \'cam hay c\'ab chi\'aau - con c\'b8c quan cai tr\'de t\'b9i ch\'f8c l\'ad\'acng kho\'b6ng t\'f5 20 \'ae\'d5n 25 ng\'b5n phr\'a8ng - v\'d2 Ph\'b8p h\'e4c kh\'e1i ph\'b6i m\'cat ti\'d2n, trong khi tr\'ce con An Nam kh\'abng sao ki\'d5m \'ae
\'ad\'eec ch\'e7 h\'e4c trong nh\'b5 tr\'ad\'eang Ph\'b8p - Nam hi\'d5m c\'e3 \'eb An Nam, n\'aan ph\'b6i ch\'deu d\'e8t n\'b8t.
\par Ng\'a9n s\'b8ch h\'b5ng t\'d8nh b\'de c\'ad\'edp gi\'cbt m\'e9t c\'b8ch v\'ab li\'aam s\'d8 cho vi\'d6c chi ti\'aau ri\'aang c\'f1a nh\'f7ng k\'ce c\'e3 quy\'d2n \'ae\'denh \'aeo\'b9t c\'b8ch s\'f6 d\'f4ng.
\par }{\f38\fs20\cgrid0\insrsid1378858 \'eb}{\f37\fs20\cgrid0\insrsid1378858  c\'b8c n\'ad\'edc kh\'b8c, c\'f6 tri hay \'ae\'b9i di\'d6n c\'f1a h\'e4 \'ae\'ad\'eec quy\'d5t \'ae\'denh v\'d2 ng\'a9n s\'b8ch do ch\'ddnh h\'e4 \'ae\'e3ng g\'e3p v\'b5o; \'eb \'ae
\'a9y ng\'ad\'eai ta \'ae\'d3 cho v\'b5i tr\'a8m ng\'ad\'eai \'a2u s\'e8ng \'eb thu\'e9c \'ae\'dea, c\'e3 quy\'d2n cao h\'acn v\'b5 b\'cat ch\'cap c\'b6 Nh\'b5 n\'ad\'edc, tu\'fa \'fd s\'f6 d\'f4ng c\'abng qu\'fc do h\'b5ng tri\'d6u ng\'ad\'eai b\'b6n x
\'f8 \'ae\'e3ng g\'e3p.
\par }\pard\plain \s18\qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs20\cgrid0\insrsid1378858 Nhi\'d2u phi\'aan h\'e4p c\'f1a h\'e9i \'ae\'e5
ng thu\'e9c \'ae\'dea ch\'d8 l\'b5 \'ae\'d3 b\'b5n c\'b8ch c\'ad\'edp gi\'cbt c\'abng qu\'fc m\'e9t c\'b8ch kh\'abn kh\'d0o. Ri\'aang m\'e9t \'abng ch\'f1 t\'dech h\'e9i \'ae\'e5ng \'ae\'b7 \'ae\'ad\'eec l\'dcnh th\'c7u nh\'f7ng c\'abng vi\'d6c tr\'de gi
\'b8 h\'acn hai tri\'d6u phr\'a8ng. M\'e9t \'abng \'ae\'e6ng l\'fd s\'f9 v\'f4, l\'b5m \'ae\'b9i di\'d6n c\'f1a Ch\'ddnh ph\'f1 trong }{\fs20\insrsid1378858 
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-274\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\expnd0\expndtw-2\cgrid0\insrsid1378858 h\'e9i \'ae\'e5ng \'ae\'b7
 xin t\'a8ng l\'ad\'acng m\'d7nh l\'aan g\'cap \'ae\'abi v\'b5 \'ae\'b7 \'ae\'ad\'eec ch\'cap thu\'cbn.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\cgrid0\insrsid1378858 N\'d5u k\'d0t b\'b9c th\'cay h\'aci v\'aci 
\'aei th\'d7 c\'f2ng ch\'bcng kh\'e3 kh\'a8n g\'d7 m\'b5 c\'b8c quan cai tr\'de kh\'abng l\'b5m cho n\'e3 \'ae\'c7y l\'b9i \'ae\'ad\'eec. T\'f9 quy\'d2n c\'b8c ng\'b5i \'ae\'e3 b\'b8o cho d\'a9n b\'b6n x\'f8 bi\'d5t l\'b5 Nh\'b5 n\'ad\'edc c\'c7n m\'e9
t kho\'b6n ti\'d2n nh\'cat \'ae\'denh, r\'e5i c\'b8c ng\'b5i b\'e6 cho c\'b8c l\'b5ng ph\'b6i \'ae\'e3ng g\'e3p. L\'b5ng x\'b7 ph\'b6i v\'e9i v\'b5ng tu\'a9n l\'d6nh \'ae\'d3 kh\'e1i b\'de tr\'f5ng ph\'b9t ngay l\'cbp t\'f8c.
\par }\pard \qc \li0\ri0\sb120\sa80\sl-270\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 C\'c7n ti\'d2n \'ad? C\'b8c ng\'b5i c\'abng s\'f8 c\'e8 g\'beng t\'d7m ph\'ad\'acng l\'cbp k\'d5, v\'b5 v
\'d7 c\'b8c ng\'b5i quan t\'a9m \'ae\'d5n vi\'d6c th\'a8ng quan ti\'d5n ch\'f8c c\'f1a c\'b8c ng\'b5i h\'acn l\'b5 t\'f3i ti\'d2n c\'f1a d\'a9n b\'de tr\'de, n\'aan c\'b8c ng\'b5i s\'e8t s\'beng b\'b5y \'ae\'c6t ra c\'b8c th\'f8 ph\'b6i \'ae\'b8nh thu\'d5
, n\'a9ng h\'b9ng m\'e9t s\'e8 ru\'e9ng \'ae\'d3 n\'b7 ti\'d2n thu\'d5 nhi\'d2u h\'acn. Ng\'ad\'eai ta k\'d3 c\'e3 m\'e9t t\'d8nh n\'b5o \'ae\'e3 \'eb B\'bec K\'fa \'ae\'b7 b\'de ki\'d6t qu\'d6 h\'bcn \'aei v\'d7 tinh th\'c7n s\'e8t s\'beng c\'f1a m\'e9
t quan c\'abng s\'f8 v\'b5o lo\'b9i \'cay.
\par }\pard \qc \li0\ri0\sb120\sa80\sl-270\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f38\fs20\cgrid0\insrsid1378858 \'eb}{\f37\fs20\cgrid0\insrsid1378858  kh\'bep \'a7\'abng D\'ad\'acng, nh\'f7ng ng\'ad\'eai \'ae\'ad\'ee
c c\'f6 v\'b5o gi\'f7 nh\'f7ng ch\'f8c v\'f4 cao nh\'cat th\'ad\'eang \'ae\'ad\'eec l\'f9a ch\'e4n trong s\'e8 nh\'f7ng k\'ce m\'adu m\'ab x\'b6o quy\'d6t l\'b5m gi\'b5u b\'bbng nh\'f7ng c\'b8ch ch\'bcng l\'ad\'acng thi\'d6n ch\'f3t n\'b5o. \'a7\'e5ng ti
\'d2n tr\'ad\'edc h\'d5t, d\'ef trong s\'b9ch hay d\'ac d\'b8y, l\'b5 c\'b8i quy\'d5t \'ae\'denh vi\'d6c tuy\'d3n l\'f9a, cho n\'aan m\'e9t th\'bbng x\'e1 l\'b8 ba que, coi nh\'ad c\'b8i r\'acm c\'b8i r\'b8c \'eb m\'e9t n\'aci kh\'b8c, l\'b9i l\'b5m n\'aa
n m\'e9t "Ng\'b5i ch\'f1 t\'dech" \'ae\'ad\'eang b\'d6 \'ae\'b8o \'ae\'d3 \'eb x\'f8 thu\'e9c \'ae\'dea n\'b5y.
\par }\pard \qc \li0\ri0\sb120\sa80\sl-270\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Khi quan th\'e8ng s\'f8 c\'e3 vi\'d6c ph\'b6i ti\'aau pha th\'d7 ng\'b5i c\'cap b\'bbng s\'bec, ph\'c8m h
\'b5m. Nhi\'d2u vi\'d6c l\'b5m theo ki\'d3u \'cay \'ae\'b7 v\'ed \'ae\'ad\'eec t\'f5 10.000 \'ae\'d5n 15.000 phr\'a8ng. M\'b5 nh\'f7ng vi\'d6c nh\'ad th\'d5 kh\'abng ph\'b6i l\'b5 hi\'d5m \'ae\'a9u.
\par }\pard\plain \s27\ql \li0\ri0\sb120\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 *\line *    *
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-300\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs20\cgrid0\insrsid1378858 \'eb}{\f37\fs20\cgrid0\insrsid1378858  \'ae
\'ad\'eang giao th\'abng V\'dcnh Long, c\'e3 m\'e9t nh\'a9n vi\'aan l\'b5m k\'d5 to\'b8n m\'e9t th\'eai gian \'ae\'b7 t\'d7m ra m\'e9t c\'b8ch \'ae\'c6c bi\'d6t t\'b5i t\'d7nh \'ae\'d3 t\'a8ng l\'ad\'acng c\'f1a m\'d7nh: m\'e7i l\'c7n c\'e3 ng\'ad\'eai b
\'b6n x\'f8 h\'e1i vay tr\'ad\'edc \'ddt ti\'d2n l\'ad\'acng, anh ta b\'bbng l\'dfng ngay, v\'b5 r\'e5i \'ae\'d5n k\'fa l\'ad\'acng sau anh ta tr\'f5 \'aei, nh\'adng anh ta gi\'f7 m\'e3n ti\'d2n tr\'f5 l\'b9i cho m\'d7nh, v\'b5 c\'f8 nh\'ad th\'d5
, anh ta \'ae\'b7 xo\'b8y \'ae\'ad\'eec s\'e8 ti\'d2n nh\'e1 m\'e4n l\'b5 200 ng\'b5n phr\'a8ng.
\par M\'e9t quan th\'e8ng s\'f8 \'ae\'b7 chi ti\'aau h\'d5t kinh ph\'dd v\'d2 chi\'d5c s\'b5l\'f3p tr\'ad\'edc th\'eai h\'b9n m\'cay th\'b8ng. Ng\'b5i b\'ccn l\'cay c\'ed c\'e3 m\'e9t cu\'e9c h\'e9i h\'cc n\'b5o \'ae\'e3 m\'b5 nh\'b5 vua s\'cf \'ae\'ad\'eec m
\'eai \'ae\'d5n ng\'f9 tr\'aan s\'b5l\'f3p v\'b5 quy\'d5t \'ae\'denh \'abng ta s\'cf ph\'b6i g\'e3p ph\'c7n v\'b5o vi\'d6c chi ph\'dd, v\'b5 ng\'ad\'eai ta d\'f9 \'aeo\'b8n r\'bbng ph\'c7n \'ae\'e3ng g\'e3p c\'f1a v\'de kh\'b8ch s\'cf nhi\'d2u \'ae\'cay.

\par }\pard \qc \li0\ri0\sb120\sa80\sl-300\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-300\slmult0\nowidctlpar\tx-2127\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 \'a4ng \'a7\'ea Lan\'d0tx\'a8ng, nguy\'aan to\'b5n quy\'d2n \'a7\'abng D\'ad\'acng v\'b5 B\'e9 tr\'ad\'eb
ng B\'e9 Thu\'e9c \'ae\'dea}{\cs17\f37\fs20\super\cgrid0\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 1) Theo c\'b8c t\'f5 \'aei\'d3n c\'f1a Ph\'b8p, Lan\'d0tx\'a8ng l\'b5 B\'e9 tr\'ad\'ebng B\'e9 H\'b5ng h\'b6i.}})}{\f37\fs20\cgrid0\insrsid1378858 , th\'f3 th\'cbt r\'bb
ng \'a7\'abng D\'ad\'acng tr\'b5n ng\'cbp nh\'f7ng vi\'aan ch\'f8c Ph\'b8p qu\'b8 \'ae\'abng v\'b5 th\'ad\'eang th\'ad\'eang l\'b5 kh\'abng \'ae\'ad\'eec t\'ddch s\'f9 g\'d7 c\'b6.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-300\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Ph\'c7n \'ae\'abng ng\'ad\'eai Ph\'b8p \'ae\'b7 s\'e8ng \'eb thu\'e9c \'ae\'dea \'ae\'d2u n\'e3i r\'bb
ng qu\'b8 n\'f6a s\'e8 quan \'ae\'c7u t\'d8nh kh\'abng c\'e3 \'ae\'f1 t\'ad c\'b8ch c\'c7n thi\'d5t \'ae\'b8ng \'ae\'d3 giao ph\'e3 nh\'f7ng quy\'d2n h\'b9n r\'e9ng r\'b7i v\'b5 gh\'aa g\'edm \'ae\'d5n th\'d5.
\par M\'e9t quan cai tr\'de m\'edi \'ae\'d5n thay ch\'a9n m\'e9t vi\'aan quan cai tr\'de c\'f2, nh\'cat \'ae\'denh th\'cay quan cai tr\'de c\'f2 l\'b5 m\'e9t t\'aan d\'e8t \'ae\'c6c hay t\'d6 h\'acn th\'d5 n\'f7a. Th\'d5 r\'e5i, \'ae\'ad\'eang s\'b8 \'aeang l
\'b5m d\'eb, c\'abng tr\'d7nh \'aeang th\'f9c hi\'d6n, k\'d5 ho\'b9ch \'ae\'b7 nghi\'aan c\'f8u, m\'e4i vi\'d6c \'ae\'d2u qu\'bcng \'aei, x\'d5p x\'e3 c\'b6.
\par }\pard \qc \li0\ri0\sb120\sa80\sl-300\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 Sang \'a7\'abng D\'ad\'acng, c\'b8c quan to\'b5n quy\'d2n ch\'d8 nh\'bbm c\'e3 m\'e9t m\'f4c \'ae\'dd
ch: ki\'d5m vi\'d6c b\'e6 d\'f4ng b\'cc b\'b9n, con c\'b8i, h\'e4 h\'b5ng, nh\'f7ng k\'ce v\'cbn \'ae\'e9ng tuy\'d3n c\'f6 cho nh\'f7ng ng\'ad\'eai h\'e4 c\'e3 th\'d3 nh\'ea v\'b6 \'ae\'ad\'eec; th\'ad\'eang th\'ad\'eang l\'b5 m\'e9t t\'aan n\'ee nh\'ad
 ch\'f3a ch\'e6m, b\'de ch\'f1 n\'ee s\'a8n \'ae\'e3n, v\'b5 h\'ben c\'c7n ti\'d2n.
\par }\pard \qc \li0\ri0\sb120\sa80\sl-272\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 N\'a8m 19.., ng\'ad\'eai ta tr\'b6 h\'d5t 36.300 \'ae\'e5ng b\'b9c ti\'d2n l\'ad\'acng cho vi\'aan ch\'f8
c ng\'e5i \'a8n kh\'abng ch\'bcng ph\'b6i l\'b5m g\'d7 c\'b6, v\'b5 n\'a8m sau n\'f7a h\'d5t 300.000.
\par N\'a8m 1909 kinh ph\'dd v\'d2 vi\'d6c thuy\'aan chuy\'d3n vi\'aan ch\'f8c trong n\'e9i \'ae\'dea \'a7\'abng D\'ad\'acng h\'d5t 155.000 phr\'a8ng. Vi\'d6c thuy\'aan chuy\'d3n ra ngo\'b5i n\'ad\'edc chi ti\'aau h\'d5t l.500.000 phr\'a8ng.
\par Ri\'aang b\'e9 m\'b8y cai tr\'de \'eb ph\'f1 to\'b5n quy\'d2n \'ae\'b7 d\'efng h\'d5t 1.000.000 phr\'a8ng k\'d3 c\'b6 50 ng\'b5n phr\'a8ng tr\'b6 c\'abng nh\'f7ng ng\'ad\'eai \'eb v\'b5 l\'b5m v\'ad\'ean.
\par Vi\'aan to\'b5n quy\'d2n v\'b5 hai m\'ad\'aci m\'e8t t\'aan tu\'fa thu\'e9c m\'e7i n\'a8m l\'dcnh h\'acn m\'e9t tri\'d6u phr\'a8ng, ch\'ada k\'d3 nh\'f7ng m\'e3n ph\'f4 c\'cap k\'d5ch s\'ef chi\'d5m m\'cat 2.500.000 \'ae\'e5ng phr\'a8ng c\'f1a c\'abng qu
\'fc.
\par Ng\'ad\'eai ta b\'e8 tr\'dd c\'b6 m\'e9t chi\'d5n h\'b9m cho vi\'aan to\'b5n quy\'d2n di chuy\'d3n. Vi\'d6c s\'bep x\'d5p t\'e8n m\'cat 300.000 phr\'a8ng, \'cay l\'b5 ch\'ada k\'d3 nh\'f7ng kho\'b6n ph\'f4 c\'cap linh tinh l\'aan t\'edi l00.000 phr\'a8
ng cho m\'e7i chuy\'d5n.
\par }{\f37\fs20\expnd0\expndtw-2\cgrid0\insrsid1378858 Ng\'b5i to\'b5n quy\'d2n ch\'ada v\'f5a \'fd v\'edi nh\'f7ng l\'a9u \'ae\'b5i nguy nga l\'e9ng l\'c9y c\'f1a ng\'b5i \'eb S\'b5i G\'dfn v\'b5 H\'b5 N\'e9i, Ng\'b5i c\'dfn mu\'e8n c\'e3 nh\'f7ng nh\'b5 ngh
\'d8 m\'b8t v\'b5 bi\'d6t th\'f9 \'eb b\'b7i bi\'d3n n\'f7a; th\'d5 l\'b5 d\'a9n An Nam kh\'e8n kh\'e6 l\'b9i ph\'b6i n\'e9p h\'b5ng tr\'a8m ng\'b5n phr\'a8ng cho h\'b5nh \'ae\'e9ng ng\'abng cu\'e5ng \'cay.
\par }{\f37\fs20\cgrid0\insrsid1378858 N\'a8m 19.., \'abng ho\'b5ng V. \'ae\'ac. \'a7. \'aei vi\'d4n chinh gh\'d0 qua S\'b5i G\'dfn. Quan th\'e8ng \'ae\'e8c ngh\'aanh ti\'d5p \'abng ho\'b5ng m\'e9t c\'b8ch \'ae\'d5 v\'ad\'acng. B\'e8n ng\'b5y ti\'d5p \'ae\'e3
n l\'b5 b\'e8n ng\'b5y lu b\'ef y\'d5n ti\'d6c. V\'b5 d\'a9n Nam K\'fa \'ae\'b8ng th\'ad\'acng \'ae\'b7 ph\'b6i tr\'b6 h\'d5t 80.000 phr\'a8ng.
\par }{\f37\fs20\expnd0\expndtw-4\cgrid0\insrsid1378858 C\'f2ng n\'a8m \'cay, trong l\'f3c d\'a9n An Nam \'aeang ch\'d5t \'ae\'e3i v\'b5 d\'a9n Nam K\'fa b\'de n\'b9n l\'f4t, ch\'bcng c\'e3 ch\'e7 n\'ad\'acng th\'a9n, th\'d7 ng\'ad\'eai ta l\'b9i m\'eb y\'d5
n ti\'d6c linh \'ae\'d7nh \'ae\'d3 ngh\'aanh ti\'d5p m\'e9t c\'b8ch \'ae\'d5 v\'ad\'acng m\'e9t h\'b9m \'ae\'e9i Anh trong t\'b8m ng\'b5y v\'b5 t\'b8m \'ae\'aam li\'d2n. D\'dc nhi\'aan l\'b5 nh\'f7ng ng\'ad\'eai n\'abng d\'a9n ngh\'cco kh\'e6 An Nam ph
\'b6i g\'b8nh nh\'f7ng ph\'dd t\'e6n \'ae\'e3, c\'f2ng nh\'ad m\'e4i l\'c7n.
\par }\pard \qc \li0\ri0\sb120\sa80\sl-280\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 *\line *    *
\par }\pard \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 M\'e9t vi\'aan th\'e8ng s\'f8 l\'cbp c\'b6 m\'e9t \'ae\'e9i k\'fe binh v\'b5 kh\'abng bao gi\'ea \'aei 
\'ae\'a9u m\'b5 kh\'abng c\'e3 \'ae\'e9i \'cay \'aei h\'e9 t\'e8ng, v\'b5 nh\'ad th\'d5, theo nh\'ad ng\'b5i n\'e3i, l\'b5 \'ae\'d3 n\'a9ng cao uy t\'ddn c\'f1a ng\'b5i v\'edi x\'f8 b\'b6o h\'e9.
\par Theo truy\'d2n th\'e8ng, c\'b8c vi\'aan cai tr\'de l\'b5 nh\'f7ng \'abng vua con mu\'e8n c\'b8i g\'d7 quanh m\'d7nh c\'f2ng xa hoa tr\'b8ng l\'d6. H\'e4 n\'e3i c\'e3 th\'d5 m\'edi n\'a9ng cao \'ae\'ad\'eec uy t\'ddn c\'f1a h\'e4 \'ae\'e8i v\'edi d\'a9n b
\'b6n x\'f8.
\par \'a7\'b7 c\'e3 s\'bdn nh\'b5 c\'f6a v\'b5 \'ae\'e5 \'ae\'b9c kh\'abng m\'cat ti\'d2n, c\'b8c ng\'b5i vi\'aan ch\'f8c Nh\'b5 n\'ad\'edc l\'b9i \'ae\'ad\'eec c\'abng qu\'fc h\'b5ng t\'d8nh tr\'b6 c\'b6 ti\'d2n \'ae\'ccn cho n\'f7a. C\'e3 l\'c7n, m\'e9t vi
\'aan quan cai tr\'de \'ae\'b7 kh\'abng ng\'c7n ng\'b9i t\'f9 \'fd chi ti\'aau h\'bcn m\'e9t s\'e8 ti\'d2n 50.000 phr\'a8ng \'ae\'d3 b\'bec \'ae\'ccn \'aei\'d6n \'eb nh\'b5 ri\'aang.
\par Kh\'abng nh\'f7ng ng\'ad\'eai tr\'abng nom qu\'d0t d\'e4n nh\'b5 c\'f6a m\'b5 c\'b6 ng\'ad\'eai \'ae\'b8nh xe ng\'f9a, ng\'ad\'eai gi\'f7 ng\'f9a v\'b5 t\'cat c\'b6 nh\'f7ng ng\'ad\'eai h\'c7u k\'ce h\'b9, \'ae\'d2u do ng\'a9n s\'b8ch \'ae\'dea ph\'ad\'ac
ng tr\'b6 ti\'d2n c\'abng c\'b6. C\'b6 s\'b8ch b\'b8o gi\'b6i tr\'dd c\'f2ng \'ae\'ad\'eec cung c\'cap kh\'abng cho nh\'f7ng con ng\'ad\'eai t\'e8t s\'e8 \'cay.
\par }{\f38\fs20\cgrid0\insrsid1378858 \'eb}{\f37\fs20\cgrid0\insrsid1378858  c\'b6 c\'b8c to\'b5 s\'f8 \'ae\'d2u c\'e3 t\'f5 6 \'ae\'d5n 9 con ng\'f9a v\'b5 5, 6 c\'e7 xe sang tr\'e4ng \'ae\'f1 c\'b8c lo\'b9i. Ngo\'b5i nh\'f7ng ph\'ad\'acng ti\'d6n giao th
\'abng \'ae\'b7 qu\'b8 th\'f5a \'cay, ng\'ad\'eai ta c\'dfn s\'bem th\'aam nh\'f7ng xe h\'aci l\'b5m t\'e8n cho c\'abng qu\'fc h\'b5ng ch\'f4c v\'b9n \'ae\'e5ng.
\par C\'e3 nh\'f7ng vi\'aan nu\'abi c\'b6 m\'e9t chu\'e5ng ng\'f9a \'aeua.
\par C\'e3 nh\'f7ng c\'abng s\'f8 \'eb m\'e9t v\'b5i t\'d8nh \'ae\'b7 k\'aa c\'b8c kho\'b6n s\'bem s\'f6a \'b8o, \'ae\'e5 d\'efng v\'d6 sinh, \'ae\'b5n d\'ad\'acng c\'c7m v\'b5 c\'b8c th\'f8c \'a8n u\'e8ng v\'b5o s\'e6 s\'b8ch k\'d5 to\'b8n th\'b5nh nh\'f7ng m
\'e3n mua v\'cbt t\'ad c\'c7n thi\'d5t \'ae\'d3 tu b\'e6 to\'b5 s\'f8, hay th\'b5nh m\'e9t kho\'b6n g\'d7 t\'ad\'acng t\'f9 nh\'ad th\'d5 \'ae\'d3 b\'bet ng\'a9n s\'b8ch \'ae\'dea ph\'ad\'acng ph\'b6i g\'b8nh.
