\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~}{\f38\fs20\cf1\cgrid0\insrsid1378858 \'eb}{
\f38\fs20\insrsid1378858  }{\f37\fs20\insrsid1378858 \'ae\'e5n \'aei\'d2n c\'f1a m\'e9t ch\'f1 \'aei\'d2n n\'e4, 6 ng\'ad\'eai b\'b6n x\'f8 \'ae\'b7 b\'de b\'bet v\'d7 kh\'abng n\'b9p thu\'d5.
\par Ra to\'b5, nh\'f7ng ng\'ad\'eai b\'de c\'b8o tuy\'aan b\'e8 r\'bbng, vi\'aan c\'abng s\'f8 \'a7\'acla R\'abs\'ac khi thu\'aa h\'e4, \'ae\'b7 h\'f8a:
\par 1. Tr\'b6 m\'e9t ph\'c7n thu\'d5 cho h\'e4,
\par 2. Mi\'d4n c\'abng d\'dech cho h\'e4, v\'b5
\par 3. Tr\'b6 cho h\'e4 10 phr\'a8ng 30 ng\'b5y c\'abng.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'c7n ph\'b6i ch\'f3 \'fd r\'bbng, t\'aan ch\'f1 \'ae\'e5
n \'aei\'d2n \'cay \'ae\'b7 tho\'b6 thu\'cbn v\'edi nh\'f7ng ng\'ad\'eai b\'b6n x\'f8: h\'e4 s\'cf ch\'d8 l\'b5m vi\'d6c cho h\'ben m\'e7i tu\'c7n m\'e9t ng\'b5y th\'abi. V\'b5 ng\'ad\'eai b\'b6n x\'f8 \'ae\'b7 k\'fd giao k\'cco l\'b5m trong 30 tu\'c7
n. Nh\'ad th\'d5 ngh\'dca l\'b5 b\'b6y th\'b8ng r\'ad\'eci m\'edi l\'b5m \'ae\'ad\'eec 10 phr\'a8ng! \'a7\'d3 ki\'d5m k\'d5 sinh nhai, ng\'ad\'eai b\'b6n x\'f8 bu\'e9c ph\'b6i l\'b5m thu\'aa cho nh\'f7ng ng\'ad\'eai Mang\'b8t b\'aan c\'b9nh. H\'acn n\'f7a
, vi\'aan c\'abng s\'f8 \'a7\'acla R\'abs\'ac kh\'abng nh\'f7ng kh\'abng n\'e9p thu\'d5 cho h\'e4 nh\'ad h\'ben \'ae\'b7 h\'f8a, v\'b5 c\'dfn chi\'d5m m\'cat s\'e8 ti\'d2n m\'b5 nh\'f7ng ng\'ad\'eai b\'b6n x\'f8 n\'b5y chuy\'d3n cho h\'ben \'ae\'d3 n\'e9
p thu\'d5.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Nh\'b5 ch\'f8c tr\'b8ch \'ae\'dea ph\'ad\'acng m\'eb m\'e9
t cu\'e9c \'aei\'d2u tra. Nh\'adng Nghi\'d6p \'aeo\'b5n nh\'b5 n\'abng \'eb Makhan\'abr\'ab (c\'e3 th\'d3 l\'b5 \'a7\'acla R\'abs\'ac l\'b5 h\'e9i vi\'aan Nghi\'d6p \'aeo\'b5n n\'b5y) bi\'d5t vi\'d6c \'cay, \'ae\'b7 \'ae\'b8nh \'aei\'d6n cho vi\'aan to
\'b5n quy\'d2n ph\'b6n \'ae\'e8i c\'b6nh binh kh\'abng k\'dep th\'eai \'ae\'d5n \'ae\'e5n \'aei\'d2n c\'f1a c\'abng s\'f8 \'a7\'acla R\'abs\'ac, v\'b5 \'ae\'b7 y\'aau c\'c7u tr\'f5ng ph\'b9t tr\'ad\'ebng \'ae\'e5n c\'b6nh binh v\'d2 t\'e9i \'ae\'b7 v\'b9
ch tr\'c7n h\'b5nh vi phi ph\'b8p c\'f1a ng\'ad\'eai Ph\'b8p.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 \'a7\'d3 \'d8m "c\'a9u chuy\'d6n" \'cay \'aei, vi\'aan to\'b5n quy\'d2n \'ae\'b7 nhanh ch\'e3ng d\'cbp t\'bet d\'ad lu
\'cbn.
\par Nh\'f7ng ng\'ad\'eai lao \'ae\'e9ng \'eb thu\'e9c \'ae\'dea \'ae\'ad\'eec b\'b6o h\'e9 nh\'ad th\'d5 \'ae\'cay v\'b5 ch\'ddnh s\'b8ch h\'eep t\'b8c \'ae\'ad\'eec th\'f9c hi\'d6n nh\'ad th\'d5 \'ae\'cay.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nguy\'d4n \'b8i qu\'e8c
