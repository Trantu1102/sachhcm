\'abm nay, ch\'f3ng t\'abi nh\'cbn \'ae\'ad\'eec m\'e9t s\'e8 }{\i\f37\fs20\insrsid1378858 Courrier Colonial}{\f37\fs20\insrsid1378858 , \'ae\'d2 ng\'b5y 27 th\'b8ng 6 v\'f5a qua, tr}{\f37\fs20\expnd0\expndtw-2\insrsid1378858 \'aan \'ae\'c7u t\'ea n\'b5
y c\'e3 \'ae\'a8ng m\'e9t b\'b5i d\'b5i hai c\'e9t, d\'ad\'edi c\'b8i \'ae\'c7u \'ae\'d2 k\'ddch \'ae\'e9ng l\'b5 "}{\f38\fs20\expnd0\expndtw-2\insrsid1378858 Gi\'ea PH\'f3T NGHI\'a3M TR\'e4NG}{\f37\fs20\expnd0\expndtw-2\insrsid1378858 ". C\'b8i \'ae\'c7
u \'ae\'d2 k\'aau r\'e7ng \'cay , k\'aau nh\'ad m\'e9t l\'eai h\'ab h\'b5o c\'c7m v\'f2 kh\'dd, \'ae\'b7 khi\'d5n ch\'f3ng t\'abi ph\'b6i \'ae\'e4c t\'f5 \'ae\'c7u ch\'dd cu\'e8i b\'b5i b\'b8o d\'b5i n\'b5y \'ae\'d3 bi\'d5t r\'e2 l\'fd do c\'f1a ti\'d5
ng k\'aau c\'c7u c\'f8u \'ae\'e3 l\'b5 g\'d7. Ch\'ada \'ae\'e4c h\'d5t c\'e9t th\'f8 nh\'cat, ch\'f3ng t\'abi c\'f2ng \'ae\'b7 g\'c7n th\'cay \'ae\'ad\'eec m\'f4c \'ae\'ddch c\'f1a t\'b8c gi\'b6, v\'b5 c\'b5ng \'ae\'e4c ti\'d5p - v\'f5a \'ae\'e4c v\'f5a m
\'d8m c\'ad\'eai - th\'d7 c\'b6m t\'ad\'ebng \'ae\'c7u ti\'aan c\'f1a ch\'f3ng t\'abi c\'b5ng v\'f7ng ch\'bec l\'b9i. C\'b6m t\'ad\'ebng c\'f1a ch\'f3ng t\'abi t\'e3m l\'b9i l\'b5: m\'e9t ch\'b5ng th\'f9c d\'a9n \'ae\'b7 mu\'e8n d\'efng b\'b6n }{
\i\f37\fs20\expnd0\expndtw-2\insrsid1378858 Y\'aau s\'b8ch c\'f1a nh\'a9n d\'a9n An Nam}{\i\f37\fs20\expnd0\expndtw-2\super\insrsid1378858 2}{\f37\fs20\expnd0\expndtw-2\insrsid1378858  \'ae\'d3 m\'eb m\'e9t cu\'e9c t\'can c\'abng gi\'b8n ti\'d5p v\'b5o ch
\'ddnh s\'b8ch c\'f1a \'abng Anbe Xar\'ab, to\'b5n quy\'d2n \'a7\'abng D\'ad\'acng, m\'e9t cu\'e9c t\'can c\'abng m\'b5 anh ta \'ae\'b7 ch\'f3 \'fd t\'ab \'aei\'d3m b\'bbng nh\'f7ng l\'eai ph\'b6n \'ae\'e8i c\'e3 t\'ddnh ch\'cat y\'aau n\'ad\'edc, b\'bb
ng l\'dfng y\'aau chu\'e9ng ch\'a9n l\'fd, b\'bbng tinh th\'c7n hy sinh v\'b5 t\'cbn tu\'fe v\'d7 l\'eei \'ddch chung, v\'a9n v\'a9n, v\'a9n v\'a9n.}{\f37\fs20\insrsid1378858    
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Ph\'a9n t\'ddch m\'e9t v\'b5i \'aeo\'b9n trong b\'b5i b\'b8
o, ch\'f3ng ta s\'cf th\'cay \'ae\'ad\'eec ch\'b5ng ta hi\'d3u ch\'f1 ngh\'dca y\'aau n\'ad\'edc, ch\'a9n l\'fd v\'b5 l\'eei \'ddch chung c\'f1a n\'ad\'edc Ph\'b8p nh\'ad th\'d5 n\'b5o.   
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \'a4ng Camil\'ac \'a7\'acvila khao kh\'b8t c\'b8i danh hi
\'d6u ng\'ad\'eai y\'aau chu\'e9ng ch\'a9n l\'fd trong th\'d5 gi\'edi n\'b5y v\'b5 trong th\'d5 gi\'edi b\'aan kia. L\'dfng khao kh\'b8t \'cay l\'b5 ch\'ddnh \'ae\'b8ng v\'b5 h\'eep l\'fd, ch\'f3ng t\'abi vui l\'dfng th\'f5a nh\'cbn nh\'ad v\'cby. Nh\'ad
ng mong \'abng cho ph\'d0p ch\'f3ng t\'abi ch\'d8 cho \'abng th\'cay r\'bbng c\'b8i }{\f37\fs20\expnd0\expndtw-2\insrsid1378858 ch\'a9n l\'fd theo t\'a9m \'ae\'dea c\'f1a \'abng, c\'b8i ch\'a9n l\'fd theo quan ni\'d6m c\'f1a b\'e4n th\'f9c d\'a9n th\'ef
 gh\'d0t d\'a9n b\'b6n x\'f8, kh\'abng c\'e3 g\'d7 l\'b5 gi\'e8ng v\'edi ch\'a9n l\'fd c\'f1a ch\'f3ng t\'abi, ch\'a9n l\'fd m\'b5 sau n\'b5y ch\'f3ng t\'abi s\'cf n\'e3i s\'ac qua \'ae\'d5n, c\'f2ng nh\'ad kh\'abng c\'e3 g\'d7 l\'b5 gi\'e8ng v\'edi ch
\'a9n l\'fd theo quan ni\'d6m c\'f1a nh\'f7ng ng\'ad\'eai Ph\'b8p t\'e8t \'eb n\'ad\'edc Ph\'b8p c\'b6. S\'eb d\'dc ch\'f3ng t\'abi nh\'cbn x\'d0t m\'e9t c\'b8ch l\'dech s\'f9 nh\'ad v\'cby, l\'b5 nh\'bbm t\'e1 th\'b8i \'ae\'e9 t\'abn tr\'e4ng quy\'d2n t
\'f9 do ng\'abn lu\'cbn.}{\f37\fs20\insrsid1378858    
\par }\pard \qj \fi397\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Tr\'ad\'edc h\'d5t, ch\'f3ng t\'abi th\'cay trong b\'b5i b\'b8o n\'e3i v\'d2 v\'can \'ae\'d2 \'ae\'e3, c\'b8i c\'a9u 
\'b8m ch\'d8 c\'e3 \'b8c \'fd l\'b5 "ngay ng\'b5y h\'abm sau \'abng Anbe Xar\'ab \'ae\'c6t ch\'a9n tr\'eb v\'d2 \'ae\'cat n\'ad\'edc Ph\'b8p, th\'d7 nh\'f7ng nh\'b5 \'b8i qu\'e8c An Nam l\'cbp t\'f8c b\'b8c b\'e1 nh\'f7ng l\'eai tuy\'aan b\'e8 l\'b9
c quan c\'f1a \'abng".   
\par }\pard \qj \fi397\li0\ri0\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ch\'f3ng t\'abi kh\'abng \'ae\'ad\'eec bi\'d5t b\'b5i di\'d4n v\'a8n m\'b5 \'abng \'a7\'acvila \'ae\'b7 \'b8m ch\'d8, ch\'f3
ng t\'abi kh\'abng b\'b5n v\'d2 b\'b5i di\'d4n v\'a8n \'cay. Nh\'adng ngay t\'f5 b\'a9y gi\'ea ch\'f3ng t\'abi c\'f2ng c\'e3 th\'d3 n\'e3i r\'bbng, d\'ef sao \'aei n\'f7a th\'d7 t\'b8m \'aei\'d3m c\'f1a b\'b6n }{\i\f37\fs20\insrsid1378858 Y\'aau s\'b8ch c
\'f1a nh\'a9n d\'a9n An Nam}{\f37\fs20\insrsid1378858  kh\'abng n\'e3i ng\'ad\'eec l\'b9i ch\'f3t n\'b5o nh\'f7ng \'fd ki\'d5n c\'f1a \'abng Anbe Xar\'ab, ng\'ad\'eai \'ae\'b7 tuy\'aan b\'e8 trong t\'cat c\'b6 nh\'f7ng di\'d4n v\'a8n c\'f1a m\'d7nh \'ae
\'e4c tr\'ad\'edc nh\'f7ng ng\'ad\'eai b\'b6n x\'f8 r\'bbng m\'d7nh
\par }\pard \qj \li0\ri0\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858  ki\'aan quy\'d5t mu\'e8n m\'eb ra cho h\'e4 m\'e9t k\'fb nguy\'aan t\'f9 do v\'b5 c\'abng l\'fd. V\'d7 nh\'f7ng l\'eai h\'f8a h
\'d1n c\'f1a \'abng ph\'ef h\'eep v\'edi nh\'f7ng y\'aau s\'b8ch c\'f1a ch\'f3ng t\'abi, n\'aan ngay khi \'ae\'ad\'eec bi\'d5t tin \'abng tr\'eb v\'d2 Ph\'b8p ch\'f3ng t\'abi v\'e9i v\'b7 g\'f6i \'ae\'d5n \'abng b\'b6n ghi nh\'f7ng y\'aau s\'b8ch c\'f1
a ch\'f3ng t\'abi. Trong l\'f3c ch\'ea xem ch\'ddnh s\'b8ch c\'f1a \'abng \'ae\'b8p \'f8ng \'ae\'ad\'eec \'ae\'d5n m\'f8c \'ae\'e9 n\'b5o nh\'f7ng nguy\'d6n v\'e4ng c\'f1a ch\'f3ng t\'abi, ch\'f3ng t\'abi vui l\'dfng th\'f5a nh\'cbn r\'bbng \'ae\'b7 nhi
\'d2u l\'c7n }{\i\f37\fs20\insrsid1378858 \'abng ta}{\f37\fs20\insrsid1378858  ph\'b8t bi\'d3u \'ae\'d3 b\'b6o v\'d6 nh\'f7ng ng\'ad\'eai b\'b6n x\'f8, ch\'e8ng l\'b9i s\'f9 \'b8p b\'f8c 
\par }\pard \qj \li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 c\'f1a }{\i\f37\fs20\insrsid1378858 nh\'f7ng t\'aan th\'f9c d\'a9n \'ae\'e9c \'b8c}{\f37\fs20\insrsid1378858  v\'b5 s\'f9 chuy
\'aan ch\'d5 c\'f1a }{\i\f37\fs20\insrsid1378858 nh\'f7ng t\'aan vi\'aan ch\'f8c t\'b5n b\'b9o,}{\f37\fs20\insrsid1378858  b\'cat ch\'cap nh\'f7ng \'ae\'dfn c\'abng k\'ddch c\'f1a m\'e9t chi\'d5n d\'dech v\'f5a \'ae\'b8ng gh\'d0t v\'f5a nham hi\'d3m c\'f1
a b\'b8o ch\'dd, m\'e9t chi\'d5n d\'dech kh\'abng gi\'cau k\'ddn \'ae\'ad\'eec t\'ddnh ph\'b6n ngh\'dech c\'f1a n\'e3 b\'bbng nh\'f7ng l\'eai ngu\'fe bi\'d6n v\'d2 uy t\'ddn v\'b5 b\'bbng nh\'f7ng l\'fd l\'cf gi\'b6 d\'e8i v\'d2 l\'eei \'ddch chung.

\par }\pard \qj \fi720\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\fs20\insrsid1378858\charrsid5792077 Ch}{\f37\fs20\insrsid1378858\charrsid5792077 \'f3ng t\'abi \'ae\'b7 nh\'can m\'b9nh nh\'f7ng ch\'f7 }{
\i\f37\fs20\insrsid1378858\charrsid5792077 nh\'f7ng t\'aan th\'f9c d\'a9n \'ae\'e9c \'b8c}{\f37\fs20\insrsid1378858\charrsid5792077  v\'b5 }{\i\f37\fs20\insrsid1378858\charrsid5792077 nh\'f7ng vi\'aan ch\'f8c t\'b5n b\'b9o}{
\f37\fs20\insrsid1378858\charrsid5792077 , v\'d7 ch\'f3ng t\'abi bi\'d5t r\'bbng c\'e3 nh\'f7ng ng\'ad\'eai th\'f9c d\'a9n ch\'ddnh tr\'f9c v\'b5 nh\'f7ng vi\'aan ch\'f8c c\'abng b\'bbng. Kh\'e8n n\'e7i,
\par }\pard\plain \s15\qj \li0\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 h\'e4 c\'dfn l\'a9u m\'edi l\'b5 \'aea s\'e8, th\'cbm ch\'dd c
\'dfn \'aeang s\'ee r\'bbng h\'e4 l\'b5 m\'e9t thi\'d3u s\'e8 r\'cat nh\'e1 n\'f7a.   
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 R\'e5i \'abng \'a7\'acvila ch\'d0p l\'b9i t\'b8m y\'aau s
\'b8ch c\'f1a ng\'ad\'eai An Nam, v\'b5 k\'ccm theo y\'aau s\'b8ch th\'f8 ba - t\'f9 do b\'b8o ch\'dd v\'b5 ng\'abn lu\'cbn - \'abng \'ae\'ada ra nh\'cbn x\'d0t n\'b5y: }{\i\f37\fs20\insrsid1378858 m\'b5 b\'b6n th\'a9n ch\'f3ng ta c\'f2ng kh\'abng \'ae
\'ad\'eec h\'ad\'ebng}{\f37\fs20\insrsid1378858 , v\'b5 k\'ccm theo y\'aau s\'b8ch th\'f8 b\'b6y - thay ch\'d5 \'ae\'e9 s\'bec l\'d6nh b\'bbng ch\'d5 \'ae\'e9 lu\'cbt- \'abng \'ae\'ada ra nh\'cbn x\'d0t n\'b5y: }{\i\f37\fs20\insrsid1378858 h\'d6t nh\'ad 
\'eb n\'ad\'edc ta}{\f37\fs20\insrsid1378858 .   
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'f2ng v\'cby th\'abi, t\'ddnh gi\'b6 d\'e8i c\'f2ng kh
\'abng \'ae\'ad\'eec che \'ae\'cby k\'ddn \'ae\'b8o g\'d7 h\'acn. Ch\'f3ng t\'abi xin ph\'d0p h\'e1i \'abng \'a7\'acvila r\'bbng ph\'b6i ch\'a8ng \'abng coi \'ae\'e9c gi\'b6 c\'f1a \'abng l\'b5 nh\'f7ng ng\'ad\'eai qu\'b8 \'ad ngu ng\'e8c, khi \'abng \'ae
\'denh d\'efng c\'b8i l\'e8i b\'d7nh lu\'cbn qu\'fb quy\'d6t \'ae\'e3 \'ae\'d3 l\'b5m cho h\'e4 l\'c9n l\'e9n t\'d7nh tr\'b9ng ho\'b5n to\'b5n v\'b5 v\'dcnh vi\'d4n kh\'abng c\'e3 quy\'d2n t\'f9 do t\'ad t\'ad\'ebng v\'edi s\'f9 ki\'d3m duy\'d6t, t\'f8c l
\'b5 m\'e9t t\'d7nh tr\'b9ng ho\'b5n to\'b5n c\'e3 t\'ddnh ch\'cat t\'b9m th\'eai v\'b5 ch\'d8 nh\'bbm m\'e9t v\'b5i lo\'b9i tin t\'f8c th\'abi. C\'dfn v\'d2 vi\'d6c thay th\'d5 ch\'d5 \'ae\'e9 s\'bec l\'d6nh b\'bbng ch\'d5 \'ae\'e9 lu\'cbt, th\'d7 ch\'f3
ng t\'abi kh\'abng hi\'d3u t\'b9i sao \'abng \'a7\'acvila l\'b9i s\'ee vi\'d6c \'cay \'ae\'d5n th\'d5, v\'d7 nh\'f7ng ng\'ad\'eai trong s\'b9ch th\'d7 kh\'abng vi\'d6c g\'d7 ph\'b6i s\'ee s\'f9 ki\'d3m so\'b8t c\'f1a ai c\'b6, ngay c\'b6 s\'f9 ki\'d3m so
\'b8t c\'f1a Ngh\'de vi\'d6n n\'f7a.
\par }{\expnd0\expndtw-4\insrsid1378858 L\'eai tr\'b8ch c\'f8 n\'c6ng nh\'cat c\'f1a \'abng \'a7\'acvila \'ae\'e8i v\'edi nh\'f7ng nh\'b5 \'b8i qu\'e8c An Nam l\'b5 \'ae\'b7 ph\'b8t bi\'d3u tr\'f9c ti\'d5p v\'edi nh\'a9n d\'a9n Ph\'b8p v\'b5 v\'edi n\'d2n C
\'abng l\'fd th\'d5 gi\'edi c\'f1a t\'cat c\'b6 c\'b8c c\'ad\'eang qu\'e8c. Ch\'f3ng t\'abi s\'bdn s\'b5ng th\'f5a nh\'cbn v\'edi \'abng r\'bbng nh\'f7ng ng\'ad\'eai An Nam \'ae\'b7 \'aei v\'b5o m\'e9t tr\'ad\'eang h\'eep ho\'b5n to\'b5n \'ae\'b8ng x\'f6
 gi\'b6o, khi kh\'abng nh\'ea \'ae\'d5n m\'e9t nh\'b5 th\'f9c d\'a9n c\'ec \'abng l\'b5m trung gian. Th\'f5a nh\'cbn nh\'ad v\'cby r\'e5i, ch\'f3ng t\'abi xin ch\'d0p l\'b9i nguy\'aan v\'a8n c\'b8i c\'a9u m\'b5 \'abng cho l\'b5 kh\'e3 hi\'d3u, c\'a9u \'ae
\'e3 nh\'ad sau: "\'a7\'ada ra nh\'f7ng y\'aau s\'b8ch tr\'aan \'ae\'a9y, nh\'a9n d\'a9n An Nam tr\'abng c\'cby v\'b5o ch\'ddnh ngh\'dca th\'d5 gi\'edi c\'f1a t\'cat c\'b6 c\'b8c c\'ad\'eang qu\'e8c v\'b5 \'ae\'c6c bi\'d6t tin v\'b5o l\'dfng r\'e9ng l\'ad
\'eeng c\'f1a nh\'a9n d\'a9n Ph\'b8p cao c\'b6, t\'f8c l\'b5 c\'f1a nh\'f7ng ng\'ad\'eai \'aeang n\'bem v\'cbn m\'d6nh c\'f1a nh\'a9n d\'a9n An Nam, c\'f1a nh\'f7ng ng\'ad\'eai, do ch\'e7 n\'ad\'edc Ph\'b8p l\'b5 m\'e9t n\'ad\'edc C\'e9ng ho\'b5, n\'aan 
\'ae\'ad\'eec coi l\'b5 nh\'f7ng ng\'ad\'eai b\'b6o h\'e9 cho nh\'a9n d\'a9n An Nam".   
\par }\pard\plain \qj \li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ch\'f3ng t\'abi kh\'abng d\'b8m gi\'b6i th\'ddch cho \'abng \'a7
\'acvila r\'bbng, th\'d5 n\'b5o l\'b5 m\'e9t n\'ad\'edc C\'e9ng ho\'b5, v\'d7 m\'abn s\'ad ph\'b9m kh\'abng ph\'b6i l\'b5 s\'eb tr\'ad\'eang c\'f1a ch\'f3ng t\'abi, nh\'adng v\'d7 \'abng t\'d7m c\'b8ch b\'ce qu\'d1o m\'e9t c\'a9u minh b\'b9ch nh\'ad v\'cb
y, n\'aan ch\'f3ng t\'abi t\'f9 h\'e1i kh\'abng bi\'d5t c\'e3 ph\'b6i \'abng \'ae\'b7 c\'e3 danh d\'f9 \'ae\'ad\'eec l\'b5m b\'e5i b\'d5p trong m\'e9t nh\'b5 b\'d5p nh\'b5 vua n\'b5o \'ae\'e3 ch\'a8ng.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 V\'b5 b\'a9y gi\'ea khi m\'b5 \'abng \'a7\'acvila t\'f9 h
\'e1i r\'bbng tr\'b8ch nhi\'d6m \'eb \'ae\'a9u, th\'d7 ch\'f3ng t\'abi ph\'b6i n\'e3i tr\'beng ra v\'edi \'abng r\'bbng c\'c7n t\'d7m tr\'b8ch nhi\'d6m, kh\'abng ph\'b6i \'eb ch\'ddnh s\'b8ch c\'f1a \'abng Xar\'ab m\'b5 \'eb t\'d7nh h\'d7nh th\'b6m h\'b9
i m\'b5 ng\'ad\'eai ta \'ae\'b7 \'ae\'d3 l\'b9i cho \'abng Xar\'ab. N\'d5u sau m\'e9t n\'f6a th\'d5 k\'fb s\'e8ng d\'ad\'edi s\'f9 th\'e8ng tr\'de c\'f1a n\'ad\'edc Ph\'b8p m\'b5 nh\'a9n d\'a9n An Nam r\'f3t cu\'e9c l\'b9i ph\'b6i \'aei xin v\'b5i b\'b6o 
\'ae\'b6m c\'b8 nh\'a9n v\'b5 v\'b5i quy\'d2n t\'f9 do m\'b5 t\'cat c\'b6 nh\'f7ng n\'ad\'edc l\'b8ng gi\'d2ng c\'f1a m\'d7nh \'ae\'d2u \'ae\'ad\'eec h\'ad\'ebng, th\'d7 \'aei\'d2u \'ae\'e3 kh\'abng ph\'b6i l\'b5 t\'b9i \'abng Xar\'ab th\'a9n d\'a9n b\'b6
n x\'f8, m\'b5 \'aei\'d2u \'ae\'e3 c\'e3 nguy\'aan nh\'a9n s\'a9u xa h\'acn n\'f7a, \'ae\'e3 l\'b5 do ch\'ddnh s\'b8ch b\'e3c l\'e9t v\'b5 ngu d\'a9n m\'b5 \'abng \'a7\'acvila v\'b5 b\'cc ph\'b8i tuy\'aan truy\'d2n, ch\'f8 kh\'abng ph\'b6i c\'f1a \'ab
ng Xar\'ab.   
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 A, b\'a9y gi\'ea ch\'f3ng t\'abi \'ae\'b7 n\'bem \'ae\'ad
\'eec \'ae\'e9ng c\'ac c\'f1a nh\'f7ng \'ae\'dfn c\'abng k\'ddch \'abng Xar\'ab r\'e5i. \'a4ng Xar\'ab b\'de c\'abng k\'ddch v\'d7 \'abng th\'a9n d\'a9n b\'b6n x\'f8.   
\par \'a4ng \'a7\'acvila nh\'bec nh\'eb r\'bbng nh\'f7ng ng\'ad\'eai \'ae\'b7 c\'e3 kinh nghi\'d6m \'eb \'a7\'abng D\'ad\'acng \'ae\'b7 c\'e8 c\'abng khuy\'aan \'abng Xar\'ab, nh\'adng \'abng Xar\'ab kh\'abng ch\'deu nghe h\'e4. Theo ng\'abn ng\'f7 c\'f1a nh
\'f7ng t\'aan th\'f9c d\'a9n \'ae\'e9c \'b8c, th\'f8 kinh nghi\'d6m \'eb \'a7\'abng D\'ad\'acng c\'e3 ngh\'dca l\'b5 kinh nghi\'d6m trong ngh\'d6 thu\'cbt b\'e3c l\'e9t, c\'ad\'edp b\'e3c ng\'ad\'eai b\'b6n x\'f8, kinh nghi\'d6m s\'e8ng b\'bbng m\'e5 h
\'abi c\'f1a ng\'ad\'eai b\'b6n x\'f8. \'a4ng Xar\'ab \'ae\'b7 khinh b\'d8 kh\'abng th\'ccm nghe l\'eai b\'e4n c\'e8 v\'can v\'f4 l\'eei \'cay, \'aei\'d2u \'ae\'e3 c\'f2ng d\'d4 hi\'d3u.   
\par }\pard \qj \li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 C\'b8i c\'a9u trong t\'ea }{\i\f37\fs20\insrsid1378858 Le Courrier d'Haiphong}{\f37\fs20\super\insrsid1378858 3}{
\f37\fs20\insrsid1378858  m\'b5 \'abng \'a7\'acvila d\'c9n ra v\'b5 tuy\'aan b\'e8 r\'bbng, c\'a9u \'ae\'e3 l\'b5 c\'e3 t\'ddnh ch\'cat ti\'aan tri }{\i\f37\fs20\insrsid1378858 (sic)}{\f37\fs20\insrsid1378858  x\'b8c nh\'cbn t\'cat c\'b6 nh\'f7ng \'aei
\'d2u m\'b5 ch\'f3ng t\'abi v\'f5a n\'e3i, nguy\'aan v\'a8n c\'a9u \'ae\'e3 nh\'ad sau:
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 "}{\insrsid1378858\charrsid5792077 Ch\'ddnh s\'b8ch \'ca
y (ch\'ddnh s\'b8ch th\'a9n d\'a9n b\'b6n x\'f8) c\'f1a \'abng Xar\'ab ch\'d8 c\'e3 th\'d3 ti\'d5n h\'b5nh \'ae\'ad\'eec b\'bbng c\'b8ch hy sinh l\'dfng t\'f9 t\'abn v\'b5 nh\'f7ng quy\'d2n l\'eei c\'f1a nh\'f7ng ng\'ad\'eai \'a2u \'eb n\'ad\'edc n\'b5
y, v\'d7 ch\'ddnh s\'b8ch \'ae\'e3 ch\'d8 nh\'bbm l\'b5m cho nh\'f7ng d\'a9n b\'b6n x\'f8 th\'b5nh nh\'f7ng ng\'ad\'eai b\'d7nh \'ae\'bcng v\'edi}{\insrsid1378858  ch\'f3ng ta, r\'e5i nhanh ch\'e3ng tr\'eb th\'b5nh ch\'f1 ch\'f3ng ta".   
\par  K\'d5t lu\'cbn: \'ae\'e8i v\'edi d\'a9n b\'b6n x\'f8, th\'d7 ph\'b6i gi\'f7 h\'e4 v\'dcnh vi\'d4n trong c\'b6nh n\'ab l\'d6. Ch\'f3ng t\'abi thi\'d5t t\'ad\'ebng r\'bbng, nh\'f7ng ng\'ad\'eai Ph\'b8p th\'abng
\par }\pard \s15\qj \li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 minh v\'b5 ch\'a9n th\'f9c bi\'d5t t\'e1 t\'ddnh \'adu vi\'d6t t\'f9 nhi\'aan c\'f1a m\'d7nh \'eb b\'cat c\'f8 n\'aci n\'b5o m\'d7
nh s\'e8ng, th\'d7 kh\'abng c\'c7n ph\'b6i s\'e8ng gi\'f7a nh\'f7ng ng\'ad\'eai b\'b6n
\par }\pard\plain \qj \li0\ri0\sa80\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 x\'f8 v\'dcnh vi\'d4n b\'de kho\'b8 m\'e5m b\'det mi\'d6ng v\'b5
 b\'de x\'e1 m\'f2i, m\'edi c\'e3 th\'d3 gi\'f7 \'ae\'ad\'eec t\'ddnh \'adu vi\'d6t \'ae\'e3.   
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Sau c\'efng, \'abng \'a7\'acvila cho r\'bbng m\'d7nh bi\'d5
t r\'e2 l\'b5 m\'e9t \'ae\'b6ng \'ae\'e9c l\'cbp \'ae\'b7 xu\'cat hi\'d6n v\'b5 \'ae\'b6ng n\'b5y \'ae\'b7 v\'ad\'eet qua \'ae\'c7u \'abng Xar\'ab \'ae\'d3 ph\'b8t bi\'d3u v\'edi nh\'a9n d\'a9n Ph\'b8p v\'b5 v\'edi c\'b8c c\'ad\'eang qu\'e8c m\'b5 h\'e4
 mu\'e8n n\'e3i v\'edi t\'ad c\'b8ch b\'d7nh \'ae\'bcng v\'edi nhau. \'a4ng n\'e3i th\'aam r\'bbng: \'ae\'a9y l\'b5 m\'e9t gi\'cac m\'ac v\'b5 t\'f5 gi\'cac m\'ac n\'b5y \'abng th\'cay ngu\'e5n g\'e8c c\'f1a sai l\'c7m m\'b5 \'abng Anbe Xar\'ab ph\'b9m ph
\'b6i l\'b5 n\'a8m 1913 \'abng Anbe \'ae\'b7 d\'b9y cho ng\'ad\'eai An Nam bi\'d5t r\'bbng n\'ad\'edc \'a7\'f8c \'ae\'b7 chi\'d5m And\'b8tx\'ac - Loren c\'f1a n\'ad\'edc Ph\'b8p n\'a8m 1871.   
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 N\'d5u c\'e3 m\'e9t \'ae\'b6ng \'ae\'e9c l\'cbp t\'e5n t
\'b9i, th\'d7 \'ae\'b6ng n\'b5y kh\'abng ph\'b6i \'aei \'a8n xin m\'e9t v\'b5i quy\'d2n t\'f9 do, m\'b5 thi\'d5u n\'e3 th\'d7 con ng\'ad\'eai l\'b5 m\'e9t t\'aan n\'ab l\'d6 kh\'e8n kh\'e6. Ch\'f3ng t\'abi th\'f6 l\'b5m y\'aan l\'dfng \'abng \'a7\'ac
vila b\'bbng c\'b8ch n\'e3i r\'bbng, \'a7\'b6ng c\'f1a ch\'f3ng t\'abi n\'e3i v\'edi nh\'a9n d\'a9n Ph\'b8p, c\'f2ng l\'b5 n\'e3i c\'b6 v\'edi \'abng \'a7\'acvila.   
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd0\expndtw-2\insrsid1378858 Cu\'e8i c\'efng, \'abng \'a7\'acvila kh
\'abng th\'d3 kh\'abng bi\'d5t v\'d2 m\'c6t qu\'e8c t\'d5, khi ng\'ad\'eai ta n\'e3i b\'d7nh \'ae\'bcng v\'edi nhau, ng\'ad\'eai ta d\'efng con \'ae\'ad\'eang ngo\'b9i giao, ch\'f8 kh\'abng ph\'b6i b\'bbng con \'ae\'ad\'eang th\'d8nh c\'c7u. V\'cby th\'d7
 gi\'cac m\'ac \'ae\'d1p m\'b5 ng\'ad\'eai ta ki\'aau h\'b7nh \'ae\'b7 t\'d7m th\'cay ch\'d7a kh\'e3a, t\'f9 n\'e3 \'ae\'b7 tan t\'b5nh.   
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ch\'f3ng t\'abi \'ae\'d3 cho \'abng \'a7\'acvila v\'edi m
\'e9t gi\'cac m\'ac kh\'b8c, gi\'cac m\'ac l\'b5m cho d\'a9n An Nam qu\'aan \'aei r\'bbng ch\'d8 v\'edi n\'f6a s\'e8 nh\'f7ng lu\'cbt d\'a9n s\'f9 m\'b5 tr\'ad\'edc kia nh\'f7ng ng\'ad\'eai And\'b8tx\'ac - Loren c\'e3 \'ae\'ad\'eec d\'ad\'edi s\'f9 th\'e8
ng tr\'de c\'f1a \'a7\'f8c, th\'d7 d\'a9n An Nam c\'f2ng s\'cf \'ae\'ec kh\'e6 h\'acn r\'cat nhi\'d2u. \'a7\'f3ng v\'cby, theo \'fd ngh\'dca \'ae\'e3 th\'d7 vi\'d6c so s\'b8nh And\'b8tx\'ac - Loren Ph\'e6 ho\'b8 v\'edi \'a7\'abng D\'ad\'acng Ph\'b8p h\'e3
a d\'dc nhi\'aan l\'b5 h\'b9i.                                                                                 
\par }\pard \qr \fi397\li0\ri0\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 
\par }\pard \qr \li0\ri283\sa80\sl-286\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin283\lin0\itap0 {\f38\fs18\insrsid1378858 NGuy\'d4n \'b8i Qu\'e8c 
\par }\pard\plain \s15\ql \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\insrsid1378858 \line T\'b5i li\'d6u \'ae\'b8nh m\'b8y, ti\'d5ng Ph
