\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \line \line \line \line \line CH\'d5 \'a7\'e9 TH\'f9C D
\'a2N
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~Kh\'abng ph\'b6i ch\'d8 c\'e3 nh\'f7ng ng\'ad\'eai c\'e9
ng s\'b6n m\'edi n\'e6i l\'aan ch\'e8ng l\'b9i s\'f9 b\'e3c l\'e9t thu\'e9c \'ae\'dea m\'e9t c\'b8ch qu\'b8 m\'f8c. B\'b8o ch\'dd v\'b5 c\'b8c di\'d4n gi\'b6 t\'ad s\'b6n c\'f2ng ph\'b6n \'ae\'e8i s\'f9 kh\'bec nghi\'d6t m\'b5 ng\'ad\'eai b\'b6n x\'f8 ph
\'b6i ch\'deu \'ae\'f9ng; ph\'b6n \'ae\'e8i s\'f9 v\'ab s\'d8 lu\'abn bao tr\'efm b\'e9 m\'b8y cai tr\'de thu\'e9c \'ae\'dea; ph\'b6n \'ae\'e8i t\'d7nh tr\'b9ng thi\'d5u h\'bcn m\'e9t ch\'ddnh s\'b8ch thu\'e9c \'ae\'dea nghi\'aam ch\'d8nh. V\'d7 v\'cb
y, ch\'f3ng t\'abi \'ae\'b7 g\'c6p g\'ec c\'b8c \'ae\'dech th\'f1 giai c\'cap c\'f1a ch\'f3ng t\'abi \'ae\'d3 \'ae\'ada ra nh\'f7ng ph\'b6n \'ae\'e8i t\'ad\'acng t\'f9. Nh\'adng ph\'b6i nh\'can m\'b9nh r\'bbng, ch\'f3ng t\'abi s\'cf chia tay h\'e4
 ngay khi \'ae\'d2 c\'cbp \'ae\'d5n c\'b8ch gi\'b6i quy\'d5t v\'can \'ae\'d2.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\expnd0\expndtw-2\insrsid1378858 Nh\'f7ng ng\'ad\'eai c\'e9ng s\'b6n \'ae
\'dfi h\'e1i ch\'cam d\'f8t b\'e3c l\'e9t thu\'e9c \'ae\'dea, m\'e9t b\'e9 ph\'cbn c\'f1a b\'e3c l\'e9t t\'ad b\'b6n n\'e3i chung. C\'b8c nh\'b5 t\'ad s\'b6n th\'d7 ch\'d8 ngh\'dc \'ae\'d5n vi\'d6c t\'a8ng c\'ad\'eang h\'d6 th\'e8ng thu\'e9c \'ae\'dea 
\'ae\'d3 khai th\'b8c l\'eei nhu\'cbn cao h\'acn, \'ae\'d3 t\'a8ng c\'ad\'eang s\'f9 c\'ad\'ecng \'aeo\'b9t. D\'dc nhi\'aan ch\'ddnh quy\'d2n l\'eei c\'f1a h\'e4, ho\'c6c l\'b5 m\'e9t th\'f8 t\'d7nh c\'b6m nh\'a9n \'ae\'b9o m\'cbp m\'ea n\'b5o \'ae\'e3 
\'ae\'abi khi \'ae\'b7 th\'f3c \'ae\'c8y h\'e4 l\'aan ti\'d5ng y\'aau c\'c7u l\'b5m d\'deu b\'edt s\'e8 ph\'cbn ng\'ad\'eai b\'b6n x\'f8. Nh\'b5 b\'d7nh lu\'cbn c\'f1a t\'ea }{\i\f37\fs20\expnd0\expndtw-2\insrsid1378858 Oeuvre}{
\f37\fs20\expnd0\expndtw-2\insrsid1378858  l\'cay l\'b5m ti\'d5c l\'b5 ng\'ad\'eai ta ch\'d8 nh\'d7n nh\'cbn nh\'f7ng ng\'ad\'eai da \'aeen nh\'ad m\'e9t th\'f8 nh\'a9n l\'f9c m\'b5 h\'e4 y\'aau c\'c7u ph\'b6i t\'ad\'edc \'aeo\'b9t s\'b9ch nh\'f7ng g\'d7
 h\'e4 t\'d7m th\'cay \'eb nh\'f7ng con ng\'ad\'eai n\'b5y? Nh\'adng ng\'ad\'eai ta kh\'abng h\'d2 k\'d5t lu\'cbn l\'b5 ph\'b6i t\'f5 b\'e1 ch\'f1 ngh\'dca th\'f9c d\'a9n. Ng\'ad\'eai ta ch\'d8 s\'ee nh\'f7ng ng\'ad\'eai b\'de b\'e3c l\'e9t n\'e6i d\'cb
y. Ng\'ad\'eai ta y\'aau c\'c7u n\'aan nghi\'aan c\'f8u c\'b8ch \'ae\'b5n \'b8p nh\'f7ng bi\'d5n lo\'b9n c\'e3 th\'d3 x\'b6y ra, ho\'c6c t\'e8t h\'acn n\'aan c\'c7n c\'e3 nh\'f7ng bi\'d6n ph\'b8p l\'b5m d\'deu \'ae\'d3 ng\'f5a tr\'ad\'edc h\'cbu qu\'b6 c
\'f1a nh\'f7ng bi\'d6n ph\'b8p t\'b5n nh\'c9n qu\'b8 hung b\'b9o. V\'can \'ae\'d2 v\'c9n ch\'d8 l\'b5 bu\'e9c c\'b8c thu\'e9c \'ae\'dea ph\'b6i l\'b5m ra nhi\'d2u h\'acn, v\'d7 l\'eei nhu\'cbn t\'e8i \'aea c\'f1a c\'b8c}{\f37\fs20\insrsid1378858  c\'ab
ng ty t\'ad b\'b6n.
\par Nh\'f7ng ng\'ad\'eai c\'e9ng s\'b6n vui s\'ad\'edng t\'d7m \'ae\'ad\'eec \'eb \'ae\'e8i th\'f1 ti\'d5ng v\'e4ng h\'ad\'ebng \'cay l\'eai ph\'b6n \'ae\'e8i c\'f1a m\'d7nh. Nh\'adng nh\'f7ng ng\'ad\'eai c\'e9ng s\'b6n \'ae\'cau tranh cho s\'f9 gi\'b6i ph
\'e3ng d\'a9n t\'e9c v\'b5 kinh t\'d5 c\'f1a c\'b8c thu\'e9c \'ae\'dea, ch\'f8 kh\'abng ph\'b6i cho nh\'f7ng bi\'d6n ph\'b8p t\'b9o \'aei\'d2u ki\'d6n d\'d4 d\'b5ng cho s\'f9 c\'ad\'edp b\'e3c.
\par Sau \'ae\'a9y, ch\'f3ng t\'abi th\'abng b\'b8o t\'e3m t\'bet nh\'f7ng h\'b5nh \'ae\'e9ng x\'cau xa c\'f1a ch\'ddnh s\'b8ch thu\'e9c \'ae\'dea. Nh\'adng ch\'f3ng t\'abi l\'adu \'fd m\'e9t l\'c7n n\'f7a l\'b5 \'ae\'e8i v\'edi nh\'f7ng ng\'ad\'eai c\'e9ng s
\'b6n, v\'can \'ae\'d2 kh\'abng ph\'b6i l\'b5 c\'b6i thi\'d6n h\'d6 th\'e8ng thu\'e9c \'ae\'dea m\'b5 ph\'b6i b\'b7i b\'e1 n\'e3.
\par }\pard \qc \li0\ri0\sb140\sa20\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 *
\par }\pard \qc \li0\ri0\sa160\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 *   *
\par }\pard \qj \fi397\li0\ri0\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 \~Nh\'f7ng hy sinh x\'ad\'acng m\'b8u v\'b5 ti\'d2n b\'b9c, nh\'f7ng cu\'e9c x\'a9m chi\'d5m \'ae\'cat \'aeai r\'e9ng m\'aa
nh m\'abng, ngu\'e5n c\'f1a c\'b6i kh\'abng bao gi\'ea c\'b9n, \'ae\'dea h\'b9t v\'ab bi\'aan d\'b5nh cho ho\'b9t \'ae\'e9ng c\'f1a con ng\'ad\'eai l\'b5 \'ae\'d3 l\'b5m g\'d7? Chi ph\'dd cho vi\'d6c chi\'d5m \'ae\'e3ng ti\'d5p t\'f4c l\'b5m th\'a9m th
\'f1ng ng\'a9n s\'b8ch, c\'dfn c\'b8c thu\'e9c \'ae\'dea b\'de \'b6nh h\'ad\'ebng c\'f1a c\'acn kh\'f1ng ho\'b6ng \'aeang gi\'d5t ch\'d5t \'ae\'cat n\'ad\'edc n\'b5y.
\par Ng\'ad\'eai Ph\'b8p \'ddt di c\'ad, v\'b5i ng\'b5nh c\'abng nghi\'d6p \'aeang ph\'e5n th\'denh m\'b5 n\'ad\'edc Ph\'b8p n\'a9ng \'ae\'ec th\'d7 l\'b9i n\'bbm trong tay ng\'ad\'eai n\'ad\'edc ngo\'b5i.
\par L\'cf ra c\'c7n ph\'b6i x\'a9y d\'f9ng m\'e9t ch\'ad\'acng tr\'d7nh h\'eep l\'fd ch\'f8 kh\'abng ph\'b6i chi\'d5m \'aeo\'b9t t\'b5i s\'b6n, c\'f1a c\'b6i \'ae\'d3 b\'e3c l\'e9t m\'e9t c\'b8ch ng\'cau nghi\'d5n. Ng\'ad\'eai ta \'ae\'b7 ho\'b5n to\'b5n tru
\'cat quy\'d2n s\'eb h\'f7u c\'f1a ng\'ad\'eai b\'b6n x\'f8. V\'d7 th\'d5, s\'f9 ph\'b8t tri\'d3n c\'f1a c\'b8c thu\'e9c \'ae\'dea th\'cbt l\'b5 kh\'e3 kh\'a8n: Thu\'e9c \'ae\'dea l\'b5 nh\'f7ng kh\'b8ch h\'b5ng y\'d5u \'edt c\'f1a n\'d2n c\'abng nghi\'d6
p ch\'ddnh qu\'e8c c\'f2ng \'aeang b\'de t\'e6n th\'cat; thu\'e9c \'ae\'dea l\'b5 nh\'f7ng ng\'ad\'eai cung \'f8ng nh\'e1 nhoi do nh\'f7ng sai l\'c7m trong khai th\'b8c.
\par Ng\'b5y nay, nh\'f7ng ng\'ad\'eai b\'e3c l\'e9t ngh\'dc t\'edi vi\'d6c t\'e6 ch\'f8c l\'b9i theo ki\'d3u hi\'d6n \'ae\'b9i. N\'ad\'edc Angi\'aari c\'c7n 1.000 tri\'d6u; T\'a9y Phi thu\'e9c Ph\'b8p mu\'e8n 1.200 tri\'d6u m\'b5 l\'cf ra c\'b8c n\'ad\'edc n
\'e3i tr\'aan ph\'b6i l\'b5 nh\'f7ng tr\'ee l\'f9c qu\'fd b\'b8u cho ch\'ddnh qu\'e8c. T\'d7nh h\'d7nh t\'b5i ch\'ddnh \'eb nh\'f7ng n\'ad\'edc n\'b5y th\'cbt th\'b6m h\'b9i. Vi\'d6c kinh doanh \'eb \'ae\'e3 th\'cbt kh\'e3 kh\'a8n ch\'ddnh l\'b5 do t\'dd
nh tham lam v\'ab l\'ad\'acng t\'a9m c\'f1a m\'e9t s\'e8 ng\'ad\'eai cai tr\'de. S\'f9 b\'e3c l\'e9t \'ddch k\'fb
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 \'ae\'e3 ch\'d8 c\'e3 th\'d3 th\'f9c hi\'d6n b\'bbng c\'b8
ch t\'ad\'edc \'aei m\'e4i quy\'d2n \'ae\'e9c l\'cbp c\'f1a c\'b8c thu\'e9c \'ae\'dea. T\'b5i nguy\'aan thi\'aan nhi\'aan c\'f1a c\'b8c thu\'e9c \'ae\'dea \'ae\'f1 \'ae\'d3 h\'e4 th\'d5 ch\'cap c\'b8c kho\'b6n vay n\'ee; c\'b8c thu\'e9c \'ae\'dea c\'e3 th
\'d3 gi\'f3p n\'ad\'edc Ph\'b8p, nh\'adng th\'f9c t\'d5 h\'e4 l\'b9i l\'b5 n\'b9n nh\'a9n c\'f1a s\'f9 thi\'d5u h\'f4t t\'b5i ch\'ddnh. Th\'cbt l\'b5 th\'b6m h\'b9i khi ph\'b6i ghi nh\'cbn l\'b5 m\'c6c d\'ef ph\'b6i g\'b8nh ch\'deu c\'b8c v\'efng c\'dfn b
\'de t\'b5n ph\'b8 c\'b8i kho\'b6n tr\'ee c\'cap cho ng\'ad\'eai go\'b8 b\'f4a do chi\'d5n tranh h\'e4 l\'b9i ph\'b6i gi\'f3p \'ae\'ec nh\'f7ng t\'e6 ch\'f8c \'aeang ch\'d5t tr\'aan \'ae\'e8ng c\'f1a.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 V\'d7 sao ch\'ddnh ph\'f1 l\'b9i phung ph\'dd h\'b5ng t
\'fb b\'b9c v\'b5o Xyri? N\'e3 kh\'abng d\'b8m th\'f3 nh\'cbn \'aei\'d2u \'ae\'e3. V\'cby \'ae\'d5n bao gi\'ea ng\'ad\'eai ta m\'edi bi\'d5t \'ae\'ad\'eec s\'f9 th\'cbt v\'d2 nh\'f7ng v\'f4 b\'aa b\'e8i \'eb Nigi\'aa?
\par Ng\'ad\'eai ta kh\'abng bao gi\'ea mu\'e8n n\'e3i x\'a9m chi\'d5m thu\'e9c \'ae\'dea l\'b5 vi\'d6c \'ae\'e8t nh\'b5, t\'b5n s\'b8t hay c\'ad\'edp b\'e3c; v\'b5 c\'f2ng kh\'abng mu\'e8n n\'e3i \'ae\'e3 l\'b5 vi\'d6c l\'b5m cho ki\'d6t qu\'d6 m\'e9t \'ae
\'cat n\'ad\'edc ch\'d8 mong mu\'e8n \'ae\'ad\'eec ph\'b8t tri\'d3n. M\'b5 \'ae\'e3 l\'b5 tri\'d6t h\'b9 s\'f9 s\'e8ng c\'f1a c\'b6 m\'e9t v\'efng khi \'ae\'c6t n\'e3 v\'b5o tay m\'e9t v\'b5i \'abng l\'edn ch\'f8 kh\'abng ph\'b6i \'ae\'d3 cho d\'a9n ch
\'f3ng canh t\'b8c tr\'aan m\'b6nh \'ae\'cat \'ae\'e3.
\par D\'a9n t\'e9c Ph\'b8p \'ae\'ad\'eec l\'eei l\'e9c g\'d7 t\'f5 c\'b8c thu\'e9c \'ae\'dea c\'f1a h\'e4? Ch\'bcng qua m\'e9t v\'b5i \'ae\'e9i qu\'a9n \'aei l\'b5m d\'deu nh\'f7ng xung \'ae\'e9t gi\'f7a t\'ad b\'b6n v\'b5 lao \'ae\'e9ng. V\'d7 v\'cby, c\'c7
n b\'bet bu\'e9c t\'cat c\'b6 c\'b8c \'f8ng c\'f6 vi\'aan ph\'b6i c\'e3 ch\'ad\'acng tr\'d7nh v\'d2 thu\'e9c \'ae\'dea trong c\'b8c cu\'e9c b\'c7u c\'f6 s\'bep t\'edi.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~}{\insrsid1378858 NGUY\'d4N \'b8I QU
\'e8C
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 L' Humanit\'d0,}{\insrsid1378858 

\par ng\'b5y 5-2-1923.
