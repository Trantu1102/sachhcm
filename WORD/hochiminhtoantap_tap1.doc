\par Theo nh\'f7ng s\'e8 li\'d6u th\'e8ng k\'aa g\'c7n \'ae\'a9y, \'eb \'a7\'abng D\'ad\'acng hi\'d6n c\'e3 63 x\'dd nghi\'d6p khai m\'e1 s\'b6n xu\'cat 70 v\'b9n t\'can than \'ae\'b8, 5 v\'b9n t\'can k\'cfm, 15 v\'b9n t\'can ch\'d7, 2.500 t\'can s\'be
t, 1.500 t\'can c\'b8c kim lo\'b9i kh\'b8c, 3.500 cara}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sb40\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) }{\i\insrsid1378858 Cara:}{\insrsid1378858  \'ae\'acn v\'de tr\'e4ng l\'ad\'eeng \'ae\'b8 qu\'fd = 0,2 gam.}})}{\f37\fs20\insrsid1378858  \'ae\'b8 qu\'fd v\'b5 100 kil\'ab
gam v\'b5ng.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd0\expndtw-4\insrsid1378858 C\'dfn v\'d2 nh\'f7ng ng\'b5nh c\'ab
ng nghi\'d6p kh\'b8c th\'d7 n\'aan l\'adu \'fd r\'bbng \'eb \'a7\'abng D\'ad\'acng c\'dfn c\'e3 140 \'ae\'e5n \'aei\'d2n cao su v\'edi di\'d6n t\'ddch chung 3.500 h\'d0cta v\'b5 s\'b6n xu\'cat 5.000 t\'can. C\'abng nghi\'d6p th\'f9c ph\'c8m c\'f2ng \'ae
\'b8ng k\'d3 - s\'b6n xu\'cat 250 t\'can th\'det h\'e9p.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 100 x\'dd nghi\'d6p t\'ac l\'f4a s\'b6n xu\'cat 100 t\'ca
n h\'b5ng t\'ac l\'f4a.
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 N\'d5u nh\'ad k\'d3 th\'aam r\'bbng \'eb \'a7\'ab
ng D\'ad\'acng c\'dfn c\'e3 355 tr\'b9m \'aei\'d6n b\'b8o, 2.100 kil\'abm\'d0t \'ae\'ad\'eang s\'bet v\'b5 3 c\'b6ng l\'edn m\'b5 m\'e7i n\'a8m b\'e8c d\'ec 7-8 tri\'d6u t\'can h\'b5ng kh\'b8c nhau th\'d7 \'aei\'d2u \'ae\'e3 s\'cf cho m\'e9t quan ni\'d6
m chung v\'d2 nh\'f7ng l\'dcnh v\'f9c s\'b6n xu\'cat m\'b5 v\'ab s\'b6n \'a7\'abng D\'ad\'acng \'aeang b\'e1 s\'f8c lao \'ae\'e9ng v\'b5o \'ae\'e3.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs20\cf1\cgrid0\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  \'a7\'abng D
\'ad\'acng c\'dfn c\'e3 nh\'f7ng x\'dd nghi\'d6p t\'ad\'acng \'ae\'e8i l\'edn: nh\'b5 m\'b8y xim\'a8ng Po\'e3clan}{\cs17\f37\fs20\super\insrsid1378858 2{\footnote \pard\plain \s30\ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f42\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 2) Nh\'b5 m\'b8y xim\'a8ng H\'b6i Ph\'dfng.}})}{\f37\fs20\insrsid1378858  c\'e3 30.000 c\'abng nh\'a9n l\'b5m thu\'aa, khu m\'e1 v\'denh H\'b9 
\par }\pard \qj \li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Long c\'e3 4.000 c\'abng nh\'a9n, nh\'b5 m\'b8y d\'d6t B\'bec K\'fa}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote 
\pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) Nh\'b5 m\'b8y d\'d6t Nam \'a7\'denh.}})}{
\f37\fs20\insrsid1378858  - 3.000 c\'abng nh\'a9n, \'ae\'ad\'eang s\'bet - 8.000 c\'abng nh\'a9n.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\expnd0\expndtw2\insrsid1378858 Ng\'b5y l\'b5m vi\'d6c 12-13 ti\'d5ng. Trong n\'abng nghi\'d6p ng\'b5y l\'b5m vi\'d6c c\'dfn d\'b5i h
\'acn. Nh\'f7ng ng\'b5y l\'d4 - v\'b5 nhi\'d2u khi c\'b6 nh\'f7ng ng\'b5y ch\'f1 nh\'cbt - \'ae\'d2u kh\'abng \'ae\'ad\'eec \'ae\'d5m x\'d8a t\'edi. Kh\'abng c\'e3 b\'b6o hi\'d3m x\'b7 h\'e9i cho tu\'e6i gi\'b5, kh\'abng c\'e3 tr\'ee c\'cap cho l\'f3c b
\'de th\'ad\'acng t\'cbt ho\'c6c \'aeau \'e8m. Ti\'d2n l\'ad\'acng c\'f1a c\'abng nh\'a9n kh\'abng l\'b5nh ngh\'d2 kh\'abng qu\'b8 50 phr\'a8ng m\'e9t th\'b8ng, c\'dfn c\'f1a c\'abng nh\'a9n l\'b5nh ngh\'d2 - 250 phr\'a8ng. C\'abng nh\'a9n nhi\'d2u khi ph
\'b6i k\'fd nh\'f7ng giao k\'cco m\'e9t ph\'dda, b\'bet bu\'e9c h\'e4 ph\'b6i l\'b5m vi\'d6c cho}{\f37\fs20\insrsid1378858  b\'e4n ch\'f1 trong m\'e9t s\'e8 n\'a8m nh\'cat \'ae\'denh. Theo giao k\'cco, b\'e4n ch\'f1 nh\'b5 m\'b8y c\'e3 th\'d3 sa th\'b6i h
\'e4 b\'cat k\'fa l\'f3c n\'b5o, nh\'adng ng\'ad\'eai c\'abng nh\'a9n l\'b9i kh\'abng th\'d3 b\'e1 vi\'d6c tr\'ad\'edc l\'f3c h\'d5t th\'eai h\'b9n nh\'ad \'ae\'b7 quy \'ae\'denh trong giao k\'cco. Trong n\'abng nghi\'d6p, nhi\'d2u khi ngay c\'b6 th\'f1 t
\'f4c h\'d7nh th\'f8c \'ae\'e3 c\'f2ng kh\'abng \'ae\'ad\'eec d\'efng, v\'b5 c\'e8 n\'abng tr\'eb th\'b5nh h\'c7u nh\'ad n\'ab l\'d6, nh\'ad s\'eb h\'f7u ri\'aang c\'f1a b\'e4n ch\'f1. \'a7\'e8i v\'edi nh\'f7ng ng\'ad\'eai kh\'abng ph\'f4c t\'efng, c\'e3
 s\'bdn c\'b6 m\'e9t h\'d6 th\'e8ng b\'bet b\'ed v\'b5 \'ae\'b8nh \'ae\'cbp.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'cat nhi\'aan, kh\'abng th\'d3 n\'e3i t\'edi t\'f9 do b
\'b7i c\'abng. M\'e9t v\'b5i cu\'e9c n\'e6i d\'cby l\'edn mang t\'ddnh ch\'cat b\'b7i c\'abng, kh\'abng ph\'b6i l\'b5 do v\'cbn \'ae\'e9ng tuy\'aan truy\'d2n g\'a9y ra m\'b5 l\'b5 do b\'de \'ae\'e3i, \'ae\'b7 b\'de \'ae\'b5n \'b8p b\'bbng m\'e4i c\'b8ch t
\'b5n \'b8c nh\'cat.
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 V\'edi s\'f9 gi\'f3p \'ae\'ec h\'b5o hi\'d6p c\'f1
a ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c Ph\'b8p, \'eb \'a7\'abng D\'ad\'acng th\'cbt ra l\'b5 \'ae\'b7 ph\'f4c h\'e5i ch\'d5 \'ae\'e9 n\'ab l\'d6. N\'ab l\'d6 c\'e3 ba lo\'b9i: 1) t\'ef kh\'e6 sai, m\'b5 ch\'ddnh quy\'d2n cai tr\'de \'ae\'b7 cho b\'e4n ch\'f1
 c\'b8c nh\'b5 m\'b8y s\'f6 d\'f4ng, sau c\'b6 m\'e9t ng\'b5y lao \'ae\'e9ng cho b\'e4n t\'ad b\'b6n th\'d7 t\'e8i \'ae\'d5n h\'e4 l\'b9i tr\'eb v\'d2 c\'b8c nh\'b5 t\'ef c\'e3 bi\'d3n \'ae\'d2 h\'f8a h\'ad\'acu h\'f8a v\'ad\'een "t\'f9 do, b\'d7nh \'ae
\'bcng v\'b5 b\'b8c \'b8i"; 2) n\'abng n\'ab, c\'e3 th\'d3 bao g\'e5m t\'cat c\'b6 ng\'ad\'eai An Nam t\'f5 18 \'ae\'d5n 60 tu\'e6i, h\'bbng n\'a8m bu\'e9c ph\'b6i \'aei phu m\'e9t s\'e8 ng\'b5y nh\'cat \'ae\'denh. V\'b6 l\'b9i, s\'e8 l\'ad\'eeng nh\'f7
ng ng\'b5y \'ae\'e3 ch\'d8 l\'b5 quy \'ae\'denh \'ad\'edc ch\'f5ng, c\'dfn tr\'aan th\'f9c t\'d5 h\'c7u nh\'ad kh\'abng c\'e3 h\'b9n \'ae\'denh. M\'e9t ph\'c7n l\'edn d\'a9n c\'ad \'ae\'b7 b\'de huy \'ae\'e9ng v\'b5o vi\'d6c l\'b5m \'ae\'ad\'eang, \'ae
\'b5o k\'aanh v\'b5 kh\'abng c\'e3 b\'cat k\'fa m\'e9t th\'f8 c\'abng s\'b8 n\'b5o h\'d5t. S\'e8 ng\'ad\'eai d\'a9n b\'b6n x\'f8 ch\'d5t v\'d7 nh\'f7ng c\'abng vi\'d6c \'cay th\'cbt r\'cat l\'edn; 3) n\'ab l\'d6, \'ae\'f3ng theo ngh\'dca \'ae\'c7y \'ae
\'f1 c\'f1a t\'f5, h\'e4 b\'de b\'b8n v\'b5 b\'de mua. Trong vi\'d6c mua b\'b8n n\'b5y, ch\'ddnh quy\'d2n th\'f9c d\'a9n \'ae\'b7 tr\'eb th\'b5nh b\'e4n ch\'f1 kinh doanh. Gi\'e8ng nh\'ad th\'eai chi\'d5n tranh, ch\'ddnh quy\'d2n th\'f9c d\'a9n \'ae\'b7
 tuy\'d3n d\'a9n b\'b6n x\'f8 l\'b5m l\'ddnh - t\'d7nh nguy\'d6n, th\'d7 b\'a9y gi\'ea ch\'f3ng l\'b9i m\'e9 c\'abng nh\'a9n - t\'d7nh nguy\'d6n \'aei c\'b8c thu\'e9c \'ae\'dea Ph\'b8p kh\'b8c, ch\'f1 y\'d5u cho c\'b8c \'ae\'b6o \'eb Th\'b8i B\'d7nh D\'ad
\'acng. Nh\'f7ng ng\'ad\'eai An Nam n\'b5y \'ae\'d5n \'ae\'e3 b\'de b\'b8n cho b\'e4n ch\'f1 \'ae\'e5n \'aei\'d2n v\'b5 ch\'f1 nh\'b5 m\'b8y ng\'ad\'eai ch\'a9u \'a2u.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 C\'e3 m\'e9t b\'f8c th\'ad, \'ae\'b7 \'ae\'a8ng kh\'bep 
\'a7\'abng D\'ad\'acng v\'b5 \'ae\'d2 ng\'b5y 17 th\'b8ng 3 n\'a8m 1924, n\'e3i v\'d2 nh\'f7ng tai ho\'b9 kh\'f1ng khi\'d5p do b\'d6nh s\'e8t r\'d0t g\'a9y ra trong s\'e8 nh\'f7ng ng\'ad\'eai n\'ab l\'d6 \'ae\'b7 b\'de \'ae\'ada t\'edi \'ae\'b6o \'a3br
\'ddt}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1}{
\i\insrsid1378858 ) H\'d0brides}{\insrsid1378858 : \'ae\'b6o nh\'e1 \'eb nam Th\'b8i B\'d7nh D\'ad\'acng.}})}{\f37\fs20\insrsid1378858 , b\'f8c th\'ad y\'aau y\'aau c\'c7u ph\'b6i ch\'cam d\'f8t c\'b8i h\'d6 th\'e8ng b\'e3c l\'e9t v\'ab li\'aam s\'d8 \'ae
\'e8i v\'edi t\'d7nh tr\'b9ng t\'a8m t\'e8i c\'f1a ng\'ad\'eai d\'a9n b\'b6n x\'f8.
\par Giai c\'cap v\'ab s\'b6n kh\'abng th\'d3 l\'b5m g\'d7 \'ae\'d3 ch\'e8ng l\'b9i c\'b8i h\'d6 th\'e8ng b\'e3c l\'e9t \'ae\'e3, ch\'ada c\'e3 m\'e9t t\'e6 ch\'f8c c\'abng nh\'a9n n\'b5o c\'b6. B\'e9 lu\'cbt thu\'e9c \'ae\'dea do nh\'f7ng nh\'b5 khai ho\'b8
 Ph\'b8p so\'b9n ra ch\'ddnh l\'b5 \'ae\'d3 \'ae\'b5n \'b8p b\'cat k\'fa m\'e9t bi\'d3u hi\'d6n n\'b5o c\'e3 t\'ddnh t\'f9 ch\'f1 c\'f1a ng\'ad\'eai d\'a9n b\'b6n x\'f8 n\'e3i chung v\'b5 t\'c7ng l\'edp v\'ab s\'b6n n\'e3i ri\'aang. Theo b\'e9 lu\'cbt 
\'ae\'e3, ng\'ad\'eai An Nam kh\'abng c\'e3 quy\'d2n xu\'cat b\'b6n b\'b8o ch\'dd b\'bbng ti\'d5ng m\'d1 \'ae\'ce, kh\'abng c\'e3 t\'f9 do h\'e9i h\'e4p v\'b5 l\'cbp h\'e9i, b\'de t\'ad\'edc \'aeo\'b9t c\'b6 quy\'d2n t\'f9 do \'aei l\'b9i t\'f5 t\'d8nh n
\'b5y sang t\'d8nh kh\'b8c. \'a7\'d3 b\'b6o v\'d6 nh\'f7ng lu\'cbt ph\'b8p \'ae\'e3 th\'d7 c\'e3 to\'b5 \'b8n g\'e5m 5-6 quan l\'b9i Ph\'b8p, ch\'f3ng x\'f6 k\'ddn v\'b5 tuy\'aan \'b8n, k\'d3 c\'b6 \'b8n t\'f6 h\'d7nh.
\par Tr\'ad\'edc chi\'d5n tranh, ng\'ad\'eai An Nam c\'e3 t\'e6 ch\'f8c v\'b5i h\'eep t\'b8c x\'b7, nh\'adng ch\'ddnh quy\'d2n th\'f9c d\'a9n \'ae\'b7 gi\'b6i t\'b8n ch\'f3ng, b\'bet giam nh\'f7ng ng\'ad\'eai t\'e6 ch\'f8c v\'d7 nghi l\'b5 tuy\'aan truy\'d2n c
\'b8ch m\'b9ng.
\par Th\'ada c\'b8c \'ae\'e5ng ch\'dd, t\'d7nh c\'b6nh c\'abng nh\'a9n An Nam l\'b5 nh\'ad th\'d5. \'a7\'e3 l\'b5 m\'e9t t\'d7nh c\'b6nh kh\'f1ng khi\'d5p, nh\'adng kh\'abng ph\'b6i l\'b5 kh\'abng c\'e3 l\'e8i tho\'b8t. T\'d7nh h\'d7nh kh\'abng ph\'b6i l\'b5
 kh\'abng c\'e3 l\'e8i tho\'b8t, b\'ebi v\'d7 v\'edi s\'f9 gi\'f3p \'ae\'ec c\'f1a c\'b8c t\'e6 ch\'f8c c\'b8ch m\'b9ng g\'c7n g\'f2i v\'edi Qu\'e8c t\'d5 C\'abng h\'e9i \'ae\'e1, 
\par }\pard \qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 ch\'f3ng t\'abi quy\'d5t \'ae\'cbp tan l\'f9c l\'ad\'eeng c\'f1a ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c ch\'a9u \'a2u \'b8p b\'f8
c ch\'f3ng t\'abi. Nh\'adng \'ae\'d3 \'ae\'b9t t\'edi k\'d5t qu\'b6 \'ae\'e3, \'ae\'d3 th\'f3c \'ae\'c8y nhanh ch\'e3ng c\'abng cu\'e9c gi\'b6i ph\'e3ng c\'f1a giai c\'cap v\'ab s\'b6n \'a7\'abng D\'ad\'acng th\'d7 c\'c7n thi\'d5t m\'e9t \'aei\'d2u l\'b5
 c\'b8c \'ae\'e5ng ch\'dd ch\'f3ng ta trong c\'b8c t\'e6 ch\'f8c c\'abng nh\'a9n c\'b8ch m\'b9ng Ph\'b8p ph\'b6i t\'ddch c\'f9c gi\'f3p \'ae\'ec ch\'f3ng t\'abi trong cu\'e9c \'ae\'cau tranh gi\'b6i ph\'e3ng c\'f1a ch\'f3ng t\'abi. }{
\i\f37\fs20\insrsid1378858 (V\'e7 tay vang d\'e9i).}{\f37\fs20\insrsid1378858 
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 In trong s\'b8ch: }{\i\insrsid1378858 \'a7\'b9i h\'e9i l\'c7n th
\'f8 III
\par Qu\'e8c t\'d5 C\'abng h\'e9i \'ae\'e1 - B\'b8o c\'b8o,
\par }{\insrsid1378858 b\'b6n t\'e8c k\'fd, ti\'d5ng Nga, M\'b8txc\'acva,
\par 1924, tr.297-299.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par 
