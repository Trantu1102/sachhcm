\par 2. Quy\'d2n \'ae\'c7u phi\'d5u. 
\par 3. Quy\'d2n t\'f9 do ng\'abn lu\'cbn, t\'f9 do b\'b8o ch\'dd, t\'f9 do h\'e9i h\'e4p, t\'f9 do l\'cbp h\'e9i, t\'f9 do b\'b7i c\'abng.   
\par }\pard\plain \s4\qj \fi397\li0\ri0\sa80\sl-280\slmult0\keepn\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel3\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B. V\'d2 kinh t\'d5   
