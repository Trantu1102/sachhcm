\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~Trong \'ae\'b8m tang to\'b5n quy\'d2n L\'abng, \'ab
ng Nguy\'d4n Kh\'bec V\'d6, ti\'d5n s\'dc khoa lu\'cbt h\'e4c, ti\'d5n s\'dc khoa ch\'ddnh tr\'de h\'e4c v\'b5 kinh t\'d5 h\'e4c, l\'b5m vi\'d6c t\'b9i To\'b5 Bi\'d6n l\'fd S\'b5i G\'dfn, \'ae\'b7 qu\'b6 quy\'d5t r\'bbng, n\'d5u c\'e3 th\'d3 ph\'b8t bi
\'d3u thay to\'b5n th\'d3 nh\'a9n d\'a9n \'a7\'abng D\'ad\'acng, th\'d7 \'abng ch\'bec ch\'ben r\'bbng, ti\'d5ng n\'e3i \'ae\'e3 s\'cf \'aeau th\'ad\'acng t\'e1 l\'dfng tri \'a9n to\'b5n quy\'d2n v\'d2 t\'cat c\'b6 nh\'f7ng g\'d7 m\'b5 to\'b5n quy\'d2n 
\'ae\'b7 ban cho d\'a9n t\'e9c An Nam. V\'b5 \'abng V\'d6 tr\'a9n tr\'e4ng l\'edn ti\'d5ng:
\par "V\'b5 nh\'f7ng ai, nh\'ea v\'b5o nh\'f7ng bi\'d6n ph\'b8p khoan dung c\'f1a Ng\'b5i, 
\par ng\'b5y nay, \'aeang c\'efng c\'b8c v\'de \'ae\'b9i di\'d6n c\'f1a n\'ad\'edc b\'b6o h\'e9 g\'e3p ph\'c7n v\'b5o c\'abng cu\'e9c ph\'e5n vinh ng\'b5y c\'b5ng t\'a8ng ti\'d5n c\'f1a x\'f8 \'a7\'abng D\'ad\'acng, s\'cf c\'cat l\'aan t\'f5 \'ae\'b8y l\'df
ng m\'d7nh l\'eai tri \'a9n Ng\'b5i v\'b5 l\'dfng s\'efng k\'ddnh \'ae\'e8i v\'edi anh linh Ng\'b5i. V\'can \'ae\'d2 kinh t\'d5 l\'b5 \'aei\'d2u m\'b5 Ng\'b5i quan t\'a9m h\'acn h\'d5t. Ng\'b5i t\'f5ng mong mu\'e8n trang b\'de cho \'a7\'abng D\'ad\'acng m
\'e4i kh\'dd c\'f4 kinh t\'d5 sao cho n\'e3 tr\'eb th\'b5nh m\'e9t n\'ad\'edc Ph\'b8p th\'f8 hai, m\'e9t n\'ad\'edc Ph\'b8p Vi\'d4n \'a7\'abng h\'efng c\'ad\'eang, m\'e9t con \'ae\'ec \'ae\'c7u c\'f1a n\'ad\'edc Ph\'b8p c\'e9ng ho\'b5".
\par "Trong s\'f8 m\'d6nh c\'f1a Ng\'b5i, Ng\'b5i \'ae\'b7 to\'b5n t\'a9m to\'b5n \'fd khai ho\'b8 cho m\'e9t d\'a9n t\'e9c b\'de ng\'f5ng tr\'d6 tr\'aan con \'ae\'ad\'eang ti\'d5n b\'e9 v\'d7 m\'e9t t\'e6ng h\'eep \'aei\'d2u ki\'d6n l\'dech s\'f6 v\'b5 kh\'dd
 h\'cbu. Ng\'b5i l\'b5 v\'de qu\'b8n qu\'a9n c\'f1a ti\'d5n b\'e9, l\'b5 s\'f8 gi\'b6 c\'f1a c\'abng cu\'e9c khai ho\'b8...".
\par }\pard \qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 V\'d2 ph\'c7n m\'d7nh, \'abng Cao V\'a8n Sen, k\'fc s\'ad, Ch\'f1 t\'dech H\'e9i nh\'f7ng ng\'ad\'eai \'a7\'abng D\'ad\'ac
ng, th\'d7 n\'e3i r\'bbng, vi\'d6c \'abng L\'abng ch\'d5t qu\'b8 s\'edm l\'b5 m\'e9t c\'b8i tang cho to\'b5n c\'e2i \'a7\'abng D\'ad\'acng. R\'e5i \'abng k\'d5t th\'f3c b\'b5i \'aei\'d5u v\'a8n b\'bbng 
\par nh\'f7ng l\'eai sau \'ae\'a9y:
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 "B\'c8m quan To\'b5n quy\'d2n, ch\'f3ng t\'abi th\'b5nh t\'a9m than kh\'e3c Ng\'b5i v\'d7 \'ae\'e8i v\'edi t\'cat c\'b6
 ch\'f3ng t\'abi, Ng\'b5i l\'b5 m\'e9t th\'f1 hi\'d5n, m\'e9t ng\'ad\'eai cha nh\'a9n h\'cbu".
\par ....................."}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {
\insrsid1378858 1) D\'dfng d\'cau ch\'cam n\'b5y l\'b5 c\'f1a nguy\'aan b\'b6n ti\'d5ng Ph\'b8p.}})}{\f37\fs20\insrsid1378858 .
\par T\'f5 s\'f9 vi\'d6c tr\'aan, t\'abi \'aei \'ae\'d5n k\'d5t lu\'cbn r\'bbng: N\'d5u qu\'b6 th\'f9c t\'cat c\'b6 nh\'f7ng ng\'ad\'eai An Nam \'ae\'d2u c\'f2ng lu\'e5n c\'f3i s\'b8t \'ae\'cat nh\'ad hai \'ae\'f8a con n\'b5y c\'f1a gu\'e5ng m\'b8y cai tr\'de
 th\'d7 qu\'b6 th\'f9c l\'b5 d\'a9n n\'b5y x\'f8ng \'ae\'b8ng v\'edi c\'b8i s\'e8 ph\'cbn \'ae\'ad\'eec cho.
\par }\pard\plain \s24\qr \fi397\li0\ri992\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin992\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~N.
