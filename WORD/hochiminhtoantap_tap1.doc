\par }}\dpx-11\dpy-834\dpxsize900\dpysize360\dpfillfgcr255\dpfillfgcg255\dpfillfgcb255\dpfillbgcr255\dpfillbgcg255\dpfillbgcb255\dpfillpat1\dplinehollow}}}}{\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 Mong r\'bbng b\'e9 }{
\i\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 H\'e5 Ch\'dd Minh To\'b5n t\'cbp}{\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 , xu\'cat b\'b6n l\'c7n th\'f8 hai, s\'cf t\'b9o th\'aam \'aei\'d2u ki\'d6n \'ae\'c8y m\'b9nh vi\'d6c h\'e4
c t\'cbp, nghi\'aan c\'f8u t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh trong to\'b5n \'a7\'b6ng, l\'b5m cho t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh, c\'efng v\'edi ch\'f1 ngh\'dca M\'b8c- L\'aanin, th\'f9c s\'f9 l\'b5 n\'d2n t\'b6ng t\'ad t\'ad\'ebng v\'b5 kim ch\'d8
 nam cho h\'b5nh \'ae\'e9ng c\'f1a ch\'f3ng ta.
\par }\pard\plain \s4\qc \li1985\ri0\sl-280\slmult0\keepn\widctlpar\aspalpha\aspnum\faauto\outlinelevel3\adjustright\rin0\lin1985\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f38\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 

