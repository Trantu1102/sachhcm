en l\'b5 gi\'e8ng ng\'ad\'eai b\'de \'b8p b\'f8c v\'b5 b\'e3c l\'e9t n\'c6ng n\'d2 nh\'cat trong lo\'b5i ng\'ad\'eai. Ai c\'f2ng bi\'d5t s\'f9 b\'b5nh tr\'ad\'edng c\'f1a ch\'f1 ngh\'dca t\'ad b\'b6n v\'b5 vi\'d6c t\'d7m ra T\'a9n th\'d5 gi\'edi \'ae\'b7
 mang l\'b9i h\'cbu qu\'b6 tr\'f9c ti\'d5p l\'b5 l\'b5m s\'e8ng l\'b9i ch\'d5 \'ae\'e9 n\'ab l\'d6, m\'e9t ch\'d5 \'ae\'e9, tr\'b6i qua nhi\'d2u th\'d5 k\'fb, \'ae\'b7 l\'b5 m\'e9t tai ho\'b9 th\'cbt s\'f9 \'ae\'e8i v\'edi ng\'ad\'eai da \'aeen v\'b5 l
\'b5 m\'e9t b\'cat 
\par h\'b9nh \'ae\'c9m m\'b8u \'ae\'e8i v\'edi nh\'a9n lo\'b9i. \'a7i\'d2u m\'b5 m\'e4i ng\'ad\'eai c\'e3 l\'cf kh\'abng bi\'d5t l\'b5 ng\'ad\'eai da \'aeen ch\'a9u M\'fc, ti\'d5ng r\'bbng \'ae\'b7 \'ae\'ad\'eec gi\'b6i ph\'e3ng 65 n\'a8m nay r\'e5i, nh\'ad
ng v\'c9n c\'dfn ph\'b6i ch\'deu \'ae\'f9ng nhi\'d2u n\'e7i th\'e8ng kh\'e6 gh\'aa g\'edm v\'d2 tinh th\'c7n v\'b5 v\'cbt ch\'cat, m\'b5 t\'b5n \'b8c nh\'cat v\'b5 gh\'aa t\'ebm nh\'cat l\'b5 }{\i\f37\fs20\insrsid1378858 t\'f4c h\'b5nh h\'d7nh ki\'d3
u Lins\'ac.}{\f37\fs20\insrsid1378858 
\par }{\insrsid1378858 Linsagi\'ac l\'b5 do t\'f5 Lins\'ac m\'b5 ra. Lins\'ac l\'b5 t\'aan m\'e9t ch\'f1 \'ae\'e5n \'aei\'d2n \'eb bang Vi\'d5cgini v\'f5a l\'b5 \'ae\'dea ch\'f1, v\'f5a l\'b5 quan to\'b5. L\'eei d\'f4ng t\'d7nh h\'d7nh r\'e8i ren trong cu\'e9
c chi\'d5n tranh gi\'b5nh \'ae\'e9c l\'cbp, h\'ben th\'a9u t\'e3m to\'b5n b\'e9 quy\'d2n h\'b5nh trong qu\'cbn. Nh\'f7ng ng\'ad\'eai thu\'e9c ph\'b8i b\'b6o ho\'b5ng v\'b5 nh\'f7ng ng\'ad\'eai thu\'e9c ph\'b8i b\'b6o th\'f1 b\'de h\'ben tr\'f5ng ph\'b9t r
\'cat d\'b7 man, kh\'abng c\'c7n x\'d0t x\'f6, kh\'abng c\'c7n \'b8n t\'f5 g\'d7 c\'b6. Nh\'ea b\'e4n ch\'f1 n\'ab, nh\'ea \'ae\'b6ng Ku Klux Klan v\'b5 nh\'f7ng t\'e6 ch\'f8c b\'dd m\'cbt kh\'b8c, n\'aan t\'f4c h\'b5nh h\'d7nh ki\'d3u Lins\'ac, m\'e9t t
\'f4c kh\'abng h\'eep ph\'b8p v\'b5 man r\'ee tr\'eb th\'b5nh ph\'e6 bi\'d5n v\'b5 k\'d0o d\'b5i m\'b7i \'eb c\'b8c bang trong Li\'aan bang M\'fc. Sau khi ng\'ad\'eai da \'aeen \'ae\'ad\'eec gi\'b6i ph\'e3ng, t\'f4c \'ae\'e3 c\'b5ng tr\'eb n\'aan v\'ab nh
\'a9n \'ae\'b9o, v\'b5 \'ae\'c6c bi\'d6t ch\'dca v\'b5o ng\'ad\'eai da \'aeen.}{\f37\fs20\insrsid1378858 
\par }\pard\plain \s25\qj \li0\ri0\sa120\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'b8C B\'b9N H\'b7Y T\'a6\'ebNG T\'a6\'eeNG...
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 C\'b8c b\'b9n h\'b7y t\'ad\'ebng t\'ad\'eeng m\'e9t \'ae
\'b8m \'ae\'abng cu\'e5ng lo\'b9n. Qu\'b6 \'ae\'cam n\'bem ch\'c6t, m\'bet \'ae\'e1 ng\'c7u, mi\'d6ng s\'efi b\'e4t, la \'e3, ch\'f6i b\'edi, nguy\'d2n r\'f1a..., \'ae\'b8m \'ae\'abng \'cay \'aeang b\'de l\'abi cu\'e8n b\'ebi c\'b8i th\'f3 cu\'e5ng lo\'b9
n \'ae\'ad\'eec ph\'b9m t\'e9i \'b8c m\'b5 kh\'abng ph\'b6i lo s\'ee g\'d7 c\'b6. H\'e4 v\'f2 trang b\'bbng g\'cby g\'e9c, \'aeu\'e8c, s\'f3ng l\'f4c, th\'f5ng, dao, k\'d0o, n\'ad\'edc l\'adu toan, d\'efi. T\'e3m l\'b9i l\'b5 b\'cat c\'f8 v\'cbt g\'d7 c
\'e3 th\'d3 d\'efng \'ae\'d3 gi\'d5t ho\'c6c l\'b5m b\'de th\'ad\'acng \'ae\'ad\'eec.
\par C\'b8c b\'b9n h\'b7y t\'ad\'ebng t\'ad\'eeng gi\'f7a \'ae\'b8m \'ae\'abng \'cay, l\'b5 m\'e9t \'ae\'e8ng th\'det \'aeen b\'de x\'ab \'ae\'c8y, \'ae\'b8nh \'ae\'cbp, gi\'b5y x\'d0o, r\'b9ch da, r\'e3c th\'det, ch\'f6i r\'f1a, b\'de \'ae\'b8 \'aei \'ae\'b8
 l\'b9i, \'ae\'c9m m\'b8u, b\'cat \'ae\'e9ng.
\par C\'b8i \'ae\'b8m \'ae\'abng \'cay, ch\'ddnh l\'b5 nh\'f7ng k\'ce tham gia h\'b5nh h\'d7nh. C\'b8i x\'b8c ng\'ad\'eai r\'b8ch n\'b8t kia, \'ae\'e3 l\'b5 ng\'ad\'eai da \'aeen, l\'b5 n\'b9n nh\'a9n.
\par Trong c\'acn s\'e3ng h\'bbn th\'ef v\'b5 th\'f3 t\'ddnh, nh\'f7ng k\'ce tham gia h\'b5nh h\'d7nh l\'abi ng\'ad\'eai da \'aeen \'ae\'d5n m\'e9t khu r\'f5ng hay m\'e9t qu\'b6ng tr\'ad\'eang c\'abng c\'e9ng n\'b5o \'ae\'e3. H\'e4 tr\'e3i ng\'ad\'eai \'ae\'e3
 v\'b5o c\'a9y, t\'ad\'edi d\'c7u l\'f6a v\'b5o ng\'ad\'eai \'ae\'e3, l\'cay nh\'f7ng ch\'cat d\'d4 ch\'b8y ph\'f1 l\'aan ng\'ad\'eai \'ae\'e3. Tr\'ad\'edc khi ch\'a9m l\'f6a, h\'e4 b\'ce d\'c7n t\'f5ng chi\'d5c r\'a8ng m\'e9t c\'f1a ng\'ad\'eai \'ae\'e3
. R\'e5i m\'e3c m\'bet ng\'ad\'eai \'ae\'e3. T\'f5ng nh\'f3m t\'e3c xo\'a8n b\'de r\'f8t kh\'e1i \'ae\'c7u, mang theo t\'f5ng m\'b6ng da, \'ae\'d3 l\'e9 ra m\'e9t s\'e4 ng\'ad\'eai \'ae\'c9m m\'b8u. Nhi\'d2u mi\'d5ng th\'det nh\'e1 r\'eai kh\'e1i c\'b8
i th\'a9n h\'d7nh \'ae\'b7 t\'ddm b\'c7m v\'d7 b\'de \'ae\'b8nh \'ae\'cbp.
\par Ng\'ad\'eai da \'aeen kh\'abng k\'aau \'ae\'ad\'eec n\'f7a: l\'ad\'eci \'ae\'b7 s\'adng ph\'e5ng l\'aan v\'d7 m\'e9t thanh s\'bet nung \'ae\'e1 g\'dd v\'b5o. To\'b5n th\'a9n ng\'ad\'eai \'cay qu\'bbn qu\'b9i nh\'ad m\'e9t con r\'ben b\'de \'ae\'b8nh, d
\'eb s\'e8ng, d\'eb ch\'d5t. M\'e9t nh\'b8t dao, th\'d5 l\'b5 r\'f4ng m\'e9t tai. }{\f38\fs20\insrsid1378858 \'b8}{\f37\fs20\insrsid1378858 i ch\'b5! N\'e3 m\'edi \'aeen l\'b5m sao! N\'e3 m\'edi \'ae\'b8ng t\'ebm l\'b5m sao! Th\'d5 l\'b5 b\'e4n \'ae\'b5
n b\'b5 r\'b9ch n\'b8t m\'c6t ng\'ad\'eai \'ae\'e3 ra...
\par C\'e3 k\'ce h\'d0t: "Ch\'a9m l\'f6a l\'aan \'aei!". M\'e9t k\'ce kh\'b8c g\'e3p th\'aam: "\'a7\'e8t v\'f5a \'ae\'f1 \'ae\'d3 thui n\'e3 t\'f5 t\'f5 th\'abi".
\par Ng\'ad\'eai da \'aeen b\'de n\'ad\'edng ch\'ddn, thui v\'b5ng, ch\'b8y th\'b5nh than. Nh\'adng ng\'ad\'eai \'ae\'e3 ph\'b6i ch\'d5t hai l\'c7n m\'edi \'ae\'b8ng \'ae\'eai. Cho n\'aan h\'e4 li\'d2n treo ng\'ad\'eai \'ae\'e3 l\'aan, n\'e3i cho \'ae\'f3ng l
\'b5 treo c\'b8i x\'b8c kh\'abng c\'dfn l\'b5 m\'e9t c\'b8i x\'b8c n\'f7a l\'aan. V\'b5 b\'a9y gi\'ea, t\'cat c\'b6 nh\'f7ng ng\'ad\'eai kh\'abng \'ae\'ad\'eec tham d\'f9 c\'b6nh thi\'aau s\'e8ng \'cay, v\'e7 tay. Hoan h\'ab!
\par Khi ai n\'cay \'ae\'b7 xem ch\'b8n r\'e5i, h\'e4 h\'b9 c\'b8i x\'b8c xu\'e8ng. C\'b8i d\'a9y treo \'ae\'ad\'eec ch\'c6t ra t\'f5ng \'aeo\'b9n, b\'b8n m\'e7i \'aeo\'b9n 3 hay 5 \'ae\'abla. B\'e4n \'ae\'b5n b\'b5 tranh nhau mua l\'b5m v\'cbt k\'fb ni\'d6m v
\'b5 \'ae\'d3 l\'cay kh\'ad\'edc.
\par Th\'d5 l\'b5 "C\'abng l\'fd nh\'a9n d\'a9n" - nh\'ad \'eb \'ae\'e3, ng\'ad\'eai ta v\'c9n g\'e4i - \'ae\'b7 \'ae\'ad\'eec th\'f9c hi\'d6n. \'a7\'b8m \'ae\'abng d\'deu \'aei, khen ng\'eei nh\'f7ng k\'ce "h\'b5nh s\'f9" r\'e5i t\'b6n d\'c7n \'aei, vui v\'ce
 nh\'ad v\'f5a d\'f9 xong m\'e9t b\'f7a ti\'d6c, v\'b5 h\'d1n g\'c6p nhau m\'e9t b\'cbn kh\'b8c.
\par Trong khi \'ae\'e3 th\'d7 tr\'aan m\'c6t \'ae\'cat nh\'b5y nh\'f4a m\'ec v\'b5 kh\'e3i, m\'e9t \'ae\'c7u l\'a9u \'aeen, n\'b8t b\'d0t, b\'de thui ch\'b8y, kh\'abng ra h\'d7nh th\'ef g\'d7 n\'f7a, nh\'a8n nh\'e3 m\'e9t c\'b8ch \'ae\'b8ng s\'ee v\'b5 h\'d7
nh nh\'ad mu\'e8n h\'e1i v\'c7ng d\'ad\'acng \'aeang l\'c6n r\'bbng: "\'a7\'e3 l\'b5 v\'a8n minh \'ad?".
\par }\pard\plain \s25\qj \li0\ri0\sb200\sa120\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 M\'e9T CH\'f3T TH\'e8NG K\'a3
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 T\'f5 1889 \'ae\'d5n 1919, \'ae\'b7 c\'e3 2.600 ng\'ad\'ea
i da \'aeen b\'de h\'b5nh h\'d7nh ki\'d3u Lins\'ac, trong \'ae\'e3 c\'e3 51 ph\'f4 n\'f7 v\'b5 thi\'d5u n\'f7, v\'edi 10 c\'f9u binh trong \'ae\'b9i chi\'d5n.
\par Trong s\'e8 78 ng\'ad\'eai da \'aeen b\'de h\'b5nh h\'d7nh ki\'d3u Lins\'ac n\'a8m 1919, c\'e3 11 ng\'ad\'eai b\'de thi\'aau s\'e8ng, 3 ng\'ad\'eai b\'de thi\'aau sau khi \'ae\'b7 b\'de gi\'d5t, 31 ng\'ad\'eai b\'de b\'ben ch\'d5t, 3 ng\'ad\'eai b\'de h
\'b5nh h\'b9 cho \'ae\'d5n ch\'d5t, 1 ng\'ad\'eai b\'de ch\'c6t ra l\'b5m nhi\'d2u m\'b6nh, 1 ng\'ad\'eai b\'de d\'d7m ch\'d5t d\'ad\'edi n\'ad\'edc, 11 ng\'ad\'eai b\'de gi\'d5t b\'bbng nhi\'d2u c\'b8ch kh\'b8c.
\par \'a7\'f8ng \'ae\'c7u l\'b5 bang Gio\'e3cgia v\'edi 22 n\'b9n nh\'a9n, th\'f8 \'ae\'d5n bang M\'ddtxixipi v\'edi con s\'e8 12. Trong c\'b6 bang th\'f8 nh\'cat v\'b5 bang th\'f8 hai \'ae\'d2u c\'e3 3 binh s\'dc trong s\'e8 b\'de h\'b5nh h\'d7nh. Trong s\'e8
 11 ng\'ad\'eai b\'de thi\'aau s\'e8ng, th\'d7 \'eb bang Gio\'e3cgia c\'e3 4 ng\'ad\'eai v\'b5 2 ng\'ad\'eai \'eb bang M\'ddtxixipi. Trong 34 v\'f4 h\'b5nh h\'d7nh c\'e3 t\'ddnh to\'b8n tr\'ad\'edc v\'b5 c\'e3 t\'e6 ch\'f8c h\'bcn hoi, th\'d7 bang Gio\'e3
cgia c\'f2ng l\'b9i \'ae\'f8ng \'ae\'c7u v\'edi 5 v\'f4. Th\'f8 hai \'ae\'d5n bang M\'ddtxixipi v\'edi 3 v\'f4.
\par C\'a8n c\'f8 theo nh\'f7ng t\'e9i tr\'b9ng bu\'e9c cho nh\'f7ng n\'b9n nh\'a9n n\'a8m 1919, th\'d7:
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 m\'e9t ng\'ad\'eai c\'e3 ch\'a9n trong Li\'aan \'aeo\'b5
n nh\'f7ng ng\'ad\'eai kh\'abng \'ae\'b6ng ph\'b8i (nh\'f7ng ch\'f1 tr\'b9i \'ae\'e9c l\'cbp);
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 m\'e9t ng\'ad\'eai \'ae\'b7 truy\'d2n b\'b8 nh\'f7ng s\'b8
ch b\'b8o c\'b8ch m\'b9ng;
\par m\'e9t ng\'ad\'eai \'ae\'b7 d\'b8m qu\'b8 t\'f9 do l\'aan ti\'d5ng c\'abng k\'ddch nh\'f7ng v\'f4 h\'b5nh h\'d7nh ki\'d3u Lins\'ac;
\par m\'e9t ng\'ad\'eai \'ae\'b7 b\'d7nh lu\'cbn v\'d2 nh\'f7ng v\'f4 x\'ab x\'b8t gi\'f7a m\'e9t ng\'ad\'eai da tr\'beng v\'b5 da \'aeen \'eb Sicag\'ab;
\par m\'e9t ng\'ad\'eai m\'b5 ng\'ad\'eai ta bi\'d5t l\'b5 l\'b7nh t\'f4 c\'f1a phong tr\'b5o \'ae\'cau tranh cho l\'eei \'ddch c\'f1a ng\'ad\'eai da \'aeen;
\par m\'e9t ng\'ad\'eai v\'d7 kh\'abng k\'dep tr\'b8nh sang b\'aan \'ae\'ad\'eang n\'aan \'ae\'b7 l\'b5m cho m\'e9t \'ae\'f8a b\'d0 da tr\'beng ng\'e5i trong \'abt\'ab ho\'b6ng s\'ee.
\par N\'a8m 1920, c\'e3 50 v\'f4 h\'b5nh h\'d7nh ki\'d3u Lins\'ac v\'b5 n\'a8m 1923, c\'e3 28 v\'f4.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nh\'f7ng t\'e9i \'b8c \'ae\'e3 bao gi\'ea c\'f2ng l\'b5
 do ghen gh\'d0t v\'d2 kinh t\'d5 m\'b5 ra, ho\'c6c do th\'cay nh\'f7ng ng\'ad\'eai da \'aeen \'eb \'ae\'dea ph\'ad\'acng l\'b5m \'a8n kh\'cam kh\'b8 h\'acn ng\'ad\'eai da tr\'beng, ho\'c6c do th\'cay c\'abng nh\'a9n da \'aeen kh\'abng ch\'deu b\'de b\'e3
c l\'e9t \'ae\'d5n x\'ad\'acng tu\'fb. Trong t\'cat c\'b6 c\'b8c v\'f4 \'ae\'e3, nh\'f7ng th\'f1 ph\'b9m ch\'ddnh kh\'abng bao gi\'ea b\'de l\'b5m r\'c7y r\'b5, ch\'d8 \'ae\'acn gi\'b6n l\'b5 v\'d7 h\'e4 lu\'abn lu\'abn \'ae\'ad\'eec b\'e4n ch\'ddnh kh
\'b8ch, b\'e4n t\'b5i ch\'ddnh, b\'e4n c\'c7m quy\'d2n v\'b5 nh\'cat l\'b5 b\'b8o ch\'dd ph\'b6n \'ae\'e9ng k\'ddch th\'ddch, khuy\'d5n kh\'ddch, x\'f3i b\'c8y, r\'e5i l\'b9i bao che.
\par M\'e7i khi s\'bep x\'b6y ra hay \'ae\'b7 x\'b6y ra m\'e9t v\'f4 h\'b5nh h\'d7nh ki\'d3u Lins\'ac th\'d5 l\'b5 b\'b8o ch\'dd ch\'edp ngay l\'cay, coi l\'b5 d\'dep may hi\'d5m c\'e3 \'ae\'d3 t\'a8ng s\'e8 b\'b8o ph\'b8t h\'b5nh. B\'b8o ch\'dd t\'ad\'ea
ng thu\'cbt s\'f9 vi\'d6c v\'edi d\'f4ng t\'a9m \'ae\'ada ra r\'cat nhi\'d2u chi ti\'d5t.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Kh\'abng m\'e9t l\'eai tr\'b8ch m\'e3c h\'ad\'edng v\'b5
o b\'e4n gi\'d5t ng\'ad\'eai. Kh\'abng m\'e9t l\'eai th\'ad\'acng x\'e3t \'ae\'e8i v\'edi nh\'f7ng n\'b9n nh\'a9n. Kh\'abng m\'e9t l\'eai b\'d7nh lu\'cbn.
\par }{\f37\fs20\expnd0\expndtw-2\insrsid1378858 B\'b8o New Orleans States ng\'b5y 26 th\'b8ng 6 n\'a8m 1919 \'ae\'a8ng n\'e6i b\'cbt tin sau \'ae\'a9y b\'bbng c\'ec ch\'f7 25 ph\'a9n su\'e8t chi\'d2u ngang trang nh\'cat: }{
\i\f37\fs20\expnd0\expndtw-2\insrsid1378858 H\'abm nay, m\'e9t t\'aan da \'aeen s\'cf b\'de 3.000 c\'abng d\'a9n thi\'aau ch\'d5t.}{\f37\fs20\expnd0\expndtw-2\insrsid1378858  V\'b5 ngay d\'ad\'edi \'ae\'e3 l\'b5 m\'e9t tin in b\'bbng ch\'f7 nh\'e1 x\'dd
