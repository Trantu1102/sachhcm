\par }\pard \qj \fi397\li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ng\'b5i \'ae\'b7 \'ae\'d5n - hay n\'e3i cho \'ae\'f3ng h\'acn l\'b5 ng\'ad\'eai ta \'ae\'b7 \'ae\'ada Ng\'b5i \'ae\'d5
n, coi nh\'ad m\'e9t m\'e3n h\'b5ng thu\'e9c \'ae\'dea v\'b5 c\'e3 th\'d3 tr\'adng b\'b5y \'eb H\'e9i ch\'ee. Ng\'ad\'eai ta \'ae\'denh \'aeem Ng\'b5i b\'b5y \'ddt nh\'cat l\'b5 v\'b5i ba th\'b8ng trong t\'f1 k\'ddnh xinh x\'ceo, nh\'adng m\'e1ng manh v
\'b5 c\'e3 th\'d3 b\'de hu\'fb ho\'b9i. Th\'d5 m\'b5 Ng\'b5i l\'b9i ra \'aei, hay n\'e3i cho \'ae\'f3ng h\'acn, l\'b5 ng\'ad\'eai ta \'ae\'b7 bu\'e9c Ng\'b5i ph\'b6i cu\'e8n g\'e3i ra \'aei. \'a7\'ad\'eec \'a8n \'eb sang tr\'e4ng t\'b9i ph\'e8 U\'aein\'ab
, \'ae\'ad\'eec ru \'aam \'cam trong tay c\'f1a }{\i\f37\fs20\insrsid1378858 \'aei\'d6n h\'b9}{\f37\fs20\insrsid1378858  Xar\'ab - \'abng Ho\'b5ng An Nam v\'b5 B\'e9 tr\'ad\'ebng B\'e9 Thu\'e9c \'ae\'dea- nh\'ad tr\'aan tay m\'e9t ng\'ad\'eai cha, th\'d5
 m\'b5 Ng\'b5i v\'c9n k\'aau l\'b5 c\'dfn r\'d0t. N\'d5u t\'cat c\'b6 \'ae\'e5ng b\'b5o c\'f1a Ng\'b5i - nh\'f7ng ng\'ad\'eai \'ae\'b7 t\'f5ng d\'can th\'a9n trong b\'efn l\'c7y, s\'ad\'acng tuy\'d5t v\'b5 d\'ad\'edi l\'b5n m\'ada \'ae\'b9n tr\'aan chi
\'d5n tr\'ad\'eang \'eb n\'ad\'edc Ph\'b8p, nh\'f7ng ng\'ad\'eai \'ae\'b7 v\'b5 \'aeang b\'de \'ae\'b5y \'aeo\'b9 d\'ad\'edi ti\'d5t tr\'eai r\'d0t nh\'ad c\'bet da c\'bet th\'det, \'ae\'b7 v\'b5 \'aeang b\'de \'aee do\'b9 b\'ebi nh\'f7ng k\'ce }{
\i\f37\fs20\insrsid1378858 m\'b5 h\'e4}{\f37\fs20\insrsid1378858  t\'can c\'abng, - n\'d5u t\'cat c\'b6 nh\'f7ng ng\'ad\'eai \'ae\'e3 \'ae\'d2u n\'e3i nh\'ad Ng\'b5i \'ae\'b7 v\'e9i ch...u\'e5n ngay, ch\'ed ch\'bcng ch\'deu li\'d2u m\'b9ng - c\'e8 nhi\'aa
n l\'b5 li\'d2u c\'b8i m\'b9ng kh\'abng \'ae\'d5 v\'ad\'acng b\'bbng, nh\'adng d\'c9u sao c\'f2ng qu\'fd b\'b8u - th\'d7 Ng\'b5i c\'e3 th\'d3 l\'cay \'ae\'a9u ra \'ae\'ad\'eec \'ae\'d3 t\'e1 c\'b8i l\'dfng trung qu\'a9n d\'d4 ki\'d5m v\'b5 l\'df
ng trung th\'b5nh r\'ce r\'f3ng \'ae\'d3 l\'b5m v\'f5a \'fd c\'b8i \'abng ch\'f1 c\'f1a Ng\'b5i, nh\'ad Ng\'b5i \'ae\'b7 t\'f5ng t\'e1 ra \'eb N\'abgi\'a8ng hay \'eb nh\'f7ng n\'aci kh\'b8c?   
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-292\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Ngo\'b5i v\'can \'ae\'d2 t\'d7nh c\'b6m ra, v\'b5 ngo\'b5
i m\'cay con ng\'f9a c\'b8i \'eb tr\'ad\'eang \'aeua L\'abngs\'a8ng c\'efng nh\'f7ng v\'ce \'ae\'d1p c\'e6 \'ae\'b9i \'eb nh\'b5 h\'b8t \'a4pera ra th\'d7 Ng\'b5i \'ae\'b7 th\'cay g\'d7 trong su\'e8t th\'eai gian "tham quan" c\'f1a Ng\'b5i \'eb c\'b8i n
\'ad\'edc Ph\'b8p l\'b9c th\'f3 n\'b5y?   
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ng\'b5i c\'e3 th\'cay \'ae\'ad\'eec nguy\'d6n v\'e4ng thi
\'d5t tha mong mu\'e8n c\'abng l\'fd, t\'f9 do v\'b5 lao \'ae\'e9ng c\'f1a qu\'c7n ch\'f3ng r\'e9ng r\'b7i c\'f1a d\'a9n t\'e9c Ph\'b8p n\'b5y kh\'abng? Ng\'b5i c\'e3 th\'cay \'ae\'ad\'eec t\'d7nh c\'b6m cao c\'b6 y\'aau chu\'e9ng ho\'b5 b\'d7nh v\'b5 h
\'f7u ngh\'de \'aeang l\'b5m rung \'ae\'e9ng tr\'b8i tim c\'f1a qu\'c7n ch\'f3ng \'ae\'e3, - s\'e8 qu\'c7n ch\'f3ng m\'b5, qua nh\'f7ng cu\'e9c c\'b8ch m\'b9ng gi\'b6i ph\'e3ng, gi\'ea \'ae\'a9y \'ae\'b7 gi\'b6i ph\'e3ng m\'d7nh kh\'e1i \'b8ch c\'f1a b
\'e4n vua ch\'f3a, \'ae\'d3 tr\'eb th\'b5nh k\'ce t\'f9 m\'d7nh l\'b5m ch\'f1 m\'d7nh \'ae\'e3 kh\'abng?   
\par }\pard\plain \s15\qj \fi397\li0\ri0\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Qua nh\'f7ng l\'eai t\'b8n t\'f4ng h\'ccn h\'b9 trong nh\'f7ng b
\'b5i di\'d4n v\'a8n c\'f1a m\'cay nh\'b5 \'ae\'ad\'acng c\'f4c v\'b5 trong nh\'f7ng b\'b5i b\'b8o \'ae\'ad\'eec tr\'ee c\'cap ti\'d2n c\'f1a m\'cay t\'ea b\'b8o "l\'ad\'acng thi\'d6n" ra, Ng\'b5i c\'dfn c\'e3 nghe th\'cay g\'d7 n\'f7a kh\'abng? Ng\'b5i c
\'e3 \'ae\'ad\'eec nghe ng\'ad\'eai ta n\'e3i \'ae\'d5n Paxt\'ac hay V\'abnte, V\'ddchto Huyg\'ab hay Annat\'abn Phr\'a8ngx\'ac kh\'abng? Ng\'b5i c\'e3 \'ae\'ad\'eec nghe ng\'ad\'eai ta n\'e3i \'ae\'d5n b\'b6n Tuy\'aan ng\'abn Nh\'a9n quy\'d2n v\'b5 D\'a9
n quy\'d2n kh\'abng? Ng\'b5i c\'e3 \'ae\'ad\'eec 
\par }\pard \s15\qj \li0\ri0\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 nghe ng\'ad\'eai ta k\'d3 l\'b9i l\'dech s\'f6 c\'f1a cu\'e9c c\'b8ch m\'b9ng b\'cat di\'d6t kh\'abng?   
\par }\pard \s15\qj \li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 Sau nh\'f7ng x\'f3c \'ae\'e9ng m\'b9nh m\'cf khi xem nh\'f7ng \'ae\'b9i b\'b8c, xe t\'a8ng ho\'b5 b\'d7nh di\'d4u qua, th\'d7
 trong c\'b8i }{\i\insrsid1378858 \'ae\'c7u}{\insrsid1378858  ch\'ddt kh\'a8n c\'f1a Ng\'b5i \'ae\'b7 v\'e9i ch\'edm n\'eb n\'e7i nh\'ed nh\'b5, th\'d5 l\'b5 Ng\'b5i v\'e9i v\'b7 cu\'e8n g\'e3i ra \'aei! Ng\'b5y mai \'ae\'a9y, Ng\'b5i s\'cf xu\'e8ng t\'b5
u, v\'b5 Ng\'b5i s\'cf l\'b9i tr\'abng th\'cay nh\'f7ng bi\'d3n c\'b6 ven theo \'ae\'cat n\'ad\'edc c\'f1a ng\'ad\'eai Ai C\'cbp v\'b5 ng\'ad\'eai }{\f38\insrsid1378858 \'ca}{\insrsid1378858 n \'a7\'e9. Ho\'b5 l\'c9n v\'edi ti\'d5ng s\'e3ng g\'c7
m vang, nh\'f7ng ti\'d5ng th\'d0t d\'f7 d\'e9i c\'f1a nh\'a9n d\'a9n b\'de \'b8p b\'f8c \'eb c\'b8c n\'ad\'edc n\'b5y, c\'f2ng nh\'ad c\'f1a nh\'a9n d\'a9n n\'ad\'edc Ng\'b5i, s\'cf x\'d0 tan b\'c7u kh\'abng kh\'dd y\'aan t\'dcnh b\'aan tai Ng\'b5i. V\'b5
 n\'d5u nh\'ad Ng\'b5i c\'e3 \'ae\'abi ch\'f3t \'e3c t\'ad\'ebng t\'ad\'eeng, Ng\'b5i s\'cf th\'cay r\'bbng \'fd ch\'dd c\'f1a nh\'a9n d\'a9n - m\'e9t \'fd ch\'dd \'ae\'b7 \'ae\'ad\'eec hun \'ae\'f3c trong ngh\'cco \'ae\'e3i v\'b5 kh\'e6 c\'f9c - m\'e9t 
\'fd ch\'dd c\'dfn m\'b9nh h\'acn v\'b5 d\'ceo dai h\'acn s\'e3ng c\'b6, cu\'e8i c\'efng s\'cf kho\'d0t h\'e6ng d\'c7n v\'b5 \'ae\'b8nh b\'cbt c\'b8i t\'b6ng \'ae\'b8 b\'d2 ngo\'b5i c\'e3 v\'ce v\'f7ng ch\'bec l\'b5 s\'f9 \'b8p b\'f8c v\'b5 b\'e3c l\'e9
t kia \'aei. C\'e3 th\'d3 Ng\'b5i s\'cf t\'f9 nh\'f1 r\'bbng c\'b8i m\'b5 Ng\'b5i tr\'abng th\'cay \'ae\'cay l\'b5 m\'e9t ch\'f3t c\'f1a n\'ad\'edc Ph\'b8p \'ae\'e3
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 V\'dcnh bi\'d6t... ng\'ad\'eai \'ae\'e5ng h\'ad\'acng! M
\'e9t khi m\'b5 nh\'f7ng \'ae\'eet s\'e3ng bi\'d3n v\'ab t\'d7nh \'ae\'b7 l\'cap k\'ddn v\'d5t \'aei c\'f1a con t\'b5u Ng\'b5i ng\'e5i th\'d7 n\'ad\'edc Ph\'b8p s\'cf qu\'aan Ng\'b5i, c\'f2ng nh\'ad Ng\'b5i s\'cf kh\'abng c\'dfn nh\'ed ch\'f3t g\'d7 v\'d2
 nh\'f7ng ng\'ad\'eai Ph\'b8p n\'f7a.   
\par \'a7\'d3 gi\'f7 k\'fb ni\'d6m c\'f1a m\'e9t n\'d2n v\'a8n minh hi\'d6n \'ae\'b9i v\'b5 l\'edn lao, Ng\'b5i mang theo v\'d2 cung \'aei\'d6n c\'f1a Ng\'b5i m\'e9t chi\'d5c d\'ad\'acng c\'c7m, v\'b5i c\'b8i nh\'c9n v\'b5 c\'b6 m\'cay chi\'d5c b\'cbt l\'f6a m
\'b5 Ng\'b5i \'ae\'b7 \'ae\'e6i \'ae\'ad\'eec b\'bbng ch\'f3t \'ddt uy t\'ddn m\'b5 Ng\'b5i \'ae\'d3 m\'cat m\'b8t \'aei trong tr\'b8i tim nh\'a9n d\'a9n c\'f1a Ng\'b5i. V\'b5 khi Ng\'b5i l\'b9i tr\'eb v\'d2 s\'e8ng gi\'f7a \'ae\'b8m phi t\'c7n v\'b5 n
\'e9i th\'de c\'f1a Ng\'b5i, gi\'f7a nh\'f7ng s\'e4t gi\'cay l\'e9n v\'b5 t\'c8u thu\'e8c phi\'d6n c\'f1a Ng\'b5i, th\'d7 m\'e9t v\'b5i t\'aan k\'fd l\'f4c gi\'b5 s\'cf th\'aau d\'d6t thay Ng\'b5i v\'b5 h\'e9 Ng\'b5i \'ae\'d3 g\'f6i cho n\'ad\'edc Ph\'b8
p m\'b5 Ng\'b5i kh\'abng h\'d2 hi\'d3u bi\'d5t m\'e9t v\'b5i c\'a9u n\'denh h\'e3t hay m\'e9t v\'b5i v\'c7n th\'ac l\'f1ng c\'f1ng, d\'ad\'edi \'ae\'e3, nh\'f7ng ng\'e3n tay \'ae\'c7y nh\'c9n c\'f1a Ng\'b5i s\'cf c\'c7m b\'f3t k\'fd c\'b8i ch\'f7 k\'fd c
\'f1a m\'e9t v\'de \'ae\'d5 v\'ad\'acng l\'b5 ngh\'d6 s\'dc v\'b5 v\'a8n nh\'a9n (!).   
\par Th\'d5 l\'b5 c\'b8i \'fd nguy\'d6n b\'d7nh sinh l\'edn c\'f1a Ng\'b5i \'ae\'b7 \'ae\'ad\'eec tho\'b6 m\'b7n. V\'b5 nh\'ad v\'cby l\'b5 h\'b9nh ph\'f3c v\'b5 \'cam no c\'f1a nh\'a9n d\'a9n An Nam c\'f2ng s\'cf \'ae\'ad\'eec x\'a9y d\'f9ng v\'b5 c\'f1ng c
\'e8 r\'e5i \'ae\'cay! 
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nguy\'d4n \'b8i qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 Le Journal du Peuple,}{\insrsid1378858 

