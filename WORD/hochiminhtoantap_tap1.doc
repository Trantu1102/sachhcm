\f37\fs20\insrsid1378858 
\par }\pard \qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Bu\'e9c ph\'b6i b\'de ki\'d2m ch\'d5 b\'ebi s\'f8c m\'b9nh, nh\'a9n d\'a9n An Nam, m\'b5 l\'dech s\'f6 ch\'a9n ch\'ddnh 
\'ae\'b7 kh\'ebi \'ae\'c7u t\'f5 h\'acn 3000 n\'a8m, t\'f5ng l\'f3c t\'f5ng l\'f3c nh\'ad c\'e3 nh\'f7ng \'ae\'eet c\'e5n c\'b5o ch\'e8ng \'ae\'e8i, bi\'d3u hi\'d6n b\'bbng nh\'f7ng m\'adu toan n\'e6i d\'cby r\'e9ng kh\'bep, ho\'c6c b\'bbng h\'b5nh \'ae
\'e9ng c\'f1a nh\'f7ng con ng\'ad\'eai tuy\'d6t v\'e4ng, nh\'ad nh\'f7ng cu\'e9c bi\'d3u t\'d7nh \'abn ho\'b5 n\'a8m 1908 (xem }{\i\f37\fs20\insrsid1378858 Bulletin officiel de la Ligue des Droits de l' Homme}{\f37\fs20\insrsid1378858 , ng\'b5
y 31-10-1912), v\'b5 nh\'ad nh\'f7ng v\'f4 n\'e6 bom g\'c7n \'ae\'a9y \'eb Nam K\'fa v\'b5 \'eb B\'bec K\'fa. Than \'abi! \'a7\'e3 l\'b5 nh\'f7ng cu\'e9c ph\'b6n kh\'b8ng v\'ab hi\'d6u m\'b5 m\'e7i l\'c7n \'ae\'d2u \'aeem l\'b9i nh\'f7ng tr\'cbn \'ae\'b5
n \'b8p \'ae\'c9m m\'b8u, v\'b5 th\'aam n\'f7a \'ae\'b7 t\'b9o c\'ed cho ch\'ddnh quy\'d2n th\'d3 theo Nap\'abl\'aa\'abng trong v\'f4 chi\'d5c "m\'b8y ma qu\'b8i"}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain 
\s28\qj \fi397\li0\ri0\sa60\sl-230\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) }{\i\insrsid1378858 Machine infernale}{\insrsid1378858 . M\'b8y ma qu
\'b8i n\'e6 c\'e3 th\'d3 g\'a9y t\'f6 vong, \'ae\'b7 t\'f5ng \'ae\'ad\'eec b\'e8 tr\'dd \'ae\'d3 \'b8m s\'b8t B\'abnap\'b8ct\'ac. May thay, B\'abnap\'b8ct\'ac tho\'b8t n\'b9n v\'b5 bi\'d5t r\'e2 th\'f1 ph\'b9m. Tuy v\'cby, \'abng kh\'d0o th\'f5a c\'ac h
\'b9 l\'d6nh \'ae\'b5y 138 ng\'ad\'eai v\'ab t\'e9i, c\'e3 h\'b5nh vi kh\'abng t\'b8n th\'b5nh ch\'ddnh s\'b8ch c\'f1a \'abng.}})}{\f37\fs20\insrsid1378858 , m\'b5 tr\'f5 kh\'f6 m\'e9t c\'b8ch l\'dech s\'f9 nh\'f7ng ng\'ad\'eai An Nam kh\'abng t\'e1 v\'ce
 hoan h\'ab th\'e3i \'ae\'e9c \'aeo\'b8n c\'f1a n\'e3. Ng\'ad\'eai ta bi\'d5t r\'bbng trong chi\'d5n tranh}{\cs17\f37\fs20\super\insrsid1378858 2{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-230\slmult0
\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 2) Chi\'d5n tranh th\'d5 gi\'edi th\'f8 nh\'cat.}})}{\f37\fs20\insrsid1378858 , \'a7\'abng D\'ad\'acng \'ae\'b7 l
\'b5 n\'aci di\'d4n ra nh\'f7ng s\'f9 ki\'d6n \'aeau l\'dfng, d\'c9n \'ae\'d5n vi\'d6c ban b\'e8 thi\'d5t qu\'a9n lu\'cbt, v\'b5 k\'ccm theo l\'b5 nh\'f7ng v\'f4 tuy\'aan \'b8n v\'b5 h\'b5nh quy\'d5t h\'b5ng lo\'b9t. Gi\'ea \'ae\'a9y, c\'b8c nh\'b5 t\'ef
 kh\'e6 sai \'eb Guyan, \'eb T\'a9n Cal\'aa\'ae\'abni, \'eb C\'abn \'a7\'b6o, v.v. \'ae\'d2u \'ae\'c7y \'bep t\'ef ch\'ddnh tr\'de ng\'ad\'eai b\'b6n x\'f8. S\'f3ng li\'aan thanh v\'b5 m\'b8y ch\'d0m \'ae\'d2u ch\'e3ng v\'b8nh bu\'e9c nh\'f7ng ai b\'ad
\'edng b\'d8nh, nh\'f7ng ai ph\'b6n kh\'b8ng ph\'b6i im h\'aci l\'c6ng ti\'d5ng.
\par }\pard\plain \s23\qj \fi397\li0\ri0\sb140\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 S\'f9 c\'b9nh tranh c\'f1a Nh\'cbt B
\'b6n
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-250\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T}{\insrsid1378858\charrsid10309197 \'d7nh h\'d7nh m\'b5 ch
\'f3ng t\'abi v\'f5a m\'edi ph\'b8c ra m\'e9t s\'e8 n\'d0t l\'edn, c\'e3 l\'cf}{\insrsid1378858   s\'cf c\'e3 th\'d3 k\'d0o d\'b5i v\'ab t\'cbn, n\'d5u cu\'e9c chi\'d5n tranh - \'ae\'b7 \'ae\'b6o l\'e9n to\'b5n b\'e9 ch\'a9u \'a2u - hi\'d6n nay kh\'abng k
\'d0o theo m\'e9t s\'f9 x\'d7 x\'b5o m\'edi v\'d2 v\'can \'ae\'d2 d\'a9n b\'b6n x\'f8. Qu\'b6 v\'cby, do chi\'d5n tranh, n\'ad\'edc Nh\'cbt \'ae\'b7 tranh th\'f1 \'ae\'ad\'eec, t\'f5 ph\'dda n\'ad\'edc Ph\'b8p, nh\'f7ng quy\'d2n \'adu ti\'aan \'ae\'c6c bi
\'d6t \'eb \'a7\'abng D\'ad\'acng. V\'cby ph\'b6i th\'cay tr\'ad\'edc r\'bbng ng\'ad\'eai Nh\'cbt s\'cf \'ae\'d5n l\'cbp nghi\'d6p ng\'b5y c\'b5ng nhi\'d2u tr\'aan x\'f8 n\'b5y v\'b5 s\'cf l\'b5m \'ae\'f1 m\'e4i ngh\'d2 \'eb \'ae\'a9y; k\'d5t qu\'b6 l\'b5
 d\'a9n b\'b6n x\'f8 s\'cf s\'e8ng c\'b5ng kh\'e8n \'ae\'e8n h\'acn: b\'de h\'b7m trong c\'b6nh d\'e8t n\'b8t b\'ebi ch\'ddnh s\'b8ch \'ae\'c7n \'ae\'e9n ho\'b8, b\'de suy y\'d5u v\'d7 ph\'b6i ch\'deu nhi\'d2u thi\'d5u th\'e8n, nhi\'d2u th\'f1 \'aeo\'b9n 
\'ae\'c7u \'ae\'e9c c\'f1a Nh\'b5 n\'ad\'edc - ng\'a9n kh\'e8 v\'b5 c\'b8c c\'abng ty \'ae\'c6c nh\'ad\'eeng \'d0p h\'e4 ti\'aau th\'f4 thu\'e8c phi\'d6n, r\'ad\'eeu -, h\'e4 s\'cf ti\'d5p t\'f4c lu\'c8n qu\'c8n trong m\'e9t c\'b8i v\'dfng thu h\'d1p qu
\'b8 \'ae\'e7i.
\par }\pard \s15\qj \fi397\li0\ri0\sl-256\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858\charrsid10309197 X\'d0t v\'d2 nguy\'aan t\'bec, ti\'d5n b\'e9 chung ph\'f4 thu\'e9c v\'b5o vi\'d6c ph\'b8t tri\'d3n ch\'f1 ngh\'dc
a qu\'e8c t\'d5; v\'b5 v\'a8n minh ch\'d8 c\'e3 l\'eei khi c\'b8c quan h\'d6 qu\'e8c t\'d5 \'ae\'ad\'eec m\'eb r\'e9ng v\'b5 t\'a8ng c\'ad\'eang. M\'c6t kh\'b8c, l\'b5 phi l\'fd n\'d5u ngh\'dc r\'bbng hai d\'a9n t\'e9c l\'b8ng gi\'d2ng nh\'ad d\'a9n t\'e9
c An Nam v\'b5 d\'a9n t\'e9c Nh\'cbt B\'b6n l\'b9i c\'e3 th\'d3 c\'f8 t\'e5n t\'b9i bi\'d6t l\'cbp \'ae\'e8i v\'edi nhau. Nh\'adng ng\'ad\'eai Nh\'cbt, nh\'ea \'eb ch\'ddnh}{\insrsid1378858   }{\insrsid1378858\charrsid10309197 ph\'f1 kh\'abn kh\'d0o c\'f1
a h\'e4, c\'e3 c\'b8c ph\'ad\'acng ti\'d6n r\'cat \'ae\'c7y \'ae\'f1, \'ae\'ad\'eec trang b\'de t\'e8t \'ae\'d3 ti\'d5n h\'b5nh \'ae\'cau tranh kinh t\'d5; trong khi \'ae\'e3 th\'d7 ng\'ad\'eai An Nam- ch\'f3ng t\'abi \'ae\'b7 n\'e3i v\'d7 sao - l\'b9i ho
\'b5n to\'b5n l\'b5 con s\'e8 kh\'abng , x\'d0t v\'d2 m\'c6t ti\'d5n b\'e9 hi\'d6n \'ae\'b9i, so v\'edi c\'b8c l\'b8ng gi\'d2ng c\'f1a h\'e4: ng\'ad\'eai Hoa, ng\'ad\'eai Nh\'cbt, ng\'ad\'eai Xi\'aam v\'b5 c\'b6 ng\'ad\'eai \'can n\'f7a. C\'a9u h\'e1i 
\'ae\'c6t ra t\'f5 r\'b5y, l\'b5 \'ae\'f8ng tr\'ad\'edc t\'d7nh h\'d7nh m\'edi \'ae\'ad\'eec t\'b9o ra b\'ebi nh\'f7ng lu\'e5ng du nh\'cbp c\'f1a ng\'ad\'eai n\'ad\'edc ngo\'b5i, ph\'b6i ch\'a8ng Ch\'ddnh ph\'f1 Ph\'b8p tin r\'bbng \'ae\'b7}{
\insrsid1378858  \'ae\'f3ng l\'f3c, v\'d7 l\'eei \'ddch chung, ph\'b6i gi\'b6i ph\'e3ng d\'a9n b\'b6n x\'f8 v\'b5 gi\'f3p \'ae\'ec h\'e4 b\'bbng t\'cat c\'b6 c\'b8c ph\'ad\'acng ti\'d6n m\'d7nh c\'e3 trong tay, \'ae\'d3 h\'e4 t\'f9 chu\'c8n b\'de cho cu
\'e9c c\'b9nh tranh gay go m\'b5 h\'e4 s\'cf \'ae\'b6m \'ae\'ad\'acng \'ae\'e8i v\'edi ng\'ad\'eai Nh\'cbt v\'b5 nh\'f7ng ng\'ad\'eai n\'ad\'edc ngo\'b5i kh\'b8c?
\par }\pard\plain \qj \li0\ri0\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858\charrsid10309197 N\'d5u l\'eai \'ae\'b8p c\'e3 chi\'d2u kh\'bcng \'ae
\'denh, th\'d7 ch\'f3ng t\'abi kh\'e3 hi\'d3u v\'d7 sao c\'b8c y\'aau s\'b8ch c\'f1a m\'d7nh, m\'b5 b\'b8o }{\i\f37\fs20\insrsid1378858\charrsid10309197 L'Humanit\'d0}{\f37\fs20\insrsid1378858\charrsid10309197  \'ae\'b7 \'ae\'a8ng trong s\'e8 ra ng\'b5
y 18-6 v\'f5a qua, }{\i\f37\fs20\insrsid1378858\charrsid10309197 l\'b9i c\'e3 th\'d3 g\'a9y ch\'can \'ae\'e9ng trong gi\'edi th\'f9c}{\i\f37\fs20\insrsid1378858  }{\i\f37\fs20\insrsid1378858\charrsid10309197  d\'a9n.}{
\f37\fs20\insrsid1378858\charrsid10309197  Ch\'f3ng t\'abi bi\'d5t \'ae\'ddch x\'b8c r\'bbng m\'e9t s\'dc quan cao c\'cap ch\'d8 huy c\'b8c t\'cbp \'aeo\'b5n lao c\'abng thu\'e9c \'ae\'dea - c\'e3 l\'cf c\'a8n c\'f8 v\'b5o nh\'f7ng ch\'d8 th\'de}{
\insrsid1378858  n}{\f37\fs20\insrsid1378858\charrsid10309197 h\'cbn \'ae\'ad\'eec t\'f5 b\'aan tr\'aan - \'ae\'b7 h\'b9 l\'d6nh cho t\'f5ng tr\'ad\'ebng t\'cbp \'aeo\'b5n h\'b7y t\'dech thu t\'cat c\'b6 nh\'f7ng b\'b6n y\'aau s\'b8ch v\'f5a n\'aau, t\'d7
m th\'cay \'eb nh\'f7ng ng\'ad\'eai lao c\'abng An Nam. R\'cat \'abn ho\'b5 c\'b6 v\'d2 n\'e9i dung l\'c9n v\'d2 h\'d7nh th\'f8c, c\'b8c nguy\'d6n v\'e4ng c\'f1a ch\'f3ng t\'abi nh\'bbm v\'b5o nh\'f7ng c\'b6i c\'b8ch ch\'f1 y\'d5u cho vi\'d6c gi\'b6i ph
\'e3ng ch\'f3ng t\'abi, v\'b5 nh\'bbm v\'b5o nh\'f7ng quy\'d2n t\'f9 do m\'b5 n\'d5u kh\'abng c\'e3 ch\'f3ng th\'d7 con ng\'ad\'eai ng\'b5y nay ch\'d8 l\'b5 m\'e9t k\'ce n\'ab l\'d6  kh\'e8n n\'b9n. Kh\'abng ai c\'e3 th\'d3 ph\'f1 nh\'cbn r\'bbng n\'d5
u kh\'abng c\'e3 c\'b8c quy\'d2n t\'f9 do \'cay, thi\'d5t y\'d5u cho vi\'d6c truy\'d2n b\'b8 nh\'f7ng t\'ad t\'ad\'ebng v\'b5 ki\'d5n th\'f8c m\'b5 \'ae\'eai s\'e8ng hi\'d6n \'ae\'b9i \'ae\'dfi h\'e1i, th\'d7 kh\'abng th\'d3 tr\'abng mong}{
\f37\fs20\insrsid1378858  }{\f37\fs20\insrsid1378858\charrsid10309197 ti\'d5n h\'b5nh b\'cat c\'f8 m\'e9t c\'abng cu\'e9c gi\'b8o ho\'b8 nghi\'aam ch\'d8nh n\'b5o c\'b6.
