 T\'deCH BAN PH\'a6\'a5NG \'a7\'a4NG}{\cs17\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 
{\insrsid1378858 1) Th\'ad n\'b5y c\'e3 th\'d3 l\'b5 Nguy\'d4n }{\f38\insrsid1378858 \'b8}{\insrsid1378858 i Qu\'e8c vi\'d5t th\'b8ng 3-1924.}})}{\insrsid1378858 
\par }\pard\plain \qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i\f37\fs20\insrsid1378858 C\'b8c \'ae\'e5ng ch\'dd th\'a9n m\'d5n,
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd0\expndtw-4\insrsid1378858 T\'abi \'ae\'b7 nh\'cbn \'ae\'ad\'eec b
\'f8c t\'e8i h\'cbu th\'ad c\'f1a }{\i\expnd0\expndtw-4\insrsid1378858 S\'eb qu\'b6n l\'fd nh\'b5}{\expnd0\expndtw-4\insrsid1378858  gi\'f4c ph\'b6i tr\'b6 40 r\'f3p 35 c\'abp\'d5ch v\'d2 ch\'e7 \'eb c\'f1a t\'abi, kh\'abng c\'e3 th\'d7 t\'abi s\'cf b\'de
 \'ae\'ada ra to\'b5.
\par }\pard\plain \qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 T\'abi ph\'b6i cho \'ae\'e5ng ch\'dd bi\'d5t r\'bbng:

\par }\pard\plain \s15\qj \fi397\li0\ri0\sa60\sl-244\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1- Trong nh\'f7ng th\'b8ng, th\'b8ng m\'ad\'eai hai, th\'b8
ng gi\'aang v\'b5 th\'b8ng hai t\'abi thu\'aa ph\'dfng s\'e8 176, \'eb \'ae\'a9y bao gi\'ea c\'f2ng c\'e3 4 v\'b5 5 ng\'ad\'eai thu\'aa. Ban ng\'b5y th\'d7 ti\'d5ng \'e5n li\'aan t\'f4c ng\'a8n tr\'eb t\'abi l\'b5m vi\'d6c. Ban \'ae\'aam t\'abi b\'de r
\'d6p \'a8n th\'det, kh\'abng cho t\'abi ngh\'d8 ng\'aci.
\par }{\expnd-1\expndtw-6\insrsid1378858 V\'d7 v\'cby t\'abi kh\'abng mu\'e8n tr\'b6 5 r\'f3p v\'d2 ti\'d2n thu\'aa nh\'b5 \'ae\'d3 t\'e1 s\'f9 ph\'b6n \'ae\'e8i.
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa60\sl-244\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 2- T\'f5 th\'b8ng ba, t\'abi nh\'cbn m\'e9t ph\'df
ng nh\'e1, r\'cat nh\'e1. S\'eb qu\'b6n l\'fd nh\'b5 bu\'e9c t\'abi g\'b8nh 13 r\'f3p 74 cho th\'b8ng ba, v\'b5 11 r\'f3p 61 cho nh\'f7ng th\'b8ng sau.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa60\sl-244\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 So s\'b8nh kh\'abng gian h\'d1p v\'b5 trang b\'de n\'e9i th
\'cat qu\'b8 \'ae\'acn s\'ac v\'edi c\'b8c ph\'dfng kh\'b8c r\'e9ng h\'acn nhi\'d2u, ti\'d6n nghi h\'acn, c\'e3 nhi\'d2u \'ae\'ccn, \'aei\'d6n tho\'b9i, t\'f1, gh\'d5 b\'b5nh d\'b5i, ph\'dfng t\'bem, v.v. v\'b5 ti\'d2n thu\'aa tho\'b6 \'ae\'b8ng th\'d7 gi
\'b8 m\'b5 ng\'ad\'eai ta mu\'e8n bu\'e9c cho t\'abi l\'b5 ho\'b5n to\'b5n \'ae\'b8ng c\'abng ph\'c9n.
\par }\pard\plain \qj \fi397\li0\ri0\sa60\sl-244\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 3- V\'d7 v\'cby t\'abi xin \'ae\'e5ng ch\'dd vui l\'dfng l
\'b5m m\'e9t cu\'e9c \'aei\'d2u tra. V\'b5 sau cu\'e9c \'aei\'d2u tra \'ae\'e3, v\'edi m\'e4i quy\'d5t \'ae\'denh c\'f1a m\'e4i to\'b5 \'b8n, t\'abi tu\'a9n theo tinh th\'c7n c\'f1a \'ae\'e5ng ch\'dd v\'d2 c\'abng b\'bbng v\'b5 b\'d7nh \'ae\'bcng.
\par }\pard \qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ch\'b5o c\'e9ng s\'b6n.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nguy\'d4n \'b8i Qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Th\'ad \'ae\'b8nh m\'b8y, ti\'d5ng Ph\'b8p,\line b\'b6n ch\'f4p l
\'adu t\'b9i Vi\'d6n H\'e5 Ch\'dd Minh.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 CH\'f1 NGH\'dcA \'a7\'d5 QU\'e8C PH\'b8P\line D\'b8M L
\'b5M NH\'f7NG G\'d7?
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Nh\'f7ng ng\'ad\'eai }{\f38\fs20\insrsid1378858 \'ca}{
\f37\fs20\insrsid1378858 n \'a7\'e9, v\'d7 ch\'d8 ph\'b9m c\'e3 m\'e7i m\'e9t c\'b8i t\'e9i l\'b5 \'ae\'cau tranh gi\'b5nh \'ae\'e9c l\'cbp cho \'ae\'cat n\'ad\'edc c\'f1a m\'d7nh, \'ae\'b7 b\'de c\'b6nh s\'b8t c\'f1a \'ae\'f8c vua Anh truy n\'b7. M\'e9
t v\'b5i ng\'ad\'eai tr\'e8n sang nh\'f7ng nh\'ad\'eeng \'ae\'dea Ph\'b8p \'eb }{\f38\fs20\insrsid1378858 \'ca}{\f37\fs20\insrsid1378858 n \'a7\'e9. H\'e4 t\'ddnh l\'b5 s\'cf \'ae\'ad\'eec h\'ad\'ebng \'ae\'b9o lu\'cbt c\'ad tr\'f3. Nh\'adng nh\'b5 c\'c7
m quy\'d2n th\'f9c d\'a9n Ph\'b8p v\'f5a tr\'f4c xu\'cat h\'e4.
\par Kh\'abng ph\'b6i l\'b5 l\'c7n \'ae\'c7u ti\'aan \'ae\'d5 qu\'e8c Ph\'b8p \'ae\'e5ng lo\'b7 v\'edi b\'e4n \'ae\'d5 qu\'e8c kh\'b8c v\'b5 c\'e3 nh\'f7ng h\'b5nh \'ae\'e9ng b\'d8 \'e6i nh\'ad th\'d5. Trong chi\'d5n tranh, khi nh\'f7ng ng\'ad\'eai da \'ae
en ch\'a9u Phi \'aeang hy sinh th\'a9n m\'d7nh tr\'aan \'ae\'cat Ph\'b8p \'ae\'d3 b\'b6o v\'d6 "v\'a8n minh", "nh\'a9n \'ae\'b9o", th\'d7 Ph\'b8p th\'abng \'ae\'e5ng v\'edi }{\f38\fs20\insrsid1378858 \'fd }{\f37\fs20\insrsid1378858 \'ae\'d3 c\'cam nh\'f7
ng ng\'ad\'eai d\'a9n T\'acrip\'abli \'aeang b\'de b\'e4n k\'ce c\'ad\'edp }{\f38\fs20\insrsid1378858 \'fd}{\f37\fs20\insrsid1378858  l\'efng b\'bet, kh\'abng cho tr\'e8n sang l\'b7nh th\'e6 Tuynidi. Vi\'d6c \'ae\'e3 x\'b6y ra nh\'ad sau:
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Trong cu\'e9c chi\'d5n tranh v\'d7 c\'abng l\'fd
, m\'e9t h\'abm c\'e3 ch\'f5ng m\'e9t ngh\'d7n ng\'ad\'eai T\'acrip\'abli g\'e5m ng\'ad\'eai gi\'b5, \'ae\'b5n \'abng, \'ae\'b5n b\'b5, tr\'ce em, \'aeu\'e6i \'ae\'b5n m\'f4c s\'f3c g\'c7y c\'dfm c\'f1a h\'e4 c\'efng ch\'b9y sang l\'b8nh n\'b9n \'eb
 Tuynidi. T\'edi bi\'aan gi\'edi, qu\'a9n \'ae\'e9i Ph\'b8p \'ae\'b7 d\'efng s\'f3ng li\'aan thanh ch\'c6n \'ae\'ad\'eang h\'e4. Nh\'f7ng ng\'ad\'eai l\'b8nh n\'b9n \'ae\'f8ng tr\'ad\'edc t\'d7nh th\'d5 ti\'d5n tho\'b8i l\'ad\'ecng nan th\'b6m thi\'d5t n
\'b5y: \'ae\'d3 cho l\'ddnh Ph\'b8p t\'b5n s\'b8t hay lui v\'b5o sa m\'b9c Xahara \'ae\'d3 r\'e5i ch\'d5t \'ae\'e3i ch\'d5t kh\'b8t \'eb \'ae\'e3. H\'e4 \'ae\'b5nh ph\'b6i theo con \'ae\'ad\'eang th\'f8 ba. H\'e4 n\'bbm c\'b6 xu\'e8ng c\'b8t v\'b5 ch\'d5
t d\'c7n ch\'d5t m\'dfn \'eb \'ae\'e3, tr\'ad\'edc m\'bet \'ae\'e9i qu\'a9n bi\'aan ph\'dfng c\'f1a ch\'f3ng ta.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 T\'can th\'b6m k\'dech \'ae\'e3, b\'b5 Cler\'ac Gi\'aani
\'ab \'ae\'b7 thu\'cbt l\'b9i trong b\'b8o 
\par 
\par }\pard \qj \li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\i\f37\fs20\insrsid1378858 Universel}{\f37\fs20\insrsid1378858  nh\'ad sau:
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 "Nh\'f7ng s\'dc quan c\'f1a ch\'f3ng ta d\'efng \'e8ng nh\'dfm \'ae\'d3 theo d\'e2i c\'b8i ch\'d5t ng\'bec ngo\'b6i d
\'c7n m\'dfn c\'f1a nh\'f7ng con ng\'ad\'eai s\'ac khai \'cay, nh\'f7ng con ng\'ad\'eai m\'b5 c\'b8c n\'ad\'edc latinh \'ae\'b7 \'aeem nh\'f7ng \'a9n hu\'d6 c\'f1a v\'a8n minh l\'b9i cho h\'e4. Nh\'f7ng tr\'ce th\'ac ch\'d5t tr\'ad\'edc ti\'aan, d\'ad\'ed
i b\'c7u s\'f7a \'ae\'b7 c\'b9n c\'f1a m\'d1 ch\'f3ng. Ch\'bcng bao l\'a9u nh\'f7ng ng\'ad\'eai \'ae\'b5n b\'b5 c\'f2ng g\'f4c xu\'e8ng. R\'e5i \'ae\'d5n l\'ad\'eet nh\'f7ng ng\'ad\'eai gi\'b5 l\'b7o, th\'a9n h\'d7nh \'ae\'b7 g\'c7y r\'b9c nh\'ad nh\'f7
ng b\'e9 x\'ad\'acng, b\'de c\'b8t ph\'f1 k\'ddn. Sau th\'d7 c\'b6 \'ae\'b5n \'abng c\'f2ng ch\'d5t n\'e8t. Khi ng\'ad\'eai ta t\'ad\'ebng r\'bbng t\'cat c\'b6 \'aeo\'b5n "ng\'ad\'eai n\'e6i lo\'b9n" \'ae\'e3 \'ae\'b7 ch\'d5t c\'b6 r\'e5i, th\'d7 b\'b8c s
\'dc Natan v\'b5 b\'b8c s\'dc C\'abngx\'a9y nh\'cbn th\'cay v\'b5i em g\'b8i b\'d0 h\'d7nh nh\'ad h\'b7y c\'dfn \'ae\'e9ng \'ae\'cby b\'aan c\'b9nh nh\'f7ng c\'b8i x\'b8c c\'f1a cha m\'d1 ch\'f3ng \'ae\'b7 ch\'d5t c\'f8ng. \'a7\'aam \'ae\'d5n, hai b\'b8
c s\'dc \'ae\'d5n g\'c7n c\'b8c em, th\'d7 nh\'cbn th\'cay qu\'b6 th\'cbt nh\'f7ng em b\'d0 m\'c6c qu\'c7n \'b8o s\'c6c s\'ec v\'b5 \'ae\'b8ng y\'aau \'ae\'e3, nh\'f7ng ng\'b5y \'ae\'c7u v\'ab t\'ad l\'f9 v\'c9n c\'dfn nh\'b6y nh\'e3t vui t\'ad\'aci, l
\'f3c \'ae\'e3 ch\'d8 c\'dfn th\'eb thoi th\'e3p. Sau khi gi\'cau nh\'f7ng em b\'d0 \'ae\'e3 v\'b5o trong xe c\'f8u th\'ad\'acng, hai \'abng r\'cat sung s\'ad\'edng \'ae\'b7 c\'f8u cho c\'b8c em s\'e8ng l\'b9i, v\'b5 x\'f3c c\'b6m tr\'ad\'edc n\'e7i \'ae
au kh\'e6 c\'abi c\'f3t v\'b5 v\'ce \'ae\'b8ng y\'aau c\'f1a c\'b8c em, hai b\'b8c s\'dc \'ae\'b7 gi\'f7 nh\'f7ng em g\'b8i nh\'e1 \'ae\'e3 l\'b9i \'ae\'d3 gi\'f3p vi\'d6c cho m\'d7nh - \'ae\'e3 l\'b5 nh\'f7ng k\'ce s\'e8ng s\'e3t duy nh\'cat trong \'aeo
\'b5n h\'acn m\'e9t ngh\'d7n ng\'ad\'eai d\'a9n T\'acrip\'abli".
\par C\'a9u chuy\'d6n th\'aa th\'b6m k\'d3 l\'b9i \'ae\'e3 kh\'abng ph\'b6i l\'b5 c\'f1a m\'e9t nh\'b5 n\'f7 c\'b8ch m\'b9ng n\'b5o \'ae\'a9u.
\par Ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c Ph\'b8p qu\'b6 l\'b5 kh\'abng h\'d2 ng\'c7n ng\'b9i nh\'f3ng tay v\'b5o nh\'f7ng t\'e9i \'b8c b\'d8 \'e6i nh\'cat.
\par }\pard\plain \s24\qc \li3686\ri283\sb360\sa80\sl-280\slmult0\nowidctlpar\tx5954\aspalpha\aspnum\faauto\adjustright\rin283\lin3686\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nguy\'d4n \'b8i qu\'e8c\line }{
