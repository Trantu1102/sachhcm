\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 NH\'f7NG K\'ce \'a7I KHAI HO\'b8
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 D\'ad\'edi \'ae\'c7u \'ae\'d2 "B\'e4n k\'ce c\'ad\'edp 
\'eb thu\'e9c \'ae\'dea", \'ae\'e5ng ch\'dd V\'ddchto M\'aar\'ddch \'ae\'b7 thu\'cbt l\'b9i cho ch\'f3ng ta nghe s\'f9 \'ae\'e9c \'b8c kh\'abng th\'d3 t\'ad\'ebng t\'ad\'eeng \'ae\'ad\'eec c\'f1a m\'e9t vi\'aan quan cai tr\'de thu\'e9c \'ae\'dea n\'e4 
\'ae\'b7 \'ae\'e6 nh\'f9a cao su v\'b5o b\'e9 ph\'cbn sinh d\'f4c c\'f1a m\'e9t ng\'ad\'eai ph\'f4 n\'f7 da \'aeen kh\'e8n kh\'e6. Sau \'ae\'e3, h\'ben b\'bet ch\'de ph\'b6i \'ae\'e9i m\'e9t t\'b6ng \'ae\'b8 l\'edn \'ae\'f8ng ph\'aci n\'beng cho \'ae\'d5
n ch\'d5t.
\par T\'aan c\'abng ch\'f8c d\'a9m b\'b9o \'ae\'e3 hi\'d6n \'aeang ti\'d5p t\'f4c nh\'f7ng th\'b5nh t\'ddch c\'f1a h\'ben trong m\'e9t t\'d8nh kh\'b8c v\'edi ch\'f8c v\'de c\'f2.
\par Kh\'e8n thay, nh\'f7ng vi\'d6c b\'d8 \'e6i nh\'ad v\'cby l\'b9i kh\'abng hi\'d5m g\'d7 \'eb c\'b8i n\'aci m\'b5 b\'b8o ch\'dd c\'f1a c\'b8c nh\'b5 c\'c7m quy\'d2n th\'ad\'eang g\'e4i l\'b5 "n\'ad\'edc Ph\'b8p h\'b6i ngo\'b9i".
\par H\'e5i th\'b8ng 3 n\'a8m 1922, m\'e9t nh\'a9n vi\'aan nh\'b5 \'aeoan B\'b5 R\'dea (Nam K\'fa) \'ae\'b7 \'ae\'b8nh g\'c7n ch\'d5t m\'e9t ph\'f4 n\'f7 An Nam l\'b5m ngh\'d2 g\'b8nh mu\'e8i, l\'cay c\'ed r\'bbng ng\'ad\'eai n\'b5y \'ae\'b7 l\'b5m m\'cat gi
\'cac ng\'f1 tr\'ada c\'f1a h\'ben, v\'d7 l\'b5m \'e5n \'b5o ngo\'b5i hi\'aan nh\'b5 h\'ben \'eb.
\par Hay ho n\'f7a l\'b5 ng\'ad\'eai \'ae\'b5n b\'b5 n\'b5y c\'dfn b\'de do\'b9 \'aeu\'e6i kh\'e1i n\'aci l\'b5m vi\'d6c n\'d5u b\'b5 th\'ada ki\'d6n g\'d7.
\par H\'e5i th\'b8ng 4, m\'e9t nh\'a9n vi\'aan nh\'b5 \'aeoan kh\'b8c \'ae\'d5n thay c\'f2ng th\'cbt x\'f8ng \'ae\'b8ng v\'edi t\'aan tr\'ad\'edc v\'d2 nh\'f7ng h\'b5nh \'ae\'e9ng t\'b5n \'b8c c\'f1a h\'ben.
\par M\'e9t b\'b5 c\'f4 ng\'ad\'eai An Nam, c\'f2ng l\'b5m ngh\'d2 g\'b8nh mu\'e8i, v\'d7 b\'de kh\'cau l\'ad\'acng n\'aan c\'b7i nhau v\'edi m\'f4 cai. M\'f4 cai \'ae\'d5n th\'ada v\'edi vi\'aan \'aeoan. Vi\'aan n\'b5y ch\'bcng x\'d0t x\'f6 g\'d7 c\'b6, t\'b8
t b\'b5 c\'f4 th\'ee mu\'e8i hai c\'b8i th\'cbt m\'b9nh v\'b5 khi b\'b5 c\'f4 gi\'b5 \'ae\'b8ng th\'ad\'acng c\'f3i xu\'e8ng nh\'c6t n\'e3n, th\'d7 nh\'b5 khai ho\'b8 \'cay, ch\'ada v\'f5a l\'dfng v\'edi tr\'cbn \'ae\'dfn m\'b5 h\'ben v\'f5a tr\'f5ng ph
\'b9t b\'b5 c\'f4, li\'d2n \'ae\'b8 m\'e9t c\'b8i r\'cat m\'b9nh v\'b5o b\'f4ng b\'b5 c\'f4 khi\'d5n cho m\'b8u \'e9c ngay ra l\'aanh l\'b8ng.
\par Khi b\'b5 c\'f4 ng\'ad\'eai An Nam \'ae\'b8ng th\'ad\'acng b\'de ng\'b7 quay xu\'e8ng \'ae\'cat, \'ae\'b8ng l\'cf ph\'b6i c\'cap c\'f8u cho b\'b5, th\'d7 ng\'ad\'eai c\'e9ng t\'b8c vi\'aan c\'f1a \'abng Xar\'ab \'cay l\'b9i cho g\'e4i l\'fd tr\'ad\'ebng 
\'ae\'d5n v\'b5 ra l\'d6nh cho l\'fd tr\'ad\'ebng \'aeem ng\'ad\'eai b\'de th\'ad\'acng \'aei n\'aci kh\'b8c. L\'fd tr\'ad\'ebng t\'f5 ch\'e8i kh\'abng l\'b5m. Vi\'aan \'aeoan li\'d2n cho g\'e4i ch\'e5ng ng\'ad\'eai b\'de n\'b9n \'ae\'d5n, - }{
\i\f37\fs20\insrsid1378858 \'abng n\'b5y b\'de m\'ef}{\f37\fs20\insrsid1378858 , - ra l\'d6nh b\'bet \'abng ph\'b6i \'aeem v\'ee \'aei. Hi\'d6n nay, b\'b5 c\'f4 gi\'b5 kh\'e8n kh\'e6 \'ae\'e3 \'aeang n\'bbm nh\'b5 th\'ad\'acng.
\par B\'b9n c\'e3 mu\'e8n \'ae\'b8nh cu\'e9c r\'bbng hai \'abng \'aeoan c\'f1a ch\'f3ng ta \'eb Nam K\'fa, c\'f2ng nh\'ad b\'b9n \'ae\'e5ng nghi\'d6p c\'f1a h\'e4 l\'b5 v\'de quan cai tr\'de n\'e4 \'eb ch\'a9u Phi, c\'e3 b\'de l\'b5m r\'c7y r\'b5 g\'d7 kh\'ab
ng ? H\'e4 h\'bcn \'ae\'b7 \'ae\'ad\'eec th\'a8ng ch\'f8c n\'f7a kia \'ae\'cay.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nguy\'d4n \'b8i Qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 Le Paria,}{\insrsid1378858 
\par s\'e8 4, ng\'b5y 1-7-1922.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
