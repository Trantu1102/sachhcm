\par }}\dpx5310\dpy-834\dpxsize900\dpysize360\dpfillfgcr255\dpfillfgcg255\dpfillfgcb255\dpfillbgcr255\dpfillbgcg255\dpfillbgcb255\dpfillpat1\dplinehollow}}}}{\lang1053\langfe1033\langnp1053\insrsid1378858 c\'dfn \'ae\'dfi h\'e1i ph\'b6i c\'e3 }{
\i\lang1053\langfe1033\langnp1053\insrsid1378858 ph\'ad\'acng ph\'b8p c\'b8ch m\'b9ng }{\lang1053\langfe1033\langnp1053\insrsid1378858 \'ae\'f3ng \'ae\'ben, linh ho\'b9t, s\'b8ng t\'b9o, ph\'ef h\'eep v\'edi th\'f9c ti\'d4n c\'b8ch m\'b9ng c\'f1a \'ae\'ca
t n\'ad\'edc. Ch\'f1 t\'dech H\'e5 Ch\'dd Minh l\'b5 b\'cbc th\'c7y v\'d2 ph\'ad\'acng ph\'b8p c\'b8ch m\'b9ng Vi\'d6t Nam. Ph\'ad\'acng ph\'b8p c\'b8ch m\'b9ng c\'f1a Ng\'ad\'eai l\'b5 s\'f9 v\'cbn d\'f4ng m\'e9t c\'b8ch s\'b8ng t\'b9o ph\'ad\'acng ph
\'b8p lu\'cbn ph\'e6 bi\'d5n c\'f1a ch\'f1 ngh\'dca M\'b8c-L\'aanin v\'b5o ho\'b5n c\'b6nh v\'b5 \'aei\'d2u ki\'d6n c\'f4 th\'d3 c\'f1a c\'b8ch m\'b9ng n\'ad\'edc ta \'ae\'d3 t\'d7m ra nh\'f7ng con \'ae\'ad\'eang, h\'d7nh th\'f8c, bi\'d6n ph\'b8p, ... nh
\'bbm th\'f9c hi\'d6n m\'f4c ti\'aau. \'a7\'e3 c\'f2ng l\'b5 s\'f9 k\'d5 th\'f5a c\'e3 ch\'e4n l\'e4c v\'b5 \'b8p d\'f4ng s\'b8ng t\'b9o v\'b5o \'aei\'d2u ki\'d6n hi\'d6n \'ae\'b9i nh\'f7ng ph\'ad\'acng ph\'b8p suy ngh\'dc v\'b5 h\'b5nh \'ae\'e9ng c\'f1
a c\'b8c nh\'b5 t\'ad t\'ad\'ebng, ch\'ddnh tr\'de, qu\'a9n s\'f9 Vi\'d6t Nam trong l\'dech s\'f6, l\'b5 s\'f9 t\'e6ng k\'d5t t\'f5 th\'f9c ti\'d4n c\'b8c phong tr\'b5o c\'b8ch m\'b9ng trong n\'ad\'edc v\'b5 tr\'aan th\'d5 gi\'edi.
\par }\pard\plain \qj \fi397\li0\ri0\sa60\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\lang1053\langfe1033\langnp1053\insrsid1378858 Ph\'ad\'acng ph\'b8p c\'b8
ch m\'b9ng c\'f1a Ch\'f1 t\'dech H\'e5 Ch\'dd Minh l\'b5 m\'e9t h\'d6 th\'e8ng \'ae\'ad\'eec th\'d3 hi\'d6n \'aea d\'b9ng v\'b5 phong ph\'f3 \'eb c\'b8c th\'eai k\'fa, c\'b8c giai \'aeo\'b9n kh\'b8c nhau. Tr\'aan tinh th\'c7n "d\'dc b\'cat bi\'d5n, \'f8
ng v\'b9n bi\'d5n", l\'cay m\'f4c ti\'aau kh\'abng thay \'ae\'e6i l\'b5 \'ae\'e9c l\'cbp, th\'e8ng nh\'cat c\'f1a T\'e6 qu\'e8c, t\'f9 do, h\'b9nh ph\'f3c c\'f1a nh\'a9n d\'a9n l\'b5m
\par }\pard \qj \li0\ri0\sa60\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs18\lang1053\langfe1033\langnp1053\insrsid1378858 g\'e8c, tu\'fa ho\'b5n c\'b6nh v\'b5 \'aei\'d2u ki\'d6n c\'f4 th\'d3, tu\'fa l\'dcnh v\'f9c v
\'b5 \'ae\'e8i t\'ad\'eeng c\'f4 th\'d3 m\'b5 c\'e3 s\'f9 v\'cbn d\'f4ng linh ho\'b9t, uy\'d3n chuy\'d3n nh\'f7ng ph\'ad\'acng ph\'b8p kh\'b8c nhau.
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa60\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\lang1053\langfe1033\langnp1053\insrsid1378858 \'a7i\'d3m n\'e6i b\'cbt c
\'f1a ph\'ad\'acng ph\'b8p c\'b8ch m\'b9ng H\'e5 Ch\'dd Minh, nh\'ad \'a7\'b6ng ta \'ae\'b7 t\'e6ng k\'d5t t\'b9i \'a7\'b9i h\'e9i l\'c7n th\'f8 IV, \'ae\'e3 l\'b5 ph\'ad\'acng ph\'b8p s\'f6 d\'f4ng b\'b9o l\'f9c c\'b8ch m\'b9ng, bao g\'e5m l\'f9c l\'ad
\'eeng ch\'ddnh tr\'de c\'f1a qu\'c7n ch\'f3ng v\'b5 l\'f9c l\'ad\'eeng v\'f2 trang c\'f1a nh\'a9n d\'a9n, ti\'d5n h\'b5nh kh\'ebi ngh\'dca to\'b5n d\'a9n v\'b5 chi\'d5n tranh c\'b8ch m\'b9ng; k\'d5t h\'eep \'ae\'cau tranh qu\'a9n s\'f9 v\'edi \'ae\'ca
u tranh ch\'ddnh tr\'de v\'b5 \'ae\'cau tranh ngo\'b9i giao; l\'eei d\'f4ng tri\'d6t \'ae\'d3 nh\'f7ng m\'a9u thu\'c9n n\'e9i b\'e9 c\'f1a \'ae\'dech, ph\'a9n ho\'b8 v\'b5 c\'ab l\'cbp cao \'ae\'e9 k\'ce th\'ef, gi\'b5nh th\'beng l\'eei t\'f5ng b\'ad\'ed
c, \'ae\'b8nh \'ae\'e6 t\'f5ng b\'e9 ph\'cbn, cu\'e8i c\'efng \'aei \'ae\'d5n th\'beng l\'eei ho\'b5n to\'b5n.
\par }\pard\plain \qj \fi397\li0\ri0\sa60\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\lang1053\langfe1033\langnp1053\insrsid1378858 Ch\'f1 t\'dech H\'e5 Ch\'dd
 Minh \'ae\'b7 ra s\'f8c ch\'a8m lo x\'a9y d\'f9ng l\'f9c l\'ad\'eeng b\'b6o \'ae\'b6m cho c\'b8ch m\'b9ng Vi\'d6t Nam \'aei t\'edi th\'beng l\'eei.
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa60\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\lang1053\langfe1033\langnp1053\insrsid1378858 "Tr\'ad\'edc h\'d5t ph\'b6
i c\'e3 \'a7\'b6ng c\'b8ch m\'d6nh... \'a7\'b6ng c\'e3 v\'f7ng c\'b8ch m\'d6nh m\'edi th\'b5nh c\'abng". }{\i\lang1053\langfe1033\langnp1053\insrsid1378858 T\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh v\'d2 \'a7\'b6ng c\'e9ng s\'b6n l\'b7nh \'ae\'b9o}{
\lang1053\langfe1033\langnp1053\insrsid1378858 , \'ae\'c6c bi\'d6t trong \'aei\'d2u ki\'d6n \'a7\'b6ng \'ae\'b7 n\'bem ch\'ddnh quy\'d2n, l\'b5 m\'e9t \'ae\'e3ng g\'e3p m\'edi v\'b5o l\'fd lu\'cbn x\'a9y d\'f9ng ch\'ddnh \'ae\'b6ng ki\'d3u m\'edi c\'f1
a giai c\'cap c\'abng nh\'a9n. \'a7\'b6ng ta ra \'ae\'eai t\'f5 m\'e9t n\'ad\'edc thu\'e9c \'ae\'dea n\'f6a phong ki\'d5n, c\'abng nghi\'d6p ch\'ada ph\'b8t tri\'d3n, giai c\'cap c\'abng nh\'a9n c\'dfn nh\'e1 b\'d0, gi\'f7a l\'f3c c\'b8c phong tr\'b5o y
\'aau n\'ad\'edc \'aeang di\'d4n\line ra s\'abi n\'e6i. \'a7\'f3ng nh\'ad Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'b7 nh\'cbn \'ae\'denh: "Ch\'f1 ngh\'dca M\'b8c-L\'aanin k\'d5t h\'eep v\'edi phong tr\'b5o c\'abng nh\'a9n v\'b5 phong tr\'b5o y\'aau n\'ad
\'edc \'ae\'b7 d\'c9n t\'edi vi\'d6c th\'b5nh l\'cbp }{\i\lang1053\langfe1033\langnp1053\insrsid1378858 \'a7\'b6ng C\'e9ng s\'b6n \'a7\'abng D\'ad\'acng}{\lang1053\langfe1033\langnp1053\insrsid1378858  v\'b5o \'ae\'c7u n\'a8m 1930". Ng\'ad\'eai n\'e3i, 
\'a7\'b6ng ta l\'b5 \'ae\'e9i ti\'aan phong c\'f1a giai c\'cap c\'abng nh\'a9n. B\'b6n ch\'cat giai c\'cap c\'abng nh\'a9n c\'f1a \'a7\'b6ng \'ae\'ad\'eec th\'d3 hi\'d6n \'eb ch\'e7 n\'e3 \'ae\'ad\'eec v\'f2 trang b\'bbng ch\'f1 ngh\'dca M\'b8c-L\'aa
nin, trung th\'b5nh v\'edi ch\'f1 ngh\'dca qu\'e8c t\'d5 v\'ab s\'b6n, ki\'aan quy\'d5t \'ae\'cau tranh ch\'e8ng m\'e4i bi\'d3u hi\'d6n c\'f1a ch\'f1 ngh\'dca c\'ac h\'e9i h\'f7u khuynh v\'b5 "t\'b6" khuynh. Ng\'ad\'eai c\'f2ng n\'e3i r\'e2: "\'a7\'b6
ng ta \'ae\'b9i bi\'d3u cho l\'eei \'ddch chung c\'f1a giai c\'cap c\'abng nh\'a9n, c\'f1a to\'b5n th\'d3 nh\'a9n d\'a9n lao \'ae\'e9ng ch\'f8 kh\'abng ph\'b6i m\'adu c\'c7u cho l\'eei \'ddch ri\'aang c\'f1a m\'e9t nh\'e3m ng\'ad\'eai n\'b5o, c\'f1a c\'b8
 nh\'a9n n\'b5o".
\par }\pard \s16\qj \fi397\li0\ri0\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\lang1024\langfe1024\noproof\insrsid1378858 
{\shp{\*\shpinst\shpleft-11\shptop-3396\shpright889\shpbottom-3036\shpfhdr0\shpbxcolumn\shpbxignore\shpbypara\shpbyignore\shpwr3\shpwrk0\shpfblwtxt0\shpz11\shplid1037{\sp{\sn shapeType}{\sv 1}}{\sp{\sn fFlipH}{\sv 0}}{\sp{\sn fFlipV}{\sv 0}}
{\sp{\sn lTxid}{\sv 589824}}{\sp{\sn dxTextLeft}{\sv 0}}{\sp{\sn dyTextTop}{\sv 0}}{\sp{\sn dxTextRight}{\sv 0}}{\sp{\sn dyTextBottom}{\sv 0}}{\sp{\sn hspNext}{\sv 1037}}{\sp{\sn fRecolorFillAsPicture}{\sv 0}}{\sp{\sn fUseShapeAnchor}{\sv 0}}
{\sp{\sn fLine}{\sv 0}}{\sp{\sn fLayoutInCell}{\sv 1}}{\shptxt \pard\plain \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XIV
\par }}}{\shprslt{\*\do\dobxcolumn\dobypara\dodhgt8203\dptxbx\dptxlrtb{\dptxbxtext\pard\plain \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XIV
\par }}\dpx-11\dpy-3396\dpxsize900\dpysize360\dpfillfgcr255\dpfillfgcg255\dpfillfgcb255\dpfillbgcr255\dpfillbgcg255\dpfillbgcb255\dpfillpat1\dplinehollow}}}}{\lang1053\langfe1033\langnp1053\insrsid1378858 \'a7\'d3 x\'f8ng \'ae\'b8ng l\'b5 \'a7\'b6ng l\'b7nh 
\'ae\'b9o, Ng\'ad\'eai n\'aau y\'aau c\'c7u ph\'b6i x\'a9y d\'f9ng \'a7\'b6ng ta th\'b5nh "m\'e9t \'ae\'b6ng to l\'edn, m\'b9nh m\'cf, ch\'bec ch\'ben, trong s\'b9ch, c\'b8ch m\'b9ng tri\'d6t \'ae\'d3". Trong \'aei\'d2u ki\'d6n \'a7\'b6ng c\'c7m quy\'d2
n, \'ae\'d3 \'ae\'d2 ph\'dfng nguy c\'ac tho\'b8i ho\'b8, bi\'d5n ch\'cat, Ng\'ad\'eai lu\'abn lu\'abn nh\'can m\'b9nh ng\'ad\'eai \'ae\'b6ng vi\'aan ph\'b6i "su\'e8t \'ae\'eai l\'b5m ng\'ad\'eai con trung th\'b5nh c\'f1a \'a7\'b6ng, ng\'ad\'eai \'ae\'b5
y t\'ed t\'cbn tu\'fe c\'f1a nh\'a9n d\'a9n". L\'c7n \'ae\'c7u ti\'aan trong c\'b8c \'ae\'b6ng c\'e9ng s\'b6n c\'c7m quy\'d2n, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh n\'aau l\'aan t\'ad t\'ad\'ebng: \'a7\'b6ng ph\'b6i x\'f8ng \'ae\'b8ng v\'f5a l\'b5 }{
\i\lang1053\langfe1033\langnp1053\insrsid1378858 ng\'ad\'eai l\'b7nh \'ae\'b9o 
\par }\pard \s16\qj \li0\ri0\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\i\lang1053\langfe1033\langnp1053\insrsid1378858 s\'b8ng su\'e8t,}{\lang1053\langfe1033\langnp1053\insrsid1378858  v\'f5a l\'b5 }{
\i\lang1053\langfe1033\langnp1053\insrsid1378858 ng\'ad\'eai \'ae\'b5y t\'ed th\'cbt trung th\'b5nh}{\lang1053\langfe1033\langnp1053\insrsid1378858  c\'f1a nh\'a9n d\'a9n. Mu\'e8n th\'d5, Ng\'ad\'eai \'ae\'dfi h\'e1i \'a7\'b6ng ta m\'e9t m\'c6t ph\'b6
i ra s\'f8c n\'a9ng cao tr\'dd tu\'d6 cho ngang t\'c7m nhi\'d6m v\'f4 l\'dech s\'f6, m\'c6t kh\'b8c ph\'b6i trau d\'e5i \'ae\'b9o \'ae\'f8c c\'b8ch m\'b9ng, kh\'abng ng\'f5ng t\'a8ng c\'ad\'eang m\'e8i li\'aan h\'d6 m\'b8u th\'det v\'edi nh\'a9n d\'a9n.

\par }\pard\plain \qj \fi397\li0\ri0\sa20\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\lang1053\langfe1033\langnp1053\insrsid1378858 C\'b8ch m\'b9ng l\'b5 s\'f9
 nghi\'d6p c\'f1a qu\'c7n ch\'f3ng. \'a7\'b6ng ch\'d8 c\'e3 th\'d3 ho\'b5n th\'b5nh s\'f8 m\'d6nh l\'dech s\'f6 c\'f1a m\'d7nh n\'d5u bi\'d5t t\'cbp h\'eep, \'aeo\'b5n k\'d5t c\'b8c t\'c7ng l\'edp nh\'a9n d\'a9n trong m\'e9t m\'c6t tr\'cbn d\'a9n t\'e9c 
th\'e8ng nh\'cat r\'e9ng r\'b7i ch\'e8ng k\'ce th\'ef chung v\'b5 x\'a9y d\'f9ng \'ae\'cat n\'ad\'edc. }{\f37\fs18\insrsid1378858 "\'a7o\'b5n k\'d5t, \'aeo\'b5n k\'d5t, \'ae\'b9i \'aeo\'b5n k\'d5t.
\par }\pard \qj \fi1701\li0\ri0\sa60\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs18\insrsid1378858 Th\'b5nh c\'abng, th\'b5nh c\'abng, \'ae\'b9i th\'b5nh c\'abng".
\par }\pard \qj \fi397\li0\ri0\sa60\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs18\insrsid1378858 Lu\'cbn \'aei\'d3m n\'e6i ti\'d5ng n\'b5y c\'f1a Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'b7 tr\'eb th\'b5nh t\'ad t\'ad
\'ebng ch\'d8 \'ae\'b9o chi\'d5n l\'ad\'eec l\'edn xuy\'aan su\'e8t c\'b6 qu\'b8 tr\'d7nh c\'b8ch m\'b9ng Vi\'d6t Nam. }{\i\f37\fs18\insrsid1378858 T\'ad t\'ad\'ebng \'ae\'b9i \'aeo\'b5n k\'d5t}{\f37\fs18\insrsid1378858  c\'f1a H\'e5 Ch\'dd Minh c\'efng v
\'edi \'ae\'b9o \'ae\'f8c v\'b5 nh\'a9n c\'b8ch v\'ab c\'efng cao th\'ad\'eeng v\'b5 trong s\'b8ng c\'f1a Ng\'ad\'eai \'ae\'b7 quy t\'f4 \'ae\'ad\'eec kh\'e8i \'ae\'b9i \'aeo\'b5n k\'d5t d\'a9n t\'e9c, \'ae\'cau tranh v\'d7 th\'beng l\'eei c\'f1a s\'f9
 nghi\'d6p c\'b8ch m\'b9ng.
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa60\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Ng\'ad\'eai cho r\'bbng: "h\'d4 l\'b5 ng\'ad\'eai Vi\'d6
t Nam th\'d7 ai c\'f2ng c\'e3 l\'dfng y\'aau n\'ad\'edc, gh\'d0t gi\'c6c", n\'aan ngay sau khi th\'b5nh l\'cbp \'a7\'b6ng, Ng\'ad\'eai \'ae\'b7 \'ae\'d2 ra ch\'f1 tr\'ad\'acng th\'b5nh l\'cbp }{\i\insrsid1378858 H\'e9i ph\'b6n \'ae\'d5 \'ae\'e5ng minh}{
\insrsid1378858 , m\'e9t h\'d7nh th\'f8c m\'c6t tr\'cbn d\'a9n t\'e9c th\'e8ng nh\'cat r\'e9ng r\'b7i ch\'e8ng \'ae\'d5 qu\'e8c. G\'e3p \'fd ki\'d5n v\'d2 \'ae\'ad\'eang l\'e8i, ch\'f1 tr\'ad\'acng c\'f1a \'a7\'b6ng
\par }\pard\plain \qj \li0\ri0\sa60\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\lang1024\langfe1024\noproof\insrsid1378858 
{\shp{\*\shpinst\shpleft5314\shptop-834\shpright6214\shpbottom-474\shpfhdr0\shpbxcolumn\shpbxignore\shpbypara\shpbyignore\shpwr3\shpwrk0\shpfblwtxt0\shpz10\shplid1036{\sp{\sn shapeType}{\sv 1}}{\sp{\sn fFlipH}{\sv 0}}{\sp{\sn fFlipV}{\sv 0}}
{\sp{\sn lTxid}{\sv 655360}}{\sp{\sn dxTextLeft}{\sv 0}}{\sp{\sn dyTextTop}{\sv 0}}{\sp{\sn dxTextRight}{\sv 0}}{\sp{\sn dyTextBottom}{\sv 0}}{\sp{\sn hspNext}{\sv 1036}}{\sp{\sn fRecolorFillAsPicture}{\sv 0}}{\sp{\sn fUseShapeAnchor}{\sv 0}}
{\sp{\sn fLine}{\sv 0}}{\sp{\sn fLayoutInCell}{\sv 1}}{\shptxt \pard\plain \qr \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XV
\par }}}{\shprslt{\*\do\dobxcolumn\dobypara\dodhgt8202\dptxbx\dptxlrtb{\dptxbxtext\pard\plain \qr \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XV
\par }}\dpx5314\dpy-834\dpxsize900\dpysize360\dpfillfgcr255\dpfillfgcg255\dpfillfgcb255\dpfillbgcr255\dpfillbgcg255\dpfillbgcb255\dpfillpat1\dplinehollow}}}}{\f37\fs18\insrsid1378858 th\'eai k\'fa 1936-1939, Ng\'ad\'eai \'ae\'b7 b\'e6 sung v\'b5o t\'aan g\'e4
i m\'c6t tr\'cbn th\'b5nh }{\i\f37\fs18\insrsid1378858 M\'c6t tr\'cbn d\'a9n t\'e9c d\'a9n ch\'f1}{\f37\fs18\insrsid1378858  r\'e9ng r\'b7i, kh\'abng nh\'f7ng ch\'d8 c\'e3 nh\'a9n d\'a9n lao \'ae\'e9ng m\'b5 g\'e5m c\'b6 giai c\'cap t\'ad s\'b6n d\'a9n t
\'e9c v\'b5 nh\'bec nh\'eb ph\'b6i tr\'b8nh h\'d5t s\'f8c \'ae\'d3 h\'e4 \'eb ngo\'b5i M\'c6t tr\'cbn. Ngay sau khi v\'d2 \'ae\'d5n Cao B\'bbng n\'a8m 1941, Ng\'ad\'eai \'ae\'b7 cho t\'e6 ch\'f8c th\'dd \'aei\'d3m c\'b8c h\'e9i qu\'c7n ch\'f3ng \'ae\'d3 r
\'f3t kinh nghi\'d6m ti\'d5n t\'edi th\'b5nh l\'cbp }{\i\f37\fs18\insrsid1378858 M\'c6t tr\'cbn Vi\'d6t Minh.
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa60\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nguy\'aan t\'bec nh\'cat qu\'b8n trong t\'ad t\'ad\'ebng 
\'ae\'b9i \'aeo\'b5n k\'d5t H\'e5 Ch\'dd Minh l\'b5: l\'cay li\'aan minh c\'abng n\'abng l\'b5m n\'d2n t\'b6ng, t\'cbp h\'eep r\'e9ng r\'b7i nh\'cat m\'e4i t\'e6 ch\'f8c v\'b5 c\'b8 nh\'a9n y\'aau n\'ad\'edc, v\'f5a \'aeo\'b5n k\'d5t, v\'f5a \'ae\'ca
u tranh; l\'cay l\'eei \'ddch t\'e8i cao c\'f1a d\'a9n t\'e9c v\'b5 quy\'d2n l\'eei c\'ac b\'b6n c\'f1a nh\'a9n d\'a9n lao \'ae\'e9ng l\'b5m n\'d2n t\'b6ng, tr\'aan c\'ac s\'eb \'ae\'e3 b\'b6o \'ae\'b6m c\'e3 s\'f9 k\'d5t h\'eep h\'b5i ho\'b5 l\'eei \'dd
ch c\'b8 nh\'a9n v\'b5 l\'eei \'ddch t\'cbp th\'d3, b\'e9 ph\'cbn v\'b5 to\'b5n c\'f4c, giai c\'cap v\'b5 d\'a9n t\'e9c, qu\'e8c gia v\'b5 qu\'e8c t\'d5.
\par }\pard\plain \qj \fi397\li0\ri0\sa60\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 Ph\'ad\'acng ph\'b8p \'aei t\'edi \'ae\'b9i \'aeo\'b5n k
\'d5t c\'f1a Ng\'ad\'eai l\'b5 v\'cbn \'ae\'e9ng, gi\'b8o d\'f4c, thuy\'d5t ph\'f4c, n\'aau g\'ad\'acng ..., l\'cay th\'bcng th\'ben ch\'a9n th\'b5nh \'ae\'d3 \'ae\'e8i x\'f6, l\'cay tin y\'aau gi\'f3p \'ae\'ec \'ae\'d3 c\'b6m ho\'b8, tr\'a9n tr\'e4ng ph
\'b8t huy nh\'a9n t\'e8 t\'ddch c\'f9c, h\'b9n ch\'d5, \'ae\'c8y l\'efi nh\'a9n t\'e8 ti\'aau c\'f9c, gi\'f3p cho m\'e4i t\'e6 ch\'f8c v\'b5 c\'b8 nh\'a9n \'ae\'d2u ti\'d5n b\'e9 v\'b5 tr\'ad\'ebng th\'b5nh, \'ae\'e3ng g\'e3p c\'e3 hi\'d6u qu\'b6 v\'b5o s
\'f9 nghi\'d6p c\'b8ch m\'b9ng chung.
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa60\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'e3m l\'b9i, trong t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh, 
\'ae\'b9i \'aeo\'b5n k\'d5t d\'a9n t\'e9c l\'b5 m\'e9t chi\'d5n l\'ad\'eec c\'ac b\'b6n, l\'a9u d\'b5i, trong c\'b8ch m\'b9ng d\'a9n t\'e9c d\'a9n ch\'f1 nh\'a9n d\'a9n c\'f2ng nh\'ad trong c\'b8ch m\'b9ng x\'b7 h\'e9i ch\'f1 ngh\'dca. T\'ad t\'ad\'ebng 
\'ae\'b9i \'aeo\'b5n k\'d5t H\'e5 Ch\'dd Minh m\'b7i m\'b7i l\'b5 m\'e9t s\'f8c m\'b9nh l\'b5m n\'aan th\'beng l\'eei c\'f1a c\'b8ch m\'b9ng Vi\'d6t Nam.
\par \'a7o\'b5n k\'d5t, t\'cbp h\'eep l\'f9c l\'ad\'eeng \'ae\'d3 \'ae\'ada qu\'c7n ch\'f3ng ra \'ae\'cau tranh gi\'b5nh t\'f9 do, \'ae\'e9c l\'cbp. K\'ce th\'ef \'ae\'b7 d\'efng s\'f8c m\'b9nh t\'b5n b\'b9o \'ae\'d3 \'ae\'b5n \'b8p cu\'e9c \'ae\'cau tranh c
\'f1a nh\'a9n d\'a9n ta. Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'b7 ch\'d8 r\'e2: "Ch\'d5 \'ae\'e9 th\'f9c d\'a9n, t\'f9 b\'b6n th\'a9n n\'e3, \'ae\'b7 l\'b5 m\'e9t h\'b5nh \'ae\'e9ng b\'b9o l\'f9c c\'f1a k\'ce m\'b9nh \'ae\'e8i v\'edi k\'ce y\'d5u". Do 
\'ae\'e3 "Trong cu\'e9c \'ae\'cau tranh gian kh\'e6 ch\'e8ng k\'ce th\'ef c\'f1a giai c\'cap v\'b5 d\'a9n t\'e9c, c\'c7n d\'efng b\'b9o l\'f9c c\'b8ch m\'b9ng ch\'e8ng l\'b9i b\'b9o l\'f9c ph\'b6n c\'b8ch m\'b9ng, gi\'b5nh l\'cay ch\'ddnh quy\'d2n v\'b5 b
\'b6o v\'d6 ch\'ddnh quy\'d2n".
\par }\pard\plain \qj \fi397\li0\ri0\sa60\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858\charrsid13836119 D\'ad\'edi \'b8nh s\'b8ng }{
\i\f37\fs18\insrsid1378858\charrsid13836119 t\'ad t\'ad\'ebng qu\'a9n s\'f9 H\'e5 Ch\'dd Minh}{\f37\fs18\insrsid1378858\charrsid13836119 , trong hai cu\'e9c kh\'b8ng chi\'d5n ch\'e8ng Ph\'b8p v\'b5 ch\'e8ng M\'fc, nh\'a9n d\'a9n ta \'ae\'b7 l\'cbp n\'aa
n nh\'f7ng chi\'d5n c\'abng vang d\'e9i, \'ae\'ad\'eec c\'b6 lo\'b5i ng\'ad\'eai kh\'a9m ph\'f4c v\'b5 ca ng\'eei. T\'ad t\'ad\'ebng qu\'a9n s\'f9 H\'e5 Ch\'dd Minh l\'b5 t\'ad t\'ad\'ebng v\'d2 k\'d5t h\'eep \'ae\'cau tranh ch\'ddnh tr\'de v\'edi \'ae
\'cau tranh v\'f2 trang. Ng\'ad\'eai n\'e3i: "Tu\'fa t\'d7nh h\'d7nh c\'f4 th\'d3 m\'b5 quy\'d5t \'ae\'denh nh\'f7ng h\'d7nh th\'f8c \'ae\'cau tranh c\'b8ch m\'b9ng th\'ddch h\'eep, s\'f6 d\'f4ng \'ae\'f3ng v\'b5 kh\'d0o k\'d5t h\'eep c\'b8c h\'d7nh th
\'f8c \'ae\'cau tranh v\'f2 trang v\'b5 \'ae\'cau tranh ch\'ddnh tr\'de \'ae\'d3 gi\'b5nh th\'beng l\'eei cho c\'b8ch m\'b9ng". T\'ad t\'ad\'ebng qu\'a9n s\'f9 H\'e5 Ch\'dd Minh \'ae\'ad\'eec th\'d3 hi\'d6n \'ae\'c6c s\'bec \'eb v\'can \'ae\'d2 x\'a9y d
\'f9ng l\'f9c l\'ad\'eeng v\'f2 trang c\'b8ch m\'b9ng "t\'f5 nh\'a9n d\'a9n m\'b5 ra, v\'d7 nh\'a9n d\'a9n m\'b5 chi\'d5n \'ae\'cau" v\'edi ba th\'f8 qu\'a9n - b\'e9 \'ae\'e9i ch\'f1 l\'f9c, b\'e9 \'ae\'e9i \'ae\'dea ph\'ad\'acng v\'b5 d\'a9n qu\'a9n t
\'f9 v\'d6; v\'can \'ae\'d2 x\'a9y d\'f9ng c\'a8n c\'f8 \'ae\'dea c\'b8ch m\'b9ng, v\'can \'ae\'d2 kh\'ebi ngh\'dca to\'b5n d\'a9n v\'b5 chi\'d5n tranh nh\'a9n d\'a9n. Ch\'ddnh t\'ad t\'ad\'ebng qu\'a9n s\'f9 \'cay \'ae\'b7 ch\'d8 \'ae\'b9o nh\'a9n d\'a9
n ta \'aei t\'edi th\'beng l\'eei l\'dech s\'f6 c\'f1a cu\'e9c C\'b8ch m\'b9ng Th\'b8ng T\'b8m v\'b5 ti\'d5p \'ae\'d5n ti\'d5n h\'b5nh cu\'e9c kh\'b8ng chi\'d5n th\'c7n th\'b8nh l\'a9u d\'b5i nh\'cat trong l\'dech s\'f6. \'a7\'d3 ch\'e8ng l\'b9i nh\'f7
ng k\'ce th\'ef c\'e3 s\'f8c m\'b9nh kinh t\'d5 v\'b5 qu\'a9n s\'f9 l\'edn h\'acn m\'d7nh nhi\'d2u l\'c7n, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'b7 \'ae\'d2 ra \'ae\'ad\'eang l\'e8i kh\'b8ng chi\'d5n to\'b5n d\'a9n, to\'b5n di\'d6n, tr\'ad\'eang k\'fa, d
\'f9a v\'b5o s\'f8c m\'d7nh l\'b5 ch\'ddnh; ch\'f1 tr\'ad\'acng v\'f5a kh\'b8ng chi\'d5n, v\'f5a ki\'d5n qu\'e8c, x\'a9y d\'f9ng th\'cbt t\'e8t m\'e8i quan h\'d6 ti\'d2n tuy\'d5n - h\'cbu ph\'ad\'acng. T\'ad t\'ad\'ebng qu\'a9n s\'f9 H\'e5 Ch\'dd Minh l
\'cay s\'f8c m\'b9nh ch\'ddnh tr\'de, tinh th\'c7n c\'f1a to\'b5n d\'a9n l\'b5m n\'d2n t\'b6ng. Tr\'aan c\'ac s\'eb \'ae\'e3 m\'b5 ph\'b8t huy t\'b5i thao l\'ad\'eec c\'f1a to\'b5n \'a7\'b6ng, to\'b5n d\'a9n, to\'b5n qu\'a9n. T\'ad t\'ad\'ebng qu\'a9n s
\'f9 H\'e5 Ch\'dd Minh l\'b5 s\'f9 k\'d5 th\'f5a truy\'d2n th\'e8ng qu\'a9n s\'f9 qu\'fd b\'b8u c\'f1a d\'a9n t\'e9c v\'b5 ti\'d5p thu tinh hoa qu\'a9n s\'f9 c\'f1a th\'d5 }{\f37\fs18\insrsid1378858 
\par }\pard\plain \s16\qj \li0\ri0\sa60\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\lang1024\langfe1024\noproof\insrsid1378858 
{\shp{\*\shpinst\shpleft-11\shptop-5348\shpright889\shpbottom-4988\shpfhdr0\shpbxcolumn\shpbxignore\shpbypara\shpbyignore\shpwr3\shpwrk0\shpfblwtxt0\shpz12\shplid1038{\sp{\sn shapeType}{\sv 1}}{\sp{\sn fFlipH}{\sv 0}}{\sp{\sn fFlipV}{\sv 0}}
{\sp{\sn lTxid}{\sv 720896}}{\sp{\sn dxTextLeft}{\sv 0}}{\sp{\sn dyTextTop}{\sv 0}}{\sp{\sn dxTextRight}{\sv 0}}{\sp{\sn dyTextBottom}{\sv 0}}{\sp{\sn hspNext}{\sv 1038}}{\sp{\sn fRecolorFillAsPicture}{\sv 0}}{\sp{\sn fUseShapeAnchor}{\sv 0}}
{\sp{\sn fLine}{\sv 0}}{\sp{\sn fLayoutInCell}{\sv 1}}{\shptxt \pard\plain \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XVI
\par }}}{\shprslt{\*\do\dobxcolumn\dobypara\dodhgt8204\dptxbx\dptxlrtb{\dptxbxtext\pard\plain \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XVI
\par }}\dpx-11\dpy-5348\dpxsize900\dpysize360\dpfillfgcr255\dpfillfgcg255\dpfillfgcb255\dpfillbgcr255\dpfillbgcg255\dpfillbgcb255\dpfillpat1\dplinehollow}}}}{\insrsid1378858 gi\'edi. Ch\'ddnh Ng\'ad\'eai \'ae\'b7 c\'efng v\'edi \'a7\'b6ng ta n\'a9ng ngh\'d6
 thu\'cbt qu\'a9n s\'f9 trong kh\'ebi 
\par ngh\'dca v\'f2 trang v\'b5 chi\'d5n tranh nh\'a9n d\'a9n \'eb th\'eai \'ae\'b9i H\'e5 Ch\'dd Minh l\'aan m\'e9t t\'c7m cao m\'edi.
\par }\pard\plain \qj \fi397\li0\ri0\sa60\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 Ch\'f1 t\'dech H\'e5 Ch\'dd Minh l\'b5 ng\'ad\'eai s\'b8
ng l\'cbp \'a7\'b6ng, M\'c6t tr\'cbn, Qu\'a9n \'ae\'e9i, \'ae\'e5ng th\'eai c\'f2ng l\'b5 ng\'ad\'eai s\'b8ng l\'cbp Nh\'b5 n\'ad\'edc Vi\'d6t Nam D\'a9n ch\'f1 C\'e9ng ho\'b5. Trong g\'c7n m\'e9t ph\'c7n t\'ad th\'d5 k\'fb \'eb c\'ad\'acng v\'de Ch\'f1 t
\'dech nh\'b5 n\'ad\'edc, Ng\'ad\'eai \'ae\'b7 b\'e1 nhi\'d2u c\'abng s\'f8c cho vi\'d6c x\'a9y d\'f9ng m\'e9t nh\'b5 n\'ad\'edc ki\'d3u m\'edi. }{\i\f37\fs18\insrsid1378858 T\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh v\'d2 x\'a9y d\'f9ng nh\'b5 n\'ad\'edc c\'f1
a d\'a9n, do d\'a9n, v\'d7 d\'a9n}{\f37\fs18\insrsid1378858  l\'b5 s\'f9 v\'cbn d\'f4ng s\'b8ng  t\'b9o h\'e4c thuy\'d5t v\'d2 nh\'b5 n\'ad\'edc c\'f1a ch\'f1 ngh\'dca M\'b8c - L\'aanin, ch\'e4n l\'e4c, k\'d5 th\'f5a c\'b6 nh\'f7ng tinh hoa trong vi\'d6
c x\'a9y d\'f9ng nh\'b5 n\'ad\'edc \'ae\'b7 c\'e3 trong l\'dech s\'f6 d\'a9n t\'e9c v\'b5 nh\'a9n lo\'b9i.
\par }\pard \qj \fi397\li0\ri0\sa60\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs18\insrsid1378858\charrsid13836119 V\'can \'ae\'d2 c\'ac b\'b6n c\'f1a nh\'b5 n\'ad\'edc l\'b5 quy\'d2n l\'f9c thu\'e9c v\'d2 ai, ph\'f4
c v\'f4 quy\'d2n l\'eei c\'f1a ai. \'a7\'b6ng ta l\'b7nh \'ae\'b9o nh\'a9n d\'a9n l\'b5m c\'b8ch m\'b9ng l\'b5 \'ae\'d3 gi\'b5nh quy\'d2n}{\f37\fs18\insrsid1378858  }{\insrsid1378858  l\'f9c }{\f37\fs18\insrsid1378858\charrsid13836119 v\'d2 tay nh\'a9n d
\'a9n. Ng\'ad\'eai kh\'bcng \'ae\'denh "N\'ad\'edc ta l\'b5 n\'ad\'edc d\'a9n ch\'f1. Bao nhi\'aau l\'eei \'ddch \'ae\'d2u v\'d7 d\'a9n. Bao nhi\'aau quy\'d2n h\'b9n \'ae\'d2u c\'f1a d\'a9n... Ch\'ddnh quy\'d2n t\'f5 x\'b7 \'ae\'d5n Ch\'ddnh ph\'f1 trung 
\'ad\'acng do d\'a9n c\'f6 ra". "T\'cat c\'b6 quy\'d2n}{\f37\fs18\insrsid1378858  }{\insrsid1378858 l\'f9c trong }{\f37\fs18\insrsid1378858\charrsid13836119 n\'ad\'edc Vi\'d6t Nam D\'a9n ch\'f1 C\'e9ng ho\'b5 \'ae\'d2u thu\'e9c v\'d2 nh\'a9n d\'a9n".

\par }\pard \qj \fi397\li0\ri0\sa60\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\lang1024\langfe1024\noproof\insrsid1378858 
{\shp{\*\shpinst\shpleft5314\shptop-830\shpright6214\shpbottom-470\shpfhdr0\shpbxcolumn\shpbxignore\shpbypara\shpbyignore\shpwr3\shpwrk0\shpfblwtxt0\shpz13\shplid1039{\sp{\sn shapeType}{\sv 1}}{\sp{\sn fFlipH}{\sv 0}}{\sp{\sn fFlipV}{\sv 0}}
{\sp{\sn lTxid}{\sv 786432}}{\sp{\sn dxTextLeft}{\sv 0}}{\sp{\sn dyTextTop}{\sv 0}}{\sp{\sn dxTextRight}{\sv 0}}{\sp{\sn dyTextBottom}{\sv 0}}{\sp{\sn hspNext}{\sv 1039}}{\sp{\sn fRecolorFillAsPicture}{\sv 0}}{\sp{\sn fUseShapeAnchor}{\sv 0}}
{\sp{\sn fLine}{\sv 0}}{\sp{\sn fLayoutInCell}{\sv 1}}{\shptxt \pard\plain \qr \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XVII
\par }}}{\shprslt{\*\do\dobxcolumn\dobypara\dodhgt8205\dptxbx\dptxlrtb{\dptxbxtext\pard\plain \qr \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XVII
\par }}\dpx5314\dpy-830\dpxsize900\dpysize360\dpfillfgcr255\dpfillfgcg255\dpfillfgcb255\dpfillbgcr255\dpfillbgcg255\dpfillbgcb255\dpfillpat1\dplinehollow}}}}{\f37\fs18\insrsid1378858 Ch\'f1 t\'dech H\'e5 Ch\'dd Minh lu\'abn coi tr\'e4ng b\'b6n ch\'cat giai c
\'cap c\'abng nh\'a9n c\'f1a Nh\'b5 n\'ad\'edc ta, \'ae\'e5ng th\'eai, Ng\'ad\'eai c\'f2ng nh\'can m\'b9nh t\'ddnh d\'a9n t\'e9c, t\'ddnh nh\'a9n d\'a9n s\'a9u s\'bec c\'f1a Nh\'b5 n\'ad\'edc.
\par Theo t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh, m\'e9t Nh\'b5 n\'ad\'edc v\'f7ng m\'b9nh, c\'e3 hi\'d6u l\'f9c ph\'b6i l\'b5 m\'e9t Nh\'b5 n\'ad\'edc l\'b5m cho m\'e4i ng\'ad\'eai d\'a9n bi\'d5t s\'e8ng v\'b5 l\'b5m vi\'d6c theo Hi\'d5n ph\'b8p v\'b5 ph\'b8p lu
\'cbt; m\'c6t kh\'b8c Nh\'b5 n\'ad\'edc \'ae\'e3 "ph\'b6i d\'f9a v\'b5o nh\'a9n d\'a9n, li\'aan h\'d6 ch\'c6t ch\'cf v\'edi nh\'a9n d\'a9n, l\'beng nghe \'fd ki\'d5n v\'b5 ch\'deu s\'f9 ki\'d3m so\'b8t c\'f1a nh\'a9n d\'a9n". M\'e9t trong nh\'f7ng m\'e8
i quan t\'a9m c\'f1a Ng\'ad\'eai l\'b5 lo l\'b5m sao \'ae\'b5o t\'b9o v\'b5 b\'e5i d\'ad\'ecng \'ae\'ad\'eec m\'e9t \'ae\'e9i ng\'f2 c\'b8n b\'e9 ch\'ddnh quy\'d2n ph\'ef h\'eep v\'edi b\'b6n ch\'cat c\'f1a Nh\'b5 n\'ad\'edc ta, th\'cam nhu\'c7n tinh th
\'c7n "d\'a9n l\'b5 ch\'f1, c\'b8n b\'e9 l\'b5 \'ae\'b5y t\'ed trung th\'b5nh c\'f1a nh\'a9n d\'a9n". R\'cat \'ae\'d2 cao ph\'b8p quy\'d2n, nh\'adng Ch\'f1 t\'dech H\'e5 Ch\'dd Minh kh\'abng l\'f3c n\'b5o coi nh\'d1 vai tr\'df c\'f1a gi\'b8o d\'f4c \'ae
\'b9o \'ae\'f8c. Trong t\'ad t\'ad\'ebng c\'f1a Ng\'ad\'eai, nh\'b5 n\'ad\'edc ph\'b8p quy\'d2n ch\'d8 ph\'b8t huy \'ae\'ad\'eec \'ae\'c7y \'ae\'f1 hi\'d6u l\'f9c khi n\'e3 bi\'d5t coi tr\'e4ng k\'d5t h\'eep gi\'b8o d\'f4c \'ae\'b9o \'ae\'f8c v\'b5 ph\'b8
p lu\'cbt trong qu\'b6n l\'fd x\'b7 h\'e9i v\'b5 Nh\'b5 n\'ad\'edc.
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa60\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Ch\'f1 t\'dech H\'e5 Ch\'dd Minh l\'b5 nh\'b5 y\'aau n\'ad
\'edc v\'dc \'ae\'b9i, \'ae\'e5ng th\'eai l\'b5 nh\'b5 qu\'e8c t\'d5 ch\'f1 ngh\'dca trong s\'b8ng, hi\'d6n th\'a9n c\'f1a }{\i\insrsid1378858 t\'ad t\'ad\'ebng v\'d2 k\'d5t h\'eep s\'f8c m\'b9nh d\'a9n t\'e9c v\'b5 s\'f8c m\'b9nh th\'eai \'ae\'b9i. }{
\insrsid1378858 Ng\'ad\'eai n\'e3i: "C\'b8ch m\'d6nh Vi\'d6t Nam c\'f2ng l\'b5 m\'e9t b\'e9 ph\'cbn trong c\'b8ch m\'d6nh th\'d5 gi\'edi. Ai l\'b5m c\'b8ch m\'d6nh tr\'aan th\'d5 gi\'edi \'ae\'d2u l\'b5 \'ae\'e5ng ch\'dd c\'f1a d\'a9n Vi\'d6t Nam c\'b6
". V\'d7 v\'cby, trong \'ae\'cau tranh gi\'b5nh \'ae\'e9c l\'cbp d\'a9n t\'e9c, m\'e9t m\'c6t Ng\'ad\'eai nh\'can m\'b9nh t\'ad t\'ad\'ebng ph\'b6i "l\'cay s\'f8c ta m\'b5 gi\'b6i ph\'e3ng cho ta", m\'c6t kh\'b8c Ng\'ad\'eai lu\'abn lu\'abn k\'aau g\'e4
i ph\'b6i t\'a8ng c\'ad\'eang s\'f9 \'aeo\'b5n k\'d5t, gi\'f3p \'ae\'ec v\'b5 ph\'e8i h\'eep nh\'dep nh\'b5ng cu\'e9c \'ae\'cau tranh c\'f1a v\'ab s\'b6n \'eb ch\'ddnh qu\'e8c v\'edi v\'ab s\'b6n \'eb thu\'e9c \'ae\'dea, nh\'ad hai c\'b8i c\'b8nh c\'f1a m
\'e9t con chim. Trong kh\'b8ng chi\'d5n ch\'e8ng Ph\'b8p, ch\'e8ng M\'fc v\'b5 x\'a9y d\'f9ng ch\'f1 ngh\'dca x\'b7 h\'e9i, Ng\'ad\'eai nh\'can m\'b9nh tinh th\'c7n \'ae\'e9c l\'cbp, t\'f9 ch\'f1, l\'b5m h\'d5t s\'f8c m\'d7nh, \'ae\'e5ng th\'eai ph\'b6
i ra s\'f8c tranh
\par }\pard\plain \qj \li0\ri0\sa60\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858  th\'f1 s\'f9 \'ae\'e5ng t\'d7nh, \'f1ng h\'e9, h\'eep t\'b8c v
\'b5 gi\'f3p \'ae\'ec c\'f1a c\'b8c n\'ad\'edc x\'b7 h\'e9i ch\'f1 ngh\'dca, c\'b8c n\'ad\'edc trong th\'d5 gi\'edi th\'f8 ba v\'b5 c\'b8c l\'f9c l\'ad\'eeng ho\'b5 b\'d7nh, d\'a9n ch\'f1 v\'b5 ti\'d5n b\'e9 tr\'aan th\'d5 gi\'edi. Ngay \'ae\'e8i v\'edi c
\'b8c n\'ad\'edc t\'ad b\'b6n ph\'b8t tri\'d3n, t\'f5 r\'cat s\'edm, Ng\'ad\'eai \'ae\'b7 tuy\'aan b\'e8: Vi\'d6t Nam mu\'e8n "L\'b5m b\'b9n v\'edi t\'cat c\'b6 m\'e4i n\'ad\'edc d\'a9n ch\'f1 v\'b5 kh\'abng g\'a9y th\'ef o\'b8n v\'edi m\'e9t ai", v\'d7 m
\'f4c ti\'aau \'ae\'e9c l\'cbp, ho\'b5 b\'d7nh, h\'f7u ngh\'de v\'b5 ti\'d5n b\'e9 x\'b7 h\'e9i.
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa60\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 M\'e9t m\'c6t ra s\'f8c tranh th\'f1 s\'f8c m\'b9nh c\'f1
a th\'eai \'ae\'b9i c\'e3 l\'eei cho c\'b8ch m\'b9ng Vi\'d6t Nam, m\'c6t kh\'b8c, Ng\'ad\'eai kh\'abng qu\'aan nh\'bec nh\'eb nh\'a9n d\'a9n ta h\'d5t l\'dfng, h\'d5t s\'f8c l\'b5m tr\'dfn ngh\'dca v\'f4 qu\'e8c t\'d5 cao c\'b6 c\'f1a m\'d7nh \'ae\'e8i v
\'edi phong tr\'b5o gi\'b6i ph\'e3ng d\'a9n t\'e9c v\'b5 phong tr\'b5o c\'e9ng s\'b6n, c\'abng nh\'a9n qu\'e8c t\'d5, coi "gi\'f3p b\'b9n l\'b5 t\'f9 gi\'f3p m\'d7nh". H\'e5 Ch\'dd Minh ch\'ddnh l\'b5 bi\'d3u t\'ad\'eeng c\'f1a tinh th\'c7n "b\'e8n ph\'ad
\'acng v\'ab s\'b6n \'ae\'d2u l\'b5 anh em".
\par }\pard\plain \qj \fi397\li0\ri0\sa60\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\lang1024\langfe1024\noproof\insrsid1378858 
{\shp{\*\shpinst\shpleft-27\shptop-2224\shpright873\shpbottom-1864\shpfhdr0\shpbxcolumn\shpbxignore\shpbypara\shpbyignore\shpwr3\shpwrk0\shpfblwtxt0\shpz15\shplid1041{\sp{\sn shapeType}{\sv 1}}{\sp{\sn fFlipH}{\sv 0}}{\sp{\sn fFlipV}{\sv 0}}
{\sp{\sn lTxid}{\sv 851968}}{\sp{\sn dxTextLeft}{\sv 0}}{\sp{\sn dyTextTop}{\sv 0}}{\sp{\sn dxTextRight}{\sv 0}}{\sp{\sn dyTextBottom}{\sv 0}}{\sp{\sn hspNext}{\sv 1041}}{\sp{\sn fRecolorFillAsPicture}{\sv 0}}{\sp{\sn fUseShapeAnchor}{\sv 0}}
{\sp{\sn fLine}{\sv 0}}{\sp{\sn fLayoutInCell}{\sv 1}}{\shptxt \pard\plain \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XVIII
\par }}}{\shprslt{\*\do\dobxcolumn\dobypara\dodhgt8207\dptxbx\dptxlrtb{\dptxbxtext\pard\plain \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XVIII
\par }}\dpx-27\dpy-2224\dpxsize900\dpysize360\dpfillfgcr255\dpfillfgcg255\dpfillfgcb255\dpfillbgcr255\dpfillbgcg255\dpfillbgcb255\dpfillpat1\dplinehollow}}}}{\f37\fs18\insrsid1378858 Ngo\'b5i t\'ad c\'b8ch l\'b5 anh h\'efng gi\'b6i ph\'e3ng d\'a9n t\'e9c, Ch
\'f1 t\'dech H\'e5 Ch\'dd Minh c\'dfn \'ae\'ad\'eec th\'d5 gi\'edi bi\'d5t \'ae\'d5n nh\'ad l\'b5 nh\'b5 v\'a8n ho\'b8 l\'edn, nh\'b5 nh\'a9n v\'a8n ch\'f1 ngh\'dca l\'e7i l\'b9c, nh\'b5 \'ae\'b9o \'ae\'f8c v\'edi t\'cam g\'ad\'acng s\'b8ng ng\'eai v\'d2
 ph\'c8m ch\'cat \'ae\'b9o \'ae\'f8c c\'f1a ng\'ad\'eai c\'b8ch m\'b9ng.
\par Ch\'f1 t\'dech H\'e5 Ch\'dd Minh l\'b5 m\'e9t l\'b7nh t\'f4 b\'b5n nhi\'d2u \'ae\'d5n \'ae\'b9o \'ae\'f8c v\'b5 vai tr\'df c\'f1a \'ae\'b9o \'ae\'f8c trong \'ae\'cau tranh c\'b8ch m\'b9ng. Ng\'ad\'eai n\'e3i: "\'a7\'b9o \'ae\'f8c l\'b5 c\'b8i g\'e8c c\'f1
a ng\'ad\'eai c\'b8ch m\'b9ng". "Ng\'ad\'eai c\'b8ch m\'b9ng ph\'b6i c\'e3 \'ae\'b9o \'ae\'f8c c\'b8ch m\'b9ng l\'b5m n\'d2n t\'b6ng m\'edi ho\'b5n th\'b5nh \'ae\'ad\'eec nhi\'d6m v\'f4 c\'b8ch m\'b9ng v\'ce vang". V\'d7 v\'cby, su\'e8t \'ae\'eai m\'d7
nh, Ng\'ad\'eai ki\'aan tr\'d7 vi\'d6c gi\'b8o d\'f4c ph\'c8m ch\'cat \'ae\'b9o \'ae\'f8c cho c\'b8n b\'e9, \'ae\'b6ng vi\'aan, nh\'can m\'b9nh kh\'abng ng\'f5ng "n\'a9ng cao \'ae\'b9o \'ae\'f8c c\'b8ch m\'b9ng, qu\'d0t s\'b9ch ch\'f1 ngh\'dca c\'b8 nh
\'a9n"; v\'b5 b\'b6n th\'a9n Ng\'ad\'eai l\'b5 m\'e9t t\'cam g\'ad\'acng tr\'e4n v\'d1n c\'f1a \'ae\'b9o \'ae\'f8c m\'edi: Su\'e8t \'ae\'eai ph\'can \'ae\'cau, hy sinh v\'d7 l\'eei \'ddch c\'f1a T\'e6 qu\'e8c, v\'d7 h\'b9nh ph\'f3c c\'f1a nh\'a9n d\'a9n.

\par }{\i\f37\fs18\insrsid1378858 T\'ad t\'ad\'ebng \'ae\'b9o \'ae\'f8c H\'e5 Ch\'dd Minh }{\f37\fs18\insrsid1378858 l\'b5 m\'e9t th\'d3 th\'e8ng nh\'cat gi\'f7a \'ae\'b9o \'ae\'f8c}{\insrsid1378858  }{\f37\fs18\insrsid1378858  v\'edi ch\'ddnh tr\'de, \'ae\'b9
o \'ae\'f8c v\'edi t\'b5i n\'a8ng, gi\'f7a n\'e3i v\'b5 l\'b5m, gi\'f7a \'ae\'b9o \'ae\'f8c c\'b8ch m\'b9ng v\'b5 \'ae\'b9o \'ae\'f8c \'ae\'eai th\'ad\'eang. Trong khi s\'f6 d\'f4ng l\'b9i m\'e9t s\'e8 kh\'b8i ni\'d6m v\'b5 thu\'cbt ng\'f7 c\'f1a \'ae\'b9
o \'ae\'f8c truy\'d2n th\'e8ng v\'e8n \'ae\'b7 ph\'e6 bi\'d5n v\'b5 quen thu\'e9c trong nh\'a9n d\'a9n, Ng\'ad\'eai \'ae\'b7 \'ae\'ada v\'b5o \'ae\'e3 nh\'f7ng n\'e9i dung m\'edi, mang \'fd ngh\'dca nh\'a9n v\'a8n v\'b5 c\'b8ch m\'b9ng c\'f1a \'ae\'b9o 
\'ae\'f8c m\'edi. Nh\'f7ng y\'aau c\'c7u \'ae\'b9o \'ae\'f8c Ng\'ad\'eai n\'aau ra cho c\'b8n b\'e9, \'ae\'b6ng vi\'aan nay \'ae\'b7 tr\'eb th\'b5nh h\'d6 chu\'c8n m\'f9c \'ae\'b9o \'ae\'f8c c\'ac b\'b6n c\'f1a con ng\'ad\'eai Vi\'d6t Nam m\'edi nh\'ad
: trung v\'edi n\'ad\'edc, hi\'d5u v\'edi d\'a9n, c\'c7n ki\'d6m li\'aam ch\'ddnh, ch\'dd c\'abng v\'ab t\'ad, "vi\'d6c g\'d7 c\'e3 l\'eei cho d\'a9n, ta ph\'b6i h\'d5t s\'f8c l\'b5m, vi\'d6c g\'d7 c\'e3 h\'b9i cho d\'a9n, ta ph\'b6i h\'d5t s\'f8c tr\'b8
nh", ph\'b6i "kh\'e6 tr\'ad\'edc thi\'aan h\'b9, s\'ad\'edng sau thi\'aan h\'b9", bi\'d5t y\'aau th\'ad\'acng con ng\'ad\'eai, c\'e3 t\'d7nh c\'b6m qu\'e8c t\'d5 trong s\'b8ng...
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa60\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'ad t\'ad\'ebng \'ae\'b9o \'ae\'f8c H\'e5 Ch\'dd Minh l
\'b5 b\'e9 ph\'cbn r\'cat quan tr\'e4ng trong t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh, c\'e3 s\'f8c s\'e8ng m\'b7nh li\'d6t, \'ae\'b7 s\'edm \'aei v\'b5o nh\'a9n d\'a9n, \'ae\'ad\'eec nh\'a9n d\'a9n ti\'d5p nh\'cbn, v\'cbn d\'f4ng v\'b5 n\'aau cao. N\'e3 \'ae
\'b7 tr\'eb th\'b5nh m\'e9t b\'e9 ph\'cbn c\'f1a v\'a8n ho\'b8 d\'a9n t\'e9c, th\'b5nh v\'f2 kh\'dd c\'f1a nh\'a9n d\'a9n trong cu\'e9c \'ae\'cau tranh ch\'e8ng l\'b9i c\'b8c hi\'d6n t\'ad\'eeng tha ho\'b8 v\'d2 \'ae\'b9o \'ae\'f8c c\'f1a x\'b7 h\'e9i nh
\'ad quan li\'aau,
\par }\pard \s16\qj \li0\ri0\sa60\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\lang1024\langfe1024\noproof\insrsid1378858 
{\shp{\*\shpinst\shpleft5314\shptop-834\shpright6214\shpbottom-474\shpfhdr0\shpbxcolumn\shpbxignore\shpbypara\shpbyignore\shpwr3\shpwrk0\shpfblwtxt0\shpz14\shplid1040{\sp{\sn shapeType}{\sv 1}}{\sp{\sn fFlipH}{\sv 0}}{\sp{\sn fFlipV}{\sv 0}}
{\sp{\sn lTxid}{\sv 917504}}{\sp{\sn dxTextLeft}{\sv 0}}{\sp{\sn dyTextTop}{\sv 0}}{\sp{\sn dxTextRight}{\sv 0}}{\sp{\sn dyTextBottom}{\sv 0}}{\sp{\sn hspNext}{\sv 1040}}{\sp{\sn fRecolorFillAsPicture}{\sv 0}}{\sp{\sn fUseShapeAnchor}{\sv 0}}
{\sp{\sn fLine}{\sv 0}}{\sp{\sn fLayoutInCell}{\sv 1}}{\shptxt \pard\plain \qr \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XIX
\par }}}{\shprslt{\*\do\dobxcolumn\dobypara\dodhgt8206\dptxbx\dptxlrtb{\dptxbxtext\pard\plain \qr \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XIX
\par }}\dpx5314\dpy-834\dpxsize900\dpysize360\dpfillfgcr255\dpfillfgcg255\dpfillfgcb255\dpfillbgcr255\dpfillbgcg255\dpfillbgcb255\dpfillpat1\dplinehollow}}}}{\insrsid1378858 tham nh\'f2ng, c\'f6a quy\'d2n, \'f8c hi\'d5p qu\'c7n ch\'f3ng...
\par }\pard\plain \qj \fi397\li0\ri0\sa60\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 Ch\'f3ng ta c\'dfn t\'d7m th\'cay trong t\'ad t\'ad\'ebng 
\'ae\'b9o \'ae\'f8c H\'e5 Ch\'dd Minh nh\'f7ng \'fd ki\'d5n ch\'d8 d\'c9n thi\'d5t th\'f9c v\'d2 nh\'f7ng nguy\'aan t\'bec v\'b5 ph\'ad\'acng ph\'b8p x\'a9y d\'f9ng n\'d2n \'ae\'b9o \'ae\'f8c x\'b7 h\'e9i ch\'f1 ngh\'dca \'eb n\'ad\'edc ta. C\'e3 th\'d3 n
\'e3i, t\'ddnh ho\'b5n ch\'d8nh c\'f1a t\'ad t\'ad\'ebng \'ae\'b9o \'ae\'f8c H\'e5 Ch\'dd Minh l\'b5 m\'e9t b\'ad\'edc ph\'b8t tri\'d3n m\'edi, m\'e9t c\'e8ng hi\'d5n \'ae\'c6c s\'bec v\'b5o s\'f9 ph\'b8t tri\'d3n c\'f1a \'ae\'b9o \'ae\'f8c h\'e4c M\'b8
c - L\'aanin v\'b5 v\'c9n gi\'f7 nguy\'aan gi\'b8 tr\'de soi s\'b8ng cho ch\'f3ng ta trong vi\'d6c gi\'b6i quy\'d5t nh\'f7ng v\'can \'ae\'d2 \'ae\'b9o \'ae\'f8c x\'b7 h\'e9i hi\'d6n nay.
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa60\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'efng v\'edi t\'ad t\'ad\'ebng \'ae\'b9o \'ae\'f8c, }{
\i\insrsid1378858 t\'ad t\'ad\'ebng nh\'a9n v\'a8n H\'e5 Ch\'dd Minh}{\insrsid1378858  l\'b5 m\'e9t \'ae\'e3ng g\'e3p r\'cat c\'e3 gi\'b8 tr\'de v\'b5o tri\'d5t h\'e4c v\'d2 con ng\'ad\'eai c\'f1a ch\'f1 ngh\'dca M\'b8c - L\'aanin. Ch\'f1 t\'dech H\'e5 Ch
\'dd Minh n\'e3i: "T\'abi ch\'d8 c\'e3 m\'e9t s\'f9 ham mu\'e8n, ham mu\'e8n t\'e9t b\'cbc, l\'b5 l\'b5m sao cho n\'ad\'edc ta \'ae\'ad\'eec ho\'b5n to\'b5n \'ae\'e9c l\'cbp, d\'a9n ta \'ae\'ad\'eec ho\'b5n to\'b5n t\'f9 do, \'ae\'e5ng b\'b5o ai c\'f2ng c
\'e3 c\'acm \'a8n, \'b8o m\'c6c, ai c\'f2ng \'ae\'ad\'eec h\'e4c h\'b5nh". \'a7\'e3 l\'b5 l\'fd t\'ad\'ebng ch\'ddnh tr\'de, l\'fd t\'ad\'ebng \'ae\'b9o \'ae\'f8c v\'b5 c\'f2ng l\'b5 l\'fd t\'ad\'ebng nh\'a9n v\'a8n c\'f1a Ng\'ad\'eai. \'a7\'e8i v\'edi H
\'e5 Ch\'dd Minh, gi\'b6i ph\'e3ng con ng\'ad\'eai tr\'ad\'edc h\'d5t l\'b5 gi\'b6i ph\'e3ng h\'e4 kh\'e1i nh\'f7ng tai ho\'b9 do c\'b8i \'ae\'e3i, c\'b8i r\'d0t, c\'b8i d\'e8t g\'a9y n\'aan. Cu\'e9c chi\'d5n \'ae\'cau \'ae\'e3 kh\'abng th\'d3 t\'b8ch r
\'eai cu\'e9c chi\'d5n \'ae\'cau \'ae\'d3 gi\'b6i ph\'e3ng d\'a9n t\'e9c. Ch\'d8 c\'e3 tho\'b8t kh\'e1i th\'a9n ph\'cbn n\'ab l\'d6, m\'e7i con ng\'ad\'eai m\'edi l\'cay l\'b9i \'ae\'ad\'eec ph\'c8m gi\'b8 l\'b5m ng\'ad\'eai. H\'acn n\'f7a, \'ae\'e3 c\'df
n l\'b5 cu\'e9c chi\'d5n \'ae\'cau v\'d7 ho\'b5 b\'d7nh v\'b5 t\'d7nh h\'f7u ngh\'de gi\'f7a c\'b8c d\'a9n t\'e9c, v\'d7 s\'f9 gi\'b6i ph\'e3ng c\'f1a to\'b5n nh\'a9n lo\'b9i. \'a7\'e3 ch\'ddnh l\'b5 gi\'b8 tr\'de c\'f1a nh\'a9n v\'a8n, m\'e9t ch\'f1 ngh
\'dca nh\'a9n v\'a8n h\'b5nh \'ae\'e9ng, ch\'f1 ngh\'dca nh\'a9n v\'a8n chi\'d5n \'ae\'cau, ch\'f1 ngh\'dca nh\'a9n \'ae\'b9o hi\'d6n th\'f9c.
\par T\'ad t\'ad\'ebng nh\'a9n v\'a8n H\'e5 Ch\'dd Minh \'ae\'ad\'eec bi\'d3u hi\'d6n v\'ab c\'efng \'aea d\'b9ng v\'b5 phong ph\'f3, n\'e3 th\'cam \'ae\'cbm trong to\'b5n b\'e9 cu\'e9c \'ae\'eai v\'b5 s\'f9 nghi\'d6p c\'f1a Ng\'ad\'eai, \'ae\'ad\'eec to\'b6 s
\'b8ng trong t\'f5ng vi\'d6c l\'b5m, t\'f5ng c\'f6 ch\'d8, t\'f5ng m\'e8i quan t\'a9m \'a9n c\'c7n \'ae\'e8i v\'edi m\'e7i con ng\'ad\'eai; t\'cat c\'b6 \'ae\'d2u to\'b8t l\'aan t\'d7nh y\'aau th\'ad\'acng, s\'f9 t\'abn tr\'e4ng, th\'b8i \'ae\'e9
 bao dung v\'b5 ni\'d2m tin v\'b5o kh\'b6 n\'a8ng c\'b6i t\'b9o c\'f1a con ng\'ad\'eai, d\'ef cho h\'e4 c\'e3 nh\'cat th\'eai l\'c7m l\'b9c. B\'bbng h\'b5nh \'ae\'e9ng v\'b5 \'f8ng x\'f6 c\'f1a m\'d7nh, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh truy\'d2n l\'b9
i cho ch\'f3ng ta m\'e9t \'ae\'b9o l\'fd l\'b5m ng\'ad\'eai l\'b5 ph\'b6i bi\'d5t y\'aau th\'ad\'acng v\'b5 s\'e8ng v\'edi nhau c\'e3 t\'d7nh ngh\'dca.
\par }\pard\plain \qj \fi397\li0\ri0\sa20\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 Ch\'f1 ngh\'dca nh\'a9n v\'a8n l\'b5 b\'b6n ch\'cat c\'e8
t l\'e2i, l\'b5 k\'d5t tinh c\'f1a v\'a8n ho\'b8. Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'ad\'eec lo\'b5i ng\'ad\'eai ti\'d5n b\'e9 suy t\'abn l\'b5 m\'e9t }{\i\f37\fs18\insrsid1378858 nh\'b5 v\'a8n ho\'b8 l\'edn}{\f37\fs18\insrsid1378858  c\'dfn v\'d7 nh
\'f7ng th\'b5nh t\'f9u xu\'cat s\'bec c\'f1a Ng\'ad\'eai trong l\'dcnh v\'f9c ho\'b9t \'ae\'e9ng v\'b5 s\'b8ng t\'b9o v\'a8n ho\'b8. }{\i\f37\fs18\insrsid1378858 T\'ad t\'ad\'ebng v\'a8n ho\'b8 H\'e5 Ch\'dd Minh}{\f37\fs18\insrsid1378858  \'ae\'ad\'eec bi
\'d3u hi\'d6n \'eb ch\'e7 Ng\'ad\'eai th\'cay r\'e2 v\'b5 kh\'bcng \'ae\'denh r\'cat s\'edm vai tr\'df quy\'d5t \'ae\'denh c\'f1a v\'a8n ho\'b8 trong chi\'d5n l\'ad\'eec ph\'b8t tri\'d3n kinh t\'d5 - x\'b7 h\'e9i c\'f1a \'ae\'cat n\'ad\'ed
c. Ngay sau khi v\'f5a gi\'b5nh \'ae\'ad\'eec \'ae\'e9c l\'cbp, t\'b9i phi\'aan h\'e4p \'ae\'c7u ti\'aan c\'f1a Ch\'ddnh ph\'f1 l\'a9m th\'eai n\'ad\'edc Vi\'d6t Nam m\'edi, Ng\'ad\'eai \'ae\'b7 \'ae\'d2 ngh\'de m\'eb ngay chi\'d5n d\'dech ch\'e8ng n\'b9
n d\'e8t. Ng\'ad\'eai n\'e3i: "M\'e9t d\'a9n t\'e9c d\'e8t l\'b5 m\'e9t d\'a9n t\'e9c y\'d5u". Ng\'ad\'eai coi d\'e8t n\'b8t c\'f2ng l\'b5 m\'e9t th\'f8 gi\'c6c, xem th\'e3i quen v\'b5 nh\'f7ng t\'cbp t\'f4c l\'b9c h\'cbu c\'f2ng l\'b5 m\'e9t lo\'b9i k
\'ce th\'ef. Ng\'ad\'eai kh\'bcng \'ae\'denh v\'a8n ho\'b8 l\'b5 tinh hoa c\'f1a d\'a9n t\'e9c, v\'a8n ho\'b8 ph\'b6i g\'e3p ph\'c7n kh\'bcng \'ae\'denh d\'a9n t\'e9c v\'b5 b\'b6n s\'bec d\'a9n t\'e9c. "R\'e2 r\'b5ng l\'b5 d\'a9n t\'e9c b\'de \'b8p b\'f8
c th\'d7 v\'a8n ngh\'d6 s\'dc c\'f2ng m\'cat t\'f9 do. V\'a8n ngh\'d6 s\'dc mu\'e8n c\'e3 t\'f9 do th\'d7 ph\'b6i tham gia c\'b8ch m\'b9ng". "V\'a8n ho\'b8 ngh\'d6 thu\'cbt c\'f2ng l\'b5 }{\i\f37\fs18\insrsid1378858 m\'e9t m\'c6t tr\'cbn}{
\f37\fs18\insrsid1378858 .
\par }\pard \qj \fi1134\li0\ri0\sa60\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\lang1024\langfe1024\noproof\insrsid1378858 
