\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'d7NH H\'d7NH \'eb TRUNG QU\'e8C
\par }\pard\plain \s4\qj \fi397\li0\ri0\sa80\sl-268\slmult0\keepn\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel3\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'ad\'acng l\'dcnh c\'f1a c\'b8
c sinh vi\'aan c\'b8ch m\'b9ng
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Nguy\'aan nh\'a9n c\'f1a t\'d7nh h\'d7nh t\'e5i t\'d6 hi
\'d6n nay \'eb Trung Qu\'e8c c\'e3 r\'cat nhi\'d2u. Tr\'ad\'edc h\'d5t Trung Qu\'e8c b\'de y\'d5u v\'d7 s\'f9 m\'a9u thu\'c9n gi\'f7a mi\'d2n B\'bec v\'b5 mi\'d2n Nam. Sau \'ae\'e3, t\'ddnh ch\'cat th\'f1 c\'f9u c\'f1a ch\'f1 ngh\'dca ngh\'de tr\'ad\'ea
ng b\'bet ch\'ad\'edc theo ki\'d3u ph\'ad\'acng T\'a9y v\'b5 tham v\'e4ng m\'ef qu\'b8ng c\'b8 nh\'a9n c\'f1a ch\'f1 ngh\'dca qu\'a9n phi\'d6t bi\'d3u hi\'d6n \'eb m\'f8c \'ae\'e9 n\'b5y hay m\'f8c \'ae\'e9 kh\'b8c d\'f9a v\'b5o n\'ad\'edc ngo\'b5i \'ae
ang ph\'b8 ho\'b9i Trung Qu\'e8c. V\'b5 cu\'e8i c\'efng l\'b5 do nh\'f7ng c\'ad\'eang qu\'e8c t\'ad b\'b6n ch\'f1 ngh\'dca t\'f5ng ph\'f3t m\'e9t, c\'e8 \'fd g\'a9y 
\par ra s\'f9 r\'e8i lo\'b9n b\'aan trong \'ae\'d3 k\'d7m h\'b7m th\'cbm ch\'dd c\'b6 nh\'f7ng c\'b6i c\'b8ch kh\'abng \'ae\'b8ng k\'d3.
\par Th\'d5 nh\'adng r\'cat may m\'ben l\'b5 ti\'d5ng vang c\'f1a C\'b8ch m\'b9ng Nga h\'d7nh nh\'ad \'ae\'b7 th\'f8c t\'d8nh th\'d5 h\'d6 m\'edi c\'f1a Trung Qu\'e8c. L\'f9c l\'ad\'eeng tr\'ce m\'edi ra \'ae\'eai c\'e3 \'ae\'c7y nhi\'d6t t\'d7nh v\'b5 s\'f8c 
s\'e8ng. \'a7i\'d2u n\'b5y th\'d3 hi\'d6n \'ae\'c6c bi\'d6t r\'e2 r\'d6t nh\'cat l\'b5 H\'e9i sinh vi\'aan c\'b8ch m\'b9ng. H\'e9i c\'e3 kho\'b6ng 100 ngh\'d7n h\'e9i vi\'aan trong c\'b6 n\'ad\'edc Trung Hoa. H\'e9i xu\'cat b\'b6n nhi\'d2u t\'ea b\'b8o, m
\'e7i t\'d8nh c\'e3 m\'e9t ho\'c6c hai t\'ea. N\'a8m 1919, H\'e9i \'ae\'b7 khuy\'aan \'aeo\'b5n \'ae\'b9i bi\'d3u Trung Qu\'e8c t\'f5 ch\'e8i k\'fd Hi\'d6p \'ad\'edc V\'d0cx\'a9y. \'a7\'e3 l\'b5 nh\'f7ng ng\'ad\'eai tham gia vi\'d6c t\'e6 ch\'f8c t\'c8
y chay Nh\'cbt B\'b6n. }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  B\'bec Kinh, sinh vi\'aan \'ae\'b7 thi\'aau hu\'fb nh\'f7ng l\'a9u \'ae\'b5i xa hoa c\'f1a hai b\'e9 tr\'ad\'ebng b\'b8n cho t\'ad b\'b6n Nh\'cbt, bu\'e9c nh\'f7ng ng\'ad
\'eai n\'b5y t\'f5 ch\'f8c v\'b5 c\'e3 nh\'f7ng l\'eai c\'b6nh c\'b8o x\'b8c \'ae\'b8ng tr\'ad\'edc \'ae\'e8i v\'edi h\'e4. T\'b9i \'a7\'b9i h\'e9i to\'b5n qu\'e8c l\'c7n th\'f8 t\'ad, H\'e9i \'ae\'b7 th\'abng qua c\'ad\'acng l\'dcnh ch\'ddnh tr\'de, m
\'b5 nh\'f7ng \'aei\'d3m c\'ac b\'b6n c\'f1a n\'e3 l\'b5:
\par }{\i\f37\fs20\insrsid1378858 Ch\'ddnh s\'b8ch \'ae\'e8i n\'e9i.}{\f37\fs20\insrsid1378858  Ngh\'de vi\'d6n v\'b5 ch\'ddnh ph\'f1 ph\'b6i th\'f9c hi\'d6n 
\par }\pard \qj \li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 trung th\'f9c \'fd ch\'dd c\'f1a nh\'a9n d\'a9n.
\par }\pard \qj \fi397\li0\ri0\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ho\'b5n to\'b5n t\'f9 do t\'e6 ch\'f8c, h\'e9i h\'e4p, ng\'abn lu\'cbn v\'b5 b\'b8o ch\'dd.
\par Quy\'d2n \'ae\'d7nh c\'abng cho c\'abng nh\'a9n.
\par \'a7\'dea v\'de \'ae\'e9c l\'cbp c\'f1a to\'b5 \'b8n.
\par }{\i\f37\fs20\insrsid1378858 Quan h\'d6 qu\'e8c t\'d5.}{\f37\fs20\insrsid1378858  Quy\'d2n t\'f9 quy\'d5t c\'f1a c\'b8c d\'a9n t\'e9c.
\par \'a7\'cau tranh ch\'e8ng ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\i\f37\fs20\insrsid1378858 V\'can \'ae\'d2 ph\'f4 n\'f7.}{\f37\fs20\insrsid1378858  B\'d7nh \'ae\'bcng v\'d2 gi\'b8o d\'f4c ch\'ddnh tr\'de v\'b5
 kinh t\'d5 cho c\'b6 nam v\'b5 n\'f7. Thi h\'b5nh h\'d6 th\'e8ng tr\'ad\'eang h\'e4c th\'e8ng nh\'cat - t\'f8c l\'b5 th\'b5nh l\'cbp c\'b8c tr\'ad\'eang h\'e4c trong \'ae\'e3 con trai v\'b5 con g\'b8i c\'efng h\'e4c.
\par Tr\'b6 c\'abng nh\'ad nhau cho lao \'ae\'e9ng nh\'ad nhau.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd-1\expndtw-6\insrsid1378858 Quy\'d2n ngh\'d8 ng\'aci v\'b5 ti\'d2n tr
\'ee c\'cap cho tr\'ad\'eang h\'eep \'aeau \'e8m v\'b5 s\'b6n ph\'f4.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\b\f37\fs20\insrsid1378858 H\'e9i \'f1ng h\'e9 t\'cat c\'b6 c\'b8c y\'aau s\'b8ch c
\'f1a c\'abng nh\'a9n.
\par }\pard\plain \s23\qj \fi397\li0\ri0\sa80\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 H\'e9i c\'e3 m\'f4c \'ae\'ddch: \'f1ng h\'e9 t\'cat c\'b6
 nh\'f7ng y\'aau s\'b8ch v\'b5 m\'e4i phong tr\'b5o c\'b8ch m\'b9ng c\'f1a n\'abng d\'a9n, c\'abng nh\'a9n v\'b5 ti\'d3u th\'ad\'acng.
\par }\pard\plain \qj \fi397\li0\ri0\sl-264\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 H\'e9i k\'aau g\'e4i t\'cat c\'b6 nh\'a9n d\'a9n lao \'ae\'e9
