\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-288\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~B\'b9n Vinh\'aa \'a7\'e8ct\'abng c\'f1a ch\'f3ng ta b
\'bbng m\'e9t cu\'e9c kh\'b6o s\'b8t phong ph\'f3 v\'d2 t\'ad li\'d6u, s\'cf cho \'ae\'e9c gi\'b6 b\'b8o }{\i\f37\fs20\insrsid1378858 Libertaire}{\f37\fs20\super\insrsid1378858 15}{\f37\fs20\insrsid1378858  th\'cay d\'ad\'edi nh\'b7n hi\'d6u T\'f9 do, B
\'d7nh \'ae\'bcng, B\'b8c \'b8i v\'b5 nh\'a9n danh "n\'d2n d\'a9n ch\'f1 Ph\'b8p", ng\'ad\'eai ta \'aeang \'ae\'c7u \'ae\'e9c m\'e9t c\'b8ch c\'e3 h\'d6 th\'e8ng ch\'f1ng t\'e9c \'a7\'abng D\'ad\'acng. Nh\'adng, b\'aan c\'b9nh vi\'d6c \'ae\'c7u \'ae\'e9
c t\'cbp th\'d3 v\'b5 ch\'ddnh th\'f8c \'aeang l\'b5m v\'ce vang l\'edn cho \'ae\'cat n\'ad\'edc c\'e3 b\'b6n Tuy\'aan ng\'abn nh\'a9n quy\'d2n}{\f37\fs20\super\insrsid1378858 16}{\f37\fs20\insrsid1378858  kia, c\'dfn c\'e3 c\'b6 nh\'f7ng v\'f4 gi\'d5t h
\'b9i c\'b8 nh\'a9n c\'f1a nh\'f7ng k\'ce \'aei khai ho\'b8. }{\f38\fs20\insrsid1378858 \'eb }{\f37\fs20\insrsid1378858 \'ae\'a9y, ch\'f3ng t\'abi n\'aau l\'aan v\'b5i v\'f4 trong nh\'f7ng chi\'d5n c\'abng \'ae\'e3, \'ae\'b7 \'ae\'ad\'eec ghi l\'b9i 

\par v\'b5 th\'c8m tra, ho\'c6c qua nhi\'d2u nh\'a9n ch\'f8ng, ho\'c6c qua ch\'ddnh b\'b6n th\'a9n c\'b8c t\'b8c gi\'b6 \'ae\'b7 k\'d3 ra \'ae\'d3 t\'f9 khoe khoang b\'bbng m\'e9t s\'eb th\'ddch qu\'b8i \'b8c th\'ad\'eeng \'ae\'bcng v\'b5 \'ae\'c6c bi\'d6t c
\'f1a nh\'f7ng k\'ce th\'f9c d\'a9n. Ch\'f3ng t\'abi xin tr\'ddch t\'f5 cu\'e8n nh\'cbt k\'fd h\'b5nh tr\'d7nh c\'f1a m\'e9t ng\'ad\'eai l\'ddnh th\'f9c d\'a9n s\'f9 vi\'d6c sau \'ae\'a9y:
\par }\pard \qj \fi397\li0\ri0\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 "Khi "nh\'f7ng ng\'ad\'eai t\'f5ng \'eb B\'bec K\'fa" vui \'ae\'efa tr\'aan t\'b5u th\'d7 d\'ad\'edi m\'b9n t\'b5u ph\'dda b
\'aan ph\'b6i c\'e3 v\'b5i chi\'d5c thuy\'d2n b\'b8n hoa qu\'b6, \'e8c h\'d5n. \'a7\'d3 \'ae\'ada h\'b5ng \'ae\'d5n t\'cbn tay ch\'f3ng t\'abi, nh\'f7ng ng\'ad\'eai An Nam bu\'e9c gi\'e1 \'ae\'f9ng h\'b5ng v\'b5o \'ae\'c7u ng\'e4n s\'b5o r\'e5i gi\'ac l
\'aan. Ch\'f3ng t\'abi ch\'d8 vi\'d6c ch\'e4n m\'b5 th\'abi. Nh\'adng \'ae\'b8ng l\'cf ph\'b6i tr\'b6 ti\'d2n, th\'d7 ng\'ad\'eai ta l\'b9i c\'e3 nh\'b7 \'fd b\'e1 v\'b5o gi\'e1 \'ae\'f1 th\'f8 nh\'ad sau: nh\'f7ng \'e8ng t\'c8u thu\'e8c l\'b8, khuy qu
\'c7n, m\'c8u thu\'e8c l\'b8. (C\'e3 l\'cf h\'e4 l\'b5m nh\'ad th\'d5 \'ae\'d3 d\'b9y cho ng\'ad\'eai b\'b6n x\'f8 t\'ddnh ngay th\'cbt
\par }\pard \qj \li0\ri0\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858  trong vi\'d6c mua b\'b8n ch\'a8ng!). \'a7\'abi khi, \'ae\'d3 mua vui, m\'e9t anh s\'e8pph\'ac n\'b5o \'ae\'e3 h\'bet c\'b6 m\'e9
t th\'efng n\'ad\'edc s\'abi xu\'e8ng l\'adng nh\'f7ng ng\'ad\'eai b\'b8n h\'b5ng kh\'e8n kh\'e6. L\'cbp t\'f8c c\'e3 nh\'f7ng ti\'d5ng r\'f3 l\'aan v\'d7 \'aeau \'ae\'edn, nh\'f7ng
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-288\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 m\'b8i ch\'cco vung l\'aan lo\'b9n x\'b9 \'ae\'d3 b\'aci tr
\'b8nh, l\'b5m cho nh\'f7ng chi\'d5c thuy\'d2n va x\'c7m v\'b5o nhau.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd0\expndtw-4\insrsid1378858 Ngay ph\'dda d\'ad\'edi t\'abi, m\'e9t ng
\'ad\'eai An Nam b\'de b\'e1ng t\'f5 \'ae\'c7u \'ae\'d5n ch\'a9n, ph\'b8t \'aei\'aan l\'aan, mu\'e8n lao xu\'e8ng bi\'d3n. Ng\'ad\'eai anh c\'f1a anh ta, qu\'aan c\'b6 nguy hi\'d3m, bu\'abng tay ch\'cco \'abm l\'cay anh v\'b5 ra s\'f8c \'ae\'cc anh ta xu
\'e8ng l\'dfng thuy\'d2n. Cu\'e9c v\'cbt l\'e9n ch\'ada \'ae\'c7y 2 gi\'a9y v\'f5a k\'d5t th\'f3c th\'d7 m\'e9t th\'efng n\'ad\'edc s\'abi n\'f7a \'ae\'ad\'eec h\'bet b\'ebi m\'e9t b\'b5n tay chu\'c8n x\'b8c l\'b9i d\'e9i xu\'e8ng k\'ce b\'cat h\'b9nh. T
\'abi th\'cay anh ta l\'a8n l\'e9n trong thuy\'d2n, v\'d5t th\'ad\'acng tr\'ac c\'b6 th\'det v\'edi nh\'f7ng ti\'d5ng k\'aau kh\'abng c\'dfn g\'d7 l\'b5 c\'f1a con ng\'ad\'eai n\'f7a! V\'b5 c\'b6nh \'ae\'e3 khi\'d5n ch\'f3ng t\'abi c\'ad\'eai; v\'edi ch
\'f3ng t\'abi, \'aei\'d2u \'ae\'e3 c\'e3 v\'ce c\'f9c k\'fa ng\'e9 ngh\'dcnh. Qu\'b6 th\'cbt ch\'f3ng t\'abi \'ae\'b7 c\'e3 t\'a9m h\'e5n th\'f9c d\'a9n!...
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 ... Trong th\'eai k\'fa t\'abi \'eb \'ae\'e3 (B\'bec K\'fa
) kh\'abng c\'e3 tu\'c7n n\'b5o l\'b5 kh\'abng c\'e3 v\'b5i c\'b8i \'ae\'c7u r\'aci.
\par Trong t\'cat c\'b6 nh\'f7ng c\'b6nh t\'ad\'eeng \'ae\'e3, t\'abi ch\'d8 c\'dfn nh\'ed \'ae\'ad\'eec m\'e9t \'aei\'d2u, l\'b5 ch\'f3ng ta c\'dfn t\'b5n b\'b9o, c\'dfn d\'b7 man h\'acn c\'b6 ch\'ddnh nh\'f7ng t\'aan c\'ad\'edp bi\'d3n. T\'b9i sao l\'b9i c
\'e3 nh\'f7ng h\'b5nh vi qu\'b8i \'b8c \'ae\'d5n th\'d5 \'ae\'e8i v\'edi m\'e9t k\'ce b\'de k\'d5t \'b8n s\'bep ph\'b6i ch\'d5t? T\'b9i sao l\'b9i c\'e3 nh\'f7ng cu\'e9c h\'b5nh h\'b9 th\'d3 x\'b8c, t\'b9i sao ph\'b6i gi\'b6i nh\'f7ng \'aeo\'b5n t\'ef 
\'aei b\'aau kh\'bep c\'b8c l\'b5ng m\'b9c?".
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~NGUY\'d4N \'b8I QU\'e8C
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\trowd \lastrow \ts11\trgaph108\trleft-108\trftsWidth1\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3 \clvertalt\clbrdrt\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3119\clshdrawnil \cellx3011\clvertalt\clbrdrt
