\par M\'edi \'ae\'a9y, m\'e9t \'ae\'b9i h\'e9i c\'abng nh\'a9n \'ae\'b7 \'ae\'ad\'eec tri\'d6u t\'cbp \'eb C\'abngxt\'a8ngtin\'e8p. Hai tr\'a8m n\'a8m m\'ad\'aci \'ae\'b9i bi\'d3u tham gia \'ae\'b9i h\'e9i. H\'e4 thay m\'c6t cho 19.000 c\'abng nh\'a9n C\'ab
ngxt\'a8ngtin\'e8p, 15.000 c\'abng nh\'a9n m\'e1 than \'eb D\'abnggun\'ae\'bec v\'b5 10.000 ng\'ad\'eai lao \'ae\'e9ng c\'b6 c\'b8c m\'e1 ch\'d7 c\'e3 b\'b9c \'eb Balyacarai\'aein.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 \'a7\'b9i h\'e9i \'ae\'b7 quy\'d5t \'ae\'denh t\'cbp h\'eep }{\i\f37\fs20\insrsid1378858 34 \'a7\'d0cn\'d5ch}{
\cs17\i\f37\fs20\super\insrsid1378858 3{\footnote \pard\plain \s30\ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f42\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 3) }{\i\insrsid1378858 Dernek}{
\insrsid1378858 . Ti\'d5ng Th\'e6 Nh\'dc K\'fa c\'e3 ngh\'dca l\'b5 h\'e9i.}})}{\f37\fs20\insrsid1378858  hi\'d6n c\'e3 th\'b5nh m\'e9t }{\i\f37\fs20\insrsid1378858 Bi\'d5cl\'ddch}{\f37\fs20\insrsid1378858 ,  t\'f8c l\'b5 m\'e9t li\'aan minh. Ngh\'de quy
\'d5t m\'b9nh d\'b9n \'ae\'e3 \'ae\'b7 l\'b5m cho ch\'ddnh ph\'f1 ph\'b6i s\'ee h\'b7i kh\'abng d\'b8m c\'abng nh\'cbn }{\i\f37\fs20\insrsid1378858 Bi\'d5cl\'ddch}{\f37\fs20\insrsid1378858 . N\'aan ch\'f3 \'fd l\'b5 th\'b8i \'ae\'e9 c\'f1a ch\'ddnh ph\'f1
 \'ae\'e8i v\'edi c\'abng nh\'a9n \'ae\'b7 thay \'ae\'e6i nhi\'d2u. Khi chi\'d5n tranh k\'d5t th\'f3c, khi v\'can \'ae\'d2 \'ae\'c6t ra l\'b5 ph\'b6i \'aeu\'e6i c\'e6 nh\'f7ng ng\'ad\'eai n\'ad\'edc ngo\'b5i th\'d7 ch\'ddnh ph\'f1 lu\'abn lu\'abn t\'e1
 ra d\'d4 d\'b7i v\'edi c\'abng nh\'a9n, nh\'adng khi \'ae\'f4ng \'ae\'d5n v\'can \'ae\'d2 t\'e6 ch\'f8c c\'abng nh\'a9n th\'d7 ch\'ddnh ph\'f1 t\'e1 ra c\'f2ng ph\'b6n \'ae\'e9ng nh\'ad t\'cat c\'b6 m\'e4i ch\'ddnh ph\'f1 t\'ad b\'b6n ch\'f1 ngh\'dca kh
\'b8c. Do \'ae\'e3, s\'f9 ph\'f1 quy\'d5t c\'f1a ch\'ddnh ph\'f1 kh\'abng l\'b5m ai ng\'b9c nhi\'aan c\'b6. V\'b6 l\'b9i, m\'e4i ng\'ad\'eai bi\'d5t r\'bbng t\'f5 khi k\'fd ho\'b5 \'ad\'edc L\'abdann\'ac}{\f37\fs20\super\insrsid1378858 43}{
\f37\fs20\insrsid1378858  th\'d7 b\'e4n t\'ad b\'b6n Th\'e6 Nh\'dc K\'fa \'ae\'b7 \'a8n c\'b8nh v\'edi b\'e4n t\'ad b\'b6n n\'ad\'edc ngo\'b5i, - b\'e4n n\'b5y sau khi \'ae\'b7 t\'b5n s\'b8t h\'b5ng v\'b9n ng\'ad\'eai Hy L\'b9p v\'b5 Th\'e6 Nh\'dc K\'fa
 kh\'e6 s\'eb nh\'adng v\'c9n kh\'abng \'ae\'c6t \'ae\'ad\'eec \'b8ch th\'f9c d\'a9n l\'aan Th\'e6 Nh\'dc K\'fa, th\'d7 nay l\'b9i x\'a9m nh\'cbp m\'e9t c\'b8ch ho\'b5 b\'d7nh v\'b5o \'ae\'cat n\'ad\'edc Tr\'a8ng l\'ad\'eci li\'d2m. Vi\'d6c ch\'ddnh ph
\'f1 t\'f5 ch\'e8i kh\'abng c\'abng nh\'cbn t\'e6 ch\'f8c }{\i\f37\fs20\insrsid1378858 Bi\'d5cl\'ddch}{\f37\fs20\insrsid1378858 , ch\'bcng kh\'b8c n\'b5o m\'e9t n\'f4 c\'ad\'eai duy\'aan d\'b8ng d\'efng \'ae\'d3 khuy\'d5n kh\'ddch gi\'edi t\'b5i ch\'dd
nh qu\'e8c t\'d5 m\'b5 ba ph\'c7n n\'a8m l\'b5 ngu\'e5n g\'e8c Ph\'b8p.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nh\'adng giai c\'cap v\'ab s\'b6n Th\'e6 Nh\'dc K\'fa \'ae
\'b7 ti\'d5n \'ae\'ad\'eec m\'e9t b\'ad\'edc \'ae\'c7u ti\'aan. Nh\'cat \'ae\'denh h\'e4 s\'cf c\'dfn ti\'d5n n\'f7a.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Nguy\'d4n \'b8i Qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 L'Humanit\'d0,}{\insrsid1378858 
\par ng\'b5y 1-1-1924.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
