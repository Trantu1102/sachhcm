\par ng\'b5y 30-5-1975.\cell }\pard\plain \qc \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\intbl\aspalpha\aspnum\faauto\adjustright\rin0\lin0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Theo b\'b5i \'ae\'a8ng b\'b8o.\cell 
}\pard \ql \li0\ri0\widctlpar\intbl\aspalpha\aspnum\faauto\adjustright\rin0\lin0 {\f37\fs20\insrsid1378858 \trowd \lastrow \ts11\trgaph108\trleft-108\trftsWidth1\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3 \clvertalt\clbrdrt\brdrtbl \clbrdrl\brdrtbl 
\clbrdrb\brdrtbl \clbrdrr\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3226\clshdrawnil \cellx3118\clvertalt\clbrdrt\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3226\clshdrawnil \cellx6344\row }\pard 
\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 \tab 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 K\'fb NI\'d6M B\'b8O }{\b0\i\insrsid1378858 LE PARIA}{
\insrsid1378858 
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-254\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~M\'e9t n\'a8m \'ae\'b7 tr\'abi qua k\'d3 t\'f5 khi b\'b8
o }{\i\f37\fs20\insrsid1378858 Le Paria}{\f37\fs20\insrsid1378858  ra \'ae\'eai. C\'b8c b\'b9n quan t\'a9m \'ae\'d5n s\'e8 ph\'cbn c\'f1a t\'ea b\'b8o ngay t\'f5 bu\'e6i \'ae\'c7u, nh\'a9n d\'dep k\'fb ni\'d6m n\'b5y, c\'b6m \'acn t\'cat c\'b6 nh\'f7
ng ai \'ae\'b7 can \'ae\'b6m v\'edi di\'d4n \'ae\'b5n nh\'e1 b\'d0 n\'b5y, b\'b6o v\'d6 nh\'a9n d\'a9n c\'b8c thu\'e9c \'ae\'dea.
\par C\'b8c b\'b9n mua d\'b5i h\'b9n, c\'b8c b\'b9n quy\'aan g\'e3p cho b\'b8o \'ae\'d5n s\'e8 g\'c7n \'ae\'a9y \'ae\'ad\'eec 645 phr\'a8ng}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0
\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) B\'b5i n\'b5y, t\'b8c gi\'b6 vi\'d5t t\'f5 tr\'ad\'edc, n\'aan vi\'d5t \'93c\'b8c b\'b9n quy\'aan g\'e3p cho b
\'b8o \'ae\'d5n s\'e8 g\'c7n \'ae\'a9y \'ae\'ad\'eec 645 phr\'a8ng\'94, nh\'adng \'eb c\'e9t 2, s\'e8 14, \'ae\'a8ng t\'e6ng s\'e8 ti\'d2n quy\'aan g\'e3p \'ae\'ad\'eec t\'f5 \'ae\'c7u \'ae\'d5n l\'f3c n\'b5y \'ae\'ad\'eec 892 phr\'a8ng. 645 phr\'a8ng l
\'b5 t\'ddnh \'ae\'d5n s\'e8 13.}})}{\f37\fs20\insrsid1378858 , h\'b7y nh\'cbn l\'cay s\'f9 bi\'d5t \'acn ch\'a9n th\'b5nh c\'f1a ch\'f3ng t\'abi.
\par Ch\'f3ng t\'abi \'ae\'b7 kh\'abng qu\'b8 l\'b9c quan \'ae\'e8i v\'edi nh\'f7ng \'aei\'d2u d\'f9 \'aeo\'b8n tr\'ad\'edc. Ch\'f3ng t\'abi hi\'d3u r\'e2 s\'f9 nghi\'d6p m\'b5 ch\'f3ng t\'abi theo \'aeu\'e6i, \'ae\'c6t ra v\'ab v\'b5n kh\'e3 kh\'a8n. M\'e9t m
\'c6t, \'ae\'abng \'ae\'b6o d\'ad lu\'cbn ch\'a9u \'a2u ch\'ada \'ae\'ad\'eec chu\'c8n b\'de \'ae\'d3 theo d\'e2i \'ae\'c7y \'ae\'f1 quan \'aei\'d3m c\'f1a ch\'f3ng ta. M\'c6t kh\'b8c, nh\'f7ng ng\'ad\'eai d\'a9n thu\'e9c \'ae\'dea \'eb Ph\'b8p th\'ad\'ea
ng ch\'ada quan t\'a9m \'ae\'d5n t\'d7nh h\'d7nh c\'e3 quan h\'d6 t\'edi s\'e8 ph\'cbn \'ae\'e5ng b\'b5o h\'e4 \'eb c\'b8c thu\'e9c \'ae\'dea \'aeang ph\'b6i \'ae\'ad\'acng \'ae\'c7u v\'edi m\'e4i s\'f9 phi\'d2n nhi\'d4u, v\'edi b\'b9o l\'f9c c\'f1a nh
\'b5 c\'c7m quy\'d2n \'eb \'ae\'dea ph\'ad\'acng, v\'edi s\'f9 b\'e3c l\'e9t t\'ad b\'b6n ch\'f1 ngh\'dca c\'f1a nh\'f7ng k\'ce \'aei khai ho\'b8. Cu\'e8i c\'efng, kho\'b6ng c\'b8ch gi\'f7a Pari v\'edi ch\'a9u Phi, ch\'a9u }{\f38\fs20\insrsid1378858 \'b8}
{\f37\fs20\insrsid1378858 , ch\'a9u M\'fc r\'cat xa. Nh\'f7ng cu\'e9c ti\'d5p x\'f3c gi\'f7a ch\'f3ng t\'abi v\'edi nh\'a9n d\'a9n c\'b8c thu\'e9c \'ae\'dea m\'b5 }{\i\f37\fs20\insrsid1378858 Le Paria}{\f37\fs20\insrsid1378858  c\'e3 tr\'b8ch nhi\'d6m b
\'b6o v\'d6 l\'b9i lu\'abn lu\'abn b\'de c\'b6n tr\'eb b\'ebi nh\'f7ng k\'ce th\'e8ng tr\'de thu\'e9c \'ae\'dea g\'a9y ra.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Nh\'adng ph\'b6i th\'f5a nh\'cbn r\'bbng, ch\'f3ng t\'abi \'aeang \'ae\'f8ng tr\'ad\'edc m\'e9t 
\par }\pard \qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 \'aei\'d2u lo l\'beng r\'cat l\'edn. Ch\'f3ng t\'abi \'ae\'b7 t\'ddnh tr\'ad\'edc r\'bbng nhi\'d6m v\'f4 kh\'c8n thi\'d5t c
\'f1a m\'e9t t\'ea b\'b8o nh\'ad t\'ea b\'b8o c\'f1a ch\'f3ng t\'abi l\'b5 ph\'b6i b\'b6o v\'d6 c\'b8c anh em b\'b6n x\'f8. Vi\'d6c \'ae\'e3n nh\'cbn l\'cay nhi\'d6m v\'f4 \'ae\'e3 \'ae\'b7 d\'b5nh cho }{\i\f37\fs20\insrsid1378858 Le Paria }{
\f37\fs20\insrsid1378858 l\'b5 \'ae\'f3ng v\'edi \'aei\'d2u mong mu\'e8n c\'f1a ch\'f3ng ta.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\expnd0\expndtw-2\insrsid1378858 Sang n\'a8m th\'f8 hai, ch\'f3ng t\'abi mu\'e8n th\'f9c hi\'d6n nh\'f7ng vi\'d6c l\'b5m t\'e8t \'ae\'d1
p h\'acn. Ph\'b6i l\'b5m cho }{\i\f37\fs20\expnd0\expndtw-2\insrsid1378858 Le Paria}{\f37\fs20\expnd0\expndtw-2\insrsid1378858  xu\'cat hi\'d6n trong m\'e9t th\'eai k\'fa v\'edi nh\'f7ng k\'d5t qu\'b6 r\'f9c r\'ec, c\'e3 nhi\'d2u ng\'ad\'eai t\'d7m \'ae
\'d5n b\'b8o, v\'edi s\'e8 l\'ad\'eeng b\'b6n in t\'a8ng h\'acn v\'b5 s\'e8 trang nhi\'d2u h\'acn tr\'ad\'edc. T\'cat c\'b6 nh\'f7ng \'aei\'d2u \'ae\'e3 ch\'d8 c\'e3 th\'d3 th\'b5nh s\'f9 th\'cbt n\'d5u c\'e3 \'ae\'ad\'eec nh\'f7ng ngu\'e5n d\'f9 tr\'f7
 th\'ddch \'ae\'b8ng. V\'cby m\'b5, kh\'abng th\'d3 \'ae\'dfi h\'e1i m\'e9t s\'f9 c\'e8 g\'beng cao h\'acn n\'f7a \'ae\'e8i v\'edi 5, 6 b\'b9n \'ae\'b7 nh\'cbn nhi\'d6m v\'f4 ngay t\'f5 \'ae\'c7u, \'ae\'b7 ch\'deu \'ae\'f9ng t\'f5 12 th\'b8ng qua. C\'e3
 th\'d3 n\'e3i r\'bbng ri\'aang nh\'f7ng vi\'d6c in v\'b5 g\'f6i \'aei, gi\'b8 3 phr\'a8ng m\'e7i s\'e8 trong m\'e9t n\'a8m l\'b5 v\'f5a ph\'b6i. \'a7\'d3 thu\'cbn ti\'d6n cho vi\'d6c tuy\'aan truy\'d2n cho t\'ea b\'b8o, l\'f3c n\'b5y ch\'f3ng t\'abi th
\'cay r\'bbng kh\'abng th\'d3 n\'a9ng gi\'b8 l\'aan ngay \'ae\'ad\'eec.
\par }{\f37\fs20\insrsid1378858 \'a7\'e8i v\'edi t\'cat c\'b6 nh\'f7ng ai \'ae\'e4c b\'b8o, mu\'e8n b\'b8o s\'e8ng l\'a9u v\'b5 l\'edn m\'b9nh, hi\'d3u nhi\'d6m v\'f4 c\'f1a n\'e3, n\'aan mua d\'b5i h\'b9n cho m\'d7nh v\'b5 v\'cbn \'ae\'e9ng nhi\'d2u ng\'ad
\'eai mua d\'b5i h\'b9n b\'b8o }{\i\f37\fs20\insrsid1378858 Le Paria}{\f37\fs20\insrsid1378858 . C\'c7n ph\'b6i l\'b5m cho trong v\'dfng 2 hay 3 th\'b8ng t\'edi \'ae\'a9y, ch\'f3ng ta c\'e3 tr\'aan 1.000 \'ae\'e9c gi\'b6, tr\'aan 1.000 ng\'ad\'eai mua b
\'b8o d\'b5i h\'b9n. Ch\'f3ng t\'abi c\'f2ng kh\'abng ng\'c7n ng\'b9i n\'e3i ra vi\'d6c quy\'aan g\'e3p r\'cat khi\'aam t\'e8n c\'f2ng l\'b5 m\'e9t s\'f9 gi\'f3p \'ae\'ec r\'cat qu\'fd b\'b8u \'ae\'e8i v\'edi ch\'f3ng t\'abi. Ch\'f3ng t\'abi n\'e3i nh\'f7
ng \'aei\'d3m cu\'e8i c\'efng v\'d2 c\'b8c c\'e9ng t\'b8c vi\'aan. }{\i\f37\fs20\insrsid1378858 Le Paria}{\f37\fs20\insrsid1378858  l\'b5 ti\'d5ng n\'e3i c\'f1a qu\'c7n ch\'f3ng b\'de \'b8p b\'f8c. T\'cat c\'b6 \'ae\'d2u cung c\'cap t\'ad li\'d6u cho ch
\'f3ng ta, \'ae\'d2u vi\'d5t v\'d2 ch\'f3ng ta.
\par }{\f37\fs20\expnd0\expndtw-4\insrsid1378858 C\'b8c b\'b9n Ph\'b8p, c\'b8c \'ae\'e5ng b\'b5o \'eb thu\'e9c \'ae\'dea c\'ad tr\'f3 tr\'aan \'ae\'cat Ph\'b8p, c\'b8c anh em b\'b6n x\'f8 \'eb c\'b8c thu\'e9c \'ae\'dea, h\'b7y \'ae\'b8p l\'b9i l\'eai k\'aau g
\'e4i c\'f1a ch\'f3ng t\'abi.
\par }{\f37\fs20\insrsid1378858 H\'b7y l\'b5m vi\'d6c cho }{\i\f37\fs20\insrsid1378858 Le Paria}{\f37\fs20\insrsid1378858 , cho s\'f9 di\'d6t tr\'f5 ch\'d5 \'ae\'e9 \'ae\'e9c \'aeo\'b8n ch\'e8ng l\'b9i b\'e4n c\'b8 m\'cbp th\'f9c d\'a9n!
\par S\'f9 nghi\'d6p gi\'b6i ph\'e3ng nh\'f7ng ng\'ad\'eai b\'de ng\'ad\'eec \'ae\'b7i mu\'abn n\'a8m!
\par S\'f9 nghi\'d6p gi\'b6i ph\'e3ng nh\'a9n d\'a9n b\'b6n x\'f8 mu\'abn n\'a8m!
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb120\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i\insrsid1378858 \~\~LE PARIA
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 Le Paria,}{\insrsid1378858  s\'e8 14,
\line th\'b8ng 5-1923.
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
