\line C\'f1A BAN NGHI\'a3N C\'f8U THU\'e9C \'a7\'deA\line C\'f1A \'a7\'b6NG C\'e9NG S\'b6N PH\'b8P
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-300\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~C\'b8c b\'b9n lao \'ae\'e9ng b\'b6n x\'f8! Nh\'f7ng ng
\'ad\'eai c\'e9ng s\'b6n \'eb ch\'ddnh qu\'e8c hi\'d3u r\'e2 n\'e7i \'aeau kh\'e6 c\'f1a c\'b8c b\'b9n... C\'b8c b\'b9n b\'de hai l\'c7n b\'e3c l\'e9t: l\'b5 lao \'ae\'e9ng v\'b5 l\'b5 d\'a9n b\'b6n x\'f8. Nh\'f7ng ng\'ad\'eai ch\'f1 c\'b8c b\'b9n t\'f5
 ch\'ddnh qu\'e8c \'ae\'d5n kh\'abng h\'b5nh \'ae\'e9ng m\'e9t m\'d7nh. Nh\'f7ng ng\'ad\'eai quy\'d2n th\'d5 \'eb n\'ad\'edc c\'b8c b\'b9n, b\'e4n \'ae\'b9i \'ae\'dea ch\'f1 v\'b5 b\'e4n c\'c7m \'ae\'c7u mu\'e8n gi\'f7 c\'f1a c\'b6i v\'b5 quy\'d2n h\'b5
nh c\'f1a ch\'f3ng. \'a7\'d3 b\'e3c l\'e9t c\'b8c b\'b9n, ch\'f3ng \'ae\'b7 c\'a9u k\'d5t v\'edi ch\'ddnh quy\'d2n, b\'e4n th\'f9c d\'a9n v\'b5 c\'b8c c\'abng ty ch\'a9u \'a2u... Nh\'ad \'eb kh\'bep m\'e4i n\'aci tr\'aan th\'d5 gi\'edi, ch\'f3ng t\'abi 
\'ae\'b7 l\'cbp ra m\'e9t \'a7\'b6ng C\'e9ng s\'b6n l\'edn \'ae\'cau tranh \'ae\'d3 gi\'b6i ph\'e3ng m\'e4i ng\'ad\'eai lao \'ae\'e9ng.
\par \'a7\'b6ng mu\'e8n ho\'b9t \'ae\'e9ng \'f1ng h\'e9 nh\'f7ng ng\'ad\'eai anh em c\'f1a m\'d7nh \'eb thu\'e9c \'ae\'dea. N\'e3 \'ae\'d2 ngh\'de c\'b8c b\'b9n cho bi\'d5t nh\'f7ng s\'f9 \'ae\'b5n \'b8p m\'b5 c\'b8c b\'b9n l\'b5 n\'b9n nh\'a9n. N\'e3 d\'b5
nh cho c\'b8c b\'b9n b\'b8o ch\'dd c\'f1a n\'e3 v\'b5 s\'f9 gi\'f3p \'ae\'ec c\'f1a nh\'f7ng nh\'b5 ho\'b9t \'ae\'e9ng ch\'ddnh tr\'de c\'f1a n\'e3. N\'e3 \'ae\'d2 ngh\'de c\'b8c b\'b9n gi\'f3p \'ae\'ec n\'e3 t\'ddch c\'f9c v\'b5 \'eb n\'ad\'edc thu\'e9c 
\'ae\'dea n\'b5o c\'e3 chi b\'e9 \'a7\'b6ng, ch\'f3ng t\'abi mong c\'b8c b\'b9n coi \'ae\'e3 l\'b5 nh\'f7ng c\'ac quan b\'b6o v\'d6 c\'b8c b\'b9n. N\'e3 \'ae\'d2 ngh\'de c\'b8c b\'b9n \'aeo\'b5n k\'d5t l\'b9i gi\'f7a nh\'f7ng ng\'ad\'eai lao \'ae\'e9ng 
\'eb nh\'b5 m\'b8y v\'b5 n\'abng th\'abn, b\'d5n t\'b5u v\'b5 c\'e3 nh\'f7ng m\'e8i quan h\'d6 h\'f7u ngh\'de v\'edi nh\'f7ng ng\'ad\'eai lao \'ae\'e9ng t\'f5 ch\'ddnh qu\'e8c t\'edi ng\'b5y c\'b5ng nhi\'d2u, h\'e4 thu\'e9c c\'efng giai c\'cap v\'edi c
\'b8c b\'b9n.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 V\'d7 n\'d2n ho\'b5 b\'d7nh th\'d5 gi\'edi, v\'d7 t\'f9 do v\'b5 \'cam no, nh\'f7ng ng\'ad\'eai b\'de b\'e3c l\'e9t thu
\'e9c m\'e4i ch\'f1ng t\'e9c c\'c7n \'aeo\'b5n k\'d5t l\'b9i v\'b5 ch\'e8ng b\'e4n \'b8p b\'f8c.
\par \~
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\intbl\aspalpha\aspnum\faauto\adjustright\rin567\lin0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \'a7\'a8ng tr\'aan b\'b8o}{\i\insrsid1378858  Nh\'a9n d\'a9n,}{
\insrsid1378858 
\par s\'e8 7.689, ng\'b5y 24-5-1975.
\par \cell }\pard \s26\qr \li0\ri140\sl-260\slmult0\nowidctlpar\intbl\aspalpha\aspnum\faauto\adjustright\rin140\lin0 {\insrsid1378858 Theo b\'b5i \'ae\'a8ng b\'b8o.\cell }\pard\plain \ql \li0\ri0\widctlpar\intbl\aspalpha\aspnum\faauto\adjustright\rin0\lin0 
