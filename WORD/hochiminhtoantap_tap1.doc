\par N\'a6\'edC AN NAM\line D\'a6\'edI CON M\'beT NG\'a6\'eaI PH\'b8P
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~Trong m\'e9t b\'b6n tuy\'aan b\'e8, \'abng B\'ab l\'f3c 
\'ae\'e3 l\'b5 to\'b5n quy\'d2n \'a7\'abng D\'ad\'acng, n\'e3i v\'edi ng\'ad\'eai An Nam nh\'ad th\'d5 n\'b5y:
\par "H\'eci nh\'a9n d\'a9n An Nam!
\par Ch\'f3ng ta \'ae\'d5n n\'ad\'edc c\'b8c ng\'ad\'aci l\'b5 n\'e8i g\'e3t \'abng cha ch\'f3ng ta \'ae\'b7 t\'f5ng lui t\'edi b\'ea bi\'d3n n\'ad\'edc c\'b8c ng\'ad\'aci t\'f5 hai th\'d5 k\'fb nay.
\par Ch\'f3ng ta \'ae\'d5n \'ae\'a9y c\'f2ng v\'edi m\'e9t tinh th\'c7n m\'b9o hi\'d3m v\'b5 m\'e9t \'fd mu\'e8n khai ho\'b8.
\par Kh\'abng hi\'d3u phong t\'f4c v\'b5 l\'dech s\'f6 n\'ad\'edc c\'b8c ng\'ad\'aci, ch\'f3ng ta t\'ad\'ebng \'aeem \'ae\'d5n cho m\'e9t d\'a9n t\'e9c d\'b7 man nh\'f7ng \'a9n hu\'d6 c\'f1a m\'e9t n\'d2n v\'a8n minh cao c\'b6.
\par }\pard \qj \fi397\li0\ri0\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ch\'f3ng ta \'ae\'b7 \'aei kh\'bep \'ae\'e5ng ru\'e9ng, n\'f3i \'ae\'e5i v\'b5 \'eb \'ae\'a9u ch\'f3ng ta c\'f2ng khen cho s
\'f9 c\'c7n c\'ef kh\'abng m\'d6t m\'e1i c\'f1a c\'b8c ng\'ad\'aci.
\par Ch\'f3ng ta \'aei qua kh\'bep kinh k\'fa, \'eb \'ae\'a9u ch\'f3ng ta c\'f2ng th\'cay c\'e3 c\'ac s\'eb t\'e6 ch\'f8c \'ae\'b8ng khen.
\par Ch\'f3ng ta \'ae\'b7 v\'b5o nh\'b5 c\'b8c ng\'ad\'aci v\'b5 ch\'f3ng ta c\'f2ng th\'cay trong gia \'ae\'d7nh tr\'aan k\'ddnh d\'ad\'edi nh\'ad\'eang, th\'ea ph\'f4ng t\'e6 ti\'aan.
\par Ch\'f3ng ta \'ae\'b7 \'aei th\'a8m c\'b8c \'ae\'d2n ch\'efa, \'ae\'ad\'eec \'ae\'e4c nh\'f7ng c\'a9u ch\'a9m ng\'abn l\'b5m v\'ce vang cho nh\'a9n lo\'b9i".
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 \'a4ng \'a7\'ea Puvu\'e8cvin c\'f2ng vi\'d5t: "Ch\'f3ng ta th\'cay \'eb \'ae\'a9y c\'b6 m\'e9t n\'d2n v\'a8n minh, m\'e4
i th\'f8 \'ae\'d2u x\'a9y d\'f9ng t\'f5 l\'a9u. Ngh\'d6 thu\'cbt, khoa h\'e4c, k\'d3 
\par }\pard \qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 c\'b6 khoa h\'e4c qu\'b6n l\'fd Nh\'b5 n\'ad\'edc \'ae\'d2u \'ae\'b7 ph\'b8t tri\'d3n m\'b9nh m\'cf. Lu\'cbt ph\'b8p, c\'e6
 phong, t\'abn gi\'b8o, v\'a8n h\'e4c, t\'cat c\'b6 \'ae\'d2u \'ae\'b7 ho\'b5n ch\'d8nh v\'b5 ho\'b5 h\'eep v\'edi nhau, tr\'b6i qua bao nhi\'aau th\'d5 k\'fb, \'ae\'b7 \'ae\'ad\'eec \'aei\'d2u ho\'b5 v\'b5 ng\'b5y c\'b5ng ho\'b5n h\'b6o th\'aam. Nh\'f7
ng v\'d5t t\'ddch man r\'ee \'ae\'b7 m\'cat \'aei t\'f5 l\'a9u, d\'a9n t\'e9c n\'b5y \'ae\'b7 s\'e8ng trong m\'e9t x\'b7 h\'e9i thu\'c7n th\'f4c c\'e3 t\'e6 ch\'f8c trong khi nh\'f7ng ng\'ad\'eai ph\'ad\'acng T\'a9y c\'dfn \'eb t\'d7nh tr\'b9ng b\'b8
n khai. Y\'aau m\'d5n qu\'aa h\'ad\'acng, quy\'d5n luy\'d5n gia \'ae\'d7nh, t\'abn k\'ddnh t\'e6 ti\'aan, y\'aau chu\'e9ng c\'abng l\'fd, t\'abn tr\'e4ng ch\'ddnh ngh\'dca, ham th\'ddch khoa h\'e4c, coi tr\'e4ng l\'eai n\'e3i th\'b8nh hi\'d2n, th\'ad\'ac
ng y\'aau n\'dfi gi\'e8ng, t\'abn k\'ddnh l\'cf ph\'b6i; gh\'d0t xa hoa, kh\'abng h\'b8m ti\'d2n t\'b5i, khinh gh\'d0t v\'f2 l\'f9c, kh\'abng s\'ee gian kh\'e6, hy sinh; \'ae\'e3 l\'b5 nh\'f7ng \'ae\'f8c t\'ddnh r\'a8n d\'b9y trong s\'b8ch th\'b8nh hi\'d2
n, l\'adu l\'b9i trong c\'e6 phong v\'b5 ghi th\'b5nh lu\'cbt ph\'b8p; hi\'d6n nay \'ae\'e3 c\'f2ng l\'b5 nh\'f7ng \'ae\'c6c \'aei\'d3m v\'d2 b\'b6n t\'ddnh c\'f1a ng\'ad\'eai An Nam h\'d7nh th\'b5nh t\'f5 bao th\'d5 h\'d6, nh\'f7ng th\'d5 h\'d6 lu\'ab
n lu\'abn c\'e8 g\'beng th\'f9c hi\'d6n \'ae\'b9o \'ae\'f8c \'cay m\'e9t c\'b8ch th\'b5nh k\'ddnh; ng\'ad\'eai An Nam b\'d7nh th\'ad\'eang m\'b5 ng\'ad\'eai ta g\'c6p b\'cat c\'f8 \'eb \'ae\'a9u c\'f2ng \'ae\'d2u nh\'ad v\'cby c\'b6... Trong \'ae\'b8m ng
\'ad\'eai b\'d7nh d\'a9n, ng\'ad\'eai ta c\'f2ng th\'cay nh\'f7ng thu\'c7n phong m\'fc t\'f4c \'cay, c\'b6 \'eb nh\'f7ng ng\'ad\'eai m\'b5 x\'ada nay ch\'f3ng ta th\'ad\'eang quen g\'e4i l\'b5 b\'e4n c\'abn \'ae\'e5, qu\'a9n \'a8n c\'ad\'edp".
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 B\'a9y gi\'ea ch\'f3ng ta x\'d0t xem d\'a9n t\'e9c \'cay b\'de ai cai tr\'de v\'b5 cai tr\'de b\'bbng c\'b8ch n\'b5o.

\par "Ch\'f3ng ta t\'edi \'ae\'a9y kh\'abng l\'b5m cho ng\'ad\'eai An Nam gi\'b5u l\'aan ch\'f3t n\'b5o m\'b5 c\'dfn g\'a9y n\'aan kh\'f1ng ho\'b6ng \'ae\'d3 di h\'b9i l\'a9u d\'b5i. C\'b9nh tranh c\'f1a ng\'ad\'eai \'a2u \'ae\'b7 b\'e3p ch\'d5t m\'e9t s\'e8 c
\'abng nghi\'d6p, thu\'d5 m\'b8 n\'c6ng n\'d2 l\'b5m ph\'b8 s\'b6n m\'e9t s\'e8 c\'abng nghi\'d6p kh\'b8c". (\'a7\'b9i t\'b8 B\'d0cna).
\par "X\'b7 h\'e9i c\'f2 An Nam t\'e6 ch\'f8c t\'e8t nh\'ad th\'d5 \'ae\'b7 b\'de ch\'f3ng ta ph\'b8 hu\'fb. Ch\'f3ng ta t\'d7m c\'b8ch thay th\'d5 n\'e3 b\'bbng nh\'f7ng t\'e6 ch\'f8c th\'ab s\'ac theo ki\'d3u Ph\'b8p, nh\'adng v\'ab hi\'d6u.
\par Kh\'bep n\'aci, ng\'ad\'eai ta vi ph\'b9m lu\'cbt l\'d6 c\'f1a ng\'ad\'eai An Nam, coi th\'ad\'eang phong t\'f4c, c\'ad\'edp b\'e3c t\'b5i s\'b6n; m\'ad\'een c\'ed \'aei tr\'can \'b8p, n\'aan qu\'a9n l\'ddnh "\'ae\'ad\'eec th\'d3" l\'b9i tha h\'e5 c\'ad
\'edp ph\'b8, gi\'d5t ch\'e3c; th\'f3 t\'ddnh x\'cau xa nh\'cat l\'b9i ho\'b5nh h\'b5nh; \'ae\'d5n c\'b8i v\'ce c\'abng l\'fd c\'f2ng kh\'abng c\'dfn; kh\'abng m\'e9t vi\'aan ch\'d8 huy n\'b5o m\'b5 mi\'d6ng kh\'abng ch\'f6i r\'f1a, tay kh\'abng m\'f3a d
\'efi cui,
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 ch\'f3ng ch\'d8 tr\'can \'b8p ch\'f8 kh\'abng c\'c7n gi\'b6
ng gi\'b6i g\'d7". (\'a7\'ea Puvu\'e8cvin).
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 "N\'d5u b\'e4n \'a7\'f8c bu\'e9c cho hai t\'d8nh}{
\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) Hai t\'d8
nh And\'b8tx\'ac v\'b5 Loren c\'f1a Ph\'b8p b\'de \'a7\'f8c chi\'d5m \'ae\'e3ng tr\'ad\'edc Chi\'d5n tranh th\'d5 gi\'edi th\'f8 nh\'cat.}})}{\f37\fs20\insrsid1378858  b\'de ch\'f3ng x\'a9m chi\'d5m m\'e9t ch\'d5 \'ae\'e9 gi\'e8ng nh\'ad ch\'d5 \'ae\'e9 m
\'b5 ch\'f3ng ta b\'bet bu\'e9c nh\'f7ng ng\'ad\'eai ch\'f3ng ta g\'e4i l\'b5 d\'a9n b\'b6o h\'e9 kia ph\'b6i theo, th\'d7 t\'cat c\'b6 ch\'a9u \'a2u v\'a8n minh s\'cf \'ae\'f8ng l\'aan ch\'e8ng l\'b9i ch\'f3ng". (V. \'a7\'e8ct\'abng).
\par }\pard\plain \s22\qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f40\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 "T\'abi m\'b9n ph\'d0p n\'e3i r\'bbng c\'b8
ch khai ho\'b8 \'ae\'b8nh v\'ec \'ae\'c7u ng\'ad\'eai ta ch\'f8 kh\'abng c\'b6i bi\'d5n \'ae\'c7u \'e3c cho ng\'ad\'eai ta, nh\'ad th\'d5 l\'b5 h\'aci th\'ab b\'b9o. \'a7\'a9y l\'b5 nh\'f7ng ng\'ad\'eai \'aeang s\'e8ng y\'aan \'e6n trong nh\'b5 h\'e4. B
\'e7ng nhi\'aan ch\'f3ng ta x\'abng v\'b5o \'ae\'cat \'aeai kh\'abng ph\'b6i c\'f1a ch\'f3ng ta, mang danh nh\'a9n \'ae\'b9o, ch\'f3ng ta ch\'d0m gi\'d5t nh\'f7ng ng\'ad\'eai b\'b6n x\'f8 ho\'c6c \'aeu\'e6i h\'e4 ra kh\'e1i nh\'b5. Ch\'ddnh c\'b8i \'ae
\'e3 \'ae\'b7 g\'eei cho h\'e4 m\'e9t \'fd ni\'d6m ki\'aau h\'b7nh \'ae\'e8i v\'edi c\'b8i v\'a8n minh \'cay. V\'d7 t\'d7nh nh\'a9n lo\'b9i, ng\'ad\'eai ta gi\'d5t; v\'d7 t\'d7nh nh\'a9n lo\'b9i, ng\'ad\'eai ta c\'ad\'edp \'aeo\'b9t; v\'d7 t\'d7nh nh\'a9
n lo\'b9i, ng\'ad\'eai ta b\'e3c l\'e9t nh\'f7ng ng\'ad\'eai b\'b6n x\'f8!". (E.Mac\'b8c).
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-274\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 "T\'abi kh\'abng t\'ad\'ebng t\'ad\'eeng \'ae\'ad\'eec - 
\'abng \'a7ume, To\'b5n quy\'d2n \'a7\'abng D\'ad\'acng vi\'d5t - t\'abi kh\'abng tin r\'bbng ng\'ad\'eai ta c\'e3 th\'d3 c\'e3 m\'e9t quan ni\'d6m v\'d2 m\'e9t ch\'ddnh ph\'f1 thu\'e9c \'ae\'dea k\'fa qu\'b8i v\'ab l\'fd n\'b5o h\'acn Ch\'ddnh ph\'f1
 Nam K\'fa hi\'d6n nay. Ngay l\'f3c \'ae\'c7u ng\'ad\'eai ta \'ae\'b7 \'ae\'b9t \'ae\'d5n l\'fd t\'ad\'ebng ki\'d3u \'ae\'e3 r\'e5i.
\par Nam K\'fa \'ae\'ad\'eec \'ae\'c6t ngang h\'b5ng v\'edi c\'b8c thu\'e9c \'ae\'dea "l\'a9u \'ae\'eai" c\'f1a ch\'f3ng ta nh\'ad M\'b8ctin\'ddch, Goa\'ae\'acl\'f3p, R\'aauyni\'abng; c\'f2ng nh\'ad nh\'f7ng thu\'e9c \'ae\'dea n\'b5y, Nam K\'fa c\'e3 \'ae\'b9
i bi\'d3u \'eb ngh\'de vi\'d6n Ph\'b8p v\'b5 c\'e3 h\'e9i \'ae\'e5ng d\'a9n c\'f6 \'ae\'dea ph\'ad\'acng".
\par }{\f38\fs20\cgrid0\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  \'ae\'a9y t\'abi kh\'abng mu\'e8n nghi\'aan c\'f8u \'ae\'d3 \'ae\'b8nh gi\'b8 t\'e6 ch\'f8c \'eb c\'b8c thu\'e9c \'ae\'dea l\'a9u \'ae\'eai, ho\'c6c \'ae\'d3 xem vi\'d6c x\'b8c l\'cbp quy
\'d2n l\'cbp ph\'b8p \'eb \'ae\'a9y c\'e3 ph\'ef h\'eep v\'edi ch\'d5 \'ae\'e9 \'ae\'b9i ngh\'de \'eb ch\'ddnh qu\'e8c kh\'abng. Nh\'adng \'ddt ra ng\'ad\'eai ta c\'f2ng ph\'b6i gi\'b6i th\'ddch s\'f9 t\'e5n t\'b9i c\'f1a m\'e9t h\'e9i \'ae\'e5ng ch\'dd
nh tr\'de c\'e3 quy\'d2n l\'f9c g\'c7n nh\'ad cao nh\'cat \'eb m\'e9t n\'ad\'edc c\'e3 ph\'e6 th\'abng \'ae\'c7u phi\'d5u, trong \'ae\'e3 t\'cat c\'b6 m\'e4i ng\'ad\'eai d\'a9n, d\'a9n b\'b6n x\'f8 hay d\'a9n Ph\'b8p, \'ae\'d2u l\'b5 c\'abng d\'a9n c\'f1
a n\'ad\'edc c\'e9ng ho\'b5 \'ae\'ad\'eec h\'ad\'ebng \'ae\'c7y \'ae\'f1 quy\'d2n l\'eei ch\'ddnh tr\'de.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f38\fs20\cgrid0\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  Nam K\'fa th\'d7 kh\'abng gi\'e8ng nh\'ad th\'d5 ch\'f3t n\'b5o, d\'a9n b\'b6n x
\'f8 l\'b5 nh\'f7ng th\'c7n d\'a9n Ph\'b8p ch\'f8 kh\'abng ph\'b6i l\'b5 c\'abng d\'a9n Ph\'b8p.
\par Trong s\'e8 2.000 ng\'ad\'eai Ph\'b8p \'eb Nam K\'fa ng\'ad\'eai ta \'ae\'b7 t\'ddnh c\'e3 \'ae\'d5n 1.500 ng\'ad\'eai s\'e8ng d\'f9a v\'b5o ng\'a9n s\'b8ch, c\'dfn trong s\'e8 500 kia th\'d7 c\'f2ng ch\'d8 c\'e3 m\'e9t s\'e8 ng\'ad\'eai kh\'abng c\'e3
 quan h\'d6 v\'edi Nh\'b5 n\'ad\'edc. Nh\'ad v\'cby l\'b5 trong d\'a9n s\'e8 3 tri\'d6u ng\'ad\'eai kh\'abng c\'e3 \'ae\'ad\'eec hai ngh\'d7n c\'f6 tri}{\cs17\f37\fs20\super\insrsid1378858 *{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0
\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cs17\super\insrsid1378858 *}{\insrsid1378858  \'a7\'d2u l\'b5 nh\'f7ng ng\'ad\'eai Ph\'b8p. (Ch\'f3 th\'ddch c\'f1a t\'b8c gi\'b6
).
\par }{\expnd0\expndtw-2\insrsid1378858 ** C\'f8 hai ng\'ad\'eai Ph\'b8p th\'d7 c\'e3 m\'e9t ng\'ad\'eai An Nam. (Ch\'f3 th\'ddch c\'f1a t\'b8c gi\'b6).}}}{\f37\fs20\insrsid1378858 , v\'b5 ba ph\'c7n t\'ad nh\'f7ng ng\'ad\'eai n\'b5y l\'b9i l\'b5 c\'abng ch
\'f8c. }{\f38\fs20\insrsid1378858 \'ca}{\f37\fs20\insrsid1378858 y th\'d5 m\'b5 ng\'ad\'eai ta g\'e4i \'ae\'e3 l\'b5 ph\'e6 th\'abng \'ae\'c7u phi\'d5u!
\par Nh\'e3m \'aea s\'e8 nh\'f7ng ng\'ad\'eai \'a8n l\'ad\'acng \'cay b\'c7u ra m\'e9t \'ae\'b9i bi\'d3u v\'b5o h\'b9 ngh\'de vi\'d6n, ch\'d8 \'ae\'denh h\'e9i ngh\'de l\'cbp ph\'b8p \'eb thu\'e9c \'ae\'dea t\'f8c l\'b5 h\'e9i \'ae\'e5ng thu\'e9c \'ae\'dea. Ng
\'ad\'eai ta c\'e3 th\'d3 b\'ce l\'b9i r\'bbng h\'e9i \'ae\'e5ng \'cay g\'e5m c\'e3 h\'e9i vi\'aan ng\'ad\'eai An Nam}{\f37\fs20\super\insrsid1378858 **}{\f37\fs20\insrsid1378858 , c\'e3 \'ae\'b9i bi\'d3u c\'f1a ph\'dfng th\'ad\'acng m\'b9i v\'b5 c\'f1a h
\'e9i \'ae\'e5ng t\'ad v\'can. Th\'f9c t\'d5 th\'d7 nh\'f7ng h\'e9i vi\'aan do \'aeo\'b5n tuy\'d3n c\'f6 Nam K\'fa b\'c7u ra l\'b5m ch\'f3a trong h\'e9i \'ae\'e5ng; nh\'f7ng th\'b5nh ph\'c7n kh\'b8c c\'f1a h\'e9i \'ae\'e5ng ch\'d8 bi\'d5t c\'f3i \'ae\'c7
u nghe theo v\'b5 kh\'abng d\'b8m h\'d0 r\'a8ng.
\par }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  \'ae\'a9y ng\'ad\'eai ta th\'cay t\'cat c\'b6 c\'b8i t\'e8t \'ae\'d1p c\'f1a ch\'d5 \'ae\'e9: m\'e9t nh\'e3m \'aea s\'e8 ng\'ad\'eai \'a8n l\'ad\'acng ng\'a9n s\'b8ch s\'bep \'ae\'c6t l\'cay c\'b8
c kho\'b6n chi v\'b5 quy\'d5t \'ae\'denh l\'cay nh\'f7ng kho\'b6n thu\'d5 ph\'b6i thu. M\'e9t c\'a9u t\'f4c ng\'f7 \'ae\'b7 n\'e3i: "Tr\'ad\'edc khi th\'ad\'acng ng\'ad\'eai ph\'b6i th\'ad\'acng m\'d7nh \'ae\'b7". Ti\'d2n thu\'d5 c\'dfn \'aeem d\'efng 
\'ae\'d3 \'ae\'b5i th\'e4 nh\'f7ng c\'abng v\'f4 m\'edi, nh\'ea \'ae\'e3 m\'b5 th\'aam \'ae\'ad\'eec c\'f6 tri, d\'efng \'ae\'d3 h\'cbu \'ae\'b7i vi\'aan ch\'f8c Nh\'b5 n\'ad\'edc v\'b5 nh\'f7ng ng\'ad\'eai b\'b9n c\'f1a h\'e4, c\'b8ch d\'efng ti\'d2n nh
\'ad th\'d5 c\'dfn g\'d7 t\'e8t h\'acn n\'f7a!
\par T\'cat c\'b6 th\'d5 l\'f9c t\'b5n b\'b9o, v\'ab ch\'ddnh ph\'f1 do c\'b8c t\'e6 ch\'f8c t\'b9o ra b\'cat 
\par }\pard \qj \li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 ch\'cap quy\'d2n l\'f9c Nh\'b5 n\'ad\'edc \'ae\'d2u t\'cbp trung trong tay \'abng X... m\'e9t ng\'ad\'eai th\'abng minh v\'b5 
}{\i\f37\fs20\insrsid1378858 kh\'abn kh\'d0o}{\f37\fs20\insrsid1378858 , \'abng ta t\'cbp h\'eep xung quanh m\'d7nh m\'e9t phe ph\'b8i d\'d4 \'aei\'d2u khi\'d3n b\'bbng c\'b8ch chi\'d2u chu\'e9ng h\'e4 v\'b5 tho\'b6 m\'b7n nh\'f7ng \'aei\'d2u h\'e4
 khao kh\'b8t. Ng\'ad\'eai ta b\'e1 phi\'d5u b\'c7u cho \'abng X... v\'b5 cho c\'b8c b\'b9n c\'f1a \'abng ta v\'b5o h\'e9i \'ae\'e5ng thu\'e9c \'ae\'dea v\'b5 h\'e9i \'ae\'e5ng th\'b5nh ph\'e8; ng\'ad\'eai ta b\'c7u \'abng X... v\'b5o h\'b9 ngh\'de vi\'d6
n. Mu\'e8n n\'bem \'ae\'ad\'eec c\'b6 b\'e9
\par m\'b8y cai tr\'de, ch\'d8 c\'c7n c\'e3 m\'e9t s\'e8 nh\'f7ng c\'f6 tri trung th\'b5nh chi\'d5m \'aea s\'e8 l\'b5 \'ae\'ad\'eec. }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  \'ae\'a9y ng\'ad\'eai ta \'ae\'b7 n\'bem \'ae\'ad\'eec h\'e4 v\'b5 n
\'bem ri\'aang t\'f5ng ng\'ad\'eai m\'e9t; r\'e5i \'ae\'c6t n\'aci n\'b5y hay n\'aci kia v\'b5i t\'aan tay sai \'ae\'d3 \'aei s\'b8t h\'e4; ng\'ad\'eai ta b\'b6o \'ae\'b6m \'ae\'dea v\'de cho h\'e4, b\'bbng c\'b8ch l\'adu \'fd \'ae\'d5n vi\'d6c tuy\'d3n l
\'f9a nh\'a9n vi\'aan Nh\'b5 n\'ad\'edc, v\'d7 ch\'ddnh nh\'f7ng ng\'ad\'eai n\'b5y c\'f2ng v\'f5a l\'b5 c\'f6 tri n\'f7a \'ae\'cay.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Nh\'e3m c\'f6 tri \'ae\'c7u ti\'aan c\'e3 k\'fb lu\'cbt l\'b5 nh\'e3m ng\'ad\'eai da \'aeen }{\f38\fs20\insrsid1378858 
\'ca}{\f37\fs20\insrsid1378858 n \'a7\'e9. Nh\'f7ng ng\'ad\'eai }{\f38\fs20\insrsid1378858 \'ca}{\f37\fs20\insrsid1378858 n Bengan kh\'abng b\'de lu\'cbt l\'d6 Ph\'b8p chi ph\'e8i, nh\'adng h\'e4 v\'c9n \'ae\'ad\'eec xem nh\'ad l\'b5 ng\'ad\'eai Ph\'b8
p nh\'ad th\'ad\'eang; h\'e4 l\'b5 c\'abng d\'a9n, l\'b5 c\'f6 tri, h\'e4 \'ae\'ad\'eec tham gia c\'b8c cu\'e9c b\'c7u c\'f6. }{\i\f37\fs20\insrsid1378858 Ng\'ad\'eai An Nam \'eb trong n\'ad\'edc m\'d7nh l\'b9i kh\'abng ph\'b6i l\'b5 c\'abng d\'a9n v\'b5
 kh\'abng \'ae\'ad\'eec \'aei b\'c7u}{\f37\fs20\insrsid1378858 . B\'aan c\'b9nh \'aeo\'b5n qu\'a9n ng\'ad\'eai }{\f38\fs20\insrsid1378858 \'ca}{\f37\fs20\insrsid1378858 n s\'bdn c\'e3, ngoan ngo\'b7n \'aei theo \'cay, c\'c7n thi\'d5t ph\'b6i b\'e6 sung m
\'e9t \'ae\'e9i qu\'a9n l\'edn m\'b9nh nh\'f7ng c\'abng ch\'f8c ng\'ad\'eai \'a2u. Th\'d7 ng\'ad\'eai ta \'ae\'b7 t\'d7m \'ae\'ad\'eec nh\'f7ng ng\'ad\'eai n\'b5y \'eb c\'b8c c\'abng s\'eb, ng\'ad\'eai ta \'ae\'b7 b\'e1 kh\'b8 nhi\'d2u }{
\i\f37\fs20\insrsid1378858 ti\'d2n thu\'d5 c\'f1a d\'a9n}{\f37\fs20\insrsid1378858  \'ae\'d3 mua chu\'e9c s\'f9 gi\'f3p \'ae\'ec c\'f1a h\'e4.
\par H\'e9i \'ae\'e5ng thu\'e9c \'ae\'dea s\'a8n s\'e3c \'ae\'d5n c\'f6 tri vi\'aan ch\'f8c nh\'adng c\'f2ng kh\'abng b\'e1 qu\'aan b\'b6n th\'a9n m\'d7nh. C\'e3 nh\'f7ng l\'f3c t\'cat c\'b6 nh\'f7ng \'abng h\'e9i \'ae\'e5ng, kh\'abng tr\'f5 m\'e9t ai, \'ae
\'d2u l\'c7n l\'ad\'eet \'ae\'ad\'eec h\'e9i \'ae\'e5ng bi\'d3u quy\'d5t giao cho nh\'f7ng vi\'d6c c\'e3 l\'eei l\'edn. Vi\'d6c tr\'adng th\'c7u m\'e9t con \'ae\'ad\'eang, m\'b5 c\'abng vi\'d6c k\'d0o d\'b5i n\'a8m n\'b5y qua n\'a8m kh\'b8c, kh\'ab
ng ai ki\'d3m so\'b8t, \'ae\'b7 \'aeem l\'b9i nh\'f7ng m\'e3n l\'eai th\'ad\'eang xuy\'aan cho m\'e9t \'abng h\'e9i \'ae\'e5ng n\'e4. M\'e9t \'abng th\'f8 hai l\'b5 b\'b8c s\'dc chuy\'aan tr\'de cho vi\'aan ch\'f8c \'eb thu\'e9c \'ae\'dea, \'ae\'ad\'eec h
\'ad\'ebng l\'ad\'acng r\'cat cao; m\'e9t \'abng kh\'b8c l\'b5 b\'b8c s\'dc c\'abng t\'b8c \'eb th\'b5nh ph\'e8 l\'edn; m\'e9t h\'e9i vi\'aan th\'f8 t\'ad \'ae\'ad\'eec tr\'adng th\'c7u cung c\'cap gi\'cay m\'b8 v\'b5 s\'e6 s\'b8ch in. Kh\'abng ph\'b6i ch
\'d8 c\'e3 c\'f6 tri m\'e9t m\'d7nh \'ae\'ad\'eec h\'ad\'ebng th\'f4 ch\'d5 \'ae\'e9 n\'b5y, ng\'ad\'eai tr\'f3ng c\'f6 c\'f2ng c\'e3 ph\'c7n m\'d7nh trong \'cay ch\'f8.
\par Ng\'ad\'eai An Nam \'a9m th\'c7m \'ae\'e3ng g\'e3p cho b\'e4n ch\'f3ng, nh\'adng b\'e4n ch\'f3ng kh\'abng th\'ccm h\'e1i \'fd ki\'d5n h\'e4 bao gi\'ea.
\par 
\par 
\par }{\f37\fs20\cgrid0\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \sect }\sectd 
