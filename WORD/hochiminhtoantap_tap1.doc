\par }\pard\plain \s25\qc \li0\ri0\sa240\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 HO\'b9T \'a7\'e9NG C\'b8CH M\'b9NG
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-300\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~Nh\'f7ng bi\'d5n c\'e8 g\'c7n \'ae\'a9y \'ae\'b7 l\'b5
m cho c\'b6 th\'d5 gi\'edi ch\'f3 \'fd \'ae\'d5n Nh\'cbt B\'b6n. Ng\'ad\'eai ta n\'e3i nhi\'d2u v\'d2 s\'f8c m\'b9nh c\'abng nghi\'d6p c\'f1a Nh\'cbt, v\'d2 vi\'d6c ph\'b8t tri\'d3n kinh t\'d5 tr\'ad\'edc kia v\'b5 sau n\'b5y c\'f1a n\'e3. M\'e4i ng\'ad
\'eai bi\'d5t r\'bbng ch\'f1 ngh\'dca t\'ad b\'b6n Nh\'cbt \'ae\'b9t \'ae\'ad\'eec m\'f8c ph\'b8t tri\'d3n nh\'ad v\'cby trong v\'dfng 20-25 n\'a8m; \'ae\'d3 \'ae\'b9t \'ae\'ad\'eec m\'f8c ph\'b8t tri\'d3n \'cay, c\'b8c b\'b9n \'ae\'e5ng nghi\'d6p c\'f1
a n\'ad\'edc Nh\'cbt \'eb ph\'ad\'acng T\'a9y \'ae\'b7 m\'cat t\'edi tr\'aan 100 n\'a8m.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 C\'efng v\'edi s\'f9 ph\'b8t tri\'d3n c\'f1a ch\'f1 ngh
\'dca t\'ad b\'b6n \'eb Nh\'cbt, c\'b8c t\'e6 ch\'f8c c\'abng nh\'a9n c\'f2ng ph\'b8t tri\'d3n v\'edi nh\'f7ng nh\'dep \'ae\'e9 nhanh ch\'e3ng. B\'aan c\'b9nh phong tr\'b5o v\'ab s\'b6n, c\'b8c phong tr\'b5o kh\'b8c c\'e3 t\'ddnh ch\'cat c\'b8ch m\'b9ng c
\'f2ng lan r\'e9ng. \'a7\'e3 l\'b5 phong tr\'b5o }{\i\f37\fs20\insrsid1378858 Eta.}{\f37\fs20\insrsid1378858  }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  \'ae\'d5 qu\'e8c M\'c6t tr\'eai m\'e4c c\'e3 m\'e9t lo\'b9i d\'a9n n\'e6i ti\'d5ng d
\'ad\'edi c\'b8i t\'aan }{\i\f37\fs20\insrsid1378858 Eta}{\f37\fs20\insrsid1378858 . V\'d2 b\'d2 ngo\'b5i th\'d7 }{\i\f37\fs20\insrsid1378858 Eta }{\f37\fs20\insrsid1378858 kh\'abng kh\'b8c g\'d7 nh\'f7ng ng\'ad\'eai Nh\'cbt kh\'b8c. Nh\'adng c\'e3 m\'e9
t c\'a9u chuy\'d6n hoang \'ae\'ad\'eang l\'b5 ng\'ad\'eai }{\i\f37\fs20\insrsid1378858 Eta}{\f37\fs20\insrsid1378858  xu\'cat th\'a9n t\'f5 nh\'f7ng b\'e9 l\'b9c n\'ab l\'d6 x\'ada kia t\'f5 n\'ad\'edc ngo\'b5i k\'d0o v\'b5o. V\'d7 v\'cby, cho n\'aan hi
\'d6n nay ng\'ad\'eai ta l\'b9i \'ae\'e8i x\'f6 v\'edi h\'e4 gi\'e8ng nh\'ad \'ae\'e8i x\'f6 v\'edi t\'e6 ti\'aan h\'e4. H\'e4 bu\'e9c ph\'b6i s\'e8ng trong nh\'f7ng v\'efng d\'b5nh ri\'aang cho h\'e4, n\'aci m\'b5 kh\'abng bao gi\'ea ng\'ad\'eai Nh\'cbt 
\'ae\'ad\'eec lui t\'edi. H\'e4 kh\'abng c\'e3 quy\'d2n giao thi\'d6p v\'edi nh\'a9n d\'a9n Nh\'cbt. H\'e4 ch\'d8 c\'e3 quy\'d2n quan h\'d6 v\'edi ng\'ad\'eai Nh\'cbt v\'edi t\'ad c\'b8ch l\'b5 nh\'f7ng ng\'ad\'eai h\'c7u h\'b9. H\'e4 nh\'cbn l\'b5m nh
\'f7ng c\'abng vi\'d6c n\'c6ng nh\'e4c v\'b5 b\'c8n th\'d8u nh\'cat. B\'c8n th\'d8u, th\'cap h\'ccn - \'ae\'e3 l\'b5 ng\'ad\'eai }{\i\f37\fs20\insrsid1378858 Eta.}{\f37\fs20\insrsid1378858  Ng\'ad\'eai Nh\'cbt kh\'abng \'ae\'ad\'eec l\'cay 
\par }\pard \qj \li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 ph\'f4 n\'f7 ng\'ad\'eai }{\i\f37\fs20\insrsid1378858 Eta}{\f37\fs20\insrsid1378858 . N\'e3i t\'e3m l\'b9i l\'b5 h\'e4 kh\'ab
ng c\'e3 m\'e9t ch\'f3t quy\'d2n h\'b9n x\'b7 h\'e9i g\'d7, v\'b5 s\'e8 ph\'cbn c\'f1a h\'e4 l\'b5m cho ng\'ad\'eai ta nh\'ed \'ae\'d5n s\'e8 ph\'cbn c\'f1a nh\'f7ng \'ae\'b8m ng\'ad\'eai "Su\'aera" \'eb }{\f38\fs20\insrsid1378858 \'ca}{
\f37\fs20\insrsid1378858 n \'a7\'e9 hay nh\'f7ng ng\'ad\'eai da \'aeen \'eb ch\'a9u Phi. Ng\'ad\'eai }{\i\f37\fs20\insrsid1378858 Eta}{\f37\fs20\insrsid1378858  c\'e3 3 tri\'d6u ng\'ad\'eai. Do \'b6nh h\'ad\'ebng c\'f1a nh\'f7ng ng\'ad\'eai v\'ab s\'b6n 
\'ae\'b7 gi\'b8c ng\'e9, nh\'f7ng ng\'ad\'eai }{\i\f37\fs20\insrsid1378858 Eta}{\f37\fs20\insrsid1378858  b\'bet \'ae\'c7u \'ae\'ad\'eec th\'f8c t\'d8nh v\'b5 c\'e3 t\'e6 ch\'f8c. H\'e4 th\'b5nh l\'cbp m\'e9t h\'e9i l\'cay t\'aan l\'b5 "Xuikh\'a9y" ("B
\'d7nh \'ae\'bcng"). M\'e4i ng\'ad\'eai nhi\'d6t t\'d7nh xin v\'b5o h\'e9i v\'b5 n\'a8m ngo\'b8i h\'e9i ngh\'de to\'b5n qu\'e8c \'ae\'c7u ti\'aan c\'f1a h\'e9i n\'b5y \'ae\'ad\'eec tri\'d6u t\'cbp. C\'e3 2.500 \'ae\'b9i bi\'d3u t\'f5 kh\'bep n\'ac
i trong n\'ad\'edc v\'d2 d\'f9 h\'e9i ngh\'de. H\'e9i ngh\'de \'ae\'b7 n\'aau kh\'c8u hi\'d6u: "Ho\'b5n to\'b5n b\'d7nh \'ae\'bcng". Ph\'ad\'acng ch\'a9m c\'f1a h\'e9i ngh\'de: "Vi\'d6c gi\'b6i ph\'e3ng }{\i\f37\fs20\insrsid1378858 Eta}{
\f37\fs20\insrsid1378858  l\'b5 s\'f9 nghi\'d6p c\'f1a ch\'ddnh ng\'ad\'eai }{\i\f37\fs20\insrsid1378858 Eta}{\f37\fs20\insrsid1378858 ". Nh\'f7ng t\'e6 ch\'f8c t\'f9 do v\'b5 c\'f1a ch\'ddnh ph\'f1 lo l\'beng tr\'ad\'edc vi\'d6c xu\'cat hi\'d6n m\'e9t l
\'f9c l\'ad\'eeng m\'edi n\'aan \'ae\'denh n\'bem l\'cay n\'e3 d\'ad\'edi s\'f9 b\'b6o h\'e9 c\'f1a m\'d7nh. Nh\'adng h\'e4 \'ae\'b7 kh\'abng th\'b5nh c\'abng.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Trong khi t\'cat c\'b6 c\'b8c c\'b8nh c\'f6a \'ae\'d2u \'ae\'e3ng ch\'c6t tr\'ad\'edc m\'bet h\'e4, th\'d7 nh\'f7ng ng
\'ad\'eai c\'abng nh\'a9n }{\i\f37\fs20\insrsid1378858 Eta}{\f37\fs20\insrsid1378858  l\'b9i \'ae\'ad\'eec nh\'f7ng ng\'ad\'eai c\'abng nh\'a9n Nh\'cbt c\'e3 t\'e6 ch\'f8c \'ae\'e3n ti\'d5p m\'e9t c\'b8ch h\'d5t s\'f8c th\'a9n t\'d7nh d\'f9a tr\'aan s\'f9
 b\'d7nh
\par }\pard \qj \li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 \'ae\'bcng ho\'b5n to\'b5n. H\'e4 \'ae\'b7 hi\'d3u r\'e2 \'ae\'ad\'eec s\'f9 \'ae\'e3n ti\'d5p \'ae\'e3. V\'d7 v\'cby ng\'b5
y nay, khi t\'f5 ch\'e8i m\'e4i s\'f9 quan t\'a9m gi\'f3p \'ae\'ec c\'f1a nh\'f7ng ng\'ad\'eai t\'f9 do v\'b5 c\'f1a ch\'ddnh ph\'f1, nh\'f7ng ng\'ad\'eai }{\i\f37\fs20\insrsid1378858 Eta}{\f37\fs20\insrsid1378858  th\'f9c hi\'d6n s\'f9 nghi\'d6p chung c
\'efng v\'edi giai c\'cap c\'abng nh\'a9n Nh\'cbt B\'b6n. Phong tr\'b5o l\'f3c \'ae\'c7u v\'edi t\'ad c\'b8ch l\'b5 cu\'e9c \'ae\'cau tranh c\'f1a l\'edp ng\'ad\'eai ri\'aang l\'ce th\'d7 hi\'d6n nay \'ae\'b7 tr\'eb th\'b5nh cu\'e9c \'ae\'cau tranh giai c
\'cap.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Tr\'ad\'edc khi khai m\'b9c \'ae\'b9i h\'e9i trong n\'a8m nay, nh\'f7ng ng\'ad\'eai }{\i\f37\fs20\insrsid1378858 Eta }{
\f37\fs20\insrsid1378858 \'ae\'b7 ra m\'e9t b\'b6n k\'aau g\'e4i "G\'f6i t\'cat c\'b6 nh\'f7ng d\'a9n t\'e9c \'ddt ng\'ad\'eai, t\'cat c\'b6 nh\'f7ng ng\'ad\'eai lao \'ae\'e9ng - n\'b9n nh\'a9n c\'f1a t\'ad b\'b6n th\'d5 gi\'edi v\'b5 ch\'f1 ngh\'dca \'ae
\'d5 qu\'e8c". Trong l\'eai k\'aau g\'e4i c\'e3 n\'e3i v\'d2 nh\'f7ng n\'e7i \'aeau kh\'e6 \'ae\'b7 tr\'b6i qua v\'b5 v\'d2 s\'f9 vi\'d3n v\'abng c\'f1a nh\'f7ng c\'b6i c\'b8ch m\'b5 ch\'ddnh ph\'f1 \'ae\'b7 \'ae\'ada ra, c\'e3 nh\'can m\'b9nh vi\'d6c "nh
\'f7ng ng\'ad\'eai }{\i\f37\fs20\insrsid1378858 Eta}{\f37\fs20\insrsid1378858  s\'bdn s\'b5ng s\'b8t c\'b8nh c\'efng giai c\'cap c\'abng nh\'a9n Nh\'cbt l\'b5m c\'b8ch m\'b9ng x\'b7 h\'e9i v\'b5 gi\'b6i ph\'e3ng t\'cat c\'b6 nh\'f7ng ng\'ad\'eai b\'de b
\'e3c l\'e9t". Trong c\'ad\'acng l\'dcnh h\'b5nh \'ae\'e9ng c\'f1a h\'e4 c\'e3 nh\'f7ng \'aei\'d3m \'ae\'c6c tr\'adng ch\'f8ng t\'e1 h\'e9i c\'e3 ngh\'de l\'f9c v\'b5 t\'ddnh ki\'aan quy\'d5t:
\par }\pard \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 A. T\'f5 ch\'e8i s\'f9 gi\'f3p \'ae\'ec t\'f5 thi\'d6n trong \'ae\'e3 c\'e3 s\'f9 gi\'f3p \'ae\'ec c\'f1a ch\'ddnh ph
\'f1.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B. \'a7\'b5o t\'b9o c\'b8n b\'e9 cho nh\'f7ng ho\'b9t \'ae
\'e9ng t\'ddch c\'f9c.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 C. Th\'b5nh l\'cbp c\'b8c c\'abng \'aeo\'b5n c\'f1a n\'ab
ng d\'a9n.
\par D. Th\'b5nh l\'cbp c\'b8c chi b\'e9 c\'f1a h\'e9i cho ph\'f4 n\'f7 v\'b5 thanh ni\'aan.
\par }\pard \qj \fi-312\li709\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin709\itap0 {\f37\fs20\insrsid1378858 E. Th\'b5nh l\'cbp c\'b8c th\'ad vi\'d6n, b\'b8o ch\'dd v\'b5 c\'b8c c\'ac quan b\'b8o ch\'dd kh\'b8c \'ae\'d3 ph
\'e6 bi\'d5n gi\'b8o d\'f4c v\'b5 tuy\'aan truy\'d2n t\'ad t\'ad\'ebng b\'b6o v\'d6 quy\'d2n l\'eei c\'f1a nh\'f7ng ng\'ad\'eai }{\i\f37\fs20\insrsid1378858 Eta}{\f37\fs20\insrsid1378858 .
\par G. \'a7\'dfi t\'f9 do ho\'b5n to\'b5n v\'d2 ch\'ddnh tr\'de v\'b5 kinh t\'d5 cho nh\'f7ng ng\'ad\'eai }{\i\f37\fs20\insrsid1378858 Eta.}{\f37\fs20\insrsid1378858 
\par }\pard \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 B\'a9y gi\'ea ch\'f3ng ta chuy\'d3n sang m\'e9t l\'f9c l\'ad\'eeng c\'b8ch m\'b9ng kh\'b8c - n\'abng d\'a9n Nh\'cbt.

\par }\pard\plain \s25\qc \li0\ri0\sb240\sa180\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'a4NG NH\'a2N N\'a4NG NGHI\'d6P
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Khi n\'e3i v\'d2 c\'abng nh\'a9n n\'abng nghi\'d6p \'eb Nh
\'cbt B\'b6n th\'d7 c\'c7n ph\'b6i nghi\'aan c\'f8u c\'b8c t\'e6 ch\'f8c c\'abng nh\'a9n n\'abng nghi\'d6p \'eb ph\'ad\'acng T\'a9y \'ae\'d3 so s\'b8nh.
\par }{\f38\fs20\insrsid1378858 \'eb}{\f37\fs20\insrsid1378858  ch\'a9u \'a2u c\'e3 1.517.000 c\'abng nh\'a9n n\'abng nghi\'d6p c\'e3 t\'e6 ch\'f8c, trong \'ae\'e3 919.000 ng\'ad\'eai tham gia Qu\'e8c t\'d5 Amxt\'d0c\'aeam}{\f37\fs20\super\insrsid1378858 39}{
\f37\fs20\insrsid1378858  v\'b5 598.000 ng\'ad\'eai tham gia Qu\'e8c t\'d5 \'ae\'e1 c\'f1a c\'b8c c\'abng \'aeo\'b5n. }{\f38\fs20\insrsid1378858 \'eb }{\f37\fs20\insrsid1378858 n\'ad\'edc Nga c\'e3 270.000 c\'abng nh\'a9n n\'abng nghi\'d6p c\'e3 t\'e6 ch
\'f8c \'ae\'ad\'eec th\'e8ng nh\'cat trong 8.000 nh\'e3m c\'abng \'aeo\'b5n, tham gia v\'b5o trong 87 t\'e6 ch\'f8c c\'abng \'aeo\'b5n.
\par N\'abng d\'a9n Nh\'cbt chia l\'b5m b\'e8n lo\'b9i:
\par 1. Dixacun\'ab hay nh\'f7ng ng\'ad\'eai s\'eb h\'f7u, lo\'b9i n\'b5y c\'e3 172.241 h\'e9.
\par 2. Dixacun\'ab lo\'b9i hai, hay nh\'f7ng ng\'ad\'eai s\'eb h\'f7u nh\'e1, - 1.507.341 h\'e9.
\par 3. Khandixacun\'ab: n\'f6a ch\'f1, n\'f6a th\'ee, - 2.244.126 h\'e9.
\par 4. C\'abxacunin, ho\'c6c nh\'f7ng ng\'ad\'eai t\'b8 \'aei\'d2n, - 1.557.847 h\'e9.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'f5 n\'a8m 1916 \'ae\'d5n n\'a8m 1922 s\'e8 l\'ad\'ee
ng Dixacun\'ab \'ae\'b7 t\'a8ng th\'aam 7.035 h\'e9, c\'dfn C\'abxacunin, - th\'aam 32.858 h\'e9 do s\'f9 ph\'a9n ho\'b8 hai nh\'e3m trung gian. \'a7i\'d2u \'ae\'e3 kh\'bcng \'ae\'denh l\'b9i m\'e9t l\'c7n n\'f7a t\'ddnh ch\'cat \'ae\'f3ng \'ae\'ben c\'f1
a h\'e4c thuy\'d5t M\'b8c v\'d2 s\'f9 thu h\'f3t v\'b5 v\'ab s\'b6n ho\'b8 c\'b8c t\'c7ng l\'edp trung gian.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 T\'e6 ch\'f8c c\'abng nh\'a9n n\'abng nghi\'d6p c\'f1a Nh
\'cbt \'ae\'ad\'eec th\'b5nh l\'cbp c\'b8ch \'ae\'a9y m\'edi \'ae\'ad\'eec ba n\'a8m, nh\'adng n\'e3 ph\'b8t tri\'d3n nhanh v\'b5 \'ae\'ad\'eec c\'f1ng c\'e8. C\'e3 hai c\'abng \'aeo\'b5n: c\'abng \'aeo\'b5n ph\'dda \'a7\'abng v\'b5 c\'abng \'aeo\'b5n ph
\'dda T\'a9y. C\'abng \'aeo\'b5n ph\'dda \'a7\'abng c\'e3 trung t\'a9m c\'f1a m\'d7nh l\'b5 T\'abki\'ab, c\'dfn ph\'dda T\'a9y l\'b5 \'a4xaca v\'b5 C\'abb\'aa. T\'cat c\'b6 c\'e3 85 chi nh\'b8nh c\'b8c c\'abng \'aeo\'b5n, 196 nh\'e3m, t\'e6ng c\'e9ng t
\'cat c\'b6 120 ngh\'d7n \'aeo\'b5n vi\'aan. N\'a8m 1922 \'eb c\'abng \'aeo\'b5n ph\'dda \'a7\'abng c\'e3 15 ngh\'d7n \'aeo\'b5n vi\'aan, c\'dfn c\'abng \'aeo\'b5n ph\'dda T\'a9y 91 ngh\'d7n. N\'a8m nay h\'e4 c\'e3 18 ngh\'d7n \'aeo\'b5n vi\'aan c\'abng 
\'aeo\'b5n ph\'dda \'a7\'abng v\'b5 102 ngh\'d7n \'aeo\'b5n vi\'aan c\'abng \'aeo\'b5n ph\'dda T\'a9y, c\'e3 ngh\'dca l\'b5 s\'e8 l\'ad\'eeng c\'f1a h\'e4 t\'a8ng l\'aan 14 ngh\'d7n trong m\'e9t n\'a8m. \'a7i\'d2u \'ae\'e3 c\'e3 ngh\'dca l\'b5 \'eb Nh\'cb
t B\'b6n \'aeang x\'b6y ra m\'e9t qu\'b8 tr\'d7nh ph\'b8t tri\'d3n ng\'ad\'eec l\'b9i v\'edi qu\'b8 tr\'d7nh ph\'b8t tri\'d3n c\'f1a c\'b8c t\'e6 ch\'f8c c\'abng nh\'a9n n\'abng nghi\'d6p \'eb c\'b8c n\'ad\'edc ch\'a9u \'a2u (tr\'f5 \'a7\'f8c v\'b5
 Nga), n\'aci c\'e3 s\'e8 l\'ad\'eeng h\'e9i vi\'aan \'aeang gi\'b6m xu\'e8ng ch\'f8 kh\'abng t\'a8ng l\'aan.
\par Nh\'ad ch\'f3ng ta \'ae\'b7 th\'cay \'eb tr\'aan, c\'abng \'aeo\'b5n ph\'dda T\'a9y c\'e3 s\'e8 l\'ad\'eeng nhi\'d2u h\'acn nhi\'d2u c\'abng \'aeo\'b5n ph\'dda \'a7\'abng, nh\'adng nh\'ea tinh th\'c7n ti\'aan ti\'d5n c\'f1a c\'b8c \'aeo\'b5n vi\'aan c\'f1
a m\'d7nh v\'b5 nh\'ea h\'e4 c\'e3 ngh\'de l\'f9c n\'aan c\'abng \'aeo\'b5n ph\'dda \'a7\'abng c\'e3 \'b6nh h\'ad\'ebng l\'edn h\'acn c\'abng \'aeo\'b5n ph\'dda T\'a9y. H\'c7u nh\'ad c\'abng \'aeo\'b5n ph\'dda \'a7\'abng bao gi\'ea c\'f2ng l\'b5 ng\'ad
\'eai \'ae\'d2 x\'ad\'edng ra cu\'e9c \'ae\'cau tranh ch\'e8ng l\'b9i ch\'f1.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd0\expndtw-2\insrsid1378858 \'a7\'c6c \'aei\'d3m "ch\'ddnh tr\'de - 
\'ae\'dea l\'fd" \'cay c\'e3 th\'d3 th\'cay c\'b6 trong nh\'f7ng c\'abng nh\'a9n c\'abng nghi\'d6p. C\'abng \'aeo\'b5n ph\'dda T\'a9y \'abn ho\'b5, c\'e3 s\'e8 l\'ad\'eeng \'ae\'abng b\'de l\'abi k\'d0o theo \'aeu\'abi c\'abng \'aeo\'b5n ph\'dda \'a7\'ab
ng ti\'aan ti\'d5n c\'e3 s\'e8 l\'ad\'eeng \'ddt.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Nh\'f7ng y\'aau s\'b8ch c\'ac b\'b6n c\'f1a c\'abng nh\'a9
n n\'abng nghi\'d6p l\'b5 x\'b7 h\'e9i ho\'b8 t\'cat c\'b6 \'ae\'cat \'aeai canh t\'b8c, s\'b8ch l\'ad\'eec ph\'e6 bi\'d5n nh\'cat c\'f1a cu\'e9c \'ae\'cau tranh l\'b5 kh\'abng \'aei l\'b5m trong th\'eai gian thu ho\'b9ch m\'efa m\'b5ng. N\'a8m 1920 \'ae
\'b7 ghi nh\'cbn l\'b9i \'ae\'ad\'eec 408 cu\'e9c \'ae\'d7nh c\'abng, v\'b5 n\'a8m 1922 - l\'aan t\'edi 1.398.
\par V\'b5o th\'b8ng 1 \'ae\'b7 c\'e3 quy\'d5t \'ae\'denh th\'e8ng nh\'cat hai c\'abng \'aeo\'b5n n\'b5y, C\'abng \'aeo\'b5n m\'edi \'ae\'ad\'eec g\'e4i l\'b5 "Nikh\'acnn\'abminkhai". Vi\'d6c th\'e8ng nh\'cat n\'b5y l\'b5m cho giai c\'cap v\'ab s\'b6n n\'ab
ng nghi\'d6p \'eb Nh\'cbt B\'b6n t\'a8ng th\'aam s\'f8c m\'b9nh v\'b5 l\'b5 m\'e9t m\'e8i lo ng\'b9i l\'edn \'ae\'e8i v\'edi b\'e4n ch\'f1.
\par }\pard\plain \s24\qr \fi397\li0\ri850\sb360\sa240\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin850\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 N.A.Q.
\par }\trowd \lastrow \ts11\trleft0\trftsWidth1 \clvertalt\clbrdrt\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3686\clshdrawnil \cellx3686\clvertalt\clbrdrt\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr
