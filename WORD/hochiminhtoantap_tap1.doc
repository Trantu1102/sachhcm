\'d0cta r\'f5ng c\'a9y tananh}{\cs17\f37\fs20\super\cgrid0\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\cgrid0\insrsid1378858 1) C\'a9y c\'e3 v\'de ch\'b8t \'ae\'d3 thu\'e9c da ho\'c6c nhu\'e9m.}})}{\f37\fs20\cgrid0\insrsid1378858 , 32.000 h\'d0cta cao su chia l\'b5m 140 \'ae\'e5n \'aei\'d2n.

\par C\'c7n ch\'f3 \'fd r\'bbng trong l\'dcnh v\'f9c n\'abng nghi\'d6p c\'f2ng nh\'ad m\'e4i l\'dcnh v\'f9c kh\'b8c, v\'d7 ph\'ad\'acng ph\'b8p canh t\'b8c l\'b9c h\'cbu c\'f1a ng\'ad\'eai An Nam v\'b5 c\'f2ng v\'d7 t\'ddnh s\'e8ng ch\'d5t m\'c6c bay c\'f1a ng
\'ad\'eai Ph\'b8p, \'a7\'abng D\'ad\'acng c\'dfn \'eb trong t\'d7nh tr\'b9ng kh\'e3 kh\'a8n. L\'cay l\'f3a l\'b5m th\'dd d\'f4: v\'edi mi\'d5ng \'ae\'cat r\'e9ng b\'bbng nhau, m\'b5u m\'ec thi\'aan nhi\'aan t\'ad\'acng t\'f9 nh\'ad nhau, n\'a8ng su\'cat 
\'eb \'a7\'abng D\'ad\'acng l\'aan xu\'e8ng kho\'b6ng 0,9 \'ae\'d5n l,8, trong l\'f3c \'eb Giava \'ae\'ad\'eec 2,2, \'eb M\'fc \'ae\'ad\'eec 2,4, Nh\'cbt \'ae\'ad\'eec 2,3.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\tx7513\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\cgrid0\insrsid1378858 B\'e4n ch\'f1 \'ae\'e5n \'aei\'d2n chi\'d5m kh\'abng, hay g\'c7n nh\'ad chi\'d5m kh\'abng h\'b5ng ng\'b5
n h\'d0cta r\'f5ng. Ch\'f3ng ch\'c6t g\'e7 b\'b8n, nh\'d0t ti\'d2n v\'b5o t\'f3i, r\'e5i v\'d2 Ph\'b8p \'ae\'b5ng ho\'b5ng ngh\'d8 ng\'aci \'eb th\'abn qu\'aa, ch\'bcng c\'c7n ch\'f3 \'fd g\'a9y l\'b9i c\'b8c r\'f5ng ch\'f3ng \'ae\'b7 ph\'b8 ph\'b8ch.

\par }{\f38\fs20\cgrid0\insrsid1378858 \'eb }{\f37\fs20\cgrid0\insrsid1378858 b\'aan \'cay, b\'e4n Ph\'b8p c\'e3:
