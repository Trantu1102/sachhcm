\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 S\'f9 QU\'b8I \'a7\'b6N C\'f1A C\'a4NG CU\'e9C KHAI HO
\'b8
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-296\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~Trong m\'e4i b\'b5i di\'d4n v\'a8n, trong m\'e4i b\'b6n b
\'b8o c\'b8o, \'eb m\'e4i n\'aci, c\'f8 c\'e3 c\'ac h\'e9i \'ae\'ad\'eec m\'eb mi\'d6ng v\'b5 c\'e3 k\'ce \'aei nghe, l\'b5 nh\'f7ng nh\'b5 ch\'ddnh kh\'b8ch c\'f1a ch\'f3ng ta kh\'abng ng\'f5ng kh\'bcng \'ae\'denh r\'bbng: ch\'d8 c\'e3 n\'ad\'edc \'a7
\'f8c man r\'ee l\'b5 \'ae\'d5 qu\'e8c v\'b5 qu\'a9n phi\'d6t. C\'dfn n\'ad\'edc Ph\'b8p, c\'b8i n\'ad\'edc Ph\'b8p y\'aau ho\'b5 b\'d7nh, nh\'a9n \'ae\'b9o, c\'e9ng ho\'b5 v\'b5 d\'a9n ch\'f1 n\'b5y, c\'b8i n\'ad\'edc Ph\'b8p \'ae\'ad\'eec h\'e4 \'ae\'b9
i di\'d6n n\'b5y, ch\'bcng h\'d2 \'ae\'d5 qu\'e8c l\'c9n qu\'a9n phi\'d6t. \'a4i! \'ae\'a9u ph\'b6i nh\'ad v\'cby. N\'d5u c\'f2ng ch\'ddnh nh\'f7ng v\'de ch\'ddnh kh\'b8ch n\'b5y g\'f6i binh l\'ddnh - con c\'b8i c\'f1a c\'abng nh\'a9n v\'b5 c\'b6 b\'b6
n th\'a9n nh\'f7ng ng\'ad\'eai c\'abng nh\'a9n n\'f7a - \'aei t\'b5n s\'b8t c\'abng nh\'a9n c\'f1a nh\'f7ng n\'ad\'edc kh\'b8c th\'d7 ch\'d8 \'ae\'acn gi\'b6n l\'b5 \'ae\'ad\'eec \'ae\'d3 d\'b9y cho h\'e4 bi\'d5t s\'e8ng t\'e8t. Ch\'d8 c\'e3 th\'d5 th\'ab
i.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-296\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Mu\'e8n hi\'d3u \'ae\'ad\'eec c\'abng cu\'e9c khai ho\'b8
 c\'f1a h\'e4, h\'b7y \'ae\'e4c \'aeo\'b9n tr\'ddch sau \'ae\'a9y t\'f5 m\'e9t cu\'e8n nh\'cbt k\'fd du l\'dech c\'f1a m\'e9t ng\'ad\'eai l\'ddnh th\'f9c d\'a9n:
\par "Khi b\'e4n l\'ddnh k\'d0o \'ae\'d5n, d\'a9n ch\'f3ng ch\'b9y tr\'e8n c\'b6, ch\'d8 c\'dfn l\'b9i hai c\'f4 gi\'b5 v\'b5 hai ph\'f4 n\'f7, m\'e9t thi\'d5u n\'f7 c\'dfn t\'a9n v\'b5 m\'e9t ph\'f4 n\'f7 \'aeang cho \'ae\'f8a con m\'edi \'ae\'ce b\'f3, tay d
\'bet m\'e9t em g\'b8i nh\'e1 l\'aan t\'b8m. B\'e4n l\'ddnh \'ae\'dfi ti\'d2n, r\'ad\'eeu m\'b9nh v\'b5 thu\'e8c phi\'d6n. Kh\'abng ai hi\'d3u ch\'f3ng n\'e3i g\'d7, th\'d5 l\'b5 ch\'f3ng n\'e6i gi\'cbn l\'cay b\'b8ng s\'f3ng n\'d6n m\'e9t c\'f4 gi\'b5 ng
\'cat \'aei, r\'e5i c\'dfn m\'e9t c\'f4 th\'d7 trong m\'cay gi\'ea li\'d2n, hai t\'aan trong b\'e4n l\'ddnh, khi k\'d0o \'ae\'d5n \'ae\'b7 say b\'dd t\'d8, \'aeem thi\'aau trong m\'e9t \'ae\'e8ng c\'f1i c\'b5nh c\'a9y l\'b5m tr\'df vui v\'ed
i nhau. Trong khi \'ae\'e3, th\'d7 nh\'f7ng t\'aan kh\'b8c hi\'d5p hai ph\'f4 n\'f7 v\'b5 em g\'b8i nh\'e1, ch\'b8n r\'e5i, ch\'f3ng gi\'d5t ch\'d5t em b\'d0. L\'f3c \'ae\'e3, ng\'ad\'eai m\'d1 b\'e5ng \'ae\'f8a con kia tr\'e8n \'ae\'ad\'eec, r\'e5i t\'f5
 trong m\'e9t \'ae\'b8m b\'f4i c\'a9y c\'b8ch \'ae\'cay \'ae\'e9 100 m\'d0t, tr\'abng th\'cay ng\'ad\'eai ch\'de em m\'d7nh b\'de h\'b5nh h\'b9. Duy\'aan c\'ed l\'b5m sao, ch\'de ch\'bcng bi\'d5t, ch\'de ch\'d8 th\'cay ng\'ad\'eai ph\'f4 n\'f7 b\'de \'ae
\'c6t ng\'f6a tr\'aan m\'c6t \'ae\'cat, tay ch\'a9n b\'de tr\'e3i ch\'c6t, mi\'d6ng b\'de b\'det l\'b9i, c\'dfn m\'e9t t\'aan l\'ddnh th\'d7 l\'cay l\'ad\'eci l\'aa c\'f8 t\'f5 t\'f5, t\'f5ng nh\'b8t m\'e9t, ch\'e4c v\'b5o b\'f4ng ch\'de r\'e5i l\'b9i ch
\'c7m ch\'cbm r\'f3t ra. Sau \'ae\'e3, ch\'f3ng ch\'c6t ng\'e3n tay ng\'ad\'eai thi\'d5u n\'f7 \'ae\'b7 ch\'d5t \'ae\'d3 c\'ad\'edp l\'cay chi\'d5c nh\'c9n v\'b5 ch\'c6t c\'e6 \'ae\'d3 c\'ad\'edp l\'cay chi\'d5c v\'dfng.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 "Tr\'aan m\'b6nh \'ae\'cat b\'bbng ph\'bcng tr\'ad\'edc kia l\'b5 ru\'e9ng mu\'e8i, ba c\'b8i x\'b8c ch\'d5t n\'bbm \'ae
\'e3: em b\'d0 b\'de l\'e9t tru\'e5ng, thi\'d5u n\'f7 b\'de m\'e6 b\'f4ng, c\'b8nh tay tr\'b8i c\'f8ng \'ae\'ea gi\'ac l\'aan tr\'eai v\'ab t\'d7nh, b\'b5n tay n\'bem ch\'c6t. C\'dfn x\'b8c \'abng c\'f4 gi\'b5 th\'d7, gh\'aa g\'edm l\'b5m sao, c\'f2ng tr
\'c7n tru\'e5ng nh\'ad th\'d5, nh\'adng b\'de thi\'aau ch\'b8y, n\'aan kh\'abng nh\'cbn ra h\'d7nh th\'ef \'ae\'ad\'eec n\'f7a, m\'ec ch\'b6y l\'aanh l\'b8ng, \'ae\'b7 \'ae\'e4ng l\'b9i v\'b5 da b\'f4ng th\'d7 ph\'e5ng l\'aan, ch\'ddn v\'b5ng, \'e3ng \'b8
nh, gi\'e8ng nh\'ad da con l\'een quay v\'cby".
\par Khi ch\'d0p \'ae\'d5n \'aeo\'b9n n\'b5y, t\'abi run l\'aan, m\'bet m\'ea l\'d6, n\'ad\'edc m\'bet ch\'b6y xu\'e8ng ho\'b5 v\'edi m\'f9c. T\'abi kh\'abng th\'d3 n\'b5o vi\'d5t \'ae\'ad\'eec n\'f7a. \'a4i! n\'ad\'edc Ph\'b8p \'aeau kh\'e6! \'a7\'abng T\'a9
y \'aeau kh\'e6! Nh\'a9n lo\'b9i \'aeau kh\'e6!
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~NGUY\'d4N \'b8I QU\'e8C
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~B\'b8o }{\i\insrsid1378858 Le Libertaire,}{\insrsid1378858 
\line ng\'b5y 30-9 - 7-10-1921.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }{\b\f37\fs20\insrsid1378858 
\par 
\par 
