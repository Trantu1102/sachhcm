\par 
\par 
\par Y\'a3U S\'b8CH C\'f1A NH\'a2N D\'a2N AN NAM
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-278\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~T\'f5 ng\'b5y \'a7\'e5ng minh th\'beng tr\'cbn, t\'cat c
\'b6 c\'b8c d\'a9n t\'e9c b\'de l\'d6 thu\'e9c \'ae\'d2u ch\'f8a chan hy v\'e4ng r\'bbng theo nh\'f7ng l\'eai cam k\'d5t ch\'ddnh th\'f8c v\'b5 tr\'denh tr\'e4ng m\'b5 c\'b8c c\'ad\'eang qu\'e8c \'a7\'e5ng minh \'ae\'b7 tuy\'aan b\'e8 v\'edi to\'b5n th
\'d5 gi\'edi, trong cu\'e9c \'ae\'cau tranh c\'f1a V\'a8n minh ch\'e8ng D\'b7 man, th\'d7 ti\'d2n \'ae\'e5 m\'e9t th\'eai \'ae\'b9i c\'abng l\'fd v\'b5 ch\'ddnh ngh\'dca nh\'cat \'ae\'denh l\'b5 ph\'b6i \'ae\'d5n v\'edi h\'e4.
\par Trong khi ch\'ea cho nguy\'aan t\'bec d\'a9n t\'e9c s\'cf t\'f5 l\'dcnh v\'f9c l\'fd t\'ad\'ebng chuy\'d3n v\'b5o l\'dcnh v\'f9c hi\'d6n th\'f9c do ch\'e7 quy\'d2n t\'f9 quy\'d5t thi\'aang li\'aang c\'f1a c\'b8c d\'a9n t\'e9c \'ae\'ad\'eec th\'f5a nh\'cb
n th\'cbt s\'f9, nh\'a9n d\'a9n n\'ad\'edc An Nam tr\'ad\'edc kia, nay l\'b5 x\'f8 \'a7\'abng - Ph\'b8p, xin tr\'d7nh v\'edi c\'b8c qu\'fd Ch\'ddnh ph\'f1 trong \'a7\'e5ng minh n\'e3i chung v\'b5 v\'edi Ch\'ddnh ph\'f1 Ph\'b8p \'ae\'b8ng k\'ddnh n\'e3i ri
\'aang, nh\'f7ng y\'aau s\'b8ch khi\'aam t\'e8n sau \'ae\'a9y:
\par 1. T\'e6ng \'a9n x\'b8 cho t\'cat c\'b6 nh\'f7ng ng\'ad\'eai b\'b6n x\'f8 b\'de \'b8n t\'ef ch\'ddnh tr\'de;
\par 2. C\'b6i c\'b8ch n\'d2n ph\'b8p l\'fd \'eb \'a7\'abng D\'ad\'acng b\'bbng c\'b8ch cho ng\'ad\'eai b\'b6n x\'f8 c\'f2ng \'ae\'ad\'eec quy\'d2n h\'ad\'ebng nh\'f7ng }{\i\f37\fs20\insrsid1378858 \'ae\'b6m b\'b6o v\'d2 m\'c6t ph\'b8p lu\'cbt}{
\f37\fs20\insrsid1378858  nh\'ad ng\'ad\'eai \'a2u ch\'a9u; }{\i\f37\fs20\insrsid1378858 xo\'b8 b\'e1 ho\'b5n to\'b5n}{\f37\fs20\insrsid1378858  c\'b8c to\'b5 \'b8n \'ae\'c6c bi\'d6t d\'efng l\'b5m c\'abng c\'f4 \'ae\'d3 kh\'f1ng b\'e8 v\'b5 \'b8p b\'f8
c b\'e9 ph\'cbn trung th\'f9c nh\'cat trong nh\'a9n d\'a9n An Nam;
\par 3. T\'f9 do }{\i\f37\fs20\insrsid1378858 b\'b8o ch\'dd}{\f37\fs20\insrsid1378858  v\'b5 t\'f9 do }{\i\f37\fs20\insrsid1378858 ng\'abn lu\'cbn}{\f37\fs20\insrsid1378858  ;
\par 4. T\'f9 do }{\i\f37\fs20\insrsid1378858 l\'cbp h\'e9i}{\f37\fs20\insrsid1378858  v\'b5 }{\i\f37\fs20\insrsid1378858 h\'e9i h\'e4p}{\f37\fs20\insrsid1378858 ;
\par 5. T\'f9 do }{\i\f37\fs20\insrsid1378858 c\'ad tr\'f3 \'eb n\'ad\'edc ngo\'b5i}{\f37\fs20\insrsid1378858  v\'b5 t\'f9 do xu\'cat d\'ad\'acng;
\par 6. T\'f9 do }{\i\f37\fs20\insrsid1378858 h\'e4c t\'cbp}{\f37\fs20\insrsid1378858 , th\'b5nh l\'cbp c\'b8c tr\'ad\'eang k\'fc thu\'cbt v\'b5 chuy\'aan nghi\'d6p \'eb t\'cat c\'b6 c\'b8c t\'d8nh cho ng\'ad\'eai b\'b6n x\'f8;
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 7. Thay }{\i\f37\fs20\insrsid1378858 ch\'d5 \'ae\'e9 ra c\'b8c s\'bec l\'d6nh b\'bbng ch\'d5 \'ae\'e9 ra c\'b8c \'ae\'b9
o lu\'cbt;}{\f37\fs20\insrsid1378858 
\par 8. \'a7o\'b5n \'ae\'b9i bi\'d3u th\'ad\'eang tr\'f9c c\'f1a ng\'ad\'eai b\'b6n x\'f8, do ng\'ad\'eai b\'b6n x\'f8 b\'c7u ra, t\'b9i Ngh\'de vi\'d6n Ph\'b8p \'ae\'d3 gi\'f3p cho Ngh\'de vi\'d6n bi\'d5t \'ae\'ad\'eec nh\'f7ng nguy\'d6n v\'e4ng c\'f1a ng\'ad
\'eai b\'b6n x\'f8.
\par \'a7\'ada ra nh\'f7ng y\'aau s\'b8ch tr\'aan \'ae\'a9y, nh\'a9n d\'a9n An Nam tr\'abng c\'cby v\'b5o ch\'ddnh ngh\'dca th\'d5 gi\'edi c\'f1a t\'cat c\'b6 c\'b8c c\'ad\'eang qu\'e8c v\'b5 \'ae\'c6c bi\'d6t tin v\'b5o l\'dfng r\'e9ng l\'ad\'eeng c\'f1a nh
\'a9n d\'a9n Ph\'b8p cao c\'b6, t\'f8c l\'b5 c\'f1a nh\'f7ng ng\'ad\'eai \'aeang n\'bem v\'cbn m\'d6nh c\'f1a nh\'a9n d\'a9n An Nam, c\'f1a nh\'f7ng ng\'ad\'eai, do ch\'e7 n\'ad\'edc Ph\'b8p l\'b5 m\'e9t n\'ad\'edc C\'e9ng ho\'b5, n\'aan \'ae\'ad\'ee
c coi l\'b5 nh\'f7ng ng\'ad\'eai b\'b6o h\'e9 cho nh\'a9n d\'a9n An Nam. Khi nh\'a9n d\'a9n An Nam nh\'bec \'ae\'d5n s\'f9 "b\'b6o h\'e9" c\'f1a nh\'a9n d\'a9n Ph\'b8p, th\'d7 kh\'abng l\'cay th\'d5 l\'b5m h\'e6 nh\'f4c ch\'f3t n\'b5o m\'b5 tr\'b8i l\'b9
i c\'dfn l\'cay l\'b5m vinh d\'f9: v\'d7 nh\'a9n d\'a9n An Nam bi\'d5t r\'bbng nh\'a9n d\'a9n Ph\'b8p \'ae\'b9i bi\'d3u cho t\'f9 do v\'b5 c\'abng l\'fd, v\'b5 kh\'abng bao gi\'ea t\'f5 b\'e1 l\'fd t\'ad\'ebng cao c\'b6 c\'f1a m\'d7nh l\'b5 t\'d7nh b\'b8
c \'b8i to\'b5n th\'d5 gi\'edi. V\'d7 th\'d5, nghe theo ti\'d5ng n\'e3i c\'f1a nh\'f7ng ng\'ad\'eai b\'de \'b8p b\'f8c, l\'b5 nh\'a9n d\'a9n Ph\'b8p s\'cf l\'b5m tr\'dfn nhi\'d6m v\'f4 c\'f1a m\'d7nh \'ae\'e8i v\'edi n\'ad\'edc Ph\'b8p v\'b5 \'ae\'e8i v
\'edi Nh\'a9n lo\'b9i.
\par }\pard\plain \s1\qc \li1701\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin1701\itap0 \b\i\f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\b0\i0\fs20\insrsid1378858 
\par }\pard \s1\qc \li1701\ri0\sa80\sl-340\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel0\adjustright\rin0\lin1701\itap0 {\b0\fs20\insrsid1378858 Thay m\'c6t nh\'e3m nh\'f7ng ng\'ad\'eai y\'aau n\'ad\'edc An Nam\line }{\b0\i0\f38\fs18\insrsid1378858 
