\par }}\dpx-27\dpy-3514\dpxsize900\dpysize360\dpfillfgcr255\dpfillfgcg255\dpfillfgcb255\dpfillbgcr255\dpfillbgcg255\dpfillbgcb255\dpfillpat1\dplinehollow}}}}{\f37\fs18\insrsid1378858 Anh ch\'de em l\'b5 }{\i\f37\fs18\insrsid1378858 chi\'d5n s\'dc}{
\f37\fs18\insrsid1378858  tr\'aan m\'c6t tr\'cbn \'cay".
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa60\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'ad t\'ad\'ebng v\'a8n ho\'b8 H\'e5 Ch\'dd Minh ch\'e8
ng l\'b9i m\'e4i bi\'d3u hi\'d6n c\'f1a ch\'f1 ngh\'dca k\'fa th\'de - \'ae\'e9c t\'abn v\'d2 v\'a8n ho\'b8. L\'b5 ng\'ad\'eai \'ae\'b7 l\'b5m gi\'b5u tr\'dd tu\'d6 c\'f1a m\'d7nh b\'bbng v\'e8n v\'a8n ho\'b8 ph\'ad\'acng \'a7\'abng v\'b5 ph\'ad\'acng T
\'a9y, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'b7 s\'edm \'ae\'d2 ra ch\'f1 tr\'ad\'acng k\'d5 th\'f5a truy\'d2n th\'e8ng t\'e8t \'ae\'d1p c\'f1a v\'a8n ho\'b8 d\'a9n t\'e9c ph\'b6i \'aei \'ae\'abi v\'edi vi\'d6c h\'e4c t\'cbp v\'b5 ti\'d5p thu c\'e3 ch
\'e4n l\'e4c tinh hoa v\'a8n ho\'b8 c\'f1a nh\'a9n lo\'b9i. Nh\'f7ng t\'ad t\'ad\'ebng l\'edn c\'f1a Ch\'f1 t\'dech H\'e5 Ch\'dd Minh v\'d2 v\'a8n ho\'b8 \'aeang l\'b5 kim ch\'d8 nam cho ch\'f3ng ta trong vi\'d6c x\'a9y d\'f9ng m\'e9t n\'d2n v\'a8n ho\'b8
 Vi\'d6t Nam ti\'aan ti\'d5n, \'ae\'cbm \'ae\'b5 b\'b6n s\'bec d\'a9n t\'e9c \'ae\'e5ng th\'eai kh\'abng ng\'f5ng m\'eb r\'e9ng s\'f9 giao l\'adu v\'a8n ho\'b8 v\'edi th\'d5 gi\'edi.
\par }\pard\plain \qj \fi397\li0\ri0\sa60\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 Nh\'f7ng gi\'b8 tr\'de phong ph\'f3 v\'b5 to\'b5n di\'d6
n n\'e3i tr\'aan \'ae\'b7 l\'b5m cho}{\i\f37\fs18\insrsid1378858  H\'e5 Ch\'dd Minh To\'b5n t\'cbp}{\f37\fs18\insrsid1378858  tr\'eb th\'b5nh b\'e9 s\'b8ch kinh \'aei\'d3n l\'edn nh\'cat, c\'e3 gi\'b8 tr\'de l\'fd lu\'cbn v\'b5 th\'f9c ti\'d4n cao nh\'ca
t v\'d2 c\'b8ch m\'b9ng Vi\'d6t Nam. B\'e9 s\'b8ch \'ae\'b7 ph\'b6n \'b8nh thi\'aan t\'b5i tr\'dd tu\'d6 c\'f1a v\'de l\'b7nh t\'f4 - ng\'ad\'eai th\'c7y c\'f1a c\'b8ch m\'b9ng Vi\'d6t Nam, nh\'b5 t\'ad t\'ad\'ebng m\'b8cx\'ddt v\'dc \'ae\'b9i; \'ae\'b7
 ph\'b6n \'b8nh qu\'b8 tr\'d7nh l\'dech s\'f6 50 n\'a8m \'ae\'cau tranh anh d\'f2ng v\'b5 th\'beng l\'eei v\'ce vang c\'f1a nh\'a9n d\'a9n ta d\'ad\'edi s\'f9 l\'b7nh \'ae\'b9o v\'b5 d\'d7u d\'bet tr\'f9c ti\'d5p c\'f1a Ch\'f1 t\'dech H\'e5 Ch\'dd Minh.

\par }\pard\plain \s16\qj \fi397\li0\ri0\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'ddnh khoa h\'e4c \'ae\'f3ng \'ae\'ben v\'b5 t\'ddnh c\'b8ch m
\'b9ng s\'b8ng t\'b9o c\'f1a t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh \'ae\'b7 \'ae\'ad\'eec l\'dech s\'f6 ki\'d3m ch\'f8ng. Tr\'b6i qua nh\'f7ng bi\'d5n \'ae\'e9ng c\'f1a th\'eai cu\'e9c, t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh c\'b5ng ch\'f8ng t\'e1 gi\'b8 tr
\'de v\'b5 s\'f8c s\'e8ng m\'b7nh li\'d6t c\'f1a n\'e3. T\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh l\'b5 tinh hoa c\'f1a d\'a9n t\'e9c Vi\'d6t Nam, l\'b5 ni\'d2m t\'f9 h\'b5o v\'ab h\'b9n c\'f1a m\'e7i ch\'f3ng ta. D\'ad\'edi \'b8nh s\'b8ng c\'f1a ch\'f1 ngh\'dc
a M\'b8c - L\'aanin v\'b5 t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh, to\'b5n \'a7\'b6ng, to\'b5n d\'a9n ta c\'b5ng v\'f7ng tin v\'b5o th\'beng l\'eei c\'f1a s\'f9 nghi\'d6p \'ae\'e6i m\'edi do \'a7\'b6ng ta kh\'ebi x\'ad\'edng v\'b5 l\'b7nh \'ae\'b9o, theo m
\'f4c 
\par }\pard \s16\qj \li0\ri0\sl-262\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\lang1024\langfe1024\noproof\insrsid1378858 
{\shp{\*\shpinst\shpleft5330\shptop-834\shpright6230\shpbottom-474\shpfhdr0\shpbxcolumn\shpbxignore\shpbypara\shpbyignore\shpwr3\shpwrk0\shpfblwtxt0\shpz17\shplid1043{\sp{\sn shapeType}{\sv 1}}{\sp{\sn fFlipH}{\sv 0}}{\sp{\sn fFlipV}{\sv 0}}
{\sp{\sn lTxid}{\sv 1048576}}{\sp{\sn dxTextLeft}{\sv 0}}{\sp{\sn dyTextTop}{\sv 0}}{\sp{\sn dxTextRight}{\sv 0}}{\sp{\sn dyTextBottom}{\sv 0}}{\sp{\sn hspNext}{\sv 1043}}{\sp{\sn fRecolorFillAsPicture}{\sv 0}}{\sp{\sn fUseShapeAnchor}{\sv 0}}
{\sp{\sn fLine}{\sv 0}}{\sp{\sn fLayoutInCell}{\sv 1}}{\shptxt \pard\plain \qr \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XXI
\par }}}{\shprslt{\*\do\dobxcolumn\dobypara\dodhgt8209\dptxbx\dptxlrtb{\dptxbxtext\pard\plain \qr \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XXI
\par }}\dpx5330\dpy-834\dpxsize900\dpysize360\dpfillfgcr255\dpfillfgcg255\dpfillfgcb255\dpfillbgcr255\dpfillbgcg255\dpfillbgcb255\dpfillpat1\dplinehollow}}}}{\lang1043\langfe1033\langnp1043\insrsid1378858 ti\'aau "d\'a9n gi\'b5u n\'ad\'edc m\'b9nh, x\'b7 h\'e9
i c\'abng b\'bbng, v\'a8n minh". M\'e7i ng\'ad\'eai Vi\'d6t Nam h\'b7y h\'e4c t\'cbp, v\'cbn d\'f4ng t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh, ph\'b8t huy l\'dfng y\'aau n\'ad\'edc, \'fd ch\'dd qu\'cbt c\'ad\'eang b\'cat khu\'cat c\'f1a d\'a9n t\'e9c \'ae\'d3
 x\'a9y d\'f9ng m\'e9t n\'ad\'edc Vi\'d6t Nam m\'edi, trong th\'eai \'ae\'b9i m\'edi, s\'b8nh vai v\'edi c\'b8c n\'ad\'edc ti\'aan ti\'d5n tr\'aan th\'d5 gi\'edi.
\par }\pard\plain \qc \li0\ri0\sb180\sa60\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 *
\par }\pard \qc \li0\ri0\sa240\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858  *     *
\par }\pard \qj \fi397\li0\ri0\sa60\sl-256\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 \'a7\'ad\'eec s\'f9 ch\'d8 \'ae\'b9o c\'f1a Ban B\'dd th\'ad Trung \'ad\'acng \'a7\'b6
ng, k\'d5 th\'f5a nh\'f7ng kinh nghi\'d6m v\'b5 th\'b5nh t\'f9u c\'f1a b\'e9 }{\i\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 H\'e5 Ch\'dd Minh To\'b5n t\'cbp}{\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858  xu\'cat b\'b6n l\'c7n th
\'f8 nh\'cat, b\'e9 }{\i\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 H\'e5 Ch\'dd Minh To\'b5n t\'cbp}{\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858  xu\'cat b\'b6n l\'c7n th\'f8 hai l\'b5 m\'e9t c\'abng tr\'d7nh lao \'ae\'e9ng khoa h
\'e4c nghi\'aam t\'f3c c\'f1a m\'e9t t\'cbp th\'d3 \'ae\'abng \'ae\'b6o c\'b8c nh\'b5 khoa h\'e4c, c\'b8n b\'e9 nghi\'aan c\'f8u, l\'adu tr\'f7, bi\'aan t\'cbp, xu\'cat b\'b6n thu\'e9c nhi\'d2u c\'ac quan \'a7\'b6ng v\'b5 Nh\'b5 n\'ad\'edc, \'eb trung 
\'ad\'acng v\'b5 \'ae\'dea ph\'ad\'acng.
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa60\sl-256\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\lang1043\langfe1033\langnp1043\insrsid1378858 T\'d7nh h\'d7nh ch\'ddnh tr
\'de tr\'aan th\'d5 gi\'edi \'ae\'b7 v\'b5 \'aeang c\'e3 nh\'f7ng thay \'ae\'e6i s\'a9u s\'bec. S\'f9 nghi\'d6p \'ae\'e6i m\'edi theo \'ae\'denh h\'ad\'edng x\'b7 h\'e9i ch\'f1 ngh\'dca \'aeang \'ae\'c6t ra nh\'f7ng v\'can \'ae\'d2 l\'fd lu\'cbn c\'cap b
\'b8ch \'ae\'dfi h\'e1i \'a7\'b6ng ta ph\'b6i kh\'c8n tr\'ad\'acng nghi\'aan c\'f8u v\'b5 gi\'b6i \'ae\'b8p, ph\'ef h\'eep v\'edi y\'aau c\'c7u v\'b5 th\'f9c ti\'d4n c\'f1a \'ae\'cat n\'ad\'edc. Nhu c\'c7u nghi\'aan c\'f8u, t\'d7m hi\'d3u v\'d2 t\'ad t
\'ad\'ebng H\'e5 Ch\'dd Minh \'aeang t\'a8ng l\'aan. C\'abng t\'b8c s\'adu t\'c7m, ph\'b8t hi\'d6n nh\'f7ng v\'a8n ki\'d6n, t\'b8c ph\'c8m, b\'b5i vi\'d5t c\'f1a Ch\'f1 t\'dech H\'e5 Ch\'dd Minh trong nh\'f7ng n\'a8m qua \'ae\'b7 thu \'ae\'ad\'eec nhi\'d2
u k\'d5t qu\'b6 m\'edi, \'ae\'ad\'eec b\'e6 sung v\'b5o b\'e9 s\'b8ch. C\'abng t\'b8c d\'dech thu\'cbt, x\'f6 l\'fd v\'a8n b\'b6n, gi\'edi thi\'d6u, ch\'f3 th\'ddch, tham kh\'b6o khoa h\'e4c ... cho b\'e9 s\'b8ch c\'f2ng \'ae\'ad\'eec n\'a9ng cao ch\'ca
t l\'ad\'eeng v\'b5 ho\'b5n thi\'d6n th\'aam m\'e9t b\'ad\'edc nh\'bbm gi\'f3p cho b\'b9n \'ae\'e4c c\'e3 \'aei\'d2u ki\'d6n t\'d7m hi\'d3u m\'e9t c\'b8ch \'ae\'c7y \'ae\'f1, ch\'ddnh x\'b8c t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh, \'ae\'e5ng th\'eai c\'f2
ng ph\'b6n \'b8nh \'ae\'ad\'eec nh\'f7ng th\'b5nh t\'f9u nghi\'aan c\'f8u v\'d2 t\'ad t\'ad\'ebng H\'e5 Ch\'dd Minh trong nh\'f7ng n\'a8m g\'c7n \'ae\'a9y.
\par Vi\'d6c xu\'cat b\'b6n l\'c7n th\'f8 hai b\'e9 }{\i\lang1043\langfe1033\langnp1043\insrsid1378858 H\'e5 Ch\'dd Minh To\'b5n t\'cbp}{\lang1043\langfe1033\langnp1043\insrsid1378858  \'ae\'b7 c\'e8 g\'beng \'ae\'b8p \'f8ng nh\'f7ng y\'aau c\'c7u tr\'aan \'ae
\'a9y. Tuy nhi\'aan, kh\'e8i l\'ad\'eeng c\'abng vi\'d6c r\'cat to l\'edn l\'b9i ph\'b6i ho\'b5n th\'b5nh trong m\'e9t th\'eai gian g\'cap r\'f3t, m\'c6c d\'c7u t\'cbp th\'d3 \'ae\'e9i ng\'f2 bi\'aan t\'cbp \'ae\'b7 c\'e3 nhi\'d2u c\'e8 g\'beng, song ch
\'bec ch\'ben v\'c9n kh\'abng tr\'b8nh kh\'e1i c\'dfn nh\'f7ng nh\'ad\'eec \'aei\'d3m v\'b5 thi\'d5u s\'e3t.
\par Nh\'a9n d\'dep b\'e9 }{\i\lang1043\langfe1033\langnp1043\insrsid1378858 H\'e5 Ch\'dd Minh To\'b5n t\'cbp}{\lang1043\langfe1033\langnp1043\insrsid1378858 , xu\'cat b\'b6n l\'c7n th\'f8 hai, ra m\'bet b\'b9n \'ae\'e4c, H\'e9i \'ae\'e5ng xu\'cat b\'b6n c\'b8
m \'acn c\'b8c nh\'b5 nghi\'aan c\'f8u, c\'b8c c\'e9ng t\'b8c vi\'aan khoa h\'e4c, \'ae\'e9i ng\'f2 c\'b8n b\'e9 bi\'aan t\'cbp \'ae\'b7 v\'ad\'eet qua nhi\'d2u kh\'e3 kh\'a8n, kh\'c8n tr\'ad\'acng ho\'b5n th\'b5nh b\'b6n th\'b6o trong m\'e9t th\'ea
i gian ng\'ben.
\par }\pard\plain \qj \fi397\li0\ri0\sa60\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\lang1024\langfe1024\noproof\insrsid1378858 
{\shp{\*\shpinst\shpleft-11\shptop-834\shpright889\shpbottom-474\shpfhdr0\shpbxcolumn\shpbxignore\shpbypara\shpbyignore\shpwr3\shpwrk0\shpfblwtxt0\shpz19\shplid1045{\sp{\sn shapeType}{\sv 1}}{\sp{\sn fFlipH}{\sv 0}}{\sp{\sn fFlipV}{\sv 0}}
