\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 TRUY\'d2N \'a7\'a5N C\'e6 \'a7\'e9NG MUA\line B\'b8O }{
\b0\i\insrsid1378858 LE PARIA}{\insrsid1378858 
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~D\'f9 ki\'d5n nh\'f7ng s\'f9 ki\'d6n nghi\'aam tr\'e4
ng c\'e3 th\'d3 x\'b6y ra ng\'b5y m\'e9t ng\'b5y hai, b\'b9n \'ae\'f5ng \'ae\'eei g\'d7 m\'b5 ch\'ada mua b\'b8o }{\i\f37\fs20\insrsid1378858 Le Paria}{\f37\fs20\insrsid1378858  v\'b5 h\'ab h\'b5o b\'b9n b\'cc mua n\'e3. T\'ea b\'b8o n\'b5y l\'b5 t\'ea b
\'b8o c\'f1a b\'b9n, gi\'f3p b\'b9n tho\'b8t kh\'e1i c\'b6nh n\'ab l\'d6 v\'b5 s\'cf ph\'b8t h\'b5nh r\'e9ng r\'b7i trong t\'cat c\'b6 c\'b8c thu\'e9c \'ae\'dea, nh\'bbm d\'bet d\'c9n m\'e4i ng\'ad\'eai b\'de b\'e3c l\'e9t thu\'e9c m\'e4i m\'b5u da \'aeo
\'b5n k\'d5t l\'b9i d\'ad\'edi l\'b8 c\'ea \'ae\'e1 b\'f3a li\'d2m \'ae\'d3 trong m\'e9t phong tr\'b5o c\'b8ch m\'b9ng qu\'e8c t\'d5 r\'e9ng l\'edn qu\'d0t s\'b9ch m\'e4i k\'ce b\'e3c l\'e9t m\'b5 ch\'f3ng ta l\'b5 nh\'f7ng ng\'ad\'eai c\'efng kh\'e6.

\par Ch\'d8 c\'e3 ch\'f1 ngh\'dca c\'e9ng s\'b6n m\'edi c\'f8u nh\'a9n lo\'b9i, \'aeem l\'b9i cho m\'e4i ng\'ad\'eai kh\'abng ph\'a9n bi\'d6t ch\'f1ng t\'e9c v\'b5 ngu\'e5n g\'e8c s\'f9 t\'f9 do, b\'d7nh \'ae\'bcng, b\'b8c \'b8i, \'aeo\'b5n k\'d5t, \'cam no tr
\'aan qu\'b6 \'ae\'cat, vi\'d6c l\'b5m cho m\'e4i ng\'ad\'eai v\'b5 v\'d7 m\'e4i ng\'ad\'eai, ni\'d2m vui, h\'dfa b\'d7nh, h\'b9nh ph\'f3c, n\'e3i t\'e3m l\'b9i l\'b5 n\'d2n c\'e9ng ho\'b5 th\'d5 gi\'edi ch\'a9n ch\'ddnh, x\'e3a b\'e1 nh\'f7ng bi\'aan gi
\'edi t\'ad b\'b6n ch\'f1 ngh\'dca cho \'ae\'d5n nay ch\'d8 l\'b5 nh\'f7ng v\'b8ch t\'ad\'eang d\'b5i ng\'a8n c\'b6n nh\'f7ng ng\'ad\'eai lao \'ae\'e9ng tr\'aan th\'d5 gi\'edi hi\'d3u nhau v\'b5 y\'aau th\'ad\'acng nhau.
\par T\'cat c\'b6 m\'e4i ng\'ad\'eai h\'b7y \'ae\'f8ng l\'aan quanh l\'b8 c\'ea \'ae\'e1 \'ae\'d3 chinh ph\'f4c th\'d5 gi\'edi.
\par Lao \'ae\'e9ng t\'cat c\'b6 c\'b8c n\'ad\'edc, \'aeo\'b5n k\'d5t l\'b9i!
\par \~
\par }\trowd \lastrow \ts11\trgaph108\trleft-108\trftsWidth1\trpaddl108\trpaddr108\trpaddfl3\trpaddfr3 \clvertalt\clbrdrt\brdrtbl \clbrdrl\brdrtbl \clbrdrb\brdrtbl \clbrdrr\brdrtbl \cltxlrtb\clftsWidth3\clwWidth3226\clshdrawnil \cellx3118\clvertalt\clbrdrt
