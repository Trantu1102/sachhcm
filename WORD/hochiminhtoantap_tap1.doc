\par \~th\'b8ng 5-1923.
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \column 
\par 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 KH\'a4NG PH\'b6I CHUY\'d6N \'a7\'efA
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-258\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~C\'e3 th\'d3 b\'b6o c\'b8c \'abng ngh\'de l\'b5 nh\'f7
ng ng\'ad\'eai thu\'e9c m\'e9t gi\'e8ng ng\'ad\'eai kh\'b8c. T\'f5 gi\'e8ng nh\'f7ng ng\'ad\'eai \'ae\'ad\'eec tr\'f3ng c\'f6, \'ae\'f3ng l\'b5 nh\'ad v\'cby. H\'e4 l\'b5 k\'ce d\'b8m l\'b5m m\'e4i vi\'d6c, k\'d3 c\'b6 vi\'d6c \'ae\'efa dai.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-258\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 K\'ce \'ae\'ad\'eec tr\'f3ng c\'f6 n\'e4, b\'de t\'e8 c\'b8
o l\'b5 l\'cbu thu\'d5, hay l\'f5a \'ae\'b6o - th\'d7 c\'f2ng th\'d5 - \'ae\'b7 kh\'abng ng\'c7n ng\'b9i ch\'cat v\'can \'abng B\'e9 tr\'ad\'ebng B\'e9 T\'b5i ch\'ddnh v\'d2 nh\'f7ng bi\'d6n ph\'b8p \'abng ta \'ae\'denh d\'efng \'ae\'d3 ng\'a8n ch\'c6n s
\'f9 b\'d0p x\'d0p c\'f1a vi\'aan ch\'f8c \'abng ta! K\'ce tr\'f3ng c\'f6 kia.... Nh\'adng th\'abi, cho qua, 
\par v\'b5 xin n\'e3i r\'bbng, nh\'f7ng \'abng ngh\'de ba hoa nh\'cat v\'c9n l\'b5 nh\'f7ng ng\'ad\'eai tr\'f3ng c\'f6 thu\'e9c \'ae\'dea.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-258\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ng\'ad\'eai ta c\'dfn nh\'ed: c\'b8c v\'de \'ae\'b8ng k
\'ddnh \'cay \'ae\'b7 \'ae\'ada ra m\'e9t ki\'d5n ngh\'de th\'d8nh c\'c7u Ch\'ddnh ph\'f1 Ph\'b8p cho ni\'aam y\'d5t v\'b5 \'aeem d\'b9y trong t\'cat c\'b6 c\'b8c tr\'ad\'eang trung h\'e4c, ti\'d3u h\'e4c, \'ae\'b9i h\'e4c, k\'fd t\'f3c x\'b8, nh\'b5 tr
\'ce, h\'e4c vi\'d6n r\'bbng n\'ad\'edc Ph\'b8p l\'b5 m\'e9t n\'ad\'edc 100 tri\'d6u d\'a9n. Kh\'abng h\'acn kh\'abng k\'d0m m\'e9t ng\'ad\'eai.
\par V\'b5 th\'d5 l\'b5 c\'b6 gi\'edi b\'b8o ch\'dd d\'b9i d\'e9t v\'b5 ch\'bcng ngh\'dc r\'bbng, c\'b8i ki\'d5n ngh\'de kh\'abi h\'b5i \'cay c\'e3 th\'d3 d\'c9n ng\'ad\'eai Ph\'b8p \'ae\'d5n nh\'f7ng h\'cbu qu\'b6 nghi\'aam tr\'e4ng, c\'f8 hoan h\'ab \'c7m 
\'dc c\'b6 l\'aan!
\par \'a7\'d5n nay, n\'d5u ki\'d5n ngh\'de \'cay \'ae\'ad\'eec ch\'cap nh\'cbn th\'d7 s\'cf th\'d5 n\'b5y n\'b5y: T\'cat c\'b6 nh\'f7ng \'abng b\'b5 ta \'eb B\'e9 Thu\'e9c \'ae\'dea - tr\'ad\'edc h\'d5t l\'b5 \'abng Anbe Xar\'ab s\'cf ch\'d5t \'ae\'e3i, v\'d7
 ph\'e3 m\'b8t thu\'e9c \'ae\'dea s\'cf t\'f9 nhi\'aan b\'de c\'bet m\'cat.
\par }\pard\plain \s15\qj \li0\ri0\sa80\sl-258\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Li\'aan \'aeo\'b5n ph\'f4c h\'e5i d\'a9n s\'e8 s\'cf bi\'d5n m
\'cat v\'b5 Ng\'b5i gi\'b8o ch\'f1 Bin\'aeria s\'cf kh\'abng th\'d3 gi\'b6ng c\'b8i thuy\'d5t \'ae\'ce m\'ben nh\'ad th\'e1 \'eb Vi\'d6n H\'b5n l\'a9m Ph\'b8p n\'f7a. V\'d7 khi s\'cf c\'e3 100 tri\'d6u ng\'ad\'eai Ph\'b8p so v\'edi 60 tri\'d6u t\'aan

\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-258\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 "b\'abs\'ac" th\'d7 ng\'ad\'eai ta s\'cf kh\'abng c\'e3 quy
\'d2n, d\'ef l\'b5 m\'e9t v\'de gi\'b8o ch\'f1 n\'e3i \'ae\'d5n chuy\'d6n h\'f4t d\'a9n s\'e8 n\'f7a.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 T\'cat c\'b6 s\'b8ch c\'f1a \'abng M\'abr\'ddtx\'ac Bar
\'d0t v\'b5 t\'cat c\'b6 nh\'f7ng b\'b5i b\'b8o c\'f1a \'abng Phor\'d0t (Lui) ch\'d8 \'ae\'b8ng \'aeem m\'b5... \'ae\'e8t c\'b6 \'aei v\'d7 d\'ef c\'e3 quy\'d2n th\'d5 \'ae\'d5n \'ae\'a9u, th\'d7 c\'b8c v\'de c\'f2ng kh\'abng th\'d3 cho r\'bbng m\'b8
u latinh \'aeang ch\'b6y trong huy\'d5t qu\'b6n c\'f1a ng\'ad\'eai An Nam hay ng\'ad\'eai \'a7ah\'abm\'a9y.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-272\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 V\'b5 khi m\'b5 kh\'abng c\'dfn thu\'e9c \'ae\'dea n\'f7
a th\'d7 binh s\'dc vinh quang c\'f1a ch\'f3ng ta s\'cf \'aei \'ae\'b8nh ch\'b8c \'eb \'ae\'a9u cho \'ae\'ec bu\'e5n tay? Bi\'d5t g\'f6i \'aei \'ae\'a9u nh\'f7ng v\'de th\'e8ng so\'b8i h\'d5t th\'eai, nh\'f7ng nh\'b5 ch\'ddnh tr\'de th\'cat c\'ac l\'ec v
\'cbn, b\'e4n gi\'d5t ng\'ad\'eai kh\'abng may, nh\'ad \'abng B\'e8p v\'b5 nh\'f7ng ng\'ad\'eai kh\'b8c?
\par Ph\'b6i h\'b5ng t\'cbp s\'b8ch, h\'b5ng t\'cbp s\'b8ch \'ae\'d3 mi\'aau t\'b6 m\'e4i \'aei\'d2u b\'cat ti\'d6n x\'b6y ra n\'d5u ki\'d5n ngh\'de \'cay \'ae\'ad\'eec ch\'cap nh\'cbn. C\'dfn ch\'f3ng t\'abi n\'f7a, ch\'f3ng t\'abi c\'f2ng h\'d5t s\'f8
c hoan ngh\'aanh n\'e3, nh\'adng d\'dc nhi\'aan v\'edi \'fd ngh\'dca kh\'b8c.
\par M\'e9t khi ch\'f3ng t\'abi l\'b5 ng\'ad\'eai Ph\'b8p, l\'cbp t\'f8c ch\'f3ng t\'abi s\'cf g\'f6i m\'e9t \'aeo\'b5n khai ho\'b8 \'ae\'d5n kh\'bep n\'ad\'edc Ph\'b8p. Ch\'f3ng t\'abi s\'cf l\'b5m cho \'ae\'cat n\'ad\'edc ng\'ad\'eai G\'abloa ng\'cbp l\'f4
t r\'ad\'eeu v\'b5 thu\'e8c phi\'d6n. }{\f38\insrsid1378858 \'eb }{\insrsid1378858 \'ae\'a9y, ch\'f3ng t\'abi s\'cf \'ae\'b8nh thu\'d5 mu\'e8i, thu\'d5 nh\'cbp th\'de, s\'cf cho b\'bet giam theo l\'d6nh h\'b5nh ch\'ddnh, ph\'b9t ti\'d2n t\'cbp th\'d3, s
\'cf cho m\'eb nh\'f7ng to\'b5 \'b8n \'ae\'c6c bi\'d6t \'ae\'d3 \'ae\'b5n \'b8p, ho\'b9t \'ae\'e9ng th\'ad\'eang xuy\'aan, l\'cbp ki\'d3m duy\'d6t, v.v. v\'b5 v.v.. N\'e3i g\'e4n l\'b9i, ch\'f3ng t\'abi s\'cf l\'b5m l\'b9i \'eb \'ae\'a9y t\'cat c\'b6 nh
\'f7ng g\'d7 m\'b5 nh\'f7ng k\'ce nguy\'aan l\'b5 b\'d2 tr\'aan c\'f1a ch\'f3ng t\'abi \'ae\'b7 l\'b5m tr\'aan \'ae\'cat n\'ad\'edc ch\'f3ng t\'abi, cho ch\'f3ng t\'abi ho\'b8 ra l\'b5 ng\'ad\'eai Ph\'b8p. Ch\'f3ng t\'abi s\'cf c\'cam t\'cat c\'b6 c\'b8
c b\'b8o, c\'b6 b\'b8o }{\i\insrsid1378858 Le Matin}{\insrsid1378858  v\'b5 b\'b8o }{\i\insrsid1378858 Le Petit Parisien}{\insrsid1378858 . Ch\'f3ng t\'abi s\'cf b\'b7i quy\'d2n t\'f9 do \'aei l\'b9i, t\'f9 do h\'e9i h\'e4p. Ch\'f3ng t\'abi s\'cf \'ae\'ad
a nh\'f7ng ng\'ad\'eai sinh \'ae\'ce \'eb \'ae\'a9y v\'b5o ch\'d5 \'ae\'e9 b\'b6n x\'f8, xi\'d5t bao \'aam \'b8i v\'b5 t\'e8t l\'b5nh, m\'b5 ch\'f3ng t\'abi, ng\'ad\'eai An Nam, ng\'ad\'eai Mang\'b8t, ng\'ad\'eai Phi ch\'a9u ch\'f3ng t\'abi \'ae\'b7 \'ae
\'ad\'eec h\'ad\'ebng t\'f5 l\'a9u. Ch\'f3ng t\'abi s\'cf b\'bet nh\'f7ng thanh ni\'aan Ph\'b8p ph\'b6i "t\'d7nh nguy\'d6n" nh\'cbp ng\'f2, kh\'abng ph\'b6i 18 th\'b8ng, m\'b5 l\'b5 ba, l\'b5 b\'e8n n\'a8m. N\'d5u c\'c7n, ch\'f3ng t\'abi s\'cf g\'f6i h
\'e4 \'aei cho ng\'ad\'eai ta gi\'d5t ch\'d5t, \'ae\'d3 b\'b6o v\'d6 T\'e6 qu\'e8c v\'b5 b\'b6o v\'d6 k\'d0t s\'bet c\'f1a ch\'f3ng t\'abi. Ch\'f3ng t\'abi s\'cf ch\'e4n nh\'f7ng c\'ab g\'b8i Ph\'b8p tr\'ce, \'ae\'d1p, cho \'ae\'d5n \'a7\'abng D\'ad\'ac
ng, \'a1ngti\'ac, Ma\'aeag\'b8txca, ch\'a9u Phi, l\'b5m con \'ae\'dfi, m\'e7i th\'b8ng 40 phr\'a8ng.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ch\'f3ng t\'abi s\'cf l\'b5 T\'e6ng th\'e8ng n\'ad\'edc C
\'e9ng ho\'b5 Ph\'b8p, B\'e9 tr\'ad\'ebng, th\'ad\'eeng ngh\'de s\'dc v\'b5 h\'b9 ngh\'de s\'dc. Ch\'f3ng t\'abi s\'cf l\'b5 nh\'f7ng nh\'b5 khai ho\'b8, nh\'f7ng nh\'b5 b\'b6o h\'e9, nh\'f7ng k\'ce b\'b5i x\'ddch ng\'ad\'eai b\'b6n x\'f8, nh\'f7ng k\'ce
 th\'a9n ng\'ad\'eai b\'b6n x\'f8. Ch\'f3ng t\'abi s\'cf cai tr\'de ng\'ad\'eai Ph\'b8p, v\'b5 khi b\'f9c m\'d7nh, c\'e3 th\'d3 g\'e4i ng\'ad\'eai th\'e6 d\'a9n - nh\'ad ch\'f3ng t\'abi \'ae\'b7 t\'f5ng b\'de g\'e4i nh\'ad th\'d5 cho \'ae\'d5n nay- l\'b5
 nh\'f7ng th\'bbng Nh\'b5 qu\'aa}{\cs17\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) Hai ch\'f7 "Nh\'b5 qu\'aa" trong nguy\'aan b\'b6n vi\'d5t b\'bbng ti\'d5ng Vi\'d6t.}})}{\f37\fs20\insrsid1378858  b\'c8n th\'d8u, hay l\'f2 "d\'aa con" b\'c8n th\'d8u.
\par \'a7\'f3ng l\'b5 s\'cf \'ae\'d5n l\'ad\'eet ch\'f3ng t\'abi, ph\'b6i kh\'abng?
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~Nguy\'d4n \'b8i Qu\'e8c
