\par }}}{\shprslt{\*\do\dobxcolumn\dobypara\dodhgt8212\dptxbx\dptxlrtb{\dptxbxtext\pard\plain \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XXIV
\par }}\dpx-27\dpy-814\dpxsize900\dpysize360\dpfillfgcr255\dpfillfgcg255\dpfillfgcb255\dpfillbgcr255\dpfillbgcg255\dpfillbgcb255\dpfillpat1\dplinehollow}}}}{\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 N\'a8m 1917, C\'b8ch m\'b9ng Th\'b8ng M\'ad\'ea
i Nga th\'beng l\'eei v\'b5 Nh\'b5 n\'ad\'edc c\'abng n\'abng \'ae\'c7u ti\'aan ra \'ae\'eai, nh\'ad ti\'d5ng s\'cam b\'b8o hi\'d6u m\'efa xu\'a9n \'ae\'e8i v\'edi nh\'a9n d\'a9n lao \'ae\'e9ng v\'b5 c\'b8c d\'a9n t\'e9c b\'de \'b8p b\'f8c tr\'aan to\'b5
n th\'d5 gi\'edi. Ti\'d5p theo l\'b5 Qu\'e8c t\'d5 th\'f8 ba th\'b5nh l\'cbp, c\'b8c \'ae\'b6ng c\'e9ng s\'b6n l\'c7n l\'ad\'eet ra \'ae\'eai, tr\'b5o l\'adu t\'ad t\'ad\'ebng c\'b6i l\'ad\'acng, c\'ac h\'e9i v\'b5 s\'abvanh trong Qu\'e8c t\'d5 th\'f8
 hai b\'de \'ae\'c8y lui. Trong ho\'b5n c\'b6nh \'cay, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'b7 ti\'d5p th\'f4 \'b8nh s\'b8ng c\'f1a C\'b8ch m\'b9ng Th\'b8ng M\'ad\'eai Nga v\'b5 }{\i\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 S\'ac th\'b6o l
\'c7n th\'f8 nh\'cat nh\'f7ng lu\'cbn c\'ad\'acng v\'d2 v\'can \'ae\'d2 d\'a9n t\'e9c v\'b5 v\'can \'ae\'d2 thu\'e9c \'ae\'dea }{\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 do V.I. L\'aanin so\'b9n th\'b6o.   
\par }\pard\plain \s18\qj \fi397\li0\ri0\sa60\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 M\'e9t trong nh\'f7ng n
\'e9i dung c\'ac b\'b6n c\'f1a t\'cbp 1 l\'b5 t\'b8c gi\'b6 t\'cbp trung v\'b9ch }{\fs18\expnd0\expndtw4\lang1043\langfe1033\langnp1043\insrsid1378858 tr\'c7n b\'b6n ch\'cat x\'cau xa, t\'e8 c\'b8o t\'e9i \'b8c c\'f1a ch\'f1 ngh\'dca th\'f9c d\'a9n \'ae
\'d5 qu\'e8c; x\'b8c \'ae\'denh r\'e2 ch\'f3ng l\'b5 k\'ce th\'ef chung c\'f1a giai c\'cap c\'abng nh\'a9n v\'b5 nh\'a9n d\'a9n b\'de \'b8p b\'f8c tr\'aan th\'d5 gi\'edi. Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'b7 vi\'d5t nhi\'d2u b\'b5i b\'b8o v\'b5 t\'b8
c ph\'c8m t\'can c\'abng v\'b5o ch\'f1 ngh\'dca th\'f9c d\'a9n \'ae\'d5 qu\'e8c nh\'ad }{\i\fs18\expnd0\expndtw4\lang1043\langfe1033\langnp1043\insrsid1378858 T\'a9m \'ae\'dea th\'f9c d\'a9n, B\'d7nh \'ae\'bcng, V\'f9c th\'bcm thu\'e9c \'ae\'dea, H\'b5
nh h\'d7nh ki\'d3u Lins\'ac, m\'e9t ph\'ad\'acng di\'d6n \'ddt ng\'ad\'eai bi\'d5t \'ae\'d5n c\'f1a n\'d2n v\'a8n minh M\'fc, C\'abng cu\'e9c khai ho\'b8 gi\'d5t ng\'ad\'eai.}{\fs18\expnd0\expndtw4\lang1043\langfe1033\langnp1043\insrsid1378858 .. D\'f9a v
\'b5o nh\'f7ng t\'b5i li\'d6u v\'b5 s\'f9 vi\'d6c c\'f4 th\'d3, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh 
\par }\pard \s18\qj \li0\ri0\sa60\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\fs18\expnd0\expndtw4\lang1043\langfe1033\langnp1043\insrsid1378858 \'ae\'b7 t\'e8 c\'b8o b\'b6n ch\'cat \'a8n c\'ad\'edp v\'b5 gi\'d5t ng\'ad\'ea
i c\'f1a ch\'f1 ngh\'dca th\'f9c d\'a9n \'ae\'d5 qu\'e8c, v\'b9ch tr\'c7n c\'b8i g\'e4i l\'b5 "khai ho\'b8 v\'a8n minh" c\'f1a ch\'f3ng. Ng\'ad\'eai vi\'d5t: "N\'d5u l\'e8i h\'b5nh h\'d7nh theo ki\'d3u Lins\'ac c\'f1a nh\'f7ng b\'e4n ng\'ad\'eai M\'fc h
\'ccn h\'b9 \'ae\'e8i v\'edi nh\'f7ng ng\'ad\'eai da \'aeen l\'b5 m\'e9t h\'b5nh \'ae\'e9ng v\'ab nh\'a9n \'ae\'b9o, th\'d7 t\'abi kh\'abng c\'dfn bi\'d5t g\'e4i vi\'d6c nh\'f7ng ng\'ad\'eai \'a2u nh\'a9n danh \'aei khai ho\'b8 m\'b5 gi\'d5t h\'b5ng lo
\'b9t nh\'f7ng ng\'ad\'eai d\'a9n ch\'a9u Phi l\'b5 c\'b8i g\'d7 n\'f7a" (Tr.321). Ng\'ad\'eai ch\'d8 r\'e2 nh\'f7ng \'a9m m\'adu v\'b5 th\'f1 \'aeo\'b9n che gi\'cau t\'e9i \'b8c c\'f1a ch\'f3ng: "\'a7\'d3 che \'ae\'cby s\'f9 x\'cau xa c\'f1a ch\'d5 \'ae
\'e9 b\'e3c l\'e9t gi\'d5t ng\'ad\'eai, ch\'f1 ngh\'dca t\'ad b\'b6n th\'f9c d\'a9n lu\'abn lu\'abn \'aei\'d3m trang cho c\'b8i huy ch\'ad\'acng m\'f4c n\'b8t c\'f1a n\'e3 b\'bbng nh\'f7ng ch\'a9m}{\fs18\lang1043\langfe1033\langnp1043\insrsid1378858   }{
\fs18\expnd0\expndtw4\lang1043\langfe1033\langnp1043\insrsid1378858  ng\'abn l\'fd t\'ad\'ebng: B\'b8c \'b8i, B\'d7nh \'ae\'bcng, v.v." (Tr.75). Trong nh\'f7ng b\'b5i c\'e3 ti\'aau \'ae\'d2 \'a7\'abng D\'ad\'acng v\'b5 h\'b5ng lo\'b9t b\'b5i kh\'b8c, Ng
\'ad\'eai \'ae\'b7 l\'aan \'b8n m\'b9nh m\'cf ch\'d5 \'ae\'e9 cai tr\'de h\'b5 kh\'bec, s\'f9 b\'e3c l\'e9t t\'b5n b\'b9o c\'f1a th\'f9c d\'a9n Ph\'b8p \'eb \'a7\'abng D\'ad\'acng tr\'aan c\'b8c l\'dcnh v\'f9c ch\'ddnh tr\'de, qu\'a9n s\'f9, kinh t\'d5, v
\'a8n ho\'b8, gi\'b8o d\'f4c.
\par  B\'bbng ng\'dfi b\'f3t s\'bec s\'b6o, ch\'a9m bi\'d5m chua cay, qua nh\'f7ng thi\'aan truy\'d6n k\'fd xu\'cat s\'bec nh\'ad }{\i\fs18\expnd0\expndtw4\lang1043\langfe1033\langnp1043\insrsid1378858 L\'eai than v\'b7n c\'f1a B\'b5 Tr\'adng Tr\'bec, "Vi h
\'b5nh"}{\fs18\expnd0\expndtw4\lang1043\langfe1033\langnp1043\insrsid1378858 ..., Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'b7 ph\'aci b\'b5y b\'e9 m\'c6t ph\'b6n d\'a9n h\'b9i n\'ad\'edc c\'f1a b\'e4n  vua ch\'f3a, quan l\'b9i \'ae\'b7 v\'d7 quy\'d2n l\'ee
i v\'b5 danh v\'e4ng c\'b8 nh\'a9n m\'b5 ch\'e8ng l\'b9i \'ae\'e5ng b\'b5}{\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 o. 
\par 
\par }\pard\plain \qj \fi397\li0\ri0\sa60\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\lang1024\langfe1024\noproof\insrsid1378858 
{\shp{\*\shpinst\shpleft5330\shptop-846\shpright6230\shpbottom-486\shpfhdr0\shpbxcolumn\shpbxignore\shpbypara\shpbyignore\shpwr3\shpwrk0\shpfblwtxt0\shpz21\shplid1047{\sp{\sn shapeType}{\sv 1}}{\sp{\sn fFlipH}{\sv 0}}{\sp{\sn fFlipV}{\sv 0}}
{\sp{\sn lTxid}{\sv 1310720}}{\sp{\sn dxTextLeft}{\sv 0}}{\sp{\sn dyTextTop}{\sv 0}}{\sp{\sn dxTextRight}{\sv 0}}{\sp{\sn dyTextBottom}{\sv 0}}{\sp{\sn hspNext}{\sv 1047}}{\sp{\sn fRecolorFillAsPicture}{\sv 0}}{\sp{\sn fUseShapeAnchor}{\sv 0}}
{\sp{\sn fLine}{\sv 0}}{\sp{\sn fLayoutInCell}{\sv 1}}{\shptxt \pard\plain \qr \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XXV
\par }}}{\shprslt{\*\do\dobxcolumn\dobypara\dodhgt8213\dptxbx\dptxlrtb{\dptxbxtext\pard\plain \qr \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XXV
\par }}\dpx5330\dpy-846\dpxsize900\dpysize360\dpfillfgcr255\dpfillfgcg255\dpfillfgcb255\dpfillbgcr255\dpfillbgcg255\dpfillbgcb255\dpfillpat1\dplinehollow}}}}{\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 T\'f5 m\'e9t ng\'ad\'eai y\'aau n\'ad\'edc tr
\'eb th\'b5nh ng\'ad\'eai c\'e9ng s\'b6n Vi\'d6t Nam \'ae\'c7u ti\'aan, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'b7 t\'d7m th\'cay con \'ae\'ad\'eang \'ae\'f3ng \'ae\'ben cho s\'f9 nghi\'d6p gi\'b6i ph\'e3ng d\'a9n t\'e9c ta v\'b5 c\'b8c d\'a9n t\'e9c b\'de
 \'b8p b\'f8c kh\'e1i \'b8ch n\'ab d\'dech c\'f1a ch\'f1 ngh\'dca th\'f9c d\'a9n \'ae\'d5 qu\'e8c, l\'b5 con \'ae\'ad\'eang c\'b8ch m\'b9ng v\'ab s\'b6n. \'a7\'e3 l\'b5 c\'ac s\'eb cho s\'f9 h\'d7nh th\'b5nh \'ae\'ad\'eang l\'e8i gi\'ad\'acng cao ng\'e4
n c\'ea \'ae\'e9c l\'cbp d\'a9n t\'e9c v\'b5 ch\'f1 ngh\'dca x\'b7 h\'e9i c\'f1a \'a7\'b6ng ta.   
\par }{\i\f37\fs18\expnd0\expndtw-4\lang1043\langfe1033\langnp1043\insrsid1378858 Lu\'cbn c\'ad\'acng }{\f37\fs18\expnd0\expndtw-4\lang1043\langfe1033\langnp1043\insrsid1378858 c\'f1a V.I.L\'aanin \'ae\'b7 ch\'d8 r\'e2: trong th\'eai \'ae\'b9i \'ae\'d5 qu\'e8
c ch\'f1 ngh\'dca, c\'b8ch m\'b9ng gi\'b6i ph\'e3ng d\'a9n t\'e9c l\'b5 m\'e9t b\'e9 ph\'cbn c\'f1a c\'b8ch m\'b9ng v\'ab s\'b6n v\'b5 nh\'f7ng ng\'ad\'eai c\'e9ng s\'b6n c\'e3 nhi\'d6m v\'f4 ph\'b6i gi\'f3p \'ae\'ec phong tr\'b5o gi\'b6i ph\'e3ng d\'a9
n t\'e9c. Ch\'ddnh Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'b7 ti\'d5p th\'f4, v\'cbn d\'f4ng v\'b5 ph\'b8t tri\'d3n s\'b8ng t\'b9o lu\'cbn \'aei\'d3m n\'b5y c\'f1a V.I.L\'aanin. Trong }{
\i\f37\fs18\expnd0\expndtw-4\lang1043\langfe1033\langnp1043\insrsid1378858 L\'eai ph\'b8t bi\'d3u t\'b9i \'a7\'b9i h\'e9i to\'b5n qu\'e8c l\'c7n th\'f8 XVIII \'a7\'b6ng X\'b7 h\'e9i Ph\'b8p}{
\f37\fs18\expnd0\expndtw-4\lang1043\langfe1033\langnp1043\insrsid1378858 , n\'a8m 1920, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'b7 ki\'aan quy\'d5t \'ae\'cau tranh cho t\'ad t\'ad\'ebng n\'b5y c\'f1a V.I. L\'aanin \'ae\'ad\'eec th\'f9c hi\'d6n trong th\'f9
c t\'d5. Ng\'ad\'eai \'ae\'d2 ngh\'de: "\'a7\'b6ng ph\'b6i tuy\'aan truy\'d2n ch\'f1 ngh\'dca x\'b7 h\'e9i trong t\'cat c\'b6 c\'b8c n\'ad\'edc thu\'e9c \'ae\'dea" (Tr.23). Tr\'aan c\'ac s\'eb ph\'a9n t\'ddch nh\'f7ng \'aei\'d2u ki\'d6n l\'dech s\'f6 - x
\'b7 h\'e9i c\'f1a ph\'ad\'acng \'a7\'abng, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'b7 kh\'bcng \'ae\'denh: ch\'d5 \'ae\'e9 c\'e9ng s\'b6n ho\'b5n to\'b5n c\'e3 th\'d3 th\'f9c hi\'d6n \'ae\'ad\'eec \'eb ch\'a9u }{
\f38\fs18\expnd0\expndtw-4\lang1043\langfe1033\langnp1043\insrsid1378858 \'b8}{\f37\fs18\expnd0\expndtw-4\lang1043\langfe1033\langnp1043\insrsid1378858 , v\'b5 \'aei\'d2u \'ae\'e3 c\'dfn d\'d4 h\'acn \'eb ch\'a9u \'a2u.   
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa60\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\lang1043\langfe1033\langnp1043\insrsid1378858 Trong l\'fd lu\'cbn c\'f2
ng nh\'ad trong ho\'b9t \'ae\'e9ng th\'f9c ti\'d4n, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh lu\'abn lu\'abn nh\'can m\'b9nh m\'e8i quan h\'d6 kh\'a8ng kh\'ddt gi\'f7a c\'b8ch m\'b9ng \'eb thu\'e9c \'ae\'dea v\'b5 c\'b8ch m\'b9ng \'eb "ch\'ddnh qu\'e8c". Ng\'ad
\'eai vi\'d5t: "Ch\'f1 ngh\'dca t\'ad b\'b6n l\'b5 m\'e9t con \'ae\'d8a c\'e3 m\'e9t c\'b8i v\'dfi b\'b8m v\'b5o giai c\'cap v\'ab s\'b6n \'eb ch\'ddnh qu\'e8c v\'b5 m\'e9t c\'b8i v\'dfi kh\'b8c b\'b8m v\'b5o giai c\'cap v\'ab s\'b6n \'eb c\'b8c thu\'e9c 
\'ae\'dea. N\'d5u ng\'ad\'eai ta mu\'e8n gi\'d5t con v\'cbt \'cay, ng\'ad\'eai ta ph\'b6i \'ae\'e5ng th\'eai c\'bet c\'b6 hai v\'dfi" (Tr.298). Ng\'ad\'eai k\'aau g\'e4i giai c\'cap c\'abng nh\'a9n c\'b8c n\'ad\'edc ph\'ad\'acng T\'a9y ph\'b6i \'ae\'c8y m
\'b9nh vi\'d6c \'f1ng h\'e9 cu\'e9c \'ae\'cau tranh gi\'b6i ph\'e3ng d\'a9n t\'e9c c\'f1a c\'b8c n\'ad\'edc thu\'e9c \'ae\'dea. Trong nh\'f7ng b\'b5i ph\'b8t bi\'d3u t\'b9i \'a7\'b9i h\'e9i l\'c7n th\'f8 V Qu\'e8c t\'d5 C\'e9ng s\'b6n, Ng\'ad\'eai n\'e3
i: "T\'cat c\'b6 c\'b8c \'ae\'e5ng ch\'dd \'ae\'d2u bi\'d5t r\'bbng, hi\'d6n nay n\'e4c \'ae\'e9c v\'b5 s\'f8c s\'e8ng c\'f1a con r\'ben \'ae\'e9c t\'ad b\'b6n ch\'f1 ngh\'dca \'aeang t\'cbp trung \'eb c\'b8c thu\'e9c \'ae\'dea h\'acn l\'b5 \'eb ch\'dd
nh qu\'e8c. C\'b8c thu\'e9c \'ae\'dea cung c\'cap nguy\'aan li\'d6u cho c\'b8c nh\'b5 m\'b8y; c\'b8c thu\'e9c \'ae\'dea cung c\'cap binh l\'ddnh cho qu\'a9n \'ae\'e9i c\'f1a ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c. C\'b8c thu\'e9c \'ae\'dea tr\'eb th\'b5nh n\'d2
n t\'b6ng c\'f1a l\'f9c l\'ad\'eeng ph\'b6n c\'b8ch m\'b9ng" (Tr.274). V\'d7 v\'cby, mu\'e8n \'ae\'b8nh th\'beng ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c, tr\'ad\'edc h\'d5t c\'c7n xo\'b8 b\'e1 h\'d6 th\'e8ng thu\'e9c \'ae\'dea c\'f1a n\'e3. T\'f5 \'ae\'e3, Ng
\'ad\'eai \'ae\'d2 xu\'cat lu\'cbn \'aei\'d3m: c\'b8ch m\'b9ng gi\'b6i ph\'e3ng d\'a9n t\'e9c c\'c7n ch\'f1 \'ae\'e9ng v\'b5 c\'e3 th\'d3 gi\'b5nh th\'beng l\'eei tr\'ad\'edc c\'b8ch m\'b9ng v\'ab s\'b6n \'eb "ch\'ddnh qu\'e8c" v\'b5 b\'bbng th\'beng l
\'eei \'ae\'e3, t\'b8c \'ae\'e9ng m\'b9nh m\'cf \'ae\'e8i v\'edi c\'b8ch m\'b9ng \'eb "ch\'ddnh qu\'e8c". Ng\'ad\'eai vi\'d5t: "Ng\'b5y m\'b5 h\'b5ng tr\'a8m tri\'d6u nh\'a9n d\'a9n ch\'a9u }{\f38\lang1043\langfe1033\langnp1043\insrsid1378858 \'b8}{
\lang1043\langfe1033\langnp1043\insrsid1378858  b\'de t\'b5n s\'b8t v\'b5 \'b8p b\'f8c th\'f8c t\'d8nh \'ae\'d3 g\'b9t b\'e1 s\'f9 b\'e3c l\'e9t \'ae\'aa ti\'d6n c\'f1a m\'e9t b\'e4n th\'f9c d\'a9n l\'dfng tham kh\'abng \'ae\'b8y, h\'e4 s\'cf h\'d7nh th
\'b5nh m\'e9t l\'f9c l\'ad\'eeng kh\'e6ng l\'e5, v\'b5 trong khi th\'f1 ti\'aau m\'e9t trong nh\'f7ng \'aei\'d2u ki\'d6n t\'e5n t\'b9i c\'f1a ch\'f1 ngh\'dca t\'ad b\'b6n l\'b5 ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c, h\'e4 c\'e3 th\'d3 gi\'f3p \'ae\'ec nh\'f7
ng ng\'ad\'eai anh em m\'d7nh \'eb ph\'ad\'acng T\'a9y trong nhi\'d6m v\'f4 gi\'b6i ph\'e3ng ho\'b5n to\'b5n" (Tr.36).   
\par }\pard\plain \qj \fi397\li0\ri0\sa60\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\lang1024\langfe1024\noproof\insrsid1378858 
{\shp{\*\shpinst\shpleft-27\shptop-3410\shpright873\shpbottom-3050\shpfhdr0\shpbxcolumn\shpbxignore\shpbypara\shpbyignore\shpwr3\shpwrk0\shpfblwtxt0\shpz23\shplid1049{\sp{\sn shapeType}{\sv 1}}{\sp{\sn fFlipH}{\sv 0}}{\sp{\sn fFlipV}{\sv 0}}
{\sp{\sn lTxid}{\sv 1376256}}{\sp{\sn dxTextLeft}{\sv 0}}{\sp{\sn dyTextTop}{\sv 0}}{\sp{\sn dxTextRight}{\sv 0}}{\sp{\sn dyTextBottom}{\sv 0}}{\sp{\sn hspNext}{\sv 1049}}{\sp{\sn fRecolorFillAsPicture}{\sv 0}}{\sp{\sn fUseShapeAnchor}{\sv 0}}
{\sp{\sn fLine}{\sv 0}}{\sp{\sn fLayoutInCell}{\sv 1}}{\shptxt \pard\plain \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XXVI
\par }\pard \qr \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 
\par }}}{\shprslt{\*\do\dobxcolumn\dobypara\dodhgt8215\dptxbx\dptxlrtb{\dptxbxtext\pard\plain \ql \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XXVI
\par }\pard \qr \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 
\par }}\dpx-27\dpy-3410\dpxsize900\dpysize360\dpfillfgcr255\dpfillfgcg255\dpfillfgcb255\dpfillbgcr255\dpfillbgcg255\dpfillbgcb255\dpfillpat1\dplinehollow}}}}{\f37\fs18\lang1043\langfe1033\langnp1043\insrsid1378858 Tin t\'ad\'ebng \'eb ti\'d2n \'ae\'e5 c\'f1a c
\'b8c d\'a9n t\'e9c b\'de \'b8p b\'f8c, trong nhi\'d2u b\'b5i vi\'d5t c\'f1a m\'d7nh, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh \'ae\'b7 ch\'d8 r\'e2 ti\'d2m l\'f9c c\'b8ch m\'b9ng v\'dc \'ae\'b9i c\'f1a h\'b5ng tr\'a8m tri\'d6u ng\'ad\'eai \'eb c\'b8c n\'ad\'ed
c thu\'e9c \'ae\'dea v\'b5 ph\'f4 thu\'e9c \'aeang \'ae\'ad\'eec th\'f8c t\'d8nh. }{\f37\fs18\lang1053\langfe1033\langnp1053\insrsid1378858 Ch\'a9u }{\f38\fs18\lang1053\langfe1033\langnp1053\insrsid1378858 \'b8}{
\f37\fs18\lang1053\langfe1033\langnp1053\insrsid1378858  tr\'ce trung \'aeang v\'ad\'acn m\'d7nh, ch\'a9u Phi \'aeen \'aeang qu\'cbt kh\'ebi... L\'ad\'eci l\'aa, \'ae\'b9i b\'b8c, ch\'ddnh s\'b8ch ngu d\'a9n c\'f1a ch\'f1 ngh\'dca t\'ad b\'b6n kh\'abng th
\'d3 \'ae\'cc b\'d1p \'fd ch\'dd chi\'d5n \'ae\'cau v\'b5 s\'f8c s\'e8ng m\'b7nh li\'d6t c\'f1a nh\'a9n d\'a9n c\'b8c d\'a9n t\'e9c thu\'e9c \'ae\'dea. Ng\'ad\'eai vi\'d5t: "\'a7\'bbng sau s\'f9 ph\'f4c t\'efng ti\'aau c\'f9c, ng\'ad\'eai \'a7\'abng D\'ad
\'acng gi\'cau m\'e9t c\'b8i g\'d7 \'aeang s\'abi s\'f4c, \'aeang g\'b5o th\'d0t v\'b5 s\'cf b\'efng n\'e6 m\'e9t c\'b8ch gh\'aa g\'edm, khi th\'eai c\'ac \'ae\'d5n. B\'e9 ph\'cbn \'adu t\'f3 c\'e3 nhi\'d6m v\'f4 ph\'b6i th\'f3c \'ae\'c8y cho th\'eai c
\'ac \'ae\'e3 mau \'ae\'d5n.   
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa60\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\lang1053\langfe1033\langnp1053\insrsid1378858 S\'f9 t\'b5n b\'b9o c\'f1
a ch\'f1 ngh\'dca t\'ad b\'b6n \'ae\'b7 chu\'c8n b\'de \'ae\'cat r\'e5i: Ch\'f1 ngh\'dca x\'b7 h\'e9i ch\'d8 c\'dfn ph\'b6i l\'b5m c\'b8i vi\'d6c l\'b5 gieo h\'b9t gi\'e8ng c\'f1a c\'abng cu\'e9c gi\'b6i ph\'e3ng n\'f7a th\'abi" (Tr.28).   
\par }\pard\plain \s18\qj \li0\ri0\sa60\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\fs18\lang1053\langfe1033\langnp1053\insrsid1378858 T\'f5 nh\'cbn th\'f8c: ch\'f1
 ngh\'dca th\'f9c d\'a9n \'ae\'d5 qu\'e8c l\'b5 k\'ce th\'ef chung c\'f1a c\'b8c d\'a9n t\'e9c b\'de \'b8p b\'f8c, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh lu\'abn lu\'abn ch\'a8m lo x\'a9y d\'f9ng kh\'e8i \'aeo\'b5n k\'d5t chi\'d5n \'ae\'cau gi\'f7a c\'b8c d\'a9
n t\'e9c b\'de \'aeo\'b9 \'ae\'b5y, \'aeau kh\'e6. Ng\'ad\'eai vi\'d5t: "D\'ef m\'b5u da c\'e3 kh\'b8c nhau, tr\'aan \'ae\'eai n\'b5y ch\'d8 c\'e3 hai gi\'e8ng ng\'ad\'eai: gi\'e8ng ng\'ad\'eai b\'e3c l\'e9t v\'b5 gi\'e8ng ng\'ad\'eai b\'de b\'e3c l\'e9
t. }{\fs18\insrsid1378858 M\'b5 c\'f2ng ch\'d8 c\'e3 m\'e9t m\'e8i t\'d7nh h\'f7u \'b8i l\'b5 th\'cbt m\'b5 th\'abi: t\'d7nh h\'f7u \'b8i v\'ab s\'b6n" (Tr.266).
\par \'a7\'f8ng v\'f7ng tr\'aan quan \'aei\'d3m c\'f1a ch\'f1 ngh\'dca M\'b8c - L\'aanin, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh ki\'aan quy\'d5t \'ae\'cau tranh ch\'e8ng l\'b9i nh\'f7ng bi\'d3u hi\'d6n c\'f1a t\'ad t\'ad\'ebng c\'ac h\'e9i, c\'b6i l\'ad\'acng, t
\'ad t\'ad\'ebng d\'a9n t\'e9c h\'d1p h\'dfi, nh\'f7ng nh\'cbn th\'f8c ch\'ada \'ae\'f3ng \'ae\'ben c\'f1a m\'e9t s\'e8 \'ae\'b6ng c\'e9ng s\'b6n ch\'a9u \'a2u trong v\'can \'ae\'d2 thu\'e9c \'ae\'dea. T\'b9i \'a7\'b9i h\'e9i l\'c7n th\'f8 V Qu\'e8c t\'d5
 C\'e9ng s\'b6n, Ng\'ad\'eai n\'e3i: "\'a7\'d2 ra nh\'f7ng lu\'cbn c\'ad\'acng d\'b5i d\'bbng d\'c6c            
\par }\pard\plain \s19\qj \li0\ri0\sa60\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\lang1024\langfe1024\noproof\insrsid1378858 
{\shp{\*\shpinst\shpleft5330\shptop-834\shpright6230\shpbottom-474\shpfhdr0\shpbxcolumn\shpbxignore\shpbypara\shpbyignore\shpwr3\shpwrk0\shpfblwtxt0\shpz22\shplid1048{\sp{\sn shapeType}{\sv 1}}{\sp{\sn fFlipH}{\sv 0}}{\sp{\sn fFlipV}{\sv 0}}
{\sp{\sn lTxid}{\sv 1441792}}{\sp{\sn dxTextLeft}{\sv 0}}{\sp{\sn dyTextTop}{\sv 0}}{\sp{\sn dxTextRight}{\sv 0}}{\sp{\sn dyTextBottom}{\sv 0}}{\sp{\sn hspNext}{\sv 1048}}{\sp{\sn fRecolorFillAsPicture}{\sv 0}}{\sp{\sn fUseShapeAnchor}{\sv 0}}
{\sp{\sn fLine}{\sv 0}}{\sp{\sn fLayoutInCell}{\sv 1}}{\shptxt \pard\plain \qr \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XXVII
\par 
\par }}}{\shprslt{\*\do\dobxcolumn\dobypara\dodhgt8214\dptxbx\dptxlrtb{\dptxbxtext\pard\plain \qr \li0\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 XXVII
\par 
\par }}\dpx5330\dpy-834\dpxsize900\dpysize360\dpfillfgcr255\dpfillfgcg255\dpfillfgcb255\dpfillbgcr255\dpfillbgcg255\dpfillbgcb255\dpfillpat1\dplinehollow}}}}{\insrsid1378858 v\'b5 th\'abng qua nh\'f7ng ngh\'de quy\'d5t r\'cat k\'aau \'ae\'d3 sau \'a7\'b9i h
\'e9i \'ae\'ada v\'b5o vi\'d6n b\'b6o t\'b5ng nh\'ad t\'f5 tr\'ad\'edc v\'c9n l\'b5m th\'d7 ch\'ada \'ae\'f1. Ch\'f3ng ta c\'c7n c\'e3 bi\'d6n ph\'b8p c\'f4 th\'d3" (Tr.281). Ng\'ad\'eai \'ae\'b7 ki\'d5n ngh\'de nh\'f7ng vi\'d6c l\'b5m thi\'d5t th\'f9c v
\'b5 y\'aau c\'c7u Qu\'e8c t\'d5 C\'e9ng s\'b6n \'ae\'c8y m\'b9nh ho\'b9t \'ae\'e9ng gi\'f3p \'ae\'ec phong tr\'b5o gi\'b6i ph\'e3ng d\'a9n t\'e9c.   
\par }\pard\plain \s16\qj \fi397\li0\ri0\sa60\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd0\expndtw4\insrsid1378858 B\'b6n th\'a9n Ng\'ad\'eai \'ae\'b7 t\'dd
ch c\'f9c truy\'d2n b\'b8 ch\'f1 ngh\'dca M\'b8c - L\'aanin, tuy\'aan truy\'d2n ch\'f1 ngh\'dca x\'b7 h\'e9i khoa h\'e4c v\'b5o c\'b8c n\'ad\'edc thu\'e9c \'ae\'dea, h\'ad\'edng qu\'c7n ch\'f3ng v\'d2 n\'ad\'edc Nga X\'abvi\'d5t t\'ad\'aci \'ae\'d1p, v
\'d2 con \'ae\'ad\'eang c\'b8ch m\'b9ng tri\'d6t \'ae\'d3. Ng\'ad\'eai kh\'bcng \'ae\'denh c\'b8ch m\'b9ng \'eb c\'b8c n\'ad\'edc thu\'e9c \'ae\'dea v\'b5 ph\'f4 thu\'e9c ph\'b6i \'aei theo con \'ae\'ad\'eang c\'f1a V.I.L\'aanin v\'b5 C\'b8ch m\'b9ng Th
\'b8ng M\'ad\'eai. Ng\'ad\'eai c\'f2ng d\'b5nh nh\'f7ng l\'eai tr\'a9n tr\'e4ng vi\'d5t v\'d2 V.I.L\'aanin, l\'b7nh t\'f4 v\'dc \'ae\'b9i c\'f1a giai c\'cap v\'ab s\'b6n v\'b5 c\'b8c d\'a9n t\'e9c b\'de \'b8p b\'f8c tr\'aan to\'b5n th\'d5 gi\'edi: "Khi c
\'dfn s\'e8ng, Ng\'ad\'eai l\'b5 ng\'ad\'eai cha, th\'c7y h\'e4c, \'ae\'e5ng ch\'dd v\'b5 c\'e8 v\'can c\'f1a ch\'f3ng ta. Ng\'b5y nay, Ng\'ad\'eai l\'b5 ng\'abi sao s\'b8ng ch\'d8 \'ae\'ad\'eang cho ch\'f3ng ta \'aei t\'edi cu\'e9c c\'b8ch m\'b9ng x\'b7
 h\'e9i" (Tr.237).   
\par }\pard\plain \qj \fi397\li0\ri0\sa60\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs18\insrsid1378858 Qua m\'e9t lo\'b9t b\'b5i vi\'d5t trong t\'cbp 1, Ch\'f1 t
\'dech H\'e5 Ch\'dd Minh \'ae\'b7 s\'edm kh\'bcng \'ae\'denh vai tr\'df quan tr\'e4ng c\'f1a giai c\'cap c\'abng nh\'a9n trong \'ae\'cau tranh c\'b8ch m\'b9ng. Ng\'ad\'eai ch\'d8 r\'e2: trong c\'b8c thu\'e9c \'ae\'dea, giai c\'cap c\'abng nh\'a9n \'ae\'b7
 b\'bet \'ae\'c7u hi\'d3u th\'d5 n\'b5o l\'b5 \'ae\'cau tranh giai c\'cap. Ph\'b6i l\'b5m cho c\'abng nh\'a9n da \'aeen v\'b5 da v\'b5ng hi\'d3u r\'bbng k\'ce th\'ef duy nh\'cat c\'f1a h\'e4 ch\'ddnh l\'b5 c\'b8i ch\'d5 \'ae\'e9 n\'b5y, m\'e9t ch\'d5 \'ae
\'e9 n\'ab l\'d6 tinh vi h\'acn ch\'d5 \'ae\'e9 c\'f2, n\'c6ng n\'d2 v\'b5 v\'ab nh\'a9n \'ae\'b9o h\'acn. Trong b\'b5i }{\i\f37\fs18\insrsid1378858 Phong tr\'b5o c\'abng nh\'a9n \'eb Th\'e6 Nh\'dc K\'fa}{\f37\fs18\insrsid1378858 , Ng\'ad\'eai n\'aau r
\'e2 giai c\'cap c\'abng nh\'a9n \'ae\'b7 \'ae\'e3ng g\'e3p nhi\'d2u v\'b5o cu\'e9c \'ae\'cau tranh gi\'b5nh \'ae\'e9c l\'cbp d\'a9n t\'e9c, song th\'b5nh qu\'b6 c\'b8ch m\'b9ng l\'b9i b\'de giai c\'cap t\'ad s\'b6n chi\'d5m \'aeo\'b9t, giai c\'cap c\'ab
ng nh\'a9n b\'bet bu\'e9c ti\'d5n h\'b5nh m\'e9t cu\'e9c \'ae\'cau tranh kh\'b8c: \'ae\'cau tranh giai c\'cap. Qua \'ae\'e3, Ch\'f1 t\'dech H\'e5 Ch\'dd Minh mu\'e8n ch\'d8 ra m\'e8i quan h\'d6 kh\'a8ng kh\'ddt gi\'f7a \'ae\'cau tranh d\'a9n t\'e9c v\'b5 
\'ae\'cau tranh giai c\'cap trong c\'b8ch m\'b9ng \'eb thu\'e9c \'ae\'dea, y\'aau c\'c7u giai c\'cap c\'abng nh\'a9n ph\'b6i n\'bem l\'cay ng\'e4n c\'ea d\'a9n t\'e9c v\'b5 ch\'f1 ngh\'dca x\'b7 h\'e9i, ph\'b6i c\'f1ng c\'e8 kh\'e8i li\'aan minh c\'abng n
\'abng - \'ae\'e9i qu\'a9n ch\'f1 l\'f9c c\'f1a c\'b8ch m\'b9ng, n\'d2n t\'b6ng c\'f1a m\'c6t tr\'cbn \'aeo\'b5n k\'d5t to\'b5n d\'a9n.   
\par Ch\'f1 t\'dech H\'e5 Ch\'dd Minh c\'f2ng \'ae\'b7 \'ae\'f8ng tr\'aan quan \'aei\'d3m c\'f1a ch\'f1 ngh\'dca M\'b8c-L\'aanin nh\'d7n nh\'cbn \'ae\'f3ng \'ae\'ben v\'can \'ae\'d2 n\'abng d\'a9n trong c\'b8ch m\'b9ng gi\'b6i ph\'e3ng d\'a9n t\'e9c.   
\par }\pard \qj \fi397\li0\ri0\sa60\sl-276\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs18\insrsid1378858 Ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c b\'e3c l\'e9t thu\'e9c \'ae\'dea ch\'f1 y\'d5u l\'b5 b\'e3c l\'e9t n\'abng d\'a9n. Ng
\'ad\'eai vi\'d5t: "Ng\'ad\'eai An Nam n\'e3i chung, ph\'b6i \'cc c\'e6 ra m\'b5 ch\'deu nh\'f7ng c\'abng \'acn b\'b6o h\'e9 c\'f1a n\'ad\'edc Ph\'b8p. Ng\'ad\'eai n\'abng d\'a9n An Nam n\'e3i ri\'aang, l\'b9i c\'b5ng ph\'b6i \'cc c\'e6 ra m\'b5 ch\'deu s
\'f9 b\'b6o h\'e9 \'cay m\'e9t c\'b8ch th\'b6m h\'b9i h\'acn: l\'b5 ng\'ad\'eai An Nam, h\'e4 b\'de \'b8p b\'f8c; l\'b5 ng\'ad\'eai n\'abng d\'a9n, h\'e4 b\'de ng\'ad\'eai ta \'a8n c\'bep, c\'ad\'edp b\'e3c, t\'ad\'edc \'aeo\'b9t, l\'b5m ph\'b8 s\'b6
n" (Tr.227). Ph\'b6i s\'e8ng trong ho\'b5n c\'b6nh c\'efng c\'f9c nh\'ad v\'cby n\'aan ng\'ad\'eai n\'abng d\'a9n n\'e3i chung v\'b5 ng\'ad\'eai n\'abng d\'a9n Vi\'d6t Nam n\'e3i ri\'aang ch\'bcng nh\'f7ng c\'e3 \'fd th\'f8c giai c\'cap r\'e2 r\'d6t m\'b5
 c\'dfn c\'e3 \'fd th\'f8c d\'a9n t\'e9c r\'cat m\'b9nh m\'cf. Trong c\'b8c b\'b5i }{\i\f37\fs18\insrsid1378858 T\'d7nh c\'b6nh n\'abng d\'a9n An Nam, T\'d7nh c\'b6nh n\'abng d\'a9n Trung Qu\'e8c, N\'abng d\'a9n B\'bec Phi}{\f37\fs18\insrsid1378858 ... v
\'b5 nh\'f7ng b\'b5i ph\'b8t bi\'d3u t\'b9i \'a7\'b9i h\'e9i V Qu\'e8c t\'d5 C\'e9ng s\'b6n, Ng\'ad\'eai \'ae\'b7 kh\'b8i qu\'b8t v\'de tr\'dd v\'b5 l\'f9c l\'ad\'eeng to l\'edn c\'f1a n\'abng d\'a9n trong c\'b8ch m\'b9ng gi\'b6i ph\'e3ng d\'a9n t\'e9c v
\'b5 ch\'d8 r\'e2 \'eb c\'b8c n\'ad\'edc thu\'e9c \'ae\'dea, n\'abng d\'a9n nhi\'d2u l\'c7n n\'e6i d\'cby ch\'e8ng ch\'f1 ngh\'dca th\'f9c d\'a9n, nh\'adng \'ae\'d2u th\'cat b\'b9i, v\'d7 thi\'d5u s\'f9 l\'b7nh \'ae\'b9o v\'b5 t\'e6 ch\'f8c. Ng\'ad\'ea
i vi\'d5t: "Qu\'e8c t\'d5 C\'e9ng s\'b6n c\'c7n ph\'b6i gi\'f3p \'ae\'ec h\'e4 t\'e6 ch\'f8c l\'b9i, c\'c7n ph\'b6i cung c\'cap c\'b8n b\'e9 l\'b7nh \'ae\'b9o cho h\'e4 v\'b5 ch\'d8 cho h\'e4 con \'ae\'ad\'eang \'aei t\'edi c\'b8ch m\'b9ng v\'b5 gi\'b6
i ph\'e3ng" (Tr.289). V\'d7 v\'cby, gi\'b6i ph\'e3ng d\'a9n t\'e9c ph\'b6i g\'ben li\'d2n v\'edi gi\'b6i ph\'e3ng n\'abng d\'a9n, \'aeem l\'b9i ru\'e9ng \'ae\'cat cho n\'abng d\'a9n.   
\par }\pard \qj \fi397\li0\ri0\sa60\sl-284\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\lang1024\langfe1024\noproof\insrsid1378858 
