\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~V\'d7 n\'e3i \'ae\'d5n \'ae\'cau tranh giai c\'cap v\'b5
 quy\'d2n b\'d7nh \'ae\'bcng gi\'f7a con ng\'ad\'eai m\'b5 \'ae\'e5ng ch\'dd Lud\'abng c\'f1a ch\'f3ng ta \'ae\'b7 b\'de k\'d5t \'b8n l\'b5 \'ae\'b7 tuy\'aan truy\'d2n th\'ef gh\'d0t ch\'f1ng t\'e9c. V\'cby ta h\'b7y xem t\'d7nh y\'aau th\'ad\'acng gi\'f7
a c\'b8c ch\'f1ng t\'e9c \'ae\'b7 \'ae\'ad\'eec quan ni\'d6m v\'b5 th\'f9c hi\'d6n \'eb \'a7\'abng D\'ad\'acng nh\'ad th\'d5 n\'b5o trong th\'eai gian g\'c7n \'ae\'a9y.
\par H\'abm nay, ch\'f3ng ta s\'cf kh\'abng n\'e3i \'ae\'d5n t\'e9i \'b8c c\'f1a ch\'ddnh quy\'d2n th\'f9c d\'a9n l\'b5 d\'efng r\'ad\'eeu v\'b5 thu\'e8c phi\'d6n \'ae\'d3 \'ae\'c7u \'ae\'e9c qu\'c7n ch\'f3ng v\'b5 l\'b5m cho h\'e4 ngu mu\'e9i \'aei. Vi\'d6c 
\'cay c\'b8c \'ae\'e5ng ch\'dd ch\'f3ng ta trong \'ae\'b6ng \'aeo\'b5n ngh\'de s\'dc t\'cat s\'cf c\'e3 ng\'b5y b\'b5n \'ae\'d5n.
\par M\'e4i ng\'ad\'eai \'ae\'d2u bi\'d5t r\'e2 nh\'f7ng th\'b5nh t\'ddch l\'edn lao c\'f1a t\'aan quan cai tr\'de s\'b8t nh\'a9n \'a7\'b8cl\'ac. Tuy nhi\'aan \'ae\'a9u c\'e3 ph\'b6i ch\'d8 m\'d7nh h\'ben m\'edi c\'e3 nh\'f7ng th\'f1 \'aeo\'b9n t\'b5n \'b8c 
\'ae\'e8i v\'edi ng\'ad\'eai b\'b6n x\'f8 nh\'ad th\'d5.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 M\'e9t g\'b7 Pu\'e8cxinh\'abng n\'b5o \'ae\'e3, \'ae\'b7 h
\'efng h\'e6 nh\'b6y ra \'ae\'b8nh m\'e9t ng\'ad\'eai An Nam ch\'d8 v\'d7 ng\'ad\'eai n\'b5y d\'b8m t\'df m\'df v\'b5 c\'b6 gan nh\'d7n ng\'abi nh\'b5 c\'f1a ng\'ad\'eai \'a2u trong m\'cay gi\'a9y \'ae\'e5ng h\'e5. H\'ben \'ae\'b8nh anh v\'b5 cu\'e8i c
\'efng gi\'d5t anh b\'bbng m\'e9t ph\'b8t s\'f3ng l\'f4c b\'ben v\'b5o \'ae\'c7u.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 M\'e9t nh\'a9n vi\'aan s\'eb ho\'b6 xa, \'ae\'b7 d\'ef
ng roi m\'a9y \'ae\'b8nh m\'e9t ng\'ad\'eai l\'fd tr\'ad\'ebng B\'bec K\'fa.
\par \'a4ng B\'d0c \'ae\'cam v\'ec s\'e4 ng\'ad\'eai l\'b8i xe cho \'abng ta.
\par \'a4ng th\'c7u kho\'b8n Br\'d0t, sau khi cho ch\'e3 c\'ben m\'e9t ng\'ad\'eai An Nam \'ae\'b7 tr\'e3i tay ng\'ad\'eai n\'b5y l\'b9i, \'ae\'b8 cho \'ae\'d5n ch\'d5t.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 \'a4ng \'a7\'d0pphi, ch\'f1 s\'eb thu\'d5 \'ae\'b7 gi\'d5t ch\'d5t ng\'ad\'eai \'ae\'c7y t\'ed An Nam c\'f1a \'abng ta b
\'bbng m\'e9t c\'b8i \'ae\'b8 h\'d5t s\'f8c m\'b9nh v\'b5o m\'b9ng m\'ec.
\par \'a4ng H\'a8ngri, th\'ee m\'b8y \'eb H\'b6i Ph\'dfng, nghe ngo\'b5i ph\'e8 c\'e3 ti\'d5ng \'e5n \'b5o; c\'f6a nh\'b5 \'abng v\'f5a m\'eb th\'d7 m\'e9t ng\'ad\'eai \'ae\'b5n b\'b5 An Nam ch\'b9y x\'e9c v\'b5o, sau l\'adng c\'e3 m\'e9t ng\'ad\'eai \'ae\'b5
n \'abng \'aeu\'e6i theo. H\'a8ngri t\'ad\'ebng l\'b5 m\'e9t ng\'ad\'eai b\'b6n x\'f8 \'aeang \'aeu\'e6i m\'e9t }{\i\f37\fs20\insrsid1378858 Con g\'b8i}{\cs17\i\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain 
\s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) Hai ch\'f7 }{\i\insrsid1378858 Con g\'b8i}{\insrsid1378858 
 trong nguy\'aan b\'b6n vi\'d5t b\'bbng ch\'f7 Vi\'d6t. Trong th\'eai k\'fa Ph\'b8p th\'e8ng tr\'de n\'ad\'edc ta, ng\'ad\'eai Ph\'b8p th\'ad\'eang nu\'abi nh\'f7ng thi\'d5u n\'f7 Vi\'d6t, v\'f5a l\'b5m ng\'ad\'eai h\'c7u h\'b9, may v\'b8, v\'f5a l\'b5
m tr\'df ch\'aci, ch\'f3ng g\'e4i h\'e4 l\'b5 }{\i\insrsid1378858 Con g\'b8i}{\insrsid1378858  .}})}{\f37\fs20\insrsid1378858 , li\'d2n v\'ed l\'cay kh\'c8u s\'f3ng s\'a8n n\'e6 m\'e9t ph\'b8t. Ng\'ad\'eai \'ae\'b5n \'abng ng\'b7 v\'cbt xu\'e8ng ch\'d5
t ngay. \'a7\'e3 l\'b5 m\'e9t ng\'ad\'eai \'a2u. H\'e1i th\'d7 H\'a8ngri tr\'b6 l\'eai: "T\'abi t\'ad\'ebng \'ae\'a9y l\'b5 m\'e9t th\'bbng b\'b6n x\'f8".
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\expnd0\expndtw-4\insrsid1378858 M\'e9t ng\'ad\'eai Ph\'b8p bu\'e9c ng\'f9
a c\'f1a m\'d7nh v\'b5o m\'e9t c\'b8i chu\'e5ng trong \'ae\'e3 \'ae\'b7 c\'e3 s\'bdn con ng\'f9a c\'b8i c\'f1a m\'e9t ng\'ad\'eai b\'b6n x\'f8. Con ng\'f9a \'ae\'f9c nh\'b6y ch\'e5m l\'aan, l\'b5m cho ng\'ad\'eai Ph\'b8p t\'f8c \'aei\'aan ru\'e9t. \'a4
ng ta \'ae\'b8nh ng\'ad\'eai b\'b6n x\'f8 h\'e9c c\'b6 m\'b8u m\'e5m, m\'b8u m\'f2i, r\'e5i \'aeem tr\'e3i l\'b9i treo l\'aan c\'c7u thang.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 M\'e9t nh\'b5 truy\'d2n gi\'b8o (V\'a9ng! m\'e9t v\'de
 linh m\'f4c nh\'a9n t\'f5) nghi m\'e9t h\'e4c sinh tr\'ad\'eang th\'c7y d\'dfng ng\'ad\'eai b\'b6n x\'f8 \'a8n c\'bep c\'f1a m\'d7nh 1.000 \'ae\'e5ng, \'abng ta tr\'e3i ng\'ad\'eai h\'e4c sinh n\'b5y l\'b9i, treo l\'aan x\'b5 nh\'b5, tra kh\'b6o. Ng\'ad
\'eai h\'e4c sinh \'ae\'b8ng th\'ad\'acng \'cay ng\'cat \'aei. H\'e4 h\'b9 anh xu\'e8ng. Khi anh h\'e5i t\'d8nh, h\'e4 l\'b9i treo l\'aan tra kh\'b6o. Anh \'ae\'b7 g\'c7n ch\'d5t. C\'e3 l\'cf h\'abm nay th\'d7 ch\'d5t r\'e5i.
\par V\'a9n v\'a9n v\'b5 v\'a9n v\'a9n.
\par To\'b5 \'b8n c\'e3 tr\'f5ng ph\'b9t nh\'f7ng t\'aan \'ae\'e3, nh\'f7ng con ng\'ad\'eai \'aei khai ho\'b8 \'ae\'e3 hay kh\'abng ?
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-270\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'e3 t\'aan th\'d7 tr\'beng \'b8n, c\'e3 t\'aan th\'d7 kh
\'abng ai \'ae\'f4ng \'ae\'d5n l\'abng ch\'a9n. S\'f9 t\'d7nh l\'b5 nh\'ad v\'cby. }{\f38\insrsid1378858 \'ca}{\insrsid1378858 y th\'d5 m\'b5 b\'a9y gi\'ea th\'d7:
\par - B\'de c\'b8o Lud\'abng, \'ae\'d5n l\'ad\'eet anh n\'e3i \'aei!
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb120\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~Nguy\'d4n \'b8i Qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 Le Paria,}{\insrsid1378858  s\'e8 4,
\line }{\fs20\insrsid1378858 ng\'b5y 1-7-1922.
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 CON NG\'a6\'eaI BI\'d5T M\'efI HUN KH\'e3I
\par }\pard\plain \qj \li1559\ri0\sb120\sa200\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin1559\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\b\f37\fs20\insrsid1378858 Xin t\'c6ng Nah\'abng}{
\cs17\b\f37\fs20\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) Nah\'ab
ng l\'b5 m\'e9t ng\'ad\'eai l\'ddnh thu\'e9c \'ae\'dea \'ae\'b7 b\'de m\'e9t t\'aan quan ba Ph\'b8p gi\'d5t h\'b9i n\'a8m 1922 \'eb mi\'d2n \'ae\'abng Mar\'e8c.
\par 2) Ha\'f3txa l\'b5 t\'aan m\'e9t t\'e9c ng\'ad\'eai \'eb T\'a9y Phi. }{\f38\insrsid1378858 \'eb}{\insrsid1378858  \'ae\'a9y, t\'b8c gi\'b6 l\'cay t\'aan \'ae\'e3 \'ae\'c6t cho m\'e9t th\'b5nh ph\'e8 t\'ad\'ebng t\'ad\'eeng c\'f1a ch\'a9u Phi \'ae\'e9c l
\'cbp v\'b5 th\'e8ng nh\'cat t\'ad\'acng lai.}})}{\b\f37\fs20\insrsid1378858 , ng\'ad\'eai \'ae\'b7 b\'de qu\'a9n phi\'d6t th\'f9c d\'a9n \'b8m h\'b9i, b\'b5i k\'fd n\'b5y.
\par }\pard \qj \fi425\li1560\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin1560\itap0 {\i\f37\fs20\insrsid1378858 "Ch\'ddnh cu\'e9c chinh ph\'f4c h\'d6 th\'e8ng thu\'e9c \'ae\'dea \'ae\'b7 r\'ccn luy\'d6n t\'b5i n\'a8ng chi
\'d5n \'ae\'cau c\'f1a s\'e8 \'ae\'abng nh\'f7ng nh\'b5 ch\'d8 huy qu\'a9n s\'f9 l\'edn c\'f1a ta, nh\'f7ng con ng\'ad\'eai \'ae\'b7 \'ae\'ada ta \'ae\'d5n chi\'d5n th\'beng, \'ae\'b7 \'ae\'ad\'eec d\'ad lu\'cbn Ph\'b8p ca ng\'eei vinh quang v\'b5 chi\'d5
n c\'abng ngay khi mang l\'b8 c\'ea n\'ad\'edc ta \'ae\'d5n d\'ad\'edi nh\'f7ng b\'c7u tr\'eai ch\'a9u Phi hay ch\'a9u }{\i\f38\fs20\insrsid1378858 \'b8}{\i\f37\fs20\insrsid1378858 ".
\par }\pard \qc \li1559\ri0\sb240\sa240\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin1559\itap0 {\f37\fs20\insrsid1378858 Anbe Xar\'ab\line B\'e9 tr\'ad\'ebng B\'e9 Thu\'e9c \'ae\'dea
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Ha\'f3txa}{\f37\fs20\super\insrsid1378858 2)}{\f37\fs20\insrsid1378858 , th\'b8ng 1 n\'a8m 1998.
\par Th\'b5nh ph\'e8 Ha\'f3txa c\'ea x\'dd t\'adng b\'f5ng. T\'ad\'ebng \'ae\'a9u nh\'ad m\'e9t v\'de ch\'f3a xu\'a9n \'ae\'b7 g\'e2 c\'a9y \'ae\'f2a th\'c7n l\'aan g\'e7 v\'b8n kh\'ab kh\'e8c \'eb c\'b8c bao l\'acn v\'b5 c}{
\f37\fs20\expnd0\expndtw-2\insrsid1378858 \'b8c c\'f6a s\'e6, l\'b5m m\'e4c ra mu\'abn v\'b5n t\'cam l\'b8 \'ae\'e1 ph\'cap ph\'edi y\'aau ki\'d2u tr\'ad\'edc gi\'e3. \'a7\'a9y l\'b5 l\'d4 k\'fb ni\'d6m l\'c7n th\'f8 n\'a8m m\'ad\'aci ng\'b5y th\'b5nh l
\'cbp C\'e9ng ho\'b5 li\'aan hi\'d6p Phi. Ch\'ada bao gi\'ea d\'a9n ch\'f3ng l\'b9i tham gia v\'edi m\'f8c \'ae\'e9 \'cay nh\'f7ng h\'e9i h\'cc lo\'b9i n\'b5y. T\'f5 s\'b8ng s\'edm, c\'b8c \'ae\'ad\'eang ph\'e8, c\'b8c qu\'b6ng tr\'ad\'eang y nh\'ad m\'e9
t d\'dfng s\'abng ng\'ad\'eai. T\'f5ng \'aeo\'b5n h\'e4c sinh, gi\'ad\'acng c\'ea \'aei \'ae\'c7u, v\'f5a di\'d4u qua c\'b8c ph\'e8 v\'f5a h\'b8t }{\i\f37\fs20\expnd0\expndtw-2\insrsid1378858 Qu\'e8c t\'d5 ca}{\f37\fs20\expnd0\expndtw-2\insrsid1378858 , 
\'ae\'ad\'eec d\'a9n ch\'f3ng v\'e7 tay hoan ngh\'aanh. Tr\'aan qu\'b6ng tr\'ad\'eang X\'abvi\'d5t, m\'e9t c\'f4 gi\'b5 h\'ab h\'b5o \'ae\'b8m \'ae\'abng. \'a7\'e3 l\'b5 c\'e8 Kimeng\'ab, m\'d6nh danh l\'b5 Con ng\'ad\'eai bi\'d5t m\'efi hun kh\'e3i.}{
\f37\fs20\insrsid1378858 
\par }\pard\plain \s15\qj \fi397\li0\ri0\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 C\'f4 Kimeng\'ab, tu\'e6i \'ae\'b7 ch\'ddn m\'ad\'aci, l\'b5 m
\'e9t c\'f9u chi\'d5n s\'dc c\'f1a qu\'a9n \'ae\'e9i c\'b8ch m\'b9ng, m\'e9t trong nh\'f7ng ng\'ad\'eai s\'b8ng l\'cbp C\'e9ng ho\'b5 da \'aeen. \'a7\'ad\'eec ph\'f3 b\'c8m m\'e9t tr\'dd th\'abng minh \'ae\'c6c bi\'d6t s\'bec s\'b6o, l\'b9i am hi\'d3u t
\'ad\'eang t\'cbn m\'e4i s\'f9 ki\'d6n ch\'ddnh tr\'de v\'b5 x\'b7 h\'e9i c\'f1a th\'eai \'ae\'b9i, c\'f4 Kimeng\'ab kh\'abng nh\'f7ng \'ae\'b7 ra s\'f8c th\'f8c t\'d8nh anh em c\'efng m\'b5u da ra kh\'e1i gi\'cac ng\'f1 m\'aa say c\'f1a con ng\'ad\'eai n
\'ab l\'d6, m\'b5 c\'dfn c\'e8 g\'beng ph\'b8 tan m\'e4i th\'b5nh ki\'d5n d\'a9n t\'e9c v\'b5 ch\'f1ng t\'e9c, t\'cbp h\'eep nh\'f7ng ng\'ad\'eai b\'de b\'e3c l\'e9t thu\'e9c c\'b8c m\'b5u da trong cu\'e9c \'ae\'cau tranh chung. C\'f4 \'ae\'b7 th\'b5nh c
\'abng. Kimeng\'ab l\'b5 m\'e9t trong s\'e8 hi\'d5m nh\'f7ng ng\'ad\'eai \'ae\'b7 ch\'deu gian kh\'e6 l\'edn \'ae\'d3 gieo h\'b9t v\'b5 
\par }\pard \s15\qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\insrsid1378858 \'ae\'ad\'eec h\'ad\'ebng h\'b9nh ph\'f3c l\'edn g\'c6t v\'f4 m\'efa th\'beng l\'eei. M\'b8i t\'e3c c\'f4 b\'b9c ph\'ac nh
\'ad tuy\'d5t khu\'abn r\'f9c r\'ec b\'e9 m\'c6t m\'b5u mun. \'a7\'abi m\'bet c\'f4 hi\'d2n d\'deu v\'b5 nh\'d7n s\'a9u th\'bcm. Mi\'d6ng c\'f4 lu\'abn t\'ad\'aci c\'ad\'eai, d\'ef tr\'ad\'edc nh\'f7ng nguy nan nghi\'aam tr\'e4ng nh\'cat hay trong nh\'f7
ng gi\'ea ph\'f3t \'aeen t\'e8i nh\'cat. T\'f5 to\'b5n b\'e9 con ng\'ad\'eai c\'f4 to\'b8t ra nh\'a9n t\'f5 v\'b5 cao qu\'fd. C\'f4 \'ae\'b8ng t\'abn k\'ddnh v\'b5 \'ae\'ad\'eec t\'abn k\'ddnh.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ch\'f3ng t\'abi \'ae\'d5n n\'aci th\'d7 c\'f4 \'ae\'b7 n
\'e3i \'ae\'ad\'eec n\'f6a ch\'f5ng, v\'b5 \'ae\'a9y l\'b5 nh\'f7ng l\'eai m\'b5 ch\'f3ng t\'abi nghe \'ae\'ad\'eec:
\par "... C\'e3 nh\'f7ng t\'f5 ng\'f7 m\'b5 ng\'ad\'eai gi\'b5 c\'b8c b\'b8c tr\'ad\'edc kia th\'ad\'eang nghe th\'ad\'eang n\'e3i, th\'d7 nay kh\'abng c\'dfn trong t\'f5 ng\'f7 c\'f1a c\'b8c ch\'b8u n\'f7a. V\'b5 nh\'ad th\'d5 l\'b5 t\'e8t. B\'a9y gi\'ea c
\'b8c b\'b8c n\'e3i \'ae\'d5n to\'b5 \'b8n, c\'b6nh s\'b8t, qu\'a9n \'ae\'e9i, nh\'b5 t\'ef, thu\'d5 kho\'b8, th\'d7 c\'b8c ch\'b8u ch\'bcng m\'cay ng\'ad\'eai hi\'d3u nh\'f7ng c\'b8i \'ae\'e3 l\'b5 c\'b8i g\'d7.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 "Th\'eai b\'b8c th\'d7 n\'ad\'edc C\'e9ng ho\'b5 c\'f1a ch
\'f3ng ta l\'b5 thu\'e9c \'ae\'dea Ph\'b8p. Trong n\'ad\'edc, c\'e3 ng\'ad\'eai gi\'b5u v\'b5 ng\'ad\'eai ngh\'cco. Ng\'ad\'eai gi\'b5u l\'b5 nh\'f7ng k\'ce h\'ad\'ebng t\'cat c\'b6, tuy g\'d7 c\'f2ng ch\'bcng l\'b5m. Ng\'ad\'eai ngh\'cco l\'b5 nh\'f7ng k
\'ce g\'d7
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 c\'f2ng l\'b5m, m\'b5 ch\'bcng \'ae\'ad\'eec h\'ad\'ebng g
\'d7 c\'b6. Ng\'ad\'eai ngh\'cco ph\'b6i ch\'deu ch\'d5t ch\'e3c cho ng\'ad\'eai gi\'b5u khi n\'b5o b\'e4n n\'b5y b\'cat ho\'b5 v\'edi nhau: c\'b8i \'ae\'e3 g\'e4i l\'b5 thu\'d5 m\'b8u. Ng\'ad\'eai ngh\'cco l\'b5m ra \'ae\'ad\'eec c\'b8i g\'d7 \'ae\'d2
u ph\'b6i n\'e9p cho ng\'ad\'eai gi\'b5u: c\'b8i \'ae\'e3 g\'e4i l\'b5 thu\'d5 ti\'d2n.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 "V\'cby nh\'d0, b\'e4n t\'ad b\'b6n da tr\'beng l\'cay n
\'ad\'edc ta l\'b5m thu\'e9c \'ae\'dea xong, n\'e3 b\'bet c\'b8c b\'b8c ph\'b6i n\'e9p c\'b8c th\'f8 thu\'d5, m\'c6c d\'c7u c\'b8c b\'b8c n\'b5o c\'e3 c\'f1a n\'b6 g\'d7 \'ae\'a9u. N\'e9p th\'d7 kh\'abng c\'e3 g\'d7 \'ae\'d3 n\'e9p; \'ae\'d3 kh\'e1i b\'de
 h\'b5nh h\'b9, c\'b8c b\'b8c ph\'b6i b\'e1 tr\'e8n v\'b5o r\'f5ng. Ch\'f3ng n\'e3 \'aeem ch\'e3 v\'b5 \'aeem s\'f3ng \'aeu\'e6i theo, c\'b8c b\'b8c \'ae\'b5nh ph\'b6i \'c8n v\'b5o m\'e9t c\'b8i hang, ng\'b5y nay g\'e4i l\'b5 hang Tu\'c9n n\'b9n.
\par "B\'e4n b\'b8c h\'acn hai tr\'a8m m\'b9ng, \'ae\'b5n \'abng c\'e3, \'ae\'b5n b\'b5 c\'e3, tr\'ce em c\'e3. C\'f8 t\'ad\'ebng r\'bbng nh\'ad th\'d5 l\'b5 t\'b9m y\'aan th\'a9n, n\'aan m\'c6c d\'c7u ph\'b6i ch\'deu \'c8m, ch\'deu t\'e8i, ch\'deu \'ae\'e3
i, c\'f9c l\'bem, c\'b8c b\'b8c c\'e3 \'fd \'ae\'denh c\'f8 n\'b8n l\'b9i \'ae\'e3 c\'b5ng l\'a9u c\'b5ng hay, v\'d7 bi\'d5t r\'bbng b\'e4n n\'e3 v\'c9n r\'d7nh \'eb ngo\'b5i hang v\'edi s\'f3ng \'e8ng. Hang t\'e8i nh\'ad b\'adng ng\'b5y c\'f2ng nh\'ad 
\'ae\'aam, b\'b8c ch\'bcng bi\'d5t \'eb trong \'ae\'e3 bao l\'a9u.
\par }\pard\plain \s15\qj \fi397\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 "Ch\'bcng tr\'abng th\'cay g\'d7 h\'d5t, ch\'bcng nghe th
\'cay g\'d7 h\'d5t, tr\'f5 ti\'d5ng ch\'e3 s\'f1a d\'f7 d\'e9i, xa x\'a8m, nh\'bec nh\'eb r\'bbng t\'d7nh th\'d5 v\'c9n hi\'d3m ngh\'cco.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-290\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 "M\'e9t ng\'b5y n\'e4, n\'e3i \'ae\'f3ng h\'acn l\'b5 m
\'e9t \'ae\'aam n\'e4, c\'b8c b\'b8c ng\'f6i th\'cay c\'e3 c\'b8i m\'efi kh\'d0t l\'d1t tr\'b5n v\'b5o ch\'e7 n\'b8u trong l\'dfng \'ae\'cat. M\'efi kh\'d0t n\'c6ng l\'aan nhanh v\'b5 tr\'eb th\'b5nh kh\'abng th\'d3 ch\'deu n\'e6i. G\'d7 th\'d5? Ch\'bc
ng ai bi\'d5t... Tr\'ce nh\'e1 th\'d7 kh\'e3c, \'ae\'b5n b\'b5 th\'d7 la, \'ae\'b5n \'abng th\'d7 ch\'f6i. Ho\'b6ng lo\'b9n! Ch\'b9y \'aei \'ad? Nh\'adng ch\'b9y \'ae\'a9u ch\'f8? Kh\'f1ng khi\'d5p qu\'b8! Ti\'d5ng r\'a8ng l\'cbp c\'cbp, ti\'d5ng th\'d0
t x\'d0 tai, ti\'d5ng n\'cac, ti\'d5ng th\'a9n ng\'ad\'eai \'ae\'e6 xu\'e8ng, ti\'d5ng kh\'e3c \'aei\'aan r\'e5, l\'b5m cho c\'b8i x\'e3 t\'e8i \'b8m kh\'e3i \'ae\'e3 h\'d6t nh\'ad l\'b5 m\'e9t \'ae\'dea ng\'f4c.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 "B\'cay gi\'ea b\'b8c \'eb t\'cbn cu\'e8i hang. B\'b8c theo b\'b6n n\'a8ng nh\'bem m\'bet, ng\'cbm mi\'d6ng, \'b8p m\'c6
t v\'b5o v\'b8ch hang. Nh\'ad th\'d5 c\'b6m th\'cay d\'d4 th\'eb h\'acn v\'b5 ng\'f1 \'aei l\'f3c n\'b5o kh\'abng bi\'d5t. T\'d8nh d\'cby th\'d7 th\'cay c\'e3 tia s\'b8ng chi\'d5u ch\'d5ch v\'b5o m\'c6t, \'ae\'cay l\'b5 m\'e9t k\'cf h\'eb qua \'ae\'ca
t, nh\'ea \'ae\'e3 m\'b5 b\'b8c th\'eb \'ae\'ad\'eec v\'b5 tho\'b8t ch\'d5t. B\'b8c nh\'bbm \'ae\'b5o m\'e9t l\'e8i ra ph\'dda \'ae\'e3, nh\'adng ch\'d8 m\'d6t x\'b8c v\'ab \'ddch. B\'b8c b\'ccn quy\'d5t \'ae\'denh th\'abi \'ae\'b5nh li\'d2u m\'b9ng c\'f8
 ph\'dda c\'f6a hang m\'b5 ra. Qu\'ea qu\'b9ng v\'b5 d\'c9m qua hai tr\'a8m x\'b8c ch\'d5t hun m\'edi tr\'eb l\'b9i \'ae\'ad\'eec v\'edi kho\'b6ng tr\'eai t\'f9 do.
\par "B\'b8c \'a8n c\'e1, \'a8n r\'d4 c\'a9y, \'aei lang thang h\'d5t l\'b5ng n\'b5y sang l\'b5ng n\'e4; cu\'e8i c\'efng th\'d7 \'ae\'ad\'eec b\'e8 c\'f1a \'ae\'e5ng ch\'dd ng\'ad\'eai da tr\'beng n\'b5y \'ae\'a9y thu nh\'cbn v\'d2 nu\'abi nh\'ad con. \'a4ng 
\'ae\'b7 d\'b9y d\'e7 b\'b8c theo nh\'f7ng nguy\'aan t\'bec c\'f1a t\'d7nh h\'f7u \'b8i v\'b5 c\'f1a ch\'f1 ngh\'dca c\'e9ng s\'b6n; \'abng c\'f2ng \'ae\'b7 cho b\'b8c bi\'d5t t\'aan th\'bbng da tr\'beng v\'d7 mu\'e8n thu thu\'d5 m\'b5 \'ae\'b7 hun c\'b8
c b\'b8c ch\'d5t ng\'b9t m\'e9t c\'b8ch man r\'ee nh\'ad v\'cby.
\par "Th\'bbng hun kh\'e3i, t\'aan n\'e3 l\'b5 Bruye, l\'b5 \'ae\'b9i di\'d6n c\'f1a n\'ad\'edc Ph\'b8p v\'b5 l\'b5 c\'abng s\'f8 \'eb Ha\'f3txa".
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 NGuy\'d4n \'b8i Qu\'e8c
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8o }{\i\insrsid1378858 L'Humanit\'d0,}{\insrsid1378858 
\par ng\'b5y 20-7-1922.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par 
\par 
\par }\pard\plain \s21\qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f39\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par 
\par 
