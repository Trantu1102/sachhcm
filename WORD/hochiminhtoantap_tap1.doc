\par }\pard\plain \qj \fi397\li0\ri0\sb120\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i\f37\fs20\insrsid1378858 K\'ddnh g\'f6i Ng\'b5i T\'e6ng th\'e8ng C\'e9ng ho\'b5
 H\'eep ch\'f1ng qu\'e8c,
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\i\f37\fs20\insrsid1378858 \tab \tab        \'a7\'b9i bi\'d3u \'eb H\'e9i ngh\'de Ho\'b5 b\'d7nh.
\par }\pard \qj \fi397\li0\ri0\sb320\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\i\f37\fs20\insrsid1378858 Th\'ada Ng\'b5i,
\par }\pard \qj \fi397\li0\ri0\sa80\sl-268\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 Nh\'a9n d\'dep chi\'d5n th\'beng c\'f1a \'a7\'e5ng minh, ch\'f3ng t\'abi xin m\'b9n ph\'d0p g\'f6i \'ae\'d5n Ng\'b5i, k
\'ccm theo \'ae\'a9y b\'b6n ghi c\'b8c y\'aau s\'b8ch c\'f1a nh\'a9n d\'a9n An Nam.
\par Tin t\'ad\'ebng \'eb \'ae\'e9 l\'ad\'eeng cao c\'b6 c\'f1a Ng\'b5i, ch\'f3ng t\'abi mong Ng\'b5i \'f1ng h\'e9 tr\'ad\'edc nh\'f7ng ng\'ad\'eai c\'e3 th\'c8m quy\'d2n.
\par Xin Ng\'b5i vui l\'dfng nh\'cbn s\'f9 bi\'d3u th\'de l\'dfng k\'ddnh tr\'e4ng s\'a9u s\'bec c\'f1a ch\'f3ng t\'abi.
\par }\pard\plain \s2\qc \li1701\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel1\adjustright\rin0\lin1701\itap0 \b\f37\fs28\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\b0\i\fs20\insrsid1378858 
\par }\pard \s2\qc \li1701\ri0\sl-300\slmult0\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel1\adjustright\rin0\lin1701\itap0 {\b0\i\fs20\insrsid1378858 Thay m\'c6t nh\'e3m nh\'f7ng ng\'ad\'eai y\'aau n\'ad\'edc An Nam}{\b0\fs20\insrsid1378858 \line }{
\b0\f38\fs18\insrsid1378858 NGUY\'d4N \'b8I QU\'e8C}{\b0\fs20\insrsid1378858 
\par }\pard\plain \s25\qc \li1701\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin1701\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 56, ph\'e8 M\'acxi\'ac L\'ac Pranhx\'ac, Pari
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 Th\'ad \'ae\'b8nh m\'b8y, ti\'d5ng Ph\'b8p,
\par b\'b6n ch\'f4p l\'adu t\'b9i Vi\'d6n H\'e5 Ch\'dd Minh.
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 VI\'d6T NAM Y\'a3U C\'c7U CA
\par }\pard\plain \qc \li0\ri0\sl-258\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 "R\'bbng nay g\'c6p h\'e9i Giao ho\'b5,
\par Mu\'abn d\'a9n h\'ccn y\'d5u g\'c7n xa vui t\'d7nh.
\par C\'cby r\'bbng c\'b8c n\'ad\'edc \'a7\'e5ng minh,
\par \'a7em g\'ad\'acng c\'abng l\'fd gi\'d5t h\'d7nh d\'b7 man.
\par M\'cay phen c\'abng b\'e8 r\'e2 r\'b5ng,
\par D\'a9n n\'b5o r\'e5i c\'f2ng \'ae\'ad\'eec trang b\'d7nh quy\'d2n.
\par Vi\'d6t Nam x\'ada c\'f2ng oai thi\'aang,
\par M\'b5 nay \'ae\'f8ng d\'ad\'edi thu\'e9c quy\'d2n Lang Sa.
\par L\'dfng th\'b5nh t\'e1 n\'e7i s\'f3t sa,
\par Gi\'b8m xin \'ae\'b9i qu\'e8c soi qua ch\'f3t n\'b5o.
\par M\'e9t xin tha k\'ce \'ae\'e5ng b\'b5o,
\par V\'d7 ch\'adng ch\'ddnh tr\'de m\'bec v\'b5o t\'ef giam.
\par Hai xin ph\'d0p lu\'cbt s\'f6a sang,
\par Ng\'ad\'eai T\'a9y ng\'ad\'eai Vi\'d6t hai ph\'ad\'acng c\'efng \'ae\'e5ng.
\par Nh\'f7ng to\'b5 \'ae\'c6c bi\'d6t b\'cat c\'abng,
\par Gi\'b8m xin b\'e1 d\'f8t r\'e9ng dung d\'a9n l\'b5nh.
\par Ba xin r\'e9ng ph\'d0p h\'e4c h\'b5nh,
\par M\'eb mang k\'fc ngh\'d6, l\'cbp th\'b5nh c\'abng th\'ad\'acng.
\par B\'e8n xin \'ae\'ad\'eec ph\'d0p h\'e9i h\'b5ng,
\par N\'a8m xin ngh\'dc ng\'eei n\'e3i b\'b5n t\'f9 do.
\par S\'b8u xin \'ae\'ad\'eec ph\'d0p l\'dech du,
\par B\'e8n ph\'ad\'acng m\'c6c s\'f8c, n\'a8m ch\'a9u m\'c6c t\'d7nh
\par B\'b6y xin hi\'d5n ph\'b8p ban h\'b5nh,
\par Tr\'a8m \'ae\'d2u ph\'b6i c\'e3 th\'c7n linh ph\'b8p quy\'d2n
\par T\'b8m xin \'ae\'ad\'eec c\'f6 ngh\'de vi\'aan,
\par Qua T\'a9y thay m\'c6t gi\'f7 quy\'d2n th\'e6 d\'a9n.
\par 
\par 
\par 
\par 
\par 
\par 
\par 
\par T\'b8m \'aei\'d2u c\'b9n t\'e1 xa g\'c7n,
\par Ch\'f8ng nh\'ea v\'b9n qu\'e8c c\'abng d\'a9n x\'d0t t\'d7nh.
\par Ri\'aang nh\'ea d\'a9n Ph\'b8p c\'abng b\'d7nh,
\par \'a7em l\'dfng \'aeo\'b8i l\'b9i c\'f1a m\'d7nh trong tay.
\par Ph\'b8p d\'a9n n\'f8c ti\'d5ng x\'ada nay,
\par \'a7\'e5ng b\'b5o, b\'b8c \'b8i s\'b8nh t\'c7y kh\'abng ai!
\par N\'ec n\'b5o ng\'b6nh m\'c6t ng\'ac tai,
\par \'a7\'d3 cho m\'cay \'f8c tri\'d6u ng\'ad\'eai b\'ac v\'ac.
\par D\'a9n Nam m\'e9t d\'b9 \'ad\'edc m\'ac,
\par L\'a9u nay t\'f5ng n\'f3p b\'e3ng c\'ea t\'f9 do.
\par R\'e9ng xin d\'a9n Ph\'b8p x\'d0t cho,
\par Trong ph\'df ti\'d5ng n\'ad\'edc, sau ph\'df l\'cf c\'abng.
\par D\'dech m\'cay ch\'f7 qu\'e8c \'a9m b\'b5y t\'e1.
\par \'a7\'d3 \'ae\'e5ng b\'b5o l\'edn nh\'e1 \'ae\'ad\'eec hay.
\par Ho\'b5 b\'d7nh may g\'c6p h\'e9i n\'b5y,
\par T\'abn s\'efng c\'abng l\'fd, \'aeo\'b9 \'ae\'b5y d\'b7 man.
\par Nay g\'c6p h\'e9i kh\'b6i ho\'b5n h\'d8 h\'b6,
\par Ti\'d5ng vui m\'f5ng kh\'bep c\'b6 \'ae\'e5ng - d\'a9n.
\par T\'a9y vui ch\'bec \'ae\'b7 m\'ad\'eai ph\'c7n,
\par L\'cf n\'b5o Nam l\'b9i ch\'deu th\'a9n t\'abi \'ae\'dfi.
\par H\'bdng m\'eb m\'bet m\'b5 soi cho r\'e2.
\par N\'b5o Ai Lan, }{\f38\fs20\insrsid1378858 \'ca}{\f37\fs20\insrsid1378858 n \'a7\'e9, Cao Ly,
\par X\'ada, h\'ccn ph\'b6i b\'ad\'edc suy vi,
\par Nay, g\'c7n \'ae\'e9c l\'cbp c\'f2ng v\'d7 d\'a9n kh\'abn
\par Hai m\'ad\'aci tri\'d6u qu\'e8c h\'e5n Nam Vi\'d6t
\par Th\'d5 cu\'e9c n\'b5y ph\'b6i bi\'d5t m\'b5 lo.
\par \'a7\'e5ng b\'b5o, b\'d7nh \'ae\'bcng, t\'f9 do,
\par X\'d0t m\'d7nh r\'e5i l\'b9i \'aeem so m\'cay ng\'ad\'eai.
\par Ng\'e6n ngang l\'eai v\'ben \'fd d\'b5i,
\par Anh em \'ae\'b7 th\'cau l\'dfng n\'b5y cho ch\'ada.
\par }\pard\plain \s24\qr \fi397\li0\ri567\sb360\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 NGUY\'d4N \'b8I QU\'e8C
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 T\'b5i li\'d6u vi\'d5t tay, ti\'d5ng Vi\'d6t, 
\par b\'b6n ch\'f4p l\'adu t\'b9i Vi\'d6n H\'e5 Ch\'dd Minh.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par }{\b\f37\fs20\insrsid1378858 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa360\sl-420\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 B\'b8O C\'b8o}{\cs17\super\insrsid1378858 1{\footnote 
\pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) T\'b5i li\'d6u \'ae\'b8nh m\'b8y, ti\'d5ng Ph\'b8p, kh
\'abng k\'fd t\'aan, l\'adu tr\'f7 t\'b9i CAOM, SLOTFOM, S\'d0rie III, c\'c6p s\'e8 3, h\'e5 s\'ac c\'f1a H\'e9i Li\'aan hi\'d6p thu\'e9c \'ae\'dea (Ph\'b8p).}})}{\insrsid1378858 \line }{\b0\i\fs20\insrsid1378858 D\'f9 TH\'b6o}{\f37\fs20\insrsid1378858 

\par }\pard\plain \s7\qr \fi397\li0\ri567\sa240\sl-280\slmult0\keepn\nowidctlpar\aspalpha\aspnum\faauto\outlinelevel6\adjustright\rin567\lin0\itap0 \i\f37\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \~Pari, ng\'b5y 20-11-1921
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 Ti\'d3u ban \'a7\'abng D\'ad\'acng thu\'e9c Ph\'b8
p trong Ban nghi\'aan c\'f8u thu\'e9c \'ae\'dea}{\f37\fs20\super\insrsid1378858 60}{\f37\fs20\insrsid1378858  c\'f1a \'a7\'b6ng C\'e9ng s\'b6n \'ae\'ad\'eec giao tr\'b8ch nhi\'d6m ph\'b8t bi\'d3u \'fd ki\'d5n v\'d2 ho\'b9t \'ae\'e9ng c\'c7n ti\'d5n h\'b5
nh \'eb Vi\'d4n \'a7\'abng nh\'bbm t\'b9o ra v\'b5 ph\'b8t tri\'d3n m\'e9t phong tr\'b5o c\'e9ng s\'b6n c\'b8ch m\'b9ng, xin tr\'d7nh b\'b5y:
\par 1. Ti\'d3u ban b\'b8c b\'e1 m\'e4i ki\'d5n ngh\'de v\'d2 kinh t\'d5 ho\'c6c ch\'ddnh tr\'de nh\'bbm c\'b6i thi\'d6n, c\'b6i c\'b8ch ho\'c6c \'ae\'b9t m\'e9t ti\'d5n b\'e9 n\'b5o \'ae\'e3, \'aei\'d2u n\'b5y, trong ch\'d5 \'ae\'e9 t\'ad b\'b6n, ch\'d8 ph
\'f4c v\'f4 ch\'ddnh quy\'d2n hi\'d6n nay v\'b5 gi\'f3p v\'b5o s\'f9 c\'f1ng c\'e8 n\'e3.
\par 2. Nh\'cbn th\'cay r\'bbng c\'b8c giai c\'cap th\'e8ng tr\'de coi c\'b8c thu\'e9c \'ae\'dea Ph\'b8p kh\'abng ch\'d8 l\'b5 m\'e9t kho v\'ab t\'cbn nguy\'aan li\'d6u, ng\'ad\'eai b\'b6n x\'f8 thu\'c7n tu\'fd l\'b5 nh\'f7ng con v\'cbt k\'d0o n\'c6ng s\'b6
n xu\'cat ra nh\'f7ng th\'f8 \'ae\'e3, m\'b5 b\'e4n k\'ce th\'ef giai c\'cap c\'f1a ch\'f3ng ta c\'dfn coi nh\'f7ng n\'ad\'edc h\'b6i ngo\'b9i \'ae\'e3 l\'b5 ngu\'e5n cung c\'cap nh\'f7ng \'ae\'e9i qu\'a9n ph\'b6n c\'b8ch m\'b9ng.
\par Do \'ae\'e3, c\'abng t\'b8c tuy\'aan truy\'d2n c\'b8ch m\'b9ng v\'b5 ch\'e8ng qu\'a9n phi\'d6t c\'c7n \'ae\'ad\'eec ti\'d5n h\'b5nh d\'ad\'edi s\'f9 l\'b7nh \'ae\'b9o v\'b5 \'ae\'abn \'ae\'e8c c\'f1a \'a7\'b6ng, trong t\'cat c\'b6 c\'b8c thu\'e9c \'ae\'de
a c\'f1a Ph\'b8p v\'b5 x\'f8 g\'e4i l\'b5 b\'b6o h\'e9.
\par 
\par }\pard \qj \li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 C\'abng t\'b8c tuy\'aan truy\'d2n n\'b5y th\'f9c hi\'d6n:
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 a) b\'bbng c\'b8c b\'b8o ch\'dd xu\'cat b\'b6n \'eb Ph\'b8p.
\par b) b\'bbng di\'d4n \'ae\'b5n c\'f1a c\'b8c \'a7\'b9i h\'e9i c\'f1a ch\'f3ng ta v\'b5 khi c\'c7n, b\'bbng di\'d4n \'ae\'b5n c\'f1a ngh\'de vi\'d6n.
\par c) b\'bbng c\'b8c h\'e9i ngh\'de.
\par d) b\'bbng m\'e4i ph\'ad\'acng th\'f8c th\'ddch h\'eep v\'edi \'ae\'e8i t\'ad\'eeng, v\'edi tr\'d7nh \'ae\'e9 gi\'b8o d\'f4c v\'b5 v\'a8n minh c\'f1a qu\'c7n ch\'f3ng b\'b6n x\'f8 \'eb c\'b8c thu\'e9c \'ae\'dea.
\par B\'b6n tr\'d7nh b\'b5y s\'ac l\'ad\'eec tr\'aan \'ae\'a9y ch\'d8 l\'b5 m\'e9t th\'abng b\'b8o b\'ad\'edc \'ae\'c7u. Ban nghi\'aan c\'f8u thu\'e9c \'ae\'dea c\'f1a ph\'a9n b\'e9 Ph\'b8p c\'f1a Qu\'e8c t\'d5 C\'e9ng s\'b6n cho r\'bbng vi\'d6c nghi\'aan c
\'f8u c\'b8c v\'can \'ae\'d2 thu\'e9c \'ae\'dea t\'f5 nay v\'d2 sau ph\'b6i l\'b5 b\'e9 ph\'cbn kh\'abng t\'b8ch r\'eai c\'b8c \'ae\'d2 c\'ad\'acng \'ae\'ada l\'aan Qu\'e8c t\'d5 C\'e9ng s\'b6n, v\'d7 c\'b8ch m\'b9ng c\'e9ng s\'b6n ch\'f1 ngh\'dca kh\'ab
ng ch\'d8 c\'e3 m\'f4c \'ae\'ddch \'eb ch\'a9u \'a2u m\'b5 c\'dfn \'eb to\'b5n th\'d5 gi\'edi. V\'d7 v\'cby, kh\'abng \'ae\'ad\'eec \'ae\'d3 m\'e9t n\'aci n\'b5o tr\'aan th\'d5 gi\'edi, do c\'c8u th\'b6 ho\'c6c kh\'abng am hi\'d3u v\'can \'ae\'d2, l\'e4
t ra ngo\'b5i nh\'f7ng ho\'b9t \'ae\'e9ng c\'e3 \'ddch cho m\'f4c \'ae\'ddch c\'b8ch m\'b9ng c\'e9ng s\'b6n ch\'f1 ngh\'dca.
\par 
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 In trong s\'b8ch: H\'e5 Ch\'dd Minh,
\par }{\i\insrsid1378858 Nh\'f7ng b\'b5i vi\'d5t 1914 - 1969,
\par }{\insrsid1378858 do Alain Ruscio bi\'aan so\'b9n, Pari, 1990, tr.40 - 41.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 
\par 
\par }{\b\f37\fs20\insrsid1378858 \column 
\par }\pard\plain \s20\qc \li0\ri0\sb1400\sa440\sl-380\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \b\f38\fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 D\'f9 TH\'b6O NGH\'de QUY\'d5T\line V\'d2\line CH\'f1
 NGH\'dcA C\'e9NG S\'b6N V\'b5 C\'b8C THU\'e9C \'a7\'dea}{\cs17\super\insrsid1378858 1{\footnote \pard\plain \s28\qj \fi397\li0\ri0\sa60\sl-240\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 
\f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 1) T\'b9i \'a7\'b9i h\'e9i l\'c7n th\'f8 I \'a7\'b6ng C\'e9ng s\'b6n Ph\'b8p h\'e4p \'eb M\'b8cx\'a9y, phi\'aan h\'e4p th\'f8 9, bu\'e6i chi\'d2u th\'f8 n\'a8m, ng\'b5
y 29-12-1921, sau khi Phr\'e8txa ph\'b8t bi\'d3u, Ch\'f1 t\'e4a gi\'edi thi\'d6u Nguy\'d4n }{\f38\insrsid1378858 \'b8}{\insrsid1378858 i Qu\'e8c l\'aan \'ae\'e4c b\'b6n D\'f9 th\'b6o ngh\'de quy\'d5t n\'b5y.}})}{\insrsid1378858 
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\insrsid1378858 \~\'a7\'b9i h\'e9i l\'c7n th\'f8 II c\'f1a Qu\'e8c t\'d5 C
\'e9ng s\'b6n h\'e4p v\'b5o th\'b8ng 8-1920 \'ae\'b7 tuy\'aan b\'e8 trong nh\'f7ng lu\'cbn c\'ad\'acng c\'f1a \'a7\'b9i h\'e9i v\'d2 nh\'f7ng v\'can \'ae\'d2 thu\'e9c \'ae\'dea r\'bbng:
\par "\'a7\'b9i chi\'d5n \'eb ch\'a9u \'a2u v\'b5 nh\'f7ng k\'d5t qu\'b6 c\'f1a n\'e3 \'ae\'b7 ch\'d8 r\'e2 r\'bbng qu\'c7n ch\'f3ng \'eb nh\'f7ng n\'ad\'edc ph\'f4 thu\'e9c ngo\'b5i ch\'a9u \'a2u g\'ben b\'e3 v\'edi phong tr\'b5o v\'ab s\'b6n ch\'a9u \'a2u m
\'e9t c\'b8ch tuy\'d6t \'ae\'e8i v\'b5 \'ae\'e3 l\'b5 h\'cbu qu\'b6 kh\'abng th\'d3 tr\'b8nh \'ae\'ad\'eec do s\'f9 t\'cbp trung c\'f1a ch\'f1 ngh\'dca t\'ad b\'b6n th\'d5 gi\'edi...
\par "Qu\'e8c t\'d5 C\'e9ng s\'b6n ph\'b6i m\'eb r\'e9ng ph\'b9m vi ho\'b9t \'ae\'e9ng c\'f1a m\'d7nh. Nhi\'d6m v\'f4 c\'f1a n\'e3 l\'b5 t\'e6 ch\'f8c giai c\'cap c\'abng nh\'a9n to\'b5n th\'d5 gi\'edi \'ae\'d3 l\'cbt \'ae\'e6 n\'d2n th\'e8ng tr\'de t\'ad b
\'b6n ch\'f1 ngh\'dca v\'b5 thi\'d5t l\'cbp ch\'f1 ngh\'dca c\'e9ng s\'b6n".
\par Nh\'f7ng ch\'d8 th\'de \'ae\'e3 l\'b5 c\'c7n thi\'d5t h\'b5ng \'ae\'c7u \'ae\'e8i v\'edi \'a7\'b6ng C\'e9ng s\'b6n Ph\'b8p, b\'ebi v\'d7 giai c\'cap t\'ad s\'b6n n\'ad\'edc n\'b5y th\'e8ng tr\'de nh\'f7ng thu\'e9c \'ae\'dea m\'b5 d\'a9n s\'e8 c\'e3 t\'ed
i 40 tri\'d6u ng\'ad\'eai.
\par Nh\'f7ng thu\'e9c \'ae\'dea b\'de c\'b8c giai c\'cap th\'e8ng tr\'de coi l\'b5 kho ch\'f8a nguy\'aan li\'d6u c\'ac b\'b6n m\'b5 \'ae\'d3 l\'b5m ra ch\'f3ng, d\'a9n b\'b6n x\'f8 b\'de ng\'ad\'eai ta coi l\'b5 nh\'f7ng con v\'cbt k\'d0o xe, nh\'ad l\'b5 n
\'aci ti\'aau th\'f4 d\'b5nh ri\'aang cho th\'ad\'acng 
\par }\pard\plain \s25\qj \li0\ri0\sa80\sl-266\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \f38\fs20\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\insrsid1378858 nghi\'d6p ch\'ddnh qu\'e8c; v\'b5 c\'f2ng l\'b5 ngu\'e5
n cung c\'cap cho ch\'f1 ngh\'dca qu\'a9n phi\'d6t binh l\'ddnh cho nh\'f7ng cu\'e9c chi\'d5n tranh s\'bep t\'edi do s\'f9 \'ae\'e8i kh\'b8ng gi\'f7a ch\'f1 ngh\'dca \'ae\'d5 qu\'e8c k\'d7nh \'ae\'dech c\'f1a nh\'f7ng n\'ad\'edc kh\'b8c nhau \'aeang chu
\'c8n b\'de.
\par }\pard\plain \qj \fi397\li0\ri0\sa80\sl-288\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 \fs24\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\f37\fs20\expnd0\expndtw-2\insrsid1378858 H\'b5ng ch\'f4c ngh\'d7n ng\'ad\'eai d
\'a9n thu\'e9c \'ae\'dea \'ae\'b7 ch\'d5t trong cu\'e9c chi\'d5n tranh ch\'a9u \'a2u. H\'b5ng ch\'f4c ngh\'d7n ng\'ad\'eai kh\'b8c c\'dfn ph\'b6i l\'b5m n\'ab l\'d6 cho ch\'f1 ngh\'dca qu\'a9n phi\'d6t Ph\'b8p; trong su\'e8t th\'eai k\'fa "ho\'b5 b\'d7nh 
\'eb t\'d7nh tr\'b9ng chi\'d5n tranh" n\'e3 ph\'b8i h\'e4 sang \'a7\'f8c, Xilixi, Xyri, v\'edi kh\'dd h\'cbu \'ae\'e9c h\'b9i nh\'cat \'ae\'d5n ch\'d5t ng\'ad\'eai \'ae\'e8i v\'edi nh\'f7ng con ng\'ad\'eai x\'f8 n\'e3ng \'cay. Ng\'ad\'eai ta \'ae\'ada ng
\'ad\'eai ch\'ddnh qu\'e8c v\'b5o qu\'a9n \'ae\'e9i v\'edi danh ngh\'dca qu\'e8c ph\'dfng: chi\'aau b\'b5i n\'b5y ch\'d8 c\'e3 th\'d3 d\'efng \'eb nh\'f7ng thu\'e9c \'ae\'dea m\'edi b\'de th\'abn t\'ddnh; \'eb \'ae\'cay, ng\'ad\'eai ta tuy\'d3n nh\'f7
ng ng\'ad\'eai ch\'a9u Phi v\'b5 nh\'f7ng ng\'ad\'eai ch\'a9u }{\f38\fs20\expnd0\expndtw-2\insrsid1378858 \'b8}{\f37\fs20\expnd0\expndtw-2\insrsid1378858  b\'bbng nh\'f7ng l\'eai h\'f8a d\'e8i tr\'b8 cho ti\'d2n b\'b9c hay cho chi\'d5n l\'eei ph\'c8m, b
\'bbng r\'ad\'eeu, b\'bbng s\'f9 chuy\'aan ch\'d5 h\'b5nh ch\'ddnh, ho\'c6c l\'b5 (khi nh\'f7ng ph\'ad\'acng s\'b8ch \'ae\'e3 th\'cat b\'b9i) b\'bbng b\'b9o l\'f9c, kh\'f1ng b\'e8 v\'b5 nh\'f7ng s\'f9 h\'b5nh quy\'d5t l\'b5m g\'ad\'acng. Qua mi\'d6ng M
\'a8nggianh, ch\'f1 ngh\'dca qu\'a9n phi\'d6t Ph\'b8p khoe khoang h\'e4 s\'f6 d\'f4ng 400.000 l\'ddnh b\'b6n x\'f8; v\'d2 th\'f9c t\'d5 v\'b5 b\'bbng nh\'f7ng ph\'ad\'acng s\'b8ch duy\'d6t th\'aam, n\'e3 c\'e3 th\'d3 \'ae\'ada l\'aan m\'e9t ho\'c6
c hai tri\'d6u ng\'ad\'eai ch\'a9u Phi v\'b5 ng\'ad\'eai ch\'a9u }{\f38\fs20\expnd0\expndtw-2\insrsid1378858 \'b8}{\f37\fs20\expnd0\expndtw-2\insrsid1378858 . Nh\'ad th\'d5, n\'e3 hy v\'e4ng c\'e3 \'ae\'ad\'eec nh\'f7ng v\'cbt hy sinh d\'d4 b\'b6o h\'ac
n l\'b5 c\'abng nh\'a9n v\'b5 n\'abng d\'a9n Ph\'b8p, v\'b5 c\'f2ng l\'b5 s\'f6 d\'f4ng \'ae\'ad\'eec nh\'f7ng l\'f8a qu\'a9n d\'dech thu\'e9c \'ae\'dea, nh\'f7ng c\'abng c\'f4 m\'ef qu\'b8ng \'ae\'d3 \'b8p b\'f8c v\'b5 \'ae\'cc b\'d1p giai c\'cap v\'ab s
\'b6n ch\'a9u}{\f37\fs20\insrsid1378858  \'a2u.
\par Ngo\'b5i s\'f9 c\'c7n thi\'d5t ch\'e8ng l\'b9i nguy c\'ac \'ae\'e8i v\'edi phong tr\'b5o gi\'b6i ph\'e3ng v\'ab s\'b6n l\'b5 s\'f9 can thi\'d6p tuy\'d6t \'ae\'e8i c\'f1a ch\'f1 ngh\'dca t\'ad s\'b6n ch\'ddnh qu\'e8c \'ae\'e8i v\'edi d\'a9n c\'ad b\'b6n x
\'f8 b\'de \'d0p v\'b5o tr\'b9i l\'ddnh, c\'c7n ph\'b6i th\'cay \'ae\'ad\'eec r\'bbng trong m\'e9t th\'eai k\'fa c\'b8ch m\'b9ng, giai c\'cap t\'ad s\'b6n s\'f6 d\'f4ng nh\'f7ng thu\'e9c \'ae\'dea l\'b5m n\'aci tr\'e8n tr\'b8nh c\'f1a l\'f9c l\'ad\'ee
ng ph\'b6n c\'b8ch m\'b9ng hay \'ddt nh\'cat c\'f2ng d\'f9a v\'b5o \'ae\'cay \'ae\'d3 t\'e6 ch\'f8c ra n\'e3. Ngay t\'f5 b\'a9y gi\'ea ch\'f3ng ta ph\'b6i d\'f9 ph\'dfng s\'b8ch l\'ad\'eec n\'b5y v\'b5 mu\'e8n v\'cby ch\'f3ng ta ph\'b6i c\'e8 g\'be
ng tranh th\'f1 c\'b6m t\'d7nh c\'f1a qu\'c7n ch\'f3ng b\'b6n x\'f8 v\'b5 gi\'b8o d\'f4c h\'e4 b\'bbng c\'b8ch ch\'d8 ra r\'bbng nh\'f7ng n\'e7i \'aeau kh\'e6 c\'f1a h\'e4 c\'f2ng c\'e3 c\'efng nguy\'aan nh\'a9n v\'edi \'aeau kh\'e6 c\'f1a giai c\'cap c
\'abng nh\'a9n \'eb ch\'ddnh qu\'e8c. \'a7\'d2 ra nhi\'d6m v\'f4 n\'b5y ch\'ada ph\'b6i l\'b5 t\'cat c\'b6 m\'b5 c\'dfn ph\'b6i d\'e8c l\'dfng l\'b5m nh\'f7ng nhi\'d6m v\'f4 th\'f9c ti\'d4n ph\'b8t sinh t\'f5 \'ae\'e3. \'a7i\'d2u \'ae\'e3 kh\'abng d\'d4
, v\'d7 nhi\'d2u l\'cf:
\par }\pard \qj \fi397\li0\ri0\sa80\sl-284\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 a/ Th\'f8 nh\'cat, \'eb trong \'a7\'b6ng C\'e9ng s\'b6n c\'dfn ch\'ada c\'e3 truy\'d2n th\'e8ng v\'f7ng v\'b5ng v\'d2 m
\'c6t ho\'b9t \'ae\'e9ng thu\'e9c \'ae\'dea. Qu\'e8c t\'d5 th\'f8 hai g\'c7n nh\'ad ho\'b5n to\'b5n th\'ea \'ac v\'edi vi\'d6c t\'b9o ra \'eb thu\'e9c \'ae\'dea phong tr\'b5o \'ae\'e8i kh\'b8ng ch\'e8ng l\'b9i ch\'f1 ngh\'dca t\'ad b\'b6n m\'b5 b\'bbng l
\'dfng v\'edi vi\'d6c \'ae\'ada ra nh\'f7ng b\'b6n tuy\'aan b\'e8 c\'f1a ch\'f1 ngh\'dca c\'b6i l\'ad\'acng l\'cbp l\'ea v\'b5 v\'ab hi\'d6u qu\'b6. V\'cby ng\'b5y nay \'a7\'b6ng c\'e9ng s\'b6n ph\'b6i t\'e6 ch\'f8c t\'cat c\'b6.
\par }{\f37\fs20\expnd0\expndtw-4\insrsid1378858 b/ \'a7i\'d2u l\'b5m cho ph\'f8c t\'b9p v\'b5 kh\'e3 kh\'a8n c\'f1a s\'f9 nghi\'d6p n\'b5y c\'f2ng ch\'ddnh l\'b5 s\'f9 kh\'b8c nhau c\'f1a c\'b8c lo\'b9i thu\'e9c \'ae\'dea h\'eep th\'b5nh l\'b7nh th\'e6 thu
\'e9c \'ae\'dea Ph\'b8p. V\'d7 th\'d5, nh\'f7ng ph\'ad\'acng s\'b8ch ho\'b9t \'ae\'e9ng kh\'abng gi\'e8ng nhau v\'b5 ph\'b6i thay \'ae\'e6i theo t\'f5ng nh\'e3m thu\'e9c \'ae\'dea l\'edn. V\'d2 \'ae\'b9i th\'d3, ng\'ad\'eai ta c\'e3 th\'d3 chia c\'b8c thu
\'e9c \'ae\'dea l\'b5m 5 lo\'b9i nh\'ad sau: B\'bec Phi, T\'a9y Phi v\'b5 ch\'a9u Phi x\'ddch \'ae\'b9o, \'a7\'abng D\'ad\'acng, Ma\'aeag\'b8txca, c\'b8c thu\'e9c \'ae\'dea c\'f2.
\par }{\f37\fs20\insrsid1378858 c/ M\'e9t kh\'e3 kh\'a8n kh\'b8c l\'b5 thi\'d5u kh\'b6 n\'a8ng t\'f9 gi\'b6i ph\'e3ng \'eb h\'c7u h\'d5t nh\'f7ng ng\'ad\'eai b\'b6n x\'f8. H\'e4 kh\'abng c\'e3 qu\'b8 kh\'f8 c\'b8ch m\'b9ng; trong nhi\'d2u thu\'e9c \'ae\'dea h
\'e4 quen th\'e3i n\'ab l\'d6 v\'b5 c\'dfn ch\'ada nh\'cbn kh\'b6 n\'a8ng t\'f9 gi\'b6i tho\'b8t kh\'e1i c\'b6nh \'ae\'e3. N\'e7 l\'f9c c\'f1a ch\'f3ng ta nh\'bbm gi\'b6i ph\'e3ng h\'e4 v\'b5 d\'bet d\'c9n h\'e4, v\'b5 qua \'ae\'e3, h\'b5nh \'ae\'e9ng c
\'b8ch m\'b9ng c\'f1a ch\'f3ng ta s\'cf kh\'abng \'ae\'ad\'eec h\'e4 \'f1ng h\'e9 nghi\'aam ch\'d8nh, \'ddt ra l\'b5 l\'f3c b\'bet \'ae\'c7u \'eb nh\'f7ng n\'ad\'edc c\'e3 ch\'d5 \'ae\'e9 chuy\'aan ch\'d5 \'ae\'e9c \'aeo\'b8n.
\par B\'bbng b\'cat c\'f8 c\'b8ch n\'b5o nh\'f7ng kh\'e3 kh\'a8n \'ae\'e3 c\'f2ng kh\'abng th\'d3 bi\'d6n minh cho vi\'d6c \'a7\'b6ng c\'e9ng s\'b6n t\'f5 b\'e1 m\'e9t ch\'ddnh s\'b8ch thu\'e9c \'ae\'dea th\'f9c t\'d5 v\'b5 c\'e3 k\'d5t qu\'b6. N\'d5u ch\'f3
ng ta n\'aau ra nh\'f7ng \'aei\'d2u \'ae\'e3 c\'e8t ch\'d8 ra \'ddch l\'eei c\'f1a m\'e9t t\'e6 ch\'f8c \'ae\'c6c bi\'d6t chuy\'aan lo tuy\'aan truy\'d2n c\'e9ng s\'b6n th\'b5nh c\'abng.
\par T\'e6 ch\'f8c \'ae\'c6c bi\'d6t n\'b5y, Ban l\'b7nh \'ae\'b9o \'ae\'b7 chu\'c8n b\'de l\'cbp m\'e9t Ban nghi\'aan c\'f8u thu\'e9c \'ae\'dea trong tr\'f4 s\'eb \'a7\'b6ng.
\par Ban n\'b5y l\'b5 m\'e9t c\'ac quan t\'ad v\'can tuy\'d3n ng\'ad\'eai trong s\'e8 c\'b8c chuy\'aan gia, ngh\'dca l\'b5 nh\'f7ng \'ae\'b6ng vi\'aan c\'e3 hi\'d3u bi\'d5t v\'d2 c\'b8c thu\'e9c \'ae\'dea \'ae\'d3 \'ae\'d5n \'ae\'e3 sinh s\'e8ng.
\par }\pard \qj \fi397\li0\ri0\sa80\sl-280\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0 {\f37\fs20\insrsid1378858 N\'e3 c\'e3 nhi\'d6m v\'f4 thu th\'cbp t\'b5i li\'d6u v\'d2 thu\'e9c \'ae\'dea, cung c\'cap cho c\'b8c \'a7\'b9i h\'e9i 
\'ae\'b6ng v\'b5 trong th\'eai gian gi\'f7a hai \'ae\'b9i h\'e9i, cho Ban l\'b7nh \'ae\'b9o nh\'f7ng k\'d5t lu\'cbn c\'e3 th\'d3 cho ph\'d0p ra nh\'f7ng quy\'d5t \'ae\'denh th\'ddch h\'eep v\'d2 m\'c6t h\'e4c thuy\'d5t, tuy\'aan truy\'d2n v\'b5 s\'b8ch l
\'ad\'eec.
\par Ban nghi\'aan c\'f8u thu\'e9c \'ae\'dea \'ae\'b7 th\'b6o m\'e9t b\'b6n t\'ad\'eang tr\'d7nh v\'d2 t\'d7nh h\'d7nh hi\'d6n nay c\'f1a c\'b8c nh\'e3m thu\'e9c \'ae\'dea kh\'b8c nhau, x\'b8c \'ae\'denh r\'e2 r\'b5ng nh\'f7ng y\'aau c\'c7u ch\'f1 y\'d5u v\'d2
 lo\'b9i kinh t\'d5, ch\'ddnh tr\'de, v\'b5 x\'b7 h\'e9i m\'b5 ng\'ad\'eai b\'b6n x\'f8 c\'f2ng nh\'ad ng\'ad\'eai lao \'ae\'e9ng ch\'ddnh qu\'e8c s\'e8ng \'eb thu\'e9c \'ae\'dea c\'b6m nh\'cbn th\'cay. T\'f5 s\'f9 ki\'d3m ch\'f8ng nh\'f7ng nhu c\'c7u 
\'ae\'e3, Ban \'ae\'b7 r\'f3t ra nh\'f7ng k\'d5t lu\'cbn, nh\'f7ng quy t\'bec s\'b8ch l\'ad\'eec th\'ddch h\'eep qua vi\'d6c v\'cbn d\'f4ng ch\'f3ng, \'ae\'d3 g\'a9y n\'aan \'eb thu\'e9c \'ae\'dea m\'e9t phong tr\'b5o \'ae\'e8i l\'cbp ch\'e8ng ch\'f1 ngh
\'dca t\'ad b\'b6n v\'b5 phong tr\'b5o g\'a9y c\'b6m t\'d7nh v\'edi c\'e9ng s\'b6n.
\par V\'d7 ch\'ad\'acng tr\'d7nh ngh\'de s\'f9 c\'f1a \'a7\'b9i h\'e9i M\'b8cx\'a9y qu\'b8 n\'c6ng n\'aan b\'b8o c\'b8o n\'b5y c\'f1a Ban nghi\'aan c\'f8u thu\'e9c \'ae\'dea, \'ae\'b8ng ti\'d5c l\'b5 kh\'abng th\'d3 \'ae\'ad\'eec xem x\'d0t v\'b5 th\'b6o lu
\'cbn \'eb \'ae\'e3 \'ae\'ad\'eec. Nh\'adng \'aei\'d2u m\'b5 ng\'ad\'eai ta c\'e3 th\'d3 tr\'abng \'ae\'eei \'eb \'a7\'b9i h\'e9i M\'b8cx\'a9y, tr\'ad\'edc h\'d5t l\'b5 \'a7\'b9i h\'e9i t\'b8n th\'b5nh nguy\'aan t\'bec th\'b5nh l\'cbp m\'e9t c\'ac quan 
\'ae\'c6c bi\'d6t ph\'f4 tr\'b8ch ch\'ddnh s\'b8ch v\'d2 thu\'e9c \'ae\'dea c\'f1a \'a7\'b6ng, ti\'d5p \'ae\'e3 l\'b5 u\'fb quy\'d2n cho Ban l\'b7nh \'ae\'b9o th\'cay r\'e2: 1/ Ti\'d5p t\'f4c v\'b5 m\'eb r\'e9ng nhi\'d6m v\'f4 chu\'c8n b\'de \'ae\'b7 \'ae
\'ad\'eec kh\'ebi \'ae\'c7u. 2/ Tr\'d7nh b\'b5y \'eb \'a7\'b9i h\'e9i sau c\'f1a \'a7\'b6ng m\'e9t lu\'cbn c\'ad\'acng v\'d2 thu\'e9c \'ae\'dea \'ae\'b7 \'ae\'ad\'eec nghi\'aan c\'f8u nghi\'aam t\'f3c \'ae\'d3 \'a7\'b9i h\'e9i th\'b6o lu\'cbn \'ae\'d5n n
\'aci \'ae\'d5n ch\'e8n sao cho t\'f5 \'ae\'e3 \'a7\'b6ng c\'e3 m\'e9t ch\'ddnh s\'b8ch thu\'e9c \'ae\'dea r\'e2 r\'b5ng, c\'e3 ph\'ad\'acng ph\'b8p v\'b5 thi\'d5t th\'f9c.
\par B\'ebi v\'cby, ch\'f3ng t\'abi \'ae\'d2 ngh\'de \'a7\'b9i h\'e9i th\'abng qua ngh\'de quy\'d5t d\'ad\'edi \'ae\'a9y:
\par " \'a7\'b9i h\'e9i l\'c7n th\'f8 II c\'f1a \'a7\'b6ng C\'e9ng s\'b6n Ph\'b8p, h\'e4p \'eb M\'b8cx\'a9y sau khi nghe b\'b6n b\'b8o c\'b8o do Ban l\'b7nh \'ae\'b9o thay m\'c6t Ban nghi\'aan c\'f8u thu\'e9c \'ae\'dea tr\'d7nh b\'b5y, ch\'d8 ra s\'f9 c\'c7
n thi\'d5t trong th\'eai gian ng\'ben nh\'cat ph\'b6i t\'b9o ra m\'e9t phong tr\'b5o \'ae\'e8i kh\'b8ng mang tinh th\'c7n c\'e9ng s\'b6n, ch\'e8ng ch\'f1 ngh\'dca t\'ad b\'b6n v\'b5 hai h\'d7nh th\'f8c \'ae\'c6c bi\'d6t c\'f1a n\'e3 l\'b5 ch\'f1 ngh\'dca 
\'ae\'d5 qu\'e8c, ch\'f1 ngh\'dca qu\'a9n phi\'d6t v\'b5 ch\'f1 ngh\'dca ph\'b8o thuy\'d2n \'eb c\'b8c thu\'e9c \'ae\'dea.
\par "X\'d0t t\'ddnh ph\'f8c t\'b9p c\'f1a v\'can \'ae\'d2 thu\'e9c \'ae\'dea, v\'d7 c\'e3 s\'f9 kh\'abng thu\'c7n nh\'cat c\'f1a c\'b8c thu\'e9c \'ae\'dea v\'b5 x\'d0t s\'f9 ph\'b8t tri\'d3n v\'d2 kinh t\'d5, ch\'ddnh tr\'de v\'b5 x\'b7 h\'e9i th\'ad\'eang ch
\'cbm ch\'b9p c\'f1a d\'a9n b\'b6n x\'f8, \'ae\'e5ng th\'eai x\'d0t \'ae\'d5n s\'f8c m\'b9nh c\'f1a ch\'d5 \'ae\'e9 chuy\'aan ch\'d5 h\'b5nh ch\'ddnh m\'b5 h\'e4 l\'b5 n\'b9n nh\'a9n.
\par "Chu\'c8n y nguy\'aan t\'bec l\'cbp th\'b5nh m\'e9t c\'ac quan \'ae\'c6c bi\'d6t chuy\'aan nghi\'aan c\'f8u v\'b5 s\'adu t\'cbp t\'ad li\'d6u v\'d2 thu\'e9c \'ae\'dea l\'b5 c\'ac quan t\'ad v\'can, \'ae\'c6t d\'ad\'edi quy\'d2n ki\'d3m tra c\'f1a Ban l
\'b7nh \'ae\'b9o.
\par "Giao cho Ban n\'b5y b\'bbng m\'e4i ph\'ad\'acng s\'b8ch c\'c7n thi\'d5t nh\'bbm t\'ddch c\'f9c tuy\'aan truy\'d2n ngay t\'f5 b\'a9y gi\'ea v\'d2 thu\'e9c \'ae\'dea trong khi ch\'ea \'ae\'eei m\'e9t d\'f9 \'b8n ho\'b5n ch\'d8nh v\'b5 chi ti\'d5t v\'d2 ho
\'b9t \'ae\'e9ng thu\'e9c \'ae\'dea \'ae\'ad\'eec th\'b6o lu\'cbn \'eb \'a7\'b9i h\'e9i t\'edi c\'f1a \'a7\'b6ng.
\par "\'a7\'c6c bi\'d6t \'a7\'b9i h\'e9i \'ae\'d2 ngh\'de Ban l\'b7nh \'ae\'b9o d\'b5nh m\'e9t m\'f4c \'ae\'d3 nghi\'aan c\'f8u v\'can \'ae\'d2 n\'b5y tr\'aan b\'b8o }{\i\f37\fs20\insrsid1378858 L'Humanit\'d0}{\f37\fs20\insrsid1378858  v\'b5 trong c\'b8c s\'b8
ch, b\'b8o v\'b5 \'can ph\'c8m c\'f1a \'a7\'b6ng.
\par "\'a7\'b9i h\'e9i \'ae\'d2 ngh\'de c\'b8c ban n\'e3i chung, \'ae\'c6c bi\'d6t l\'b5 c\'b8c ban t\'e5n t\'b9i \'eb c\'b8c thu\'e9c \'ae\'dea hay \'eb nh\'f7ng th\'b5nh ph\'e8 c\'e3 quan h\'d6 th\'ad\'eang xuy\'aan v\'edi c\'b8c thu\'e9c \'ae\'dea \'ae\'e3
 c\'f2ng nh\'ad nh\'f7ng ng\'ad\'eai c\'e9ng s\'b6n bi\'d6t l\'cbp thu\'e9c m\'e4i ch\'f1ng t\'e9c, h\'eep t\'b8c ngay t\'f5 b\'a9y gi\'ea v\'edi Ban nghi\'aan c\'f8u thu\'e9c \'ae\'dea".
\par }\pard\plain \s24\qc \li2835\ri284\sb360\sa80\sl-320\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin284\lin2835\itap0 \f38\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\i\f37\insrsid1378858 Th\'b8ng 12 n\'a8m 1921}{\insrsid1378858 
\line BAN NGHI\'a3N C\'f8U THU\'e9C \'a7\'deA
\par }\pard\plain \s26\ql \li0\ri567\sl-260\slmult0\nowidctlpar\aspalpha\aspnum\faauto\adjustright\rin567\lin0\itap0 \f37\fs18\lang1033\langfe1033\cgrid\langnp1033\langfenp1033 {\insrsid1378858 \line T\'b5i li\'d6u ti\'d5ng Ph\'b8p,
\par b\'b6n ch\'f4p l\'adu t\'b9i Vi\'d6n H\'e5 Ch\'dd Minh.
\par 
